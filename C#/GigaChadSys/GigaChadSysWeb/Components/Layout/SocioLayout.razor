@inherits LayoutComponentBase

@inject GigaChadSys.Servicios.SessionServicio Session

<div class="socio-shell">
    <aside class="socio-sidebar">

        <!-- LOGO -->
        <div class="socio-logo admin-logo-image-box">
            <img src="/img/logo-gigachad-sidebar.png"
                 alt="GigaChad"
                 class="admin-brand-logo" />
        </div>

        <!-- MENÚ -->
        <nav class="socio-nav">

            <NavLink href="/socio/inicio" Match="NavLinkMatch.All">
                <i class="bi bi-house-door nav-bi"></i>
                <span>Inicio</span>
            </NavLink>

            <NavLink href="/socio/membresia">
                <i class="bi bi-gem nav-bi"></i>
                <span>Mi Membresía</span>
            </NavLink>

            <NavLink href="/socio/reservar">
                <i class="bi bi-calendar-plus nav-bi"></i>
                <span>Reservar Clase</span>
            </NavLink>

            <NavLink href="/socio/reservas">
                <i class="bi bi-calendar-check nav-bi"></i>
                <span>Mis Reservas</span>
            </NavLink>

            <NavLink href="/socio/pagos">
                <i class="bi bi-cash-coin nav-bi"></i>
                <span>Mis Pagos</span>
            </NavLink>

            <NavLink href="/socio/perfil">
                <i class="bi bi-person-circle nav-bi"></i>
                <span>Mi Perfil</span>
            </NavLink>

        </nav>

        <!-- PERFIL ABAJO -->
        <div class="socio-bottom">
            <div class="socio-profile">
                <div class="profile-avatar">
                    @(Session.EstaAutenticado && !string.IsNullOrWhiteSpace(Session.Nombres)
                        ? Session.Nombres[0].ToString()
                        : "S")
                </div>

                <div>
                    <strong>@(Session.EstaAutenticado ? Session.Nombres : "Socio")</strong>
                    <span class="profile-role">
                        @(Session.EstaAutenticado ? Session.Rol : "Miembro")
                    </span>
                </div>
            </div>
        </div>

    </aside>

    <!-- CONTENIDO -->
    <div class="socio-content-area">

        <header class="entrenador-topbar">
            <div></div>

            <div class="topbar-actions">
                <button class="topbar-btn" title="Notificaciones">
                    <i class="bi bi-bell"></i>
                </button>

                <button class="topbar-btn" title="Buscar">
                    <i class="bi bi-search"></i>
                </button>

                <a class="topbar-btn topbar-logout" href="/login" title="Salir">
                    <i class="bi bi-box-arrow-right"></i>
                    <span>Salir</span>
                </a>
            </div>
        </header>

        <main class="socio-main">
            @Body
        </main>

    </div>
</div>