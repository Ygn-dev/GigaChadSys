@inherits LayoutComponentBase
@inject GigaChadSys.Servicios.SessionServicio Session
@inject NavigationManager Navigation
@inject GigaChadSysWeb.AppAdminsToggleService ToggleSvc
@inject IJSRuntime JS
@using Microsoft.AspNetCore.Components.Server.ProtectedBrowserStorage
@inject ProtectedSessionStorage SessionStorage
@implements IDisposable

@if (Session.EstaAutenticado && Session.EsSocio)
{
    <div class="admin-shell">
        <aside class="admin-sidebar">

            <div class="admin-logo admin-logo-image-box">
                <img src="/img/logo-gigachad-sidebar.png"
                     alt="GigaChad"
                     class="admin-brand-logo" />
            </div>

            <nav class="socio-nav">

                <NavLink href="/socio/inicio" Match="NavLinkMatch.All">
                    <i class="bi bi-house-door nav-bi"></i>
                    <span>Inicio</span>
                </NavLink>

                <div class="nav-section">Mi Cuenta</div>

                <NavLink href="/socio/perfil">
                    <i class="bi bi-person nav-bi"></i>
                    <span>Mi Perfil</span>
                </NavLink>

                <NavLink href="/socio/membresia">
                    <i class="bi bi-gem nav-bi"></i>
                    <span>Membresía</span>
                </NavLink>

                <NavLink href="/socio/pagos">
                    <i class="bi bi-cash-stack nav-bi"></i>
                    <span>Historial de Pagos</span>
                </NavLink>

                <div class="nav-section">Servicios</div>

                <NavLink href="/socio/reservar">
                    <i class="bi bi-calendar-plus nav-bi"></i>
                    <span>Reservar Clase</span>
                </NavLink>

                <NavLink href="/socio/reservas">
                    <i class="bi bi-calendar-check nav-bi"></i>
                    <span>Mis Reservas</span>
                </NavLink>

            </nav>

            <div class="socio-bottom">
                <div class="socio-profile">
                    <div class="profile-avatar">
                        @(Session.EstaAutenticado && !string.IsNullOrWhiteSpace(Session.Nombres)
                            ? Session.Nombres[0].ToString()
                            : "S")
                    </div>

                    <div class="profile-info">
                        <strong>@(Session.EstaAutenticado ? Session.Nombres : "Socio")</strong>
                        <span>Miembro Activo</span>
                    </div>
                </div>

                <button class="socio-logout" @onclick="CerrarSesion">
                    <i class="bi bi-box-arrow-left nav-bi"></i>
                    <span>Cerrar Sesión</span>
                </button>
            </div>

        </aside>

        <div class="socio-content-area">

            <header class="entrenador-topbar">
                <div class="topbar-search">
                </div>

                <div class="topbar-actions">
                    <div style="position: relative;">
                        <button class="topbar-btn topbar-notif" @onclick="ToggleNotificacionesSocio">
                            <i class="bi bi-bell"></i>
                            @if (mostrarBadgeNotificacionSocio)
                            {
                                <span class="badge">1</span>
                            }
                        </button>

                        @if (mostrarNotificacionesSocio)
                        {
                            <div style="position: absolute; right: 0; top: 100%; width: 320px; background: var(--sidebar); border: 1px solid #333; border-radius: 8px; box-shadow: 0 10px 15px -3px rgba(0,0,0,0.5); z-index: 1000; margin-top: 8px; text-align: left; color: var(--blanco);">
                                <div style="padding: 12px 16px; border-bottom: 1px solid #333; font-weight: 600; color: var(--blanco); display: flex; justify-content: space-between; align-items: center;">
                                    Notificaciones
                                    <button style="background: none; border: none; font-size: 1.2rem; cursor: pointer; color: var(--gris);" onmouseover="this.style.color='white'" onmouseout="this.style.color='var(--gris)'" @onclick="() => mostrarNotificacionesSocio = false">&times;</button>
                                </div>
                                <div style="max-height: 300px; overflow-y: auto;">
                                    @if (mostrarBadgeNotificacionSocio)
                                    {
                                        <div style="padding: 12px 16px; border-bottom: 1px solid #333; display: flex; gap: 12px; cursor: pointer; background: #1a1a1a;" onmouseover="this.style.background='#222'" onmouseout="this.style.background='#1a1a1a'">
                                            <div style="background: rgba(229, 57, 53, 0.15); color: var(--rojo); width: 36px; height: 36px; border-radius: 50%; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
                                                <i class="bi bi-info-circle"></i>
                                            </div>
                                            <div>
                                                <div style="font-size: 0.9rem; font-weight: 500; color: var(--blanco); margin-bottom: 4px;">Bienvenido a GigaChadSys</div>
                                                <div style="font-size: 0.8rem; color: var(--gris);">Tu cuenta ha sido configurada correctamente. ¡Disfruta de la experiencia!</div>
                                                <div style="font-size: 0.75rem; color: #777; margin-top: 4px;">Hace 1 hora</div>
                                            </div>
                                        </div>
                                    }
                                    else
                                    {
                                        <div style="padding: 24px 16px; text-align: center; color: var(--gris);">
                                            <i class="bi bi-bell-slash" style="font-size: 2rem; margin-bottom: 8px; display: block; color: #555;"></i>
                                            No tienes notificaciones nuevas
                                        </div>
                                    }
                                </div>
                                @if (mostrarBadgeNotificacionSocio)
                                {
                                    <div style="padding: 8px; text-align: center; border-top: 1px solid #333; background: var(--fondo); border-bottom-left-radius: 8px; border-bottom-right-radius: 8px;">
                                        <button style="background: none; border: none; color: var(--rojo); font-size: 0.85rem; font-weight: 500; cursor: pointer;" onmouseover="this.style.color='var(--hover)'" onmouseout="this.style.color='var(--rojo)'" @onclick="MarcarNotificacionesLeidasSocio">Marcar como leídas</button>
                                    </div>
                                }
                            </div>
                        }
                    </div>

                    <button class="topbar-btn topbar-logout" title="Salir" @onclick="CerrarSesion">
                        <i class="bi bi-box-arrow-right"></i>
                        <span>Salir</span>
                    </button>
                </div>
            </header>

            <main class="socio-main">
                @Body
            </main>

        </div>

    </div>

    <!-- El Asistente IA Botonsito -->
    <AsistenteSocioBot />

    <GlobalToast />

    @if (ToggleSvc.Visible)
    {
        <AppAdmins />
    }
}
else
{
    <div class="loading-overlay">
        <p>Verificando permisos...</p>
    </div>
}

@code {
    private bool mostrarNotificacionesSocio = false;
    private bool mostrarBadgeNotificacionSocio = true;

    private void ToggleNotificacionesSocio()
    {
        mostrarNotificacionesSocio = !mostrarNotificacionesSocio;
    }

    private void MarcarNotificacionesLeidasSocio()
    {
        mostrarBadgeNotificacionSocio = false;
    }

    protected override void OnInitialized()
    {
        ToggleSvc.OnChange += HandleToggleChange;
        ToggleSvc.OnAutoClick += HandleAutoClick;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await Session.RestaurarDesdeStorageAsync(SessionStorage);
            if (!Session.EstaAutenticado || !Session.EsSocio)
            {
                Navigation.NavigateTo("/login", forceLoad: true);
                return;
            }
            StateHasChanged();
        }
    }

    private async void HandleAutoClick()
    {
        await InvokeAsync(async () =>
        {
            StateHasChanged();
            await Task.Delay(300);
            await JS.InvokeVoidAsync("eval", "document.querySelector('.gc-btn-danger-float')?.click()");
        });
    }

    private async void HandleToggleChange()
    {
        await InvokeAsync(StateHasChanged);
    }

    private async Task CerrarSesion()
    {
        await Session.LimpiarStorageAsync(SessionStorage);
        Session.CerrarSesion();
        Navigation.NavigateTo("/login", forceLoad: true);
    }

    public void Dispose()
    {
        ToggleSvc.OnChange -= HandleToggleChange;
        ToggleSvc.OnAutoClick -= HandleAutoClick;
    }
}