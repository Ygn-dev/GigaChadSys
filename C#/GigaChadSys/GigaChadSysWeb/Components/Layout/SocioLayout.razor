@inherits LayoutComponentBase
@inject GigaChadSys.Servicios.SessionServicio Session
@inject NavigationManager Navigation
@inject GigaChadSysWeb.AppAdminsToggleService ToggleSvc
@inject IJSRuntime JS
@implements IDisposable

<div class="role-shell socio-shell">
    <aside class="role-sidebar socio-sidebar">

        <div class="role-logo">
            <img src="/img/logo-gigachad-sidebar.png"
                 alt="GigaChad"
                 class="role-brand-logo" />
        </div>

        <nav class="role-nav socio-nav">

            <NavLink href="/socio/inicio" Match="NavLinkMatch.All">
                <i class="bi bi-house-door role-nav-icon"></i>
                <span>Inicio</span>
            </NavLink>

            <NavLink href="/socio/membresia">
                <i class="bi bi-gem role-nav-icon"></i>
                <span>Mi Membresía</span>
            </NavLink>

            <NavLink href="/socio/reservar">
                <i class="bi bi-calendar-plus role-nav-icon"></i>
                <span>Reservar Clase</span>
            </NavLink>

            <NavLink href="/socio/reservas">
                <i class="bi bi-calendar-check role-nav-icon"></i>
                <span>Mis Reservas</span>
            </NavLink>

            <NavLink href="/socio/pagos">
                <i class="bi bi-cash-coin role-nav-icon"></i>
                <span>Mis Pagos</span>
            </NavLink>

            <NavLink href="/socio/perfil">
                <i class="bi bi-person-circle role-nav-icon"></i>
                <span>Mi Perfil</span>
            </NavLink>

        </nav>

        <div class="role-bottom socio-bottom">
            <div class="role-profile socio-profile">
                <div class="profile-avatar">
                    @(Session.EstaAutenticado && !string.IsNullOrWhiteSpace(Session.Nombres)
                        ? Session.Nombres[0].ToString()
                        : "S")
                </div>

                <div class="role-profile-text">
                    <strong>@(Session.EstaAutenticado ? Session.Nombres : "Socio")</strong>
                    <span>@(Session.EstaAutenticado ? Session.Rol : "Miembro")</span>
                </div>
            </div>

            <button class="role-logout" title="Salir" @onclick="CerrarSesion">
                <i class="bi bi-box-arrow-left role-nav-icon"></i>
                <span>Cerrar Sesión</span>
            </button>
        </div>

    </aside>

    <div class="role-content socio-content-area">

        <header class="role-topbar entrenador-topbar">
            <div></div>

            <div class="topbar-actions">
                <button class="topbar-btn" title="Notificaciones">
                    <i class="bi bi-bell"></i>
                </button>

                <button class="topbar-btn" title="Buscar">
                    <i class="bi bi-search"></i>
                </button>

                <button class="topbar-btn topbar-logout" title="Salir" @onclick="CerrarSesion">
                    <i class="bi bi-box-arrow-right"></i>
                    <span>Salir</span>
                </button>
            </div>
        </header>

        <main class="role-main socio-main">
            @Body
        </main>

    </div>
</div>

<AsistenteSocioBot />

@if (ToggleSvc.Visible)
{
    <AppAdmins />
}

@code {
    protected override void OnInitialized()
    {
        ToggleSvc.OnChange += HandleToggleChange;
        ToggleSvc.OnAutoClick += HandleAutoClick;
    }

    private async void HandleAutoClick()
    {
        await InvokeAsync(async () =>
        {
            StateHasChanged();
            await Task.Delay(300);
            await JS.InvokeVoidAsync("eval", "document.querySelector('.gc-btn-danger-float')?.click()");
        });
    }

    private async void HandleToggleChange()
    {
        await InvokeAsync(StateHasChanged);
    }

    private void CerrarSesion()
    {
        Session.CerrarSesion();
        Navigation.NavigateTo("/login", forceLoad: true);
    }

    public void Dispose()
    {
        ToggleSvc.OnChange -= HandleToggleChange;
        ToggleSvc.OnAutoClick -= HandleAutoClick;
    }
}