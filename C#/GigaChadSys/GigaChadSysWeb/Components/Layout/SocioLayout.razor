@inherits LayoutComponentBase
@inject GigaChadSys.Servicios.SessionServicio Session
@inject NavigationManager Navigation
@inject GigaChadSysWeb.AppAdminsToggleService ToggleSvc
@inject IJSRuntime JS
@using Microsoft.AspNetCore.Components.Server.ProtectedBrowserStorage
@inject ProtectedSessionStorage SessionStorage
@implements IDisposable

@if (Session.EstaAutenticado && Session.EsSocio)
{
    <div class="socio-shell">
        <aside class="socio-sidebar">

            <div class="socio-logo socio-logo-image-box">
                <img src="/img/logo-gigachad-sidebar.png"
                     alt="GigaChad"
                     class="socio-brand-logo" />
            </div>

            <nav class="socio-nav">

                <NavLink href="/socio/inicio" Match="NavLinkMatch.All">
                    <i class="bi bi-house-door nav-bi"></i>
                    <span>Inicio</span>
                </NavLink>

                <div class="nav-section">Mi Cuenta</div>

                <NavLink href="/socio/perfil">
                    <i class="bi bi-person nav-bi"></i>
                    <span>Mi Perfil</span>
                </NavLink>

                <NavLink href="/socio/membresia">
                    <i class="bi bi-gem nav-bi"></i>
                    <span>Membresía</span>
                </NavLink>

                <NavLink href="/socio/pagos">
                    <i class="bi bi-cash-stack nav-bi"></i>
                    <span>Historial de Pagos</span>
                </NavLink>

                <div class="nav-section">Servicios</div>

                <NavLink href="/socio/reservar">
                    <i class="bi bi-calendar-plus nav-bi"></i>
                    <span>Reservar Clase</span>
                </NavLink>

                <NavLink href="/socio/reservas">
                    <i class="bi bi-calendar-check nav-bi"></i>
                    <span>Mis Reservas</span>
                </NavLink>

            </nav>

            <div class="socio-bottom">
                <div class="socio-profile">
                    <div class="profile-avatar">
                        @(Session.EstaAutenticado && !string.IsNullOrWhiteSpace(Session.Nombres)
                            ? Session.Nombres[0].ToString()
                            : "S")
                    </div>

                    <div class="profile-info">
                        <strong>@(Session.EstaAutenticado ? Session.Nombres : "Socio")</strong>
                        <span>Miembro Activo</span>
                    </div>
                </div>

                <button class="socio-logout" @onclick="CerrarSesion">
                    <i class="bi bi-box-arrow-left nav-bi"></i>
                    <span>Cerrar Sesión</span>
                </button>
            </div>

        </aside>

        <div class="socio-content-area">

            <header class="entrenador-topbar">
                <div class="topbar-search">
                </div>

                <div class="topbar-actions">
                    <button class="topbar-btn topbar-notif">
                        <i class="bi bi-bell"></i>
                        <span class="badge">1</span>
                    </button>

                    <button class="topbar-btn topbar-logout" title="Salir" @onclick="CerrarSesion">
                        <i class="bi bi-box-arrow-right"></i>
                        <span>Salir</span>
                    </button>
                </div>
            </header>

            <main class="socio-main">
                @Body
            </main>

        </div>

    </div>

    <!-- El Asistente IA Botonsito -->
    <AsistenteSocioBot />

    @if (ToggleSvc.Visible)
    {
        <AppAdmins />
    }
}
else
{
    <div class="loading-overlay">
        <p>Verificando permisos...</p>
    </div>
}

@code {
    protected override void OnInitialized()
    {
        ToggleSvc.OnChange += HandleToggleChange;
        ToggleSvc.OnAutoClick += HandleAutoClick;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await Session.RestaurarDesdeStorageAsync(SessionStorage);
            if (!Session.EstaAutenticado || !Session.EsSocio)
            {
                Navigation.NavigateTo("/login", forceLoad: true);
                return;
            }
            StateHasChanged();
        }
    }

    private async void HandleAutoClick()
    {
        await InvokeAsync(async () =>
        {
            StateHasChanged();
            await Task.Delay(300);
            await JS.InvokeVoidAsync("eval", "document.querySelector('.gc-btn-danger-float')?.click()");
        });
    }

    private async void HandleToggleChange()
    {
        await InvokeAsync(StateHasChanged);
    }

    private async Task CerrarSesion()
    {
        await Session.LimpiarStorageAsync(SessionStorage);
        Session.CerrarSesion();
        Navigation.NavigateTo("/login", forceLoad: true);
    }

    public void Dispose()
    {
        ToggleSvc.OnChange -= HandleToggleChange;
        ToggleSvc.OnAutoClick -= HandleAutoClick;
    }
}