@inherits LayoutComponentBase

@inject GigaChadSys.Servicios.SessionServicio Session
@inject NavigationManager Navigation

<div class="role-shell entrenador-shell">
    <aside class="role-sidebar entrenador-sidebar">

        <div class="role-logo">
            <img src="/img/logo-gigachad-sidebar.png"
                 alt="GigaChad"
                 class="role-brand-logo" />
        </div>

        <nav class="role-nav entrenador-nav">

            <NavLink href="/entrenador/inicio" Match="NavLinkMatch.All">
                <i class="bi bi-house-door role-nav-icon"></i>
                <span>Inicio</span>
            </NavLink>

            <NavLink href="/entrenador/horario">
                <i class="bi bi-calendar-week role-nav-icon"></i>
                <span>Mi Horario / Sesiones</span>
            </NavLink>

            <NavLink href="/entrenador/pagos">
                <i class="bi bi-cash-coin role-nav-icon"></i>
                <span>Mis Pagos</span>
            </NavLink>

            <NavLink href="/entrenador/perfil">
                <i class="bi bi-person-circle role-nav-icon"></i>
                <span>Mi Perfil</span>
            </NavLink>

        </nav>

        <div class="role-bottom entrenador-bottom">
            <div class="role-profile entrenador-profile">
                <div class="profile-avatar">
                    @(Session.EstaAutenticado && !string.IsNullOrWhiteSpace(Session.Nombres)
                        ? Session.Nombres[0].ToString()
                        : "E")
                </div>

                <div class="role-profile-text">
                    <strong>@(Session.EstaAutenticado ? Session.Nombres : "Entrenador")</strong>
                    <span>@(Session.EstaAutenticado ? Session.Rol : "Staff")</span>
                </div>
            </div>

            <button class="role-logout" title="Salir" @onclick="CerrarSesion">
                <i class="bi bi-box-arrow-left role-nav-icon"></i>
                <span>Cerrar Sesión</span>
            </button>
        </div>

    </aside>

    <div class="role-content entrenador-content-area">

        <header class="role-topbar entrenador-topbar">
            <div></div>

            <div class="topbar-actions">
                <button class="topbar-btn" title="Notificaciones">
                    <i class="bi bi-bell"></i>
                </button>

                <button class="topbar-btn" title="Buscar">
                    <i class="bi bi-search"></i>
                </button>

                <button class="topbar-btn topbar-logout" title="Salir" @onclick="CerrarSesion">
                    <i class="bi bi-box-arrow-right"></i>
                    <span>Salir</span>
                </button>
            </div>
        </header>

        <main class="role-main entrenador-main">
            @Body
        </main>

    </div>
</div>

@code {
    private void CerrarSesion()
    {
        Session.CerrarSesion();
        Navigation.NavigateTo("/login", forceLoad: true);
    }
}