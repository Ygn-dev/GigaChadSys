@inherits LayoutComponentBase
@inject GigaChadSys.Servicios.SessionServicio Session
@inject NavigationManager Navigation
@inject GigaChadSysWeb.AppAdminsToggleService ToggleSvc
@inject IJSRuntime JS
@using Microsoft.AspNetCore.Components.Server.ProtectedBrowserStorage
@inject ProtectedSessionStorage SessionStorage
@implements IDisposable

@if (Session.EstaAutenticado && Session.EsEntrenador)
{
    <div class="admin-shell">
        <aside class="admin-sidebar">

            <div class="admin-logo admin-logo-image-box">
                <img src="/img/logo-gigachad-sidebar.png"
                     alt="GigaChad"
                     class="admin-brand-logo" />
            </div>

            <nav class="entrenador-nav">

                <NavLink href="/entrenador/inicio" Match="NavLinkMatch.All">
                    <i class="bi bi-house-door nav-bi"></i>
                    <span>Inicio</span>
                </NavLink>

                <div class="nav-section">Clases y Horarios</div>

                <NavLink href="/entrenador/horario">
                    <i class="bi bi-calendar3 nav-bi"></i>
                    <span>Mi Horario</span>
                </NavLink>

                <div class="nav-section">Mis Pagos</div>

                <NavLink href="/entrenador/pagos">
                    <i class="bi bi-cash-stack nav-bi"></i>
                    <span>Historial de Pagos</span>
                </NavLink>

                <div class="nav-section">Cuenta</div>

                <NavLink href="/entrenador/perfil">
                    <i class="bi bi-person-circle nav-bi"></i>
                    <span>Mi Perfil</span>
                </NavLink>

            </nav>

            <div class="entrenador-bottom">
                <div class="entrenador-profile">
                    <div class="profile-avatar">
                        @(Session.EstaAutenticado && !string.IsNullOrWhiteSpace(Session.Nombres)
                            ? Session.Nombres[0].ToString()
                            : "E")
                    </div>

                    <div class="profile-info">
                        <strong>@(Session.EstaAutenticado ? Session.Nombres : "Entrenador")</strong>
                        <span>Instructor</span>
                    </div>
                </div>

                <button class="entrenador-logout" @onclick="CerrarSesion">
                    <i class="bi bi-box-arrow-left nav-bi"></i>
                    <span>Cerrar Sesión</span>
                </button>
            </div>

        </aside>

        <div class="entrenador-content-area">

            <header class="entrenador-topbar">
                <div class="topbar-search">
                    <i class="bi bi-search"></i>
                    <input type="text" placeholder="Buscar clases, alumnos..." />
                </div>

                <div class="topbar-actions">
                    <div style="position: relative;">
                        <button class="topbar-btn topbar-notif" @onclick="ToggleNotificacionesEntrenador">
                            <i class="bi bi-bell"></i>
                            @if (mostrarBadgeNotificacionEntrenador)
                            {
                                <span class="badge">3</span>
                            }
                        </button>

                        @if (mostrarNotificacionesEntrenador)
                        {
                            <div style="position: absolute; right: 0; top: 100%; width: 320px; background: white; border: 1px solid #e2e8f0; border-radius: 8px; box-shadow: 0 10px 15px -3px rgba(0,0,0,0.1); z-index: 1000; margin-top: 8px; text-align: left;">
                                <div style="padding: 12px 16px; border-bottom: 1px solid #e2e8f0; font-weight: 600; color: #1e293b; display: flex; justify-content: space-between; align-items: center;">
                                    Notificaciones
                                    <button style="background: none; border: none; font-size: 1.2rem; cursor: pointer; color: #94a3b8;" @onclick="() => mostrarNotificacionesEntrenador = false">&times;</button>
                                </div>
                                <div style="max-height: 300px; overflow-y: auto;">
                                    @if (mostrarBadgeNotificacionEntrenador)
                                    {
                                        <div style="padding: 12px 16px; border-bottom: 1px solid #f1f5f9; display: flex; gap: 12px; cursor: pointer;">
                                            <div style="background: #e0f2fe; color: #0284c7; width: 36px; height: 36px; border-radius: 50%; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
                                                <i class="bi bi-calendar-event"></i>
                                            </div>
                                            <div>
                                                <div style="font-size: 0.9rem; font-weight: 500; color: #334155; margin-bottom: 4px;">Asignación de clases</div>
                                                <div style="font-size: 0.8rem; color: #64748b;">Recuerda revisar tu horario para las clases de hoy.</div>
                                                <div style="font-size: 0.75rem; color: #94a3b8; margin-top: 4px;">Hace 2 horas</div>
                                            </div>
                                        </div>
                                    }
                                    else
                                    {
                                        <div style="padding: 24px 16px; text-align: center; color: #94a3b8;">
                                            <i class="bi bi-bell-slash" style="font-size: 2rem; margin-bottom: 8px; display: block;"></i>
                                            No tienes notificaciones nuevas
                                        </div>
                                    }
                                </div>
                                @if (mostrarBadgeNotificacionEntrenador)
                                {
                                    <div style="padding: 8px; text-align: center; border-top: 1px solid #e2e8f0;">
                                        <button style="background: none; border: none; color: #0f172a; font-size: 0.85rem; font-weight: 500; cursor: pointer;" @onclick="MarcarNotificacionesLeidasEntrenador">Marcar como leídas</button>
                                    </div>
                                }
                            </div>
                        }
                    </div>

                    <button class="topbar-btn topbar-logout" title="Salir" @onclick="CerrarSesion">
                        <i class="bi bi-box-arrow-right"></i>
                        <span>Salir</span>
                    </button>
                </div>
            </header>

            <main class="entrenador-main">
                @Body
            </main>

        </div>

    </div>

    <GlobalToast />

    @if (ToggleSvc.Visible)
    {
        <AppAdmins />
    }
}
else
{
    <div class="loading-overlay">
        <p>Verificando permisos...</p>
    </div>
}

@code {
    private bool mostrarNotificacionesEntrenador = false;
    private bool mostrarBadgeNotificacionEntrenador = true;

    private void ToggleNotificacionesEntrenador()
    {
        mostrarNotificacionesEntrenador = !mostrarNotificacionesEntrenador;
    }

    private void MarcarNotificacionesLeidasEntrenador()
    {
        mostrarBadgeNotificacionEntrenador = false;
    }

    protected override void OnInitialized()
    {
        ToggleSvc.OnChange += HandleToggleChange;
        ToggleSvc.OnAutoClick += HandleAutoClick;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await Session.RestaurarDesdeStorageAsync(SessionStorage);
            if (!Session.EstaAutenticado || !Session.EsEntrenador)
            {
                Navigation.NavigateTo("/login", forceLoad: true);
                return;
            }
            StateHasChanged();
        }
    }

    private async void HandleAutoClick()
    {
        await InvokeAsync(async () =>
        {
            StateHasChanged();
            await Task.Delay(300);
            await JS.InvokeVoidAsync("eval", "document.querySelector('.gc-btn-danger-float')?.click()");
        });
    }

    private async void HandleToggleChange()
    {
        await InvokeAsync(StateHasChanged);
    }

    private async Task CerrarSesion()
    {
        await Session.LimpiarStorageAsync(SessionStorage);
        Session.CerrarSesion();
        Navigation.NavigateTo("/login", forceLoad: true);
    }

    public void Dispose()
    {
        ToggleSvc.OnChange -= HandleToggleChange;
        ToggleSvc.OnAutoClick -= HandleAutoClick;
    }
}