@inherits LayoutComponentBase
@inject GigaChadSys.Servicios.SessionServicio Session
@inject NavigationManager Navigation
<div class="entrenador-shell">
    <aside class="entrenador-sidebar">
        <div class="entrenador-logo">
            <div class="logo-mark">GC</div>
            <div>
                <h2>GIGACHAD</h2>
                <span>ENTRENADOR</span>
            </div>
        </div>

        <nav class="entrenador-nav">
            <NavLink href="/entrenador/inicio" Match="NavLinkMatch.All">
                <span class="nav-icon">⌂</span> Inicio
            </NavLink>

            <NavLink href="/entrenador/horario">
                <span class="nav-icon">◷</span> Mi Horario / Sesiones
            </NavLink>

            <NavLink href="/entrenador/pagos">
                <span class="nav-icon">⬡</span> Mis Pagos
            </NavLink>

            <NavLink href="/entrenador/perfil">
                <span class="nav-icon">○</span> Mi Perfil
            </NavLink>
        </nav>

        <div class="entrenador-bottom">
            <div class="entrenador-profile">
                <div class="profile-avatar">@(Session.EstaAutenticado && Session.Nombres.Length > 0 ? Session.Nombres[0].ToString() : "E")</div>
                <div>
                    <strong>@(Session.EstaAutenticado ? Session.Nombres : "Entrenador")</strong>
                    <span class="profile-role">@(Session.EstaAutenticado ? Session.Rol : "Staff")</span>
                </div>
            </div>
        </div>
    </aside>

    <div class="entrenador-content-area">
        <header class="entrenador-topbar">
            <div></div>
            <div class="topbar-actions">
                <button class="topbar-btn" title="Notificaciones">🔔</button>
                <button class="topbar-btn" title="Buscar">🔍</button>
                <button class="topbar-btn topbar-logout" title="Salir" @onclick="CerrarSesion">⏻ Salir</button>
            </div>
        </header>

        <main class="entrenador-main">
            @Body
        </main>
    </div>
</div>

@code {
    private void CerrarSesion()
    {
        Session.CerrarSesion();
        Navigation.NavigateTo("/login", forceLoad: true);
    }
}