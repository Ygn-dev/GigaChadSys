@inherits LayoutComponentBase
@inject GigaChadSysWeb.AppAdminsToggleService ToggleSvc
@inject IJSRuntime JS
@implements IDisposable

<div class="auth-layout">
    @Body
</div>

@if (ToggleSvc.Visible)
{
    <AppAdmins />
}

@code {
    protected override void OnInitialized()
    {
        ToggleSvc.OnChange += HandleToggleChange;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (ToggleSvc.Visible && ToggleSvc.AutoClick)
        {
            ToggleSvc.ResetAutoClick();
            await Task.Delay(500);
            await JS.InvokeVoidAsync("eval", "document.querySelector('.gc-btn-danger-float')?.click()");
        }
    }

    private async void HandleToggleChange()
    {
        await InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        ToggleSvc.OnChange -= HandleToggleChange;
    }
}