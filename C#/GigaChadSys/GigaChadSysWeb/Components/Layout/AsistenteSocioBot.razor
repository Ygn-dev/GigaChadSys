@implements IAsyncDisposable
@inject AsistenteSocioServicio Asistente
@inject GigaChadSys.Servicios.SessionServicio Session
@inject IJSRuntime JS

<div class="socio-assistant-shell" aria-live="polite">
    @if (Abierto)
    {
        <section class="socio-assistant-panel" role="dialog" aria-label="Asistente de socio">
            <header class="socio-assistant-header">
                <div>
                    <span class="socio-assistant-kicker">Asistente de socio</span>
                    <h3>@Titulo</h3>
                </div>
                <button type="button" class="socio-assistant-close" @onclick="TogglePanel" aria-label="Cerrar asistente">
                    <i class="bi bi-x-lg"></i>
                </button>
            </header>

            <div class="socio-assistant-body">
                <div class="socio-assistant-hint">
                    <span>Sesión: @(string.IsNullOrWhiteSpace(Asistente.NombreUsuario) ? "Invitado" : Asistente.NombreUsuario)</span>
                    <button type="button" class="socio-assistant-reset" @onclick="ReiniciarAsync" disabled="@Procesando">
                        Reiniciar charla
                    </button>
                </div>

                <div class="socio-assistant-chat" @ref="ChatContainer">
                    @if (Asistente.Conversacion.Count == 0)
                    {
                        <article class="socio-assistant-message asistente">
                            <div class="message-badge">GC</div>
                            <p class="socio-assistant-text">Hola. Pregúntame por tu membresía, tus pagos o tus reservas.</p>
                        </article>
                    }
                    else
                    {
                        @foreach (var mensaje in Asistente.Conversacion)
                        {
                            <article class="socio-assistant-message @mensaje.Rol">
                                <div class="message-badge">@(mensaje.Rol == "usuario" ? "Tú" : "GC")</div>
                                <p class="socio-assistant-text">@mensaje.Texto</p>
                            </article>
                        }
                    }

                    @if (Procesando)
                    {
                        <article class="socio-assistant-message asistente">
                            <div class="message-badge">GC</div>
                            <p class="socio-assistant-text"><em>Procesando...</em></p>
                        </article>
                    }
                </div>

                <div class="socio-assistant-shortcuts">
                    <button type="button" @onclick="AtajoMembresia" disabled="@Procesando">Mi membresía</button>
                    <button type="button" @onclick="AtajoPagos" disabled="@Procesando">Pagos</button>
                    <button type="button" @onclick="AtajoReservas" disabled="@Procesando">Reservas</button>
                </div>

                <form class="socio-assistant-form" @onsubmit="EnviarAsync">
                    <input class="socio-assistant-input"
                           type="text"
                           placeholder="Escribe tu pregunta..."
                           @bind="Consulta"
                           @bind:event="oninput"
                           disabled="@Procesando"
                           autocomplete="off" />

                    <button type="submit" class="socio-assistant-send" disabled="@(Procesando || string.IsNullOrWhiteSpace(Consulta))">
                        <i class="bi bi-send"></i>
                        <span>Enviar</span>
                    </button>
                </form>
            </div>
        </section>
    }

    <button type="button" class="socio-assistant-launcher" @onclick="TogglePanel">
        <i class="bi bi-robot"></i>
        <span>@(Abierto ? "Cerrar" : "Ayuda")</span>
    </button>
</div>

@code {
    private string Consulta { get; set; } = string.Empty;
    private bool Abierto { get; set; }
    private bool Procesando { get; set; }
    private ElementReference ChatContainer;

    private string Titulo => string.IsNullOrWhiteSpace(Asistente.NombreUsuario)
        ? "Bot de ayuda"
        : $"Hola, {Asistente.NombreUsuario}";

    protected override void OnInitialized()
    {
        Session.OnCambio += HandleSessionChange;
    }

    protected override async Task OnInitializedAsync()
    {
        await Asistente.CargarContextoAsync();
    }

    private async void HandleSessionChange()
    {
        await Asistente.CargarContextoAsync();
        await InvokeAsync(StateHasChanged);
    }

    private async Task EnviarAsync()
    {
        string texto = Consulta.Trim();
        if (string.IsNullOrWhiteSpace(texto) || Procesando)
            return;

        Consulta = string.Empty;
        Procesando = true;
        Abierto = true;

        StateHasChanged();
        await ScrollToBottomAsync();

        try
        {
            await Asistente.ResponderAsync(texto);
        }
        finally
        {
            Procesando = false;
            StateHasChanged();
            await ScrollToBottomAsync();
        }
    }

    private async Task UsarAtajoAsync(string texto)
    {
        Consulta = texto;
        await EnviarAsync();
    }

    private Task AtajoMembresia() => UsarAtajoAsync("Resúmeme mi membresía");
    private Task AtajoPagos() => UsarAtajoAsync("Cuáles son mis pagos");
    private Task AtajoReservas() => UsarAtajoAsync("Ayúdame con reservas");

    private void TogglePanel()
    {
        Abierto = !Abierto;
        if (Abierto)
        {
            _ = ScrollToBottomAsync();
        }
    }

    private async Task ReiniciarAsync()
    {
        Asistente.ReiniciarConversacion();
        await Asistente.CargarContextoAsync();
        StateHasChanged();
    }

    private async Task ScrollToBottomAsync()
    {
        try
        {
            if (Abierto)
            {
                await JS.InvokeVoidAsync("eval", @"
                    var chat = document.querySelector('.socio-assistant-chat');
                    if(chat) chat.scrollTop = chat.scrollHeight;
                ");
            }
        }
        catch { /* Ignorar errores durante el renderizado inicial */ }
    }

    public async ValueTask DisposeAsync()
    {
        Session.OnCambio -= HandleSessionChange;
    }
}