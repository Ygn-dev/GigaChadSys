@inherits LayoutComponentBase

<div class="admin-shell">
    <aside class="admin-sidebar">

        <div class="admin-logo">
            <div class="logo-mark">GC</div>
            <div>
                <h2>GIGACHAD</h2>
                <span>Admin Panel</span>
            </div>
        </div>

        <nav class="admin-nav">
            <NavLink href="/admin/inicio" Match="NavLinkMatch.All">Inicio</NavLink>

            <div class="nav-section">Usuarios</div>
            <NavLink href="/admin/socios">Socios</NavLink>
            <NavLink href="/admin/entrenadores">Entrenadores</NavLink>

            <div class="nav-section">Membresías</div>
            <NavLink href="/admin/membresias">Membresías</NavLink>
            <NavLink href="/admin/suscripciones">Suscripciones</NavLink>

            <div class="nav-section">Operaciones</div>
            <NavLink href="/admin/clases">Clases</NavLink>
            <NavLink href="/admin/sesiones">Sesiones</NavLink>
            <NavLink href="/admin/reservas">Reservas</NavLink>
            <NavLink href="/admin/pagos">Pagos</NavLink>

            <div class="nav-section">Infraestructura</div>
            <NavLink href="/admin/salones">Salones</NavLink>
            <NavLink href="/admin/maquinas">Máquinas</NavLink>

            <div class="nav-section">Análisis</div>
            <NavLink href="/admin/reportes">Reportes</NavLink>

            <div class="nav-section">Cuenta</div>
            <NavLink href="/admin/perfil">Mi Perfil</NavLink>
        </nav>

        <div class="admin-bottom">
            <div class="admin-profile">
                <div class="profile-avatar">A</div>
                <div>
                    <strong>Administrador</strong>
                    <span>admin@gigachad.com</span>
                </div>
            </div>

            <a class="admin-logout" href="/login">Cerrar Sesión</a>
        </div>

    </aside>

    <div class="admin-content-area">
        <header class="entrenador-topbar">
            <div></div>
            <div class="topbar-actions">
                <button class="topbar-btn" title="Notificaciones">🔔</button>
                <button class="topbar-btn" title="Buscar">🔍</button>
                <a class="topbar-btn topbar-logout" href="/login" title="Salir">⏻ Salir</a>
            </div>
        </header>

        <main class="admin-main">
            @Body
        </main>
    </div>
</div>