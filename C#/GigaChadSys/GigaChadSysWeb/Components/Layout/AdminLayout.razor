@inherits LayoutComponentBase
@inject GigaChadSys.Servicios.SessionServicio Session
@inject NavigationManager Navigation
@inject GigaChadSysWeb.AppAdminsToggleService ToggleSvc
@inject IJSRuntime JS
@using Microsoft.AspNetCore.Components.Server.ProtectedBrowserStorage
@inject ProtectedSessionStorage SessionStorage
@implements IDisposable

<div class="d-flex vh-100 overflow-hidden bg-dark text-white">
    <aside class="col-md-3 col-lg-2 p-0 bg-black border-end border-secondary d-flex flex-column" style="border-color: #333 !important;">

        <!-- LOGO -->
        <div class="p-3 text-center border-bottom border-secondary" style="border-color: #333 !important;">
            <img src="/img/logo-gigachad-sidebar.png"
                 alt="GigaChad"
                 class="img-fluid" style="max-width: 140px;" />
        </div>

        <!-- MENÚ -->
        <nav class="nav flex-column flex-grow-1 overflow-auto p-2">

            <NavLink class="nav-link text-secondary fw-bold rounded-2 mb-1 py-2 px-3 d-flex align-items-center" href="/admin/inicio" Match="NavLinkMatch.All">
                <i class="bi bi-house-door me-3 fs-5"></i>
                <span>Inicio</span>
            </NavLink>

            <div class="text-uppercase text-muted small fw-bold px-3 mt-3 mb-2" style="font-size: 11px; letter-spacing: 1px;">Usuarios</div>

            <NavLink class="nav-link text-secondary fw-bold rounded-2 mb-1 py-2 px-3 d-flex align-items-center" href="/admin/socios">
                <i class="bi bi-people me-3 fs-5"></i>
                <span>Socios</span>
            </NavLink>

            <NavLink class="nav-link text-secondary fw-bold rounded-2 mb-1 py-2 px-3 d-flex align-items-center" href="/admin/entrenadores">
                <i class="bi bi-person-badge me-3 fs-5"></i>
                <span>Entrenadores</span>
            </NavLink>

            <NavLink class="nav-link text-secondary fw-bold rounded-2 mb-1 py-2 px-3 d-flex align-items-center" href="/admin/administradores">
                <i class="bi bi-person-workspace me-3 fs-5"></i>
                <span>Administradores</span>
            </NavLink>

            <div class="text-uppercase text-muted small fw-bold px-3 mt-3 mb-2" style="font-size: 11px; letter-spacing: 1px;">Membresías</div>

            <NavLink class="nav-link text-secondary fw-bold rounded-2 mb-1 py-2 px-3 d-flex align-items-center" href="/admin/membresias">
                <i class="bi bi-gem me-3 fs-5"></i>
                <span>Planes</span>
            </NavLink>

            <NavLink class="nav-link text-secondary fw-bold rounded-2 mb-1 py-2 px-3 d-flex align-items-center" href="/admin/suscripciones">
                <i class="bi bi-card-checklist me-3 fs-5"></i>
                <span>Suscripciones</span>
            </NavLink>

            <div class="text-uppercase text-muted small fw-bold px-3 mt-3 mb-2" style="font-size: 11px; letter-spacing: 1px;">Operaciones</div>

            <NavLink class="nav-link text-secondary fw-bold rounded-2 mb-1 py-2 px-3 d-flex align-items-center" href="/admin/clases">
                <i class="bi bi-fire me-3 fs-5"></i>
                <span>Clases</span>
            </NavLink>

            <NavLink class="nav-link text-secondary fw-bold rounded-2 mb-1 py-2 px-3 d-flex align-items-center" href="/admin/sesiones">
                <i class="bi bi-calendar-check me-3 fs-5"></i>
                <span>Sesiones</span>
            </NavLink>

            <NavLink class="nav-link text-secondary fw-bold rounded-2 mb-1 py-2 px-3 d-flex align-items-center" href="/admin/reservas">
                <i class="bi bi-clipboard-check me-3 fs-5"></i>
                <span>Reservas</span>
            </NavLink>

            <NavLink class="nav-link text-secondary fw-bold rounded-2 mb-1 py-2 px-3 d-flex align-items-center" href="/admin/pagos">
                <i class="bi bi-cash-coin me-3 fs-5"></i>
                <span>Pagos</span>
            </NavLink>

            <div class="text-uppercase text-muted small fw-bold px-3 mt-3 mb-2" style="font-size: 11px; letter-spacing: 1px;">Infraestructura</div>

            <NavLink class="nav-link text-secondary fw-bold rounded-2 mb-1 py-2 px-3 d-flex align-items-center" href="/admin/salones">
                <i class="bi bi-building me-3 fs-5"></i>
                <span>Salones</span>
            </NavLink>

            <div class="text-uppercase text-muted small fw-bold px-3 mt-3 mb-2" style="font-size: 11px; letter-spacing: 1px;">Análisis</div>

            <NavLink class="nav-link text-secondary fw-bold rounded-2 mb-1 py-2 px-3 d-flex align-items-center" href="/admin/reportes">
                <i class="bi bi-bar-chart-line me-3 fs-5"></i>
                <span>Reportes</span>
            </NavLink>

            <div class="text-uppercase text-muted small fw-bold px-3 mt-3 mb-2" style="font-size: 11px; letter-spacing: 1px;">Cuenta</div>

            <NavLink class="nav-link text-secondary fw-bold rounded-2 mb-1 py-2 px-3 d-flex align-items-center" href="/admin/perfil">
                <i class="bi bi-person-circle me-3 fs-5"></i>
                <span>Mi Perfil</span>
            </NavLink>

        </nav>

        <!-- PERFIL ABAJO -->
        <div class="p-3 border-top border-secondary bg-black" style="border-color: #333 !important;">
            <div class="d-flex align-items-center mb-3">
                <div class="d-flex align-items-center justify-content-center bg-danger text-white rounded-circle fw-bold me-3" style="width: 40px; height: 40px; font-size: 18px;">
                    @(Session.EstaAutenticado && !string.IsNullOrWhiteSpace(Session.Nombres)
                        ? Session.Nombres[0].ToString()
                        : "A")
                </div>

                <div class="text-truncate">
                    <div class="fw-bold text-white fs-6">@(Session.EstaAutenticado ? Session.Nombres : "Administrador")</div>
                    <div class="text-muted small">@(Session.EstaAutenticado ? Session.Rol : "admin@gigachad.com")</div>
                </div>
            </div>

            <button class="btn btn-outline-danger w-100 d-flex justify-content-center align-items-center border-0" @onclick="CerrarSesion">
                <i class="bi bi-box-arrow-left me-2"></i>
                <span>Cerrar Sesión</span>
            </button>
        </div>

    </aside>

    <!-- CONTENIDO -->
    <div class="col-md-9 col-lg-10 p-0 d-flex flex-column bg-dark">

        <header class="d-flex justify-content-between align-items-center p-3 border-bottom border-secondary bg-black" style="border-color: #333 !important;">
            <div></div>

            <div class="d-flex gap-3">
                <button class="btn btn-outline-secondary border-0 text-white d-flex align-items-center" title="Salir" @onclick="CerrarSesion">
                    <i class="bi bi-box-arrow-right me-2"></i>
                    <span>Salir</span>
                </button>
            </div>
        </header>

        <main class="flex-grow-1 p-4 overflow-auto" style="background-color: #0D0D0D;">
            @Body
        </main>

    </div>

</div>

@if (ToggleSvc.Visible)
{
    <AppAdmins />
}

@code {
    protected override void OnInitialized()
    {
        ToggleSvc.OnChange += HandleToggleChange;
        ToggleSvc.OnAutoClick += HandleAutoClick;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await Session.RestaurarDesdeStorageAsync(SessionStorage);
            StateHasChanged();
        }
    }

    private async void HandleAutoClick()
    {
        await InvokeAsync(async () =>
        {
            StateHasChanged();
            await Task.Delay(300);
            await JS.InvokeVoidAsync("eval", "document.querySelector('.gc-btn-danger-float')?.click()");
        });
    }

    private async void HandleToggleChange()
    {
        await InvokeAsync(StateHasChanged);
    }

    private async Task CerrarSesion()
    {
        await Session.LimpiarStorageAsync(SessionStorage);
        Session.CerrarSesion();
        Navigation.NavigateTo("/login", forceLoad: true);
    }

    public void Dispose()
    {
        ToggleSvc.OnChange -= HandleToggleChange;
        ToggleSvc.OnAutoClick -= HandleAutoClick;
    }
}