@page "/entrenador/perfil"
@using GigaChadSys.Servicios
@using GigaChadSys.Servicios.DTO
@layout EntrenadorLayout
@rendermode InteractiveServer
@inject SessionServicio Session
@inject EntrenadorServicio EntrenadorService

<section class="perfil-page">
    <div class="perfil-header">
        <h1>Mi Perfil</h1>
        <p class="perfil-subtitle">Tu información personal y profesional</p>
    </div>

    @if (!string.IsNullOrWhiteSpace(mensaje))
    {
        <div class="@claseMensaje" style="padding: 12px 18px; border-radius: 8px; margin-bottom: 16px; font-size: 0.95rem;">
            @mensaje
        </div>
    }

    <!-- Profile Card -->
    <div class="perfil-card">
        <div class="perfil-card-left">
            <div class="perfil-avatar-large">
                <span>👤</span>
            </div>
            <div class="perfil-card-info">
                <h2>@perfil.NombreCompleto</h2>
                <p class="perfil-email">@perfil.Correo</p>
                <div class="perfil-badges">
                    <span class="perfil-badge badge-activo">
                        <span class="estado-dot"></span> @perfil.Estado
                    </span>
                    <span class="perfil-badge badge-especialidad">
                        💪 @perfil.Especialidad
                    </span>
                </div>
            </div>
        </div>
        <div class="perfil-card-actions">
            <button class="btn-perfil-edit" @onclick="ToggleEditar">
                @(editando ? "✕ Cancelar" : "✏️ Editar Perfil")
            </button>
            <button class="btn-perfil-password" @onclick="ToggleCambiarContrasenia">
                @(cambiandoContrasenia ? "✕ Cancelar" : "⚙ Cambiar Contraseña")
            </button>
        </div>
    </div>

    <!-- Información Personal -->
    <div class="perfil-info-card">
        <h3>Información Personal</h3>

        <div class="perfil-info-list">
            <div class="perfil-info-row">
                <div class="perfil-info-icon">
                    <span>🪪</span>
                </div>
                <div>
                    <span class="perfil-info-label">DNI</span>
                    <strong>@perfil.DNI</strong>
                </div>
            </div>

            <div class="perfil-info-row">
                <div class="perfil-info-icon">
                    <span>👤</span>
                </div>
                <div>
                    <span class="perfil-info-label">Nombre Completo</span>
                    @if (editando)
                    {
                        <input type="text" @bind="editNombres" style="padding: 6px 10px; border: 1px solid #ccc; border-radius: 6px; width: 200px;" placeholder="Nombres" />
                    }
                    else
                    {
                        <strong>@perfil.NombreCompleto</strong>
                    }
                </div>
            </div>

            <div class="perfil-info-row">
                <div class="perfil-info-icon">
                    <span>📞</span>
                </div>
                <div>
                    <span class="perfil-info-label">Teléfono</span>
                    @if (editando)
                    {
                        <input type="text" @bind="editTelefono" style="padding: 6px 10px; border: 1px solid #ccc; border-radius: 6px; width: 200px;" placeholder="Teléfono" />
                    }
                    else
                    {
                        <strong>@perfil.Telefono</strong>
                    }
                </div>
            </div>

            <div class="perfil-info-row">
                <div class="perfil-info-icon">
                    <span>✉️</span>
                </div>
                <div>
                    <span class="perfil-info-label">Correo Electrónico</span>
                    @if (editando)
                    {
                        <input type="email" @bind="editEmail" style="padding: 6px 10px; border: 1px solid #ccc; border-radius: 6px; width: 200px;" placeholder="Email" />
                    }
                    else
                    {
                        <strong>@perfil.Correo</strong>
                    }
                </div>
            </div>

            <div class="perfil-info-row">
                <div class="perfil-info-icon">
                    <span>💪</span>
                </div>
                <div>
                    <span class="perfil-info-label">Especialidad</span>
                    @if (editando)
                    {
                        <input type="text" @bind="editEspecialidad" style="padding: 6px 10px; border: 1px solid #ccc; border-radius: 6px; width: 200px;" placeholder="Especialidad" />
                    }
                    else
                    {
                        <strong>@perfil.Especialidad</strong>
                    }
                </div>
            </div>

            <div class="perfil-info-row">
                <div class="perfil-info-icon">
                    <span>📅</span>
                </div>
                <div>
                    <span class="perfil-info-label">Fecha de Ingreso</span>
                    <strong>@perfil.FechaIngreso.ToString("yyyy-MM-dd")</strong>
                </div>
            </div>

            <div class="perfil-info-row">
                <div class="perfil-info-icon">
                    <span>🏋️</span>
                </div>
                <div>
                    <span class="perfil-info-label">Estado</span>
                    <strong class="estado-al-dia">@perfil.Estado</strong>
                </div>
            </div>
        </div>

        @if (editando)
        {
            <div style="display: flex; gap: 12px; margin-top: 16px;">
                <button class="btn-perfil-edit" @onclick="GuardarPerfil" style="background: #22c55e; border-color: #22c55e;">
                    💾 Guardar Cambios
                </button>
                <button class="btn-perfil-password" @onclick="ToggleEditar">
                    ✕ Cancelar
                </button>
            </div>
        }
    </div>

    @if (cambiandoContrasenia)
    {
        <div class="perfil-info-card" style="margin-top: 16px;">
            <h3>Cambiar Contraseña</h3>
            <div class="perfil-info-list">
                <div class="perfil-info-row">
                    <div class="perfil-info-icon"><span>🔒</span></div>
                    <div style="flex:1;">
                        <span class="perfil-info-label">Nueva Contraseña</span>
                        <input type="password" @bind="nuevaContrasenia" style="padding: 6px 10px; border: 1px solid #ccc; border-radius: 6px; width: 200px;" placeholder="Nueva contraseña" />
                    </div>
                </div>
                <div class="perfil-info-row">
                    <div class="perfil-info-icon"><span>🔒</span></div>
                    <div style="flex:1;">
                        <span class="perfil-info-label">Confirmar Contraseña</span>
                        <input type="password" @bind="confirmarContrasenia" style="padding: 6px 10px; border: 1px solid #ccc; border-radius: 6px; width: 200px;" placeholder="Confirmar contraseña" />
                    </div>
                </div>
            </div>
            <div style="display: flex; gap: 12px; margin-top: 16px;">
                <button class="btn-perfil-edit" @onclick="GuardarContrasenia" style="background: #22c55e; border-color: #22c55e;">
                    💾 Guardar Contraseña
                </button>
                <button class="btn-perfil-password" @onclick="ToggleCambiarContrasenia">
                    ✕ Cancelar
                </button>
            </div>
        </div>
    }
</section>

@code {
    private PerfilEntrenador perfil = new();
    private EntrenadorDTO? entrenadorActual;

    private bool editando = false;
    private bool cambiandoContrasenia = false;

    private string editNombres = "";
    private string editTelefono = "";
    private string editEmail = "";
    private string editEspecialidad = "";

    private string nuevaContrasenia = "";
    private string confirmarContrasenia = "";

    private string mensaje = "";
    private string claseMensaje = "";

    protected override async Task OnInitializedAsync()
    {
        if (Session.EstaAutenticado)
        {
            entrenadorActual = await EntrenadorService.ObtenerPorIdAsync(Session.IdUsuario);
            if (entrenadorActual != null)
            {
                perfil = new PerfilEntrenador
                {
                    DNI = entrenadorActual.Dni.ToString(),
                    NombreCompleto = $"{entrenadorActual.Nombres} {entrenadorActual.ApellidoPaterno} {entrenadorActual.ApellidoMaterno}",
                    Telefono = entrenadorActual.Telefono.ToString(),
                    Correo = entrenadorActual.Email,
                    Especialidad = entrenadorActual.Especialidad,
                    FechaIngreso = DateTime.Today,
                    Estado = entrenadorActual.Activo ? "Activo" : "Inactivo"
                };

                editNombres = entrenadorActual.Nombres;
                editTelefono = entrenadorActual.Telefono.ToString();
                editEmail = entrenadorActual.Email;
                editEspecialidad = entrenadorActual.Especialidad;
            }
        }
    }

    private void ToggleEditar()
    {
        editando = !editando;
        cambiandoContrasenia = false;
        mensaje = "";

        if (editando && entrenadorActual != null)
        {
            editNombres = entrenadorActual.Nombres;
            editTelefono = entrenadorActual.Telefono.ToString();
            editEmail = entrenadorActual.Email;
            editEspecialidad = entrenadorActual.Especialidad;
        }
    }

    private void ToggleCambiarContrasenia()
    {
        cambiandoContrasenia = !cambiandoContrasenia;
        editando = false;
        mensaje = "";
        nuevaContrasenia = "";
        confirmarContrasenia = "";
    }

    private async Task GuardarPerfil()
    {
        if (entrenadorActual == null) return;

        entrenadorActual.Nombres = editNombres;
        entrenadorActual.Email = editEmail;
        entrenadorActual.Especialidad = editEspecialidad;
        if (int.TryParse(editTelefono, out int tel))
            entrenadorActual.Telefono = tel;

        var resultado = await EntrenadorService.ActualizarAsync(entrenadorActual.IdUsuario, entrenadorActual);

        if (!resultado.ToLower().Contains("error"))
        {
            perfil.NombreCompleto = $"{entrenadorActual.Nombres} {entrenadorActual.ApellidoPaterno} {entrenadorActual.ApellidoMaterno}";
            perfil.Correo = entrenadorActual.Email;
            perfil.Telefono = entrenadorActual.Telefono.ToString();
            perfil.Especialidad = entrenadorActual.Especialidad;
            editando = false;
            mensaje = "✓ Perfil actualizado correctamente.";
            claseMensaje = "renew-message success";
        }
        else
        {
            mensaje = "✗ Error al actualizar: " + resultado;
            claseMensaje = "renew-message error";
        }
    }

    private async Task GuardarContrasenia()
    {
        if (entrenadorActual == null) return;

        if (string.IsNullOrWhiteSpace(nuevaContrasenia))
        {
            mensaje = "✗ Debes ingresar una contraseña.";
            claseMensaje = "renew-message error";
            return;
        }

        if (nuevaContrasenia != confirmarContrasenia)
        {
            mensaje = "✗ Las contraseñas no coinciden.";
            claseMensaje = "renew-message error";
            return;
        }

        entrenadorActual.Contrasenia = nuevaContrasenia;
        var resultado = await EntrenadorService.ActualizarAsync(entrenadorActual.IdUsuario, entrenadorActual);

        if (!resultado.ToLower().Contains("error"))
        {
            cambiandoContrasenia = false;
            nuevaContrasenia = "";
            confirmarContrasenia = "";
            mensaje = "✓ Contraseña actualizada correctamente.";
            claseMensaje = "renew-message success";
        }
        else
        {
            mensaje = "✗ Error al actualizar contraseña: " + resultado;
            claseMensaje = "renew-message error";
        }
    }

    private class PerfilEntrenador
    {
        public string DNI { get; set; } = "—";
        public string NombreCompleto { get; set; } = "Cargando...";
        public string Telefono { get; set; } = "—";
        public string Correo { get; set; } = "—";
        public string Especialidad { get; set; } = "—";
        public DateTime FechaIngreso { get; set; } = DateTime.Today;
        public string Estado { get; set; } = "—";
    }
}
