@code {
    private PerfilEntrenador perfil = new();
    private EntrenadorDTO? entrenadorActual;

    private bool cargando = true;
    private bool guardando = false;

    private bool editando = false;
    private bool cambiandoContrasenia = false;

    private string editNombres = "";
    private string editApellidoPaterno = "";
    private string editApellidoMaterno = "";
    private string editTelefono = "";
    private string editEmail = "";
    private string editEspecialidad = "";

    private string nuevaContrasenia = "";
    private string confirmarContrasenia = "";

    private bool intentoGuardar = false;

    private string InicialesPerfil
    {
        get
        {
            string nombres = entrenadorActual?.Nombres ?? "";
            string apellido = entrenadorActual?.ApellidoPaterno ?? "";

            string inicial1 = !string.IsNullOrWhiteSpace(nombres)
                ? nombres.Trim()[0].ToString().ToUpper()
                : "E";

            string inicial2 = !string.IsNullOrWhiteSpace(apellido)
                ? apellido.Trim()[0].ToString().ToUpper()
                : "";

            return inicial1 + inicial2;
        }
    }

    private string ClaseBadgeEstado =>
        perfil.Estado == "Activo"
            ? "ep-badge active"
            : "ep-badge inactive";

    private string ClaseTextoEstado =>
        perfil.Estado == "Activo"
            ? "ep-text-green"
            : "ep-text-red";

    protected override async Task OnInitializedAsync()
    {
        cargando = true;

        try
        {
            if (!Session.EstaAutenticado)
                return;

            entrenadorActual = await EntrenadorService.ObtenerPorIdAsync(Session.IdUsuario);

            if (entrenadorActual != null)
            {
                CargarPerfilDesdeEntrenador();
            }
        }
        finally
        {
            cargando = false;
        }
    }

    private void CargarPerfilDesdeEntrenador()
    {
        if (entrenadorActual == null)
            return;

        perfil = new PerfilEntrenador
        {
            DNI = entrenadorActual.Dni.ToString(),
            NombreCompleto = $"{entrenadorActual.Nombres} {entrenadorActual.ApellidoPaterno} {entrenadorActual.ApellidoMaterno}".Trim(),
            Telefono = entrenadorActual.Telefono.ToString(),
            Correo = entrenadorActual.Email,
            Especialidad = string.IsNullOrWhiteSpace(entrenadorActual.Especialidad) ? "Sin especialidad" : entrenadorActual.Especialidad,
            Sueldo = entrenadorActual.Sueldo,
            TiempoTrabajo = NormalizarTiempoTrabajo(entrenadorActual.TiempoTrabajado),
            Estado = entrenadorActual.Activo ? "Activo" : "Inactivo"
        };

        editNombres = entrenadorActual.Nombres;
        editApellidoPaterno = entrenadorActual.ApellidoPaterno;
        editApellidoMaterno = entrenadorActual.ApellidoMaterno;
        editTelefono = entrenadorActual.Telefono.ToString();
        editEmail = entrenadorActual.Email;
        editEspecialidad = entrenadorActual.Especialidad;
    }

    private void ToggleEditar()
    {
        editando = !editando;
        cambiandoContrasenia = false;
        LimpiarMensaje();

        if (editando && entrenadorActual != null)
        {
            editNombres = entrenadorActual.Nombres;
            editApellidoPaterno = entrenadorActual.ApellidoPaterno;
            editApellidoMaterno = entrenadorActual.ApellidoMaterno;
            editTelefono = entrenadorActual.Telefono.ToString();
            editEmail = entrenadorActual.Email;
            editEspecialidad = entrenadorActual.Especialidad;
        }
    }

    private void ToggleCambiarContrasenia()
    {
        cambiandoContrasenia = !cambiandoContrasenia;
        editando = false;
        LimpiarMensaje();

        nuevaContrasenia = "";
        confirmarContrasenia = "";
    }

    private async Task GuardarPerfil()
    {
        if (entrenadorActual == null)
            return;

        intentoGuardar = true;

        if (string.IsNullOrWhiteSpace(editNombres))
        {
            MostrarError("Los nombres son obligatorios.");
            return;
        }

        if (string.IsNullOrWhiteSpace(editApellidoPaterno))
        {
            MostrarError("El apellido paterno es obligatorio.");
            return;
        }

        if (string.IsNullOrWhiteSpace(editApellidoMaterno))
        {
            MostrarError("El apellido materno es obligatorio.");
            return;
        }

        if (string.IsNullOrWhiteSpace(editTelefono) ||
            editTelefono.Length != 9 ||
            !int.TryParse(editTelefono, out int telefonoConvertido))
        {
            MostrarError("El teléfono debe tener 9 dígitos numéricos.");
            return;
        }

        if (string.IsNullOrWhiteSpace(editEmail) ||
            !editEmail.Contains("@") ||
            !editEmail.Contains("."))
        {
            MostrarError("Ingrese un correo electrónico válido.");
            return;
        }

        if (string.IsNullOrWhiteSpace(editEspecialidad))
        {
            MostrarError("La especialidad es obligatoria.");
            return;
        }

        try
        {
            guardando = true;

            entrenadorActual.Nombres = editNombres.Trim();
            entrenadorActual.ApellidoPaterno = editApellidoPaterno.Trim();
            entrenadorActual.ApellidoMaterno = editApellidoMaterno.Trim();
            entrenadorActual.Telefono = telefonoConvertido;
            entrenadorActual.Email = editEmail.Trim();
            entrenadorActual.Especialidad = editEspecialidad.Trim();

            if (string.IsNullOrWhiteSpace(entrenadorActual.Rol))
                entrenadorActual.Rol = "Entrenador";

            var resultado = await EntrenadorService.ActualizarAsync(entrenadorActual.IdUsuario, entrenadorActual);

            if (!resultado.ToLower().Contains("error"))
            {
                CargarPerfilDesdeEntrenador();

                editando = false;
                MostrarExito("Perfil actualizado correctamente.");
            }
            else
            {
                MostrarError("Error al actualizar: " + resultado);
            }
        }
        finally
        {
            guardando = false;
        }
    }

    private async Task GuardarContrasenia()
    {
        if (entrenadorActual == null)
            return;

        intentoGuardar = true;

        if (string.IsNullOrWhiteSpace(nuevaContrasenia))
        {
            MostrarError("Debes ingresar una contraseña.");
            return;
        }

        if (nuevaContrasenia.Length < 6)
        {
            MostrarError("La contraseña debe tener mínimo 6 caracteres.");
            return;
        }

        if (nuevaContrasenia != confirmarContrasenia)
        {
            MostrarError("Las contraseñas no coinciden.");
            return;
        }

        try
        {
            guardando = true;

            entrenadorActual.Contrasenia = nuevaContrasenia;

            if (string.IsNullOrWhiteSpace(entrenadorActual.Rol))
                entrenadorActual.Rol = "Entrenador";

            var resultado = await EntrenadorService.ActualizarAsync(entrenadorActual.IdUsuario, entrenadorActual);

            if (!resultado.ToLower().Contains("error"))
            {
                cambiandoContrasenia = false;
                nuevaContrasenia = "";
                confirmarContrasenia = "";

                MostrarExito("Contraseña actualizada correctamente.");
            }
            else
            {
                MostrarError("Error al actualizar contraseña: " + resultado);
            }
        }
        finally
        {
            guardando = false;
        }
    }

    private string NormalizarTiempoTrabajo(string? valor)
    {
        if (string.IsNullOrWhiteSpace(valor))
            return "—";

        return valor.Trim() switch
        {
            "08:00:00" => "Tiempo completo - 8 horas",
            "8:00:00" => "Tiempo completo - 8 horas",
            "04:00:00" => "Medio tiempo - 4 horas",
            "4:00:00" => "Medio tiempo - 4 horas",
            "02:00:00" => "Por horas - 2 horas",
            "2:00:00" => "Por horas - 2 horas",
            _ => valor
        };
    }

    private void MostrarExito(string texto)
    {
        ToastService.ShowSuccess(texto);
    }

    private void MostrarError(string texto)
    {
        ToastService.ShowError(texto);
    }

    private void LimpiarMensaje()
    {
        // No-op
    }

    private class PerfilEntrenador
    {
        public string DNI { get; set; } = "—";
        public string NombreCompleto { get; set; } = "Cargando...";
        public string Telefono { get; set; } = "—";
        public string Correo { get; set; } = "—";
        public string Especialidad { get; set; } = "—";
        public double Sueldo { get; set; }
        public string TiempoTrabajo { get; set; } = "—";
        public string Estado { get; set; } = "—";
    }
}