@page "/entrenador/perfil"
@using GigaChadSys.Servicios
@using GigaChadSys.Servicios.DTO
@layout EntrenadorLayout
@rendermode InteractiveServer
@inject SessionServicio Session
@inject EntrenadorServicio EntrenadorService
@inject ToastService ToastService

<section class="ep-page">

    <div class="ep-header">
        <h1>Mi Perfil</h1>
        <p>Tu información personal y profesional</p>
    </div>

    @if (cargando)
    {
        <div class="ep-card ep-loading">
            <div class="ep-card-icon blue">
                <i class="bi bi-hourglass-split"></i>
            </div>

            <div>
                <h2>Cargando perfil...</h2>
                <p>Obteniendo tu información desde el servidor.</p>
            </div>
        </div>
    }
    else if (entrenadorActual == null)
    {
        <div class="ep-card ep-loading">
            <div class="ep-card-icon red">
                <i class="bi bi-exclamation-triangle"></i>
            </div>

            <div>
                <h2>No se encontró información del entrenador</h2>
                <p>Vuelve a iniciar sesión o contacta al administrador.</p>
            </div>
        </div>
    }
    else
    {
        <div class="ep-profile-card">

            <div class="ep-profile-left">
                <div class="ep-avatar">
                    @InicialesPerfil
                </div>

                <div class="ep-profile-info">
                    <h2>@perfil.NombreCompleto</h2>
                    <p>@perfil.Correo</p>

                    <div class="ep-badges">
                        <span class="@ClaseBadgeEstado">
                            <i class="bi bi-circle-fill"></i>
                            @perfil.Estado
                        </span>

                        <span class="ep-badge specialty">
                            <i class="bi bi-person-badge"></i>
                            @perfil.Especialidad
                        </span>
                    </div>
                </div>
            </div>

            <div class="ep-profile-actions">
                <button type="button"
                        class="ep-outline-btn"
                        @onclick="ToggleEditar"
                        disabled="@guardando">
                    <i class="bi @(editando ? "bi-x-circle" : "bi-pencil")"></i>
                    @(editando ? "Cancelar edición" : "Editar Perfil")
                </button>

                <button type="button"
                        class="ep-outline-btn"
                        @onclick="ToggleCambiarContrasenia"
                        disabled="@guardando">
                    <i class="bi @(cambiandoContrasenia ? "bi-x-circle" : "bi-lock")"></i>
                    @(cambiandoContrasenia ? "Cancelar cambio" : "Cambiar Contraseña")
                </button>
            </div>

        </div>

        <div class="ep-grid">

            <div class="ep-card">
                <div class="ep-card-title">
                    <div class="ep-card-icon red">
                        <i class="bi bi-person-vcard"></i>
                    </div>

                    <div>
                        <h3>Información Personal</h3>
                        <p>Datos principales de tu cuenta</p>
                    </div>
                </div>

                <div class="ep-info-list">

                    <div class="ep-info-row">
                        <div class="ep-info-label">
                            <i class="bi bi-credit-card-2-front"></i>
                            <span>DNI</span>
                        </div>
                        <strong>@perfil.DNI</strong>
                    </div>

                    <div class="ep-info-row">
                        <div class="ep-info-label">
                            <i class="bi bi-person"></i>
                            <span>Nombres</span>
                        </div>

                        @if (editando)
                        {
                            <input class="ep-input @(intentoGuardar && string.IsNullOrWhiteSpace(editNombres) ? "input-error" : "")"
                                   type="text"
                                   @bind="editNombres"
                                   placeholder="Nombres" />
                        }
                        else
                        {
                            <strong>@entrenadorActual.Nombres</strong>
                        }
                    </div>

                    <div class="ep-info-row">
                        <div class="ep-info-label">
                            <i class="bi bi-person-lines-fill"></i>
                            <span>Apellido paterno</span>
                        </div>

                        @if (editando)
                        {
                            <input class="ep-input @(intentoGuardar && string.IsNullOrWhiteSpace(editApellidoPaterno) ? "input-error" : "")"
                                   type="text"
                                   @bind="editApellidoPaterno"
                                   placeholder="Apellido paterno" />
                        }
                        else
                        {
                            <strong>@entrenadorActual.ApellidoPaterno</strong>
                        }
                    </div>

                    <div class="ep-info-row">
                        <div class="ep-info-label">
                            <i class="bi bi-person-lines-fill"></i>
                            <span>Apellido materno</span>
                        </div>

                        @if (editando)
                        {
                            <input class="ep-input @(intentoGuardar && string.IsNullOrWhiteSpace(editApellidoMaterno) ? "input-error" : "")"
                                   type="text"
                                   @bind="editApellidoMaterno"
                                   placeholder="Apellido materno" />
                        }
                        else
                        {
                            <strong>@entrenadorActual.ApellidoMaterno</strong>
                        }
                    </div>

                    <div class="ep-info-row">
                        <div class="ep-info-label">
                            <i class="bi bi-telephone"></i>
                            <span>Teléfono</span>
                        </div>

                        @if (editando)
                        {
                            <input class="ep-input @(intentoGuardar && (string.IsNullOrWhiteSpace(editTelefono) || editTelefono.Length != 9) ? "input-error" : "")"
                                   type="text"
                                   maxlength="9"
                                   @bind="editTelefono"
                                   placeholder="Teléfono" />
                        }
                        else
                        {
                            <strong>@perfil.Telefono</strong>
                        }
                    </div>

                    <div class="ep-info-row">
                        <div class="ep-info-label">
                            <i class="bi bi-envelope"></i>
                            <span>Correo electrónico</span>
                        </div>

                        @if (editando)
                        {
                            <input class="ep-input @(intentoGuardar && (string.IsNullOrWhiteSpace(editEmail) || !editEmail.Contains("@")) ? "input-error" : "")"
                                   type="email"
                                   @bind="editEmail"
                                   placeholder="Correo electrónico" />
                        }
                        else
                        {
                            <strong>@perfil.Correo</strong>
                        }
                    </div>

                    <div class="ep-info-row">
                        <div class="ep-info-label">
                            <i class="bi bi-activity"></i>
                            <span>Estado</span>
                        </div>
                        <strong class="@ClaseTextoEstado">@perfil.Estado</strong>
                    </div>

                </div>

                @if (editando)
                {
                    <div class="ep-actions">
                        <button type="button"
                                class="ep-main-btn"
                                @onclick="GuardarPerfil"
                                disabled="@guardando">
                            <i class="bi @(guardando ? "bi-hourglass-split" : "bi-check-circle")"></i>
                            @(guardando ? "Guardando..." : "Guardar Cambios")
                        </button>

                        <button type="button"
                                class="ep-secondary-btn"
                                @onclick="ToggleEditar"
                                disabled="@guardando">
                            <i class="bi bi-x-circle"></i>
                            Cancelar
                        </button>
                    </div>
                }
            </div>

            <aside class="ep-side">

                <div class="ep-card ep-work-card">
                    <div class="ep-card-title compact">
                        <div class="ep-card-icon gold">
                            <i class="bi bi-person-workspace"></i>
                        </div>

                        <div>
                            <h3>Información Profesional</h3>
                            <p>Datos laborales del entrenador</p>
                        </div>
                    </div>

                    <div class="ep-work-summary">
                        <span>Especialidad</span>

                        @if (editando)
                        {
                            <input class="ep-input @(intentoGuardar && string.IsNullOrWhiteSpace(editEspecialidad) ? "input-error" : "")"
                                   type="text"
                                   @bind="editEspecialidad"
                                   placeholder="Especialidad" />
                        }
                        else
                        {
                            <strong>@perfil.Especialidad</strong>
                        }
                    </div>

                    <div class="ep-work-summary">
                        <span>Sueldo mensual</span>
                        <strong>S/@perfil.Sueldo.ToString("0.00")</strong>
                    </div>

                    <div class="ep-work-summary">
                        <span>Tiempo de trabajo</span>
                        <strong>@perfil.TiempoTrabajo</strong>
                    </div>
                </div>

                <div class="ep-card ep-security-card">
                    <div class="ep-card-title compact">
                        <div class="ep-card-icon blue">
                            <i class="bi bi-shield-lock"></i>
                        </div>

                        <div>
                            <h3>Acceso y Seguridad</h3>
                            <p>Credenciales de tu cuenta</p>
                        </div>
                    </div>

                    <div class="ep-security-item">
                        <i class="bi bi-lock"></i>
                        <div>
                            <strong>Contraseña protegida</strong>
                            <span>Actualiza tu contraseña cuando lo necesites.</span>
                        </div>
                    </div>

                    <div class="ep-security-item">
                        <i class="bi bi-person-check"></i>
                        <div>
                            <strong>Cuenta de entrenador</strong>
                            <span>Acceso a sesiones asignadas, horario y pagos.</span>
                        </div>
                    </div>
                </div>

            </aside>

        </div>

        @if (cambiandoContrasenia)
        {
            <div class="ep-card ep-password-card">
                <div class="ep-card-title">
                    <div class="ep-card-icon blue">
                        <i class="bi bi-lock"></i>
                    </div>

                    <div>
                        <h3>Cambiar Contraseña</h3>
                        <p>Actualiza tus credenciales de acceso</p>
                    </div>
                </div>

                <div class="ep-password-grid">
                    <div class="ep-form-group">
                        <label>Nueva contraseña</label>
                        <input class="ep-input @(intentoGuardar && (string.IsNullOrWhiteSpace(nuevaContrasenia) || nuevaContrasenia.Length < 6) ? "input-error" : "")"
                               type="password"
                               @bind="nuevaContrasenia"
                               placeholder="Nueva contraseña" />
                    </div>

                    <div class="ep-form-group">
                        <label>Confirmar contraseña</label>
                        <input class="ep-input @(intentoGuardar && nuevaContrasenia != confirmarContrasenia ? "input-error" : "")"
                               type="password"
                               @bind="confirmarContrasenia"
                               placeholder="Confirmar contraseña" />
                    </div>
                </div>

                <div class="ep-actions">
                    <button type="button"
                            class="ep-main-btn"
                            @onclick="GuardarContrasenia"
                            disabled="@guardando">
                        <i class="bi @(guardando ? "bi-hourglass-split" : "bi-check-circle")"></i>
                        @(guardando ? "Guardando..." : "Guardar Contraseña")
                    </button>

                    <button type="button"
                            class="ep-secondary-btn"
                            @onclick="ToggleCambiarContrasenia"
                            disabled="@guardando">
                        <i class="bi bi-x-circle"></i>
                        Cancelar
                    </button>
                </div>
            </div>
        }
    }

</section>

