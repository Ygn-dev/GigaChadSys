@page "/admin/suscripciones"
@layout AdminLayout
@rendermode InteractiveServer
@using GigaChadSys.Servicios
@using GigaChadSys.Servicios.DTO
@inject SuscripcionServicio SuscripcionService
@inject SocioServicio SocioService

<section class="admin-list-page">
    <div class="admin-list-header">
        <div>
            <h1>Suscripciones Activas</h1>
            <p>Monitorea todas las suscripciones de los socios del gimnasio.</p>
        </div>
    </div>

    <div class="admin-list-toolbar">
        <input class="admin-search"
               type="text"
               placeholder="Buscar por ID Socio..."
               @bind="TextoBusqueda"
               @bind:event="oninput" />

        <div class="admin-filter-group">
            <button class="@FiltroClaseTodos" @onclick="MostrarTodos">Todas</button>
            <button class="@FiltroClaseActivos" @onclick="MostrarActivas">Activas</button>
            <button class="@FiltroClaseInactivos" @onclick="MostrarInactivas">Inactivas</button>
        </div>
    </div>

    @{
        var suscripciones = SuscripcionesPaginadas.ToList();
    }

    <div class="admin-table-card">
        <table class="admin-table">
            <thead>
                <tr>
                    <th>ID Susc.</th>
                    <th>Socio</th>
                    <th>Tipo Plan</th>
                    <th>F. Inicio</th>
                    <th>F. Fin</th>
                    <th>Estado Membresía</th>
                    <th>Estado Reg.</th>
                </tr>
            </thead>

            <tbody>
                @if (Cargando)
                {
                    <tr>
                        <td colspan="7" class="empty-row">
                            Cargando suscripciones...
                        </td>
                    </tr>
                }
                else if (suscripciones.Count == 0)
                {
                    <tr>
                        <td colspan="7" class="empty-row">
                            No se encontraron suscripciones.
                        </td>
                    </tr>
                }
                else
                {
                    @foreach (var suscripcion in suscripciones)
                    {
                        <tr>
                            <td>#@suscripcion.IdSuscripcion</td>
                            <td>
                                <strong>@ObtenerNombreSocio(suscripcion.IdUsuario)</strong>
                                <br />
                                <small style="color: #6c757d;">ID Usuario: @suscripcion.IdUsuario</small>
                            </td>
                            <td>
                                @if (suscripcion.EsBlack)
                                {
                                    <span class="badge-s badge-s-black"><i class="bi bi-gem"></i> Black</span>
                                }
                                else if (suscripcion.EsBasic)
                                {
                                    <span class="badge-s badge-s-basic"><i class="bi bi-info-circle"></i> Basic</span>
                                }
                                else
                                {
                                    <span style="color: #6c757d;">Desconocido</span>
                                }
                            </td>
                            <td>@suscripcion.FechaInicioTexto</td>
                            <td>@suscripcion.FechaFinTexto</td>

                            <td>
                                @if (suscripcion.EsActiva)
                                {
                                    <span class="status-badge active">Activa</span>
                                }
                                else
                                {
                                    <span class="status-badge inactive">Inactiva</span>
                                }
                            </td>
                            
                            <td>
                                @if (suscripcion.Activo)
                                {
                                    <span class="status-badge active">Registro Activo</span>
                                }
                                else
                                {
                                    <span class="status-badge inactive">Registro Inactivo</span>
                                }
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>

    <div class="socios-pagination">
        <span class="pagination-s-info">
            Mostrando @(((PaginaActual - 1) * ElementosPorPagina) + 1) - @Math.Min(PaginaActual * ElementosPorPagina, SuscripcionesFiltradas.Count()) de @SuscripcionesFiltradas.Count()
        </span>
        <div class="pagination-s-btns">
            <button class="pgbtn" disabled="@(PaginaActual == 1)" @onclick="PaginaAnterior">‹</button>
            @for (int i = 1; i <= TotalPaginas; i++)
            {
                int pagina = i;
                <button class="pgbtn @(PaginaActual == pagina ? "pgbtn-active" : "")" @onclick="() => IrAPagina(pagina)">@pagina</button>
            }
            <button class="pgbtn" disabled="@(PaginaActual == TotalPaginas)" @onclick="PaginaSiguiente">›</button>
        </div>
    </div>
</section>

@code {
    private bool Cargando { get; set; } = true;

    private List<SuscripcionDTO> Suscripciones = new();
    private List<SocioDTO> Socios = new();

    private string _textoBusqueda = "";
    private string TextoBusqueda
    {
        get => _textoBusqueda;
        set
        {
            if (_textoBusqueda != value)
            {
                _textoBusqueda = value;
                PaginaActual = 1;
            }
        }
    }

    private string _filtroEstado = "Todos";
    private string FiltroEstado
    {
        get => _filtroEstado;
        set
        {
            if (_filtroEstado != value)
            {
                _filtroEstado = value;
                PaginaActual = 1;
            }
        }
    }

    private int PaginaActual = 1;
    private int ElementosPorPagina = 10;

    private string FiltroClaseTodos => FiltroEstado == "Todos" ? "filter-button active" : "filter-button";
    private string FiltroClaseActivos => FiltroEstado == "Activas" ? "filter-button active" : "filter-button";
    private string FiltroClaseInactivos => FiltroEstado == "Inactivas" ? "filter-button active" : "filter-button";

    protected override async Task OnInitializedAsync()
    {
        await CargarDatos();
    }

    private async Task CargarDatos()
    {
        Cargando = true;
        try
        {
            var taskSocios = SocioService.ListarSociosAsync();
            var taskSuscripciones = SuscripcionService.ListarSuscripcionesAsync();

            await Task.WhenAll(taskSocios, taskSuscripciones);

            Socios = taskSocios.Result ?? new List<SocioDTO>();
            Suscripciones = taskSuscripciones.Result ?? new List<SuscripcionDTO>();
        }
        finally
        {
            Cargando = false;
        }
    }

    private string ObtenerNombreSocio(int idUsuario)
    {
        var socio = Socios.FirstOrDefault(s => s.IdUsuario == idUsuario);
        return socio != null ? socio.NombreCompleto : "Socio Desconocido";
    }

    private void MostrarTodos() { FiltroEstado = "Todos"; }
    private void MostrarActivas() { FiltroEstado = "Activas"; }
    private void MostrarInactivas() { FiltroEstado = "Inactivas"; }

    private void PaginaAnterior() { if (PaginaActual > 1) PaginaActual--; }
    private void PaginaSiguiente() { if (PaginaActual < TotalPaginas) PaginaActual++; }
    private void IrAPagina(int pagina) { PaginaActual = pagina; }

    private IEnumerable<SuscripcionDTO> SuscripcionesFiltradas
    {
        get
        {
            IEnumerable<SuscripcionDTO> resultado = Suscripciones;

            if (FiltroEstado == "Activas")
                resultado = resultado.Where(e => e.EsActiva);
            else if (FiltroEstado == "Inactivas")
                resultado = resultado.Where(e => !e.EsActiva);

            if (!string.IsNullOrWhiteSpace(TextoBusqueda))
            {
                string texto = TextoBusqueda.Trim();
                resultado = resultado.Where(e =>
                    e.IdUsuario.ToString().Contains(texto) ||
                    ObtenerNombreSocio(e.IdUsuario).Contains(texto, StringComparison.OrdinalIgnoreCase)
                );
            }

            return resultado;
        }
    }

    private IEnumerable<SuscripcionDTO> SuscripcionesPaginadas =>
        SuscripcionesFiltradas.Skip((PaginaActual - 1) * ElementosPorPagina).Take(ElementosPorPagina);

    private int TotalPaginas =>
        Math.Max(1, (int)Math.Ceiling(SuscripcionesFiltradas.Count() / (double)ElementosPorPagina));
}
