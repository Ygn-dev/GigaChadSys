@page "/socio/reservas"
@using GigaChadSys.Servicios
@using GigaChadSys.Servicios.DTO
@layout SocioLayout
@rendermode InteractiveServer
@inject SessionServicio Session
@inject ReservaServicio ReservaService

<section class="container-fluid py-4">
    <div class="reservas-breadcrumb">Reservar clase / Mis Reservas</div>

    <div class="reservas-header">
        <h1>Mis Reservas</h1>
        <p class="reservas-subtitle">Gestiona tus reservas de clases</p>
    </div>

    <div class="reservas-tabs">
        <button class="reservas-tab @(tabActiva == "activas" ? "tab-activa" : "")" @onclick='() => tabActiva = "activas"'>
            Reservas Activas (@reservasActivas.Count)
        </button>
        <button class="reservas-tab @(tabActiva == "historial" ? "tab-activa" : "")" @onclick='() => tabActiva = "historial"'>
            Historial (@historial.Count)
        </button>
    </div>

    <div class="reservas-list">
        @{
            var listaActual = tabActiva == "activas" ? reservasActivas : historial;
        }

        @if (listaActual.Count == 0)
        {
            <div class="reservas-empty">
                <p>No hay reservas en esta sección.</p>
            </div>
        }
        else
        {
            @foreach (var r in listaActual)
            {
                <div class="reserva-row">
                    <div class="reserva-row-icon">
                        <span>📅</span>
                    </div>

                    <div class="reserva-row-info">
                        <strong>@r.NombreClase</strong>
                        <span>@r.Disciplina</span>
                    </div>

                    <div class="reserva-row-meta">
                        <span class="meta-label">Entrenador</span>
                        <strong>@r.Entrenador</strong>
                    </div>

                    <div class="reserva-row-meta">
                        <span class="meta-label">Fecha</span>
                        <strong>@r.Fecha</strong>
                    </div>

                    <div class="reserva-row-meta">
                        <span class="meta-label">Hora</span>
                        <strong>@r.Hora</strong>
                    </div>

                    <div class="reserva-row-meta">
                        <span class="meta-label">Salón</span>
                        <strong>@r.Salon</strong>
                    </div>

                    <div class="reserva-row-estado">
                        <span class="estado-badge estado-@r.Estado.ToLower()">
                            @r.Estado
                        </span>
                    </div>

                    @if (tabActiva == "activas")
                    {
                        <button class="btn-cancelar-reserva" @onclick="() => CancelarReserva(r)" title="Cancelar reserva">✕</button>
                    }
                </div>
            }
        }
    </div>
</section>

@code {
    private string tabActiva = "activas";
    private List<ReservaVista> reservasActivas = new();
    private List<ReservaVista> historial = new();

    protected override async Task OnInitializedAsync()
    {
        await CargarReservas();
    }

    private async Task CargarReservas()
    {
        if (!Session.EstaAutenticado)
            return;

        var todasReservas = await ReservaService.ListarReservasAsync();

        var misReservas = todasReservas
            .Where(r => r.IdUsuario == Session.IdUsuario)
            .ToList();

        reservasActivas.Clear();
        historial.Clear();

        var ahora = DateTime.Now;

        var reservasActivasSinDuplicar = misReservas
            .Where(r => r.Activo)
            .Where(r => r.SesionClase != null)
            .Where(r => r.SesionClase!.ClaseGrupal != null)
            .Where(r => r.SesionClase!.FechaHoraFin != default && r.SesionClase.FechaHoraFin >= ahora)
            .GroupBy(r => r.SesionClase!.ClaseGrupal!.IdClase)
            .Select(g => g.OrderBy(r => r.SesionClase!.FechaSesion)
                          .ThenBy(r => r.SesionClase!.HoraInicio)
                          .ThenBy(r => r.IdReserva)
                          .First())
            .ToList();

        foreach (var r in reservasActivasSinDuplicar)
        {
            reservasActivas.Add(MapearReservaVista(r, "Confirmada"));
        }

        var reservasHistorial = misReservas
            .Where(r =>
                !r.Activo ||
                r.Asistio ||
                r.SesionClase == null ||
                r.SesionClase.FechaHoraFin == default ||
                r.SesionClase.FechaHoraFin < ahora)
            .OrderByDescending(r => r.SesionClase?.FechaSesion ?? DateTime.MinValue)
            .ThenByDescending(r => r.IdReserva)
            .ToList();

        foreach (var r in reservasHistorial)
        {
            string estado = "Finalizada";

            if (!r.Activo)
                estado = "Cancelada";
            else if (r.Asistio)
                estado = "Completada";

            historial.Add(MapearReservaVista(r, estado));
        }
    }

    private ReservaVista MapearReservaVista(ReservaDTO r, string estado)
    {
        var sesion = r.SesionClase;
        var clase = sesion?.ClaseGrupal;
        var entrenador = sesion?.Entrenador;
        var salon = sesion?.Salon;

        return new ReservaVista
        {
            IdReserva = r.IdReserva,
            NombreClase = clase?.Nombre ?? clase?.NombreDisciplina ?? "Clase General",
            Disciplina = clase?.Disciplina ?? clase?.NombreDisciplina ?? "-",
            Entrenador = entrenador != null
                ? $"{entrenador.Nombres} {entrenador.ApellidoPaterno}".Trim()
                : "Sin asignar",
            Fecha = sesion != null ? sesion.FechaSesion.ToString("yyyy-MM-dd") : "-",
            Hora = sesion != null ? $"{sesion.HoraInicio:HH:mm} - {sesion.HoraFin:HH:mm}" : "-",
            Salon = salon?.Nombre ?? salon?.NombreSalon ?? "Sin asignar",
            Estado = estado
        };
    }

    private async Task CancelarReserva(ReservaVista r)
    {
        var resultado = await ReservaService.EliminarAsync(r.IdReserva);

        if (!resultado.StartsWith("Error") && !resultado.ToLower().Contains("error"))
        {
            await CargarReservas();
        }
    }

    private class ReservaVista
    {
        public int IdReserva { get; set; }
        public string NombreClase { get; set; } = "";
        public string Disciplina { get; set; } = "";
        public string Entrenador { get; set; } = "";
        public string Fecha { get; set; } = "";
        public string Hora { get; set; } = "";
        public string Salon { get; set; } = "";
        public string Estado { get; set; } = "";
    }
}