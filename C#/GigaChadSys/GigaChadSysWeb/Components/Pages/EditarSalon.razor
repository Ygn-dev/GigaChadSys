@page "/admin/salones/editar/{Id:int}"
@layout AdminLayout
@rendermode InteractiveServer

@inject NavigationManager Navigation
@using GigaChadSys.Servicios
@using GigaChadSys.Servicios.DTO
@inject SalonServicio SalonService

<section class="container-fluid py-4">

    <nav class="salon-form-breadcrumb">
        <NavLink href="/admin/inicio">Inicio</NavLink>
        <span>/</span>
        <NavLink href="/admin/salones">Salones</NavLink>
        <span>/</span>
        <strong>Editar Salón</strong>
    </nav>

    <header class="salon-form-header">
        <h1>Editar Salón</h1>
        <p>
            <span>•</span>
            Actualice la información del espacio disponible para las sesiones de clase
        </p>
    </header>

    <div class="row g-4">

        <section class="salon-form-card">
            <div class="salon-card-title">
                <div class="salon-card-title-icon">⊞</div>

                <div>
                    <h2>Información del Salón</h2>
                    <p>Modifique los datos registrados del salón</p>
                </div>
            </div>

            <div class="salon-form-group">
                <label>Nombre del salón <span>*</span></label>

                <input class="form-input"
                       type="text"
                       placeholder="Ej: Sala Principal, Sala Yoga, Sala Ciclo..."
                       @bind="nombreSalon"
                       @bind:event="oninput" />

                <small>El nombre debe ser único</small>
            </div>

            <div class="salon-form-group">
                <label>Capacidad máxima <span>*</span></label>

                <input class="form-input"
                       type="number"
                       min="1"
                       placeholder="Ej: 30"
                       @bind="capacidad"
                       @bind:event="oninput" />

                <small>Ingrese el número máximo de personas que puede contener el salón</small>
            </div>

            <div class="salon-form-group">
                <label>Estado <span>*</span></label>

                <div class="salon-status-options">

                    <label class="salon-status-option @(estado ? "active" : "")">
                        <input type="radio"
                               name="estadoSalon"
                               checked="@estado"
                               @onchange="@(() => estado = true)" />

                        <div>
                            <strong>Activo</strong>
                            <p>El salón estará disponible</p>
                        </div>
                    </label>

                    <label class="salon-status-option @(!estado ? "active" : "")">
                        <input type="radio"
                               name="estadoSalon"
                               checked="@(!estado)"
                               @onchange="@(() => estado = false)" />

                        <div>
                            <strong>Inactivo</strong>
                            <p>El salón no estará disponible</p>
                        </div>
                    </label>

                </div>
            </div>

            <p class="salon-required-text">
                Los campos marcados con * son obligatorios
            </p>
        </section>

        <aside class="salon-preview-panel">
            <div class="salon-card-title">
                <div class="salon-card-title-icon preview-icon">⊙</div>

                <div>
                    <h2>Vista Previa</h2>
                    <p>Así se verá el salón actualizado en el sistema</p>
                </div>
            </div>

            <div class="salon-preview-card">
                <div class="salon-preview-top">
                    <div class="salon-preview-icon">⊞</div>

                    <span class="salon-preview-status @(estado ? "activo" : "inactivo")">
                        @(estado ? "Activo" : "Inactivo")
                    </span>
                </div>

                <h3>@NombrePreview</h3>

                <p>
                    <span>♙</span>
                    Capacidad máxima:
                    <strong>@CapacidadPreview</strong>
                    personas
                </p>
            </div>
        </aside>

    </div>

    <div class="salon-form-actions">
        <NavLink href="/admin/salones" class="salon-back-btn">
            <span>←</span>
            Volver al listado
        </NavLink>

        <div class="salon-action-right">
            <button type="button"
                    class="salon-cancel-btn"
                    @onclick="Cancelar">
                Cancelar
            </button>

            <button type="button"
                    class="salon-save-btn"
                    @onclick="GuardarCambios">
                <span>▣</span>
                Guardar cambios
            </button>
        </div>
    </div>

</section>

@code {
    [Parameter]
    public int Id { get; set; }

    private string nombreSalon = string.Empty;
    private int? capacidad;
    private bool estado = true;

    private string NombrePreview =>
        string.IsNullOrWhiteSpace(nombreSalon)
            ? "Nombre del Salón"
            : nombreSalon;

    private string CapacidadPreview =>
        capacidad is null or <= 0
            ? "--"
            : capacidad.Value.ToString();

    protected override async Task OnInitializedAsync()
    {
        await CargarSalon();
    }

    private async Task CargarSalon()
    {
        var salon = await SalonService.ObtenerPorIdAsync(Id);

        if (salon is null)
        {
            Navigation.NavigateTo("/admin/salones");
            return;
        }

        nombreSalon = salon.NombreSalon;
        capacidad = salon.AforoMaximo;
        estado = salon.Estado;
    }

    private void Cancelar()
    {
        Navigation.NavigateTo("/admin/salones");
    }

    private async Task GuardarCambios()
    {
        if (string.IsNullOrWhiteSpace(nombreSalon) || capacidad is null or <= 0)
        {
            return;
        }

        var salonEditado = new SalonDTO
        {
            IdSalon = Id,
            NombreSalon = nombreSalon.Trim(),
            AforoMaximo = capacidad.Value,
            Estado = estado
        };

        await SalonService.ActualizarAsync(Id, salonEditado);

        Navigation.NavigateTo("/admin/salones");
    }
}