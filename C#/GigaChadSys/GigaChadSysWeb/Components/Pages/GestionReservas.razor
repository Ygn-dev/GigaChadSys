@page "/admin/reservas"
@using System.Text.Json.Serialization
@using GigaChadSys.Servicios
@using GigaChadSys.Servicios.DTO
@layout AdminLayout
@rendermode InteractiveServer
@inject ReservaServicio ReservaService
@inject SocioServicio SocioService

<section class="container-fluid py-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1>Gestión de Reservas</h1>
            <p>Administre las reservas de clases de los socios</p>
        </div>
        <a class="btn btn-danger fw-bold text-uppercase px-4" href="/admin/reservas/nueva">
            + Nueva Reserva
        </a>
    </div>

    <div class="d-flex flex-wrap justify-content-between align-items-center mb-4 gap-3 bg-dark p-3 rounded border border-secondary">
        <input class="form-control bg-black text-white border-secondary"
               type="text"
               placeholder="Buscar por socio, clase, entrenador o salón..."
               @bind="TextoBusqueda"
               @bind:event="oninput" />

        <div class="btn-group">
            <button class="@GetFiltroClase("Todas")" @onclick='() => SetFiltro("Todas")'>Todas</button>
            <button class="@GetFiltroClase("Confirmadas")" @onclick='() => SetFiltro("Confirmadas")'>Confirmadas</button>
            <button class="@GetFiltroClase("Pendientes")" @onclick='() => SetFiltro("Pendientes")'>Pendientes</button>
            <button class="@GetFiltroClase("Asistió")" @onclick='() => SetFiltro("Asistió")'>Asistió</button>
            <button class="@GetFiltroClase("Canceladas")" @onclick='() => SetFiltro("Canceladas")'>Canceladas</button>
        </div>
    </div>

    <div class="table-responsive bg-dark border border-secondary rounded shadow">
        <table class="table table-dark table-hover table-striped align-middle mb-0 table-dark table-hover table-striped align-middle mb-0">
            <thead>
                <tr>
                    <th>SOCIO</th>
                    <th>CLASE</th>
                    <th>ENTRENADOR</th>
                    <th>FECHA</th>
                    <th>HORARIO</th>
                    <th>CUPOS</th>
                    <th>ESTADO</th>
                    <th>ACCIONES</th>
                </tr>
            </thead>

            <tbody>
                @{
                    var lista = ReservasFiltradas.ToList();
                }

                @if (lista.Count == 0)
                {
                    <tr>
                        <td colspan="8" class="empty-row">
                            No se encontraron reservas con los filtros actuales.
                        </td>
                    </tr>
                }
                else
                {
                    @foreach (var r in lista)
                    {
                        <tr>
                            <td>
                                <div class="d-flex align-items-center gap-3">
                                    <div class="bg-danger text-white rounded-circle d-flex align-items-center justify-content-center fw-bold" style="width:40px; height:40px;">@r.Iniciales</div>
                                    <div>
                                        <strong>@r.SocioNombre</strong>
                                        <span>DNI: @r.SocioDni</span>
                                    </div>
                                </div>
                            </td>

                            <td>
                                <div>
                                    <strong>@r.ClaseNombre</strong>
                                    <span style="display:block;color:#666;font-size:12px;">@r.ClaseTipo</span>
                                </div>
                            </td>

                            <td>@r.Entrenador</td>
                            <td>@r.Fecha</td>
                            <td>@r.Horario</td>

                            <td>
                                <div class="reserva-cupos-cell">
                                    <span class="reserva-cupos-text">@r.CuposOcupados / @r.CuposTotal</span>
                                    <div class="reserva-bar-track">
                                        <div class="reserva-bar-fill @GetBarColor(r.CuposOcupados, r.CuposTotal)"
                                             style="width: @GetCuposPct(r.CuposOcupados, r.CuposTotal)%"></div>
                                    </div>
                                </div>
                            </td>

                            <td>
                                <span class="reserva-estado-badge reserva-estado-@NormalizeEstado(r.Estado)">
                                    <span class="reserva-estado-dot"></span>
                                    @r.Estado
                                </span>
                            </td>

                            <td>
                                <div style="display:flex;gap:6px;">
                                    <button class="btn btn-sm btn-outline-light" title="Ver detalle" @onclick="() => ShowModal(r)">👁</button>
                                    <a class="btn btn-sm btn-outline-light"
                                       href="@($"/admin/reservas/editar/{r.Id}")"
                                       title="Editar">✎</a>
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>

    @if (IsModalVisible && SelectedReserva != null)
    {
        <div class="modal-backdrop" @onclick="CloseModal">
            <div class="dark-theme-modal" @onclick:stopPropagation="true">
                <div class="modal-header">
                    <h2>Detalles de la Reserva</h2>
                    <button class="close-btn" @onclick="CloseModal">✖</button>
                </div>

                <div class="modal-body">
                    <div class="detail-section">
                        <h3>Socio</h3>
                        <div class="detail-grid">
                            <div class="detail-item">
                                <span class="detail-label">Nombre</span>
                                <span class="detail-value">@SelectedReserva.SocioNombre</span>
                            </div>
                            <div class="detail-item">
                                <span class="detail-label">DNI</span>
                                <span class="detail-value">@SelectedReserva.SocioDni</span>
                            </div>
                        </div>
                    </div>

                    <div class="detail-section">
                        <h3>Clase / Sesión</h3>
                        <div class="detail-grid">
                            <div class="detail-item">
                                <span class="detail-label">Disciplina</span>
                                <span class="detail-value">@SelectedReserva.ClaseNombre</span>
                            </div>
                            <div class="detail-item">
                                <span class="detail-label">Nivel</span>
                                <span class="detail-value">@SelectedReserva.ClaseTipo</span>
                            </div>
                            <div class="detail-item">
                                <span class="detail-label">Entrenador</span>
                                <span class="detail-value">@SelectedReserva.Entrenador</span>
                            </div>
                            <div class="detail-item">
                                <span class="detail-label">Horario</span>
                                <span class="detail-value">@SelectedReserva.Fecha @SelectedReserva.Horario</span>
                            </div>
                            <div class="detail-item">
                                <span class="detail-label">Ocupación</span>
                                <span class="detail-value">@SelectedReserva.CuposOcupados de @SelectedReserva.CuposTotal cupos</span>
                            </div>
                        </div>
                    </div>

                    <div class="detail-section">
                        <h3>Reserva</h3>
                        <div class="detail-grid">
                            <div class="detail-item">
                                <span class="detail-label">ID Reserva</span>
                                <span class="detail-value">#@SelectedReserva.Id</span>
                            </div>
                            <div class="detail-item">
                                <span class="detail-label">Estado</span>
                                <span class="detail-value" style="margin-top:4px;">
                                    <span class="reserva-estado-badge reserva-estado-@NormalizeEstado(SelectedReserva.Estado)" style="margin:0;">
                                        <span class="reserva-estado-dot"></span>
                                        @SelectedReserva.Estado
                                    </span>
                                </span>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="modal-footer">
                    <button class="btn-cerrar" @onclick="CloseModal">Cerrar</button>
                </div>
            </div>
        </div>
    }

</section>

<style>
    .modal-backdrop {
        position: fixed;
        top: 0;
        left: 0;
        width: 100vw;
        height: 100vh;
        background: rgba(0, 0, 0, 0.7);
        display: flex;
        justify-content: center;
        align-items: center;
        z-index: 1000;
        backdrop-filter: blur(5px);
    }

    .dark-theme-modal {
        background: #1e1e1e;
        border: 1px solid #333;
        border-radius: 12px;
        width: 500px;
        max-width: 90%;
        box-shadow: 0 10px 30px rgba(0,0,0,0.5);
        color: #eee;
        overflow: hidden;
        animation: fadeIn 0.2s ease-out;
    }

    @@keyframes fadeIn {
        from {
            opacity: 0;
            transform: scale(0.95);
        }

        to {
            opacity: 1;
            transform: scale(1);
        }
    }

    .modal-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 16px 20px;
        border-bottom: 1px solid #333;
        background: #252525;
    }

        .modal-header h2 {
            margin: 0;
            font-size: 18px;
            font-weight: 600;
            color: #fff;
        }

    .close-btn {
        background: none;
        border: none;
        color: #888;
        font-size: 20px;
        cursor: pointer;
        transition: 0.2s;
    }

        .close-btn:hover {
            color: #fff;
        }

    .modal-body {
        padding: 20px;
        display: flex;
        flex-direction: column;
        gap: 20px;
    }

    .detail-section h3 {
        margin: 0 0 10px 0;
        font-size: 14px;
        text-transform: uppercase;
        color: #aaa;
        letter-spacing: 1px;
        border-bottom: 1px solid #333;
        padding-bottom: 5px;
    }

    .detail-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 10px;
    }

    .detail-item {
        display: flex;
        flex-direction: column;
        gap: 4px;
    }

    .detail-label {
        font-size: 12px;
        color: #888;
    }

    .detail-value {
        font-size: 14px;
        color: #fff;
        font-weight: 500;
    }

    .modal-footer {
        padding: 16px 20px;
        border-top: 1px solid #333;
        display: flex;
        justify-content: flex-end;
        background: #252525;
    }

    .btn-cerrar {
        background: #333;
        color: #fff;
        border: none;
        padding: 8px 16px;
        border-radius: 6px;
        cursor: pointer;
        font-weight: 500;
        transition: 0.2s;
    }

        .btn-cerrar:hover {
            background: #444;
        }
</style>

@code {
    private string TextoBusqueda = "";
    private string FiltroEstado = "Todas";

    private bool IsModalVisible = false;
    private ReservaVista? SelectedReserva = null;

    private List<ReservaVista> Reservas { get; set; } = new();

    private void ShowModal(ReservaVista reserva)
    {
        SelectedReserva = reserva;
        IsModalVisible = true;
    }

    private void CloseModal()
    {
        IsModalVisible = false;
        SelectedReserva = null;
    }

    private string GetFiltroClase(string filtro) =>
        FiltroEstado == filtro ? "btn btn-danger" : "btn btn-outline-secondary";

    private void SetFiltro(string filtro) => FiltroEstado = filtro;

    private IEnumerable<ReservaVista> ReservasFiltradas
    {
        get
        {
            IEnumerable<ReservaVista> resultado = Reservas;

            if (FiltroEstado != "Todas")
                resultado = resultado.Where(r => r.Estado == FiltroEstado);

            if (!string.IsNullOrWhiteSpace(TextoBusqueda))
            {
                string t = TextoBusqueda.Trim();

                resultado = resultado.Where(r =>
                    r.SocioNombre.Contains(t, StringComparison.OrdinalIgnoreCase) ||
                    r.ClaseNombre.Contains(t, StringComparison.OrdinalIgnoreCase) ||
                    r.Entrenador.Contains(t, StringComparison.OrdinalIgnoreCase) ||
                    r.Salon.Contains(t, StringComparison.OrdinalIgnoreCase));
            }

            return resultado.OrderBy(r => r.Fecha)
                            .ThenBy(r => r.Horario)
                            .ThenBy(r => r.SocioNombre);
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await CargarReservas();
    }

    private async Task CargarReservas()
    {
        var reservasTask = ReservaService.ListarReservasAsync();
        var sociosTask = SocioService.ListarSociosAsync();

        await Task.WhenAll(reservasTask, sociosTask);

        var reservasResult = reservasTask.Result;
        var sociosResult = sociosTask.Result;

        var dictSocios = sociosResult.ToDictionary(s => s.IdUsuario, s => s);

        Reservas.Clear();

        var reservasSinDuplicar = reservasResult
            .Where(r => r.SesionClase?.ClaseGrupal != null)
            .OrderByDescending(r => r.Activo)
            .ThenBy(r => r.SesionClase!.FechaSesion)
            .ThenBy(r => r.SesionClase!.HoraInicio)
            .ThenBy(r => r.IdReserva)
            .GroupBy(r => new
            {
                r.IdUsuario,
                IdClase = r.SesionClase!.ClaseGrupal!.IdClase
            })
            .Select(g => g.First())
            .ToList();

        foreach (var r in reservasSinDuplicar)
        {
            var socio = dictSocios.ContainsKey(r.IdUsuario) ? dictSocios[r.IdUsuario] : null;

            var sesion = r.SesionClase;
            var claseGrupal = sesion?.ClaseGrupal;
            var entrenador = sesion?.Entrenador;
            var salon = sesion?.Salon;

            int cuposTotal = salon?.AforoMaximo ?? sesion?.CuposDisponibles ?? 0;

            int cuposOcupados = reservasResult.Count(x =>
                x.Activo &&
                x.SesionClase?.IdSesion == sesion?.IdSesion);

            if (cuposOcupados < 0)
                cuposOcupados = 0;

            if (cuposTotal > 0 && cuposOcupados > cuposTotal)
                cuposOcupados = cuposTotal;

            Reservas.Add(new ReservaVista
            {
                Id = r.IdReserva,
                SocioNombre = socio != null ? $"{socio.Nombres} {socio.ApellidoPaterno}".Trim() : "Desconocido",
                SocioDni = socio != null ? socio.Dni.ToString() : "-",
                ClaseNombre = claseGrupal?.Nombre ?? claseGrupal?.NombreDisciplina ?? "-",
                ClaseTipo = claseGrupal?.NivelDificultad ?? claseGrupal?.Nivel ?? "-",
                Entrenador = entrenador != null
                    ? $"{entrenador.Nombres} {entrenador.ApellidoPaterno}".Trim()
                    : "Sin asignar",
                Salon = salon?.Nombre ?? salon?.NombreSalon ?? "Sin asignar",
                Fecha = sesion != null ? sesion.FechaSesion.ToString("yyyy-MM-dd") : "-",
                Horario = sesion != null ? $"{sesion.HoraInicio:HH:mm} - {sesion.HoraFin:HH:mm}" : "-",
                CuposOcupados = cuposOcupados,
                CuposTotal = cuposTotal,
                Estado = ObtenerEstadoReserva(r)
            });
        }
    }

    private static string ObtenerEstadoReserva(ReservaDTO reserva)
    {
        if (!reserva.Activo)
            return "Canceladas";

        if (reserva.Asistio)
            return "Asistió";

        if (reserva.SesionClase != null &&
            reserva.SesionClase.FechaHoraFin != default &&
            reserva.SesionClase.FechaHoraFin < DateTime.Now)
        {
            return "Pendientes";
        }

        return "Confirmadas";
    }

    private int GetCuposPct(int ocupados, int total)
    {
        if (total <= 0)
            return 0;

        return (int)Math.Round((double)ocupados / total * 100);
    }

    private string GetBarColor(int ocupados, int total)
    {
        if (total <= 0)
            return "reserva-bar-green";

        double pct = (double)ocupados / total;

        return pct >= 0.9 ? "reserva-bar-red"
             : pct >= 0.6 ? "reserva-bar-yellow"
             : "reserva-bar-green";
    }

    private string NormalizeEstado(string estado) =>
        estado.ToLower()
              .Replace("ó", "o")
              .Replace(" ", "");

    private class ReservaVista
    {
        [JsonPropertyName("idReserva")]
        public int Id { get; set; }

        [JsonPropertyName("socioNombre")]
        public string SocioNombre { get; set; } = "";

        [JsonPropertyName("socioDni")]
        public string SocioDni { get; set; } = "";

        [JsonPropertyName("claseNombre")]
        public string ClaseNombre { get; set; } = "";

        [JsonPropertyName("claseTipo")]
        public string ClaseTipo { get; set; } = "";

        [JsonPropertyName("entrenador")]
        public string Entrenador { get; set; } = "";

        [JsonPropertyName("salon")]
        public string Salon { get; set; } = "";

        [JsonPropertyName("fechaAsignada")]
        public string Fecha { get; set; } = "";

        [JsonPropertyName("horario")]
        public string Horario { get; set; } = "";

        [JsonPropertyName("cuposOcupados")]
        public int CuposOcupados { get; set; }

        [JsonPropertyName("cuposTotal")]
        public int CuposTotal { get; set; }

        [JsonPropertyName("estado")]
        public string Estado { get; set; } = "";

        public string Iniciales
        {
            get
            {
                var partes = SocioNombre.Split(' ', StringSplitOptions.RemoveEmptyEntries);
                return partes.Length >= 2
                    ? $"{partes[0][0]}{partes[1][0]}".ToUpper()
                    : SocioNombre.Length > 0 ? SocioNombre[0].ToString().ToUpper() : "S";
            }
        }
    }
}