@page "/socio/pagos"
@using GigaChadSys.Servicios
@using GigaChadSys.Servicios.DTO
@layout SocioLayout
@rendermode InteractiveServer
@inject SessionServicio Session
@inject SuscripcionServicio SuscripcionService
@inject PagoServicio PagoService
@inject MetodoPagoServicio MetodoPagoService

<section class="socio-payments-page">

    <div class="socio-payments-header">
        <h1>Mis Pagos</h1>
        <p>Historial completo de tus pagos</p>
    </div>

    <div class="socio-payments-stats">
        <div class="socio-payment-stat-card">
            <div class="socio-payment-icon success">✓</div>

            <div>
                <span>Total pagado</span>
                <strong>S/@TotalPagado.ToString("0.00")</strong>
                <p>@TotalPagosRealizados pagos realizados</p>
            </div>
        </div>

        <div class="socio-payment-stat-card">
            <div class="socio-payment-icon warning">◷</div>

            <div>
                <span>Pendiente</span>
                <strong>S/@TotalPendiente.ToString("0.00")</strong>
                <p>@CantidadPendientes pago(s) pendiente(s)</p>
            </div>
        </div>

        <div class="socio-payment-stat-card">
            <div class="socio-payment-icon danger">!</div>

            <div>
                <span>Vencido</span>
                <strong>S/0.00</strong>
                <p>0 pagos vencidos</p>
            </div>
        </div>

        <div class="socio-payment-stat-card">
            <div class="socio-payment-icon red">S/</div>

            <div>
                <span>Monto promedio</span>
                <strong>S/@PromedioPago.ToString("0.00")</strong>
                <p>Por pago</p>
            </div>
        </div>
    </div>

    <div class="socio-payments-table-card">
        <h2>Historial de Pagos</h2>

        <div class="socio-payments-table-wrapper">
            <table class="socio-payments-table">
                <thead>
                    <tr>
                        <th>Concepto</th>
                        <th>Tipo</th>
                        <th>Método</th>
                        <th>Monto</th>
                        <th>Fecha</th>
                        <th>Estado</th>
                        <th>Acción</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var pago in Pagos)
                    {
                        <tr>
                            <td>
                                <strong>@pago.Concepto</strong>
                            </td>

                            <td>
                                <span class="payment-muted">▣ @pago.Tipo</span>
                            </td>

                            <td>
                                @if (string.IsNullOrWhiteSpace(pago.Metodo))
                                {
                                    <span class="payment-muted">-</span>
                                }
                                else
                                {
                                    <span class="payment-muted">▭ @pago.Metodo</span>
                                }
                            </td>

                            <td>
                                <strong>S/@pago.Monto</strong>
                            </td>

                            <td>
                                <span class="payment-muted">@pago.Fecha</span>
                            </td>

                            <td>
                                <span class="@ObtenerClaseEstado(pago.Estado)">
                                    @pago.Estado
                                </span>
                            </td>

                            <td>
                                @if (pago.Estado == "pendiente" || pago.Estado == "vencido")
                                {
                                    <a class="socio-pay-button"
                                       href="@($"/socio/pagos/realizar/{pago.Codigo}")">
                                        Realizar Pago
                                    </a>
                                }
                                else
                                {
                                    <span class="payment-muted">—</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

</section>

@code {
    private List<PagoSocioVista> Pagos { get; set; } = new();

    private decimal TotalPagado => Pagos.Where(p => p.Estado == "pagado").Sum(p => decimal.TryParse(p.Monto, out decimal m) ? m : 0);
    private int TotalPagosRealizados => Pagos.Count(p => p.Estado == "pagado");
    
    private decimal TotalPendiente => Pagos.Where(p => p.Estado == "pendiente").Sum(p => decimal.TryParse(p.Monto, out decimal m) ? m : 0);
    private int CantidadPendientes => Pagos.Count(p => p.Estado == "pendiente");

    private decimal PromedioPago => TotalPagosRealizados > 0 ? TotalPagado / TotalPagosRealizados : 0;

    protected override async Task OnInitializedAsync()
    {
        if (!Session.EstaAutenticado) return;

        var suscripciones = await SuscripcionService.ListarSuscripcionesAsync();
        var misSuscripciones = suscripciones.Where(s => s.IdUsuario == Session.IdUsuario).ToList();
        var misIdsPagos = misSuscripciones.Select(s => s.IdPago).ToList();

        var todosPagos = await PagoService.ListarPagosAsync();
        var metodos = await MetodoPagoService.ListarMetodosDePagoAsync();
        var dictMetodos = metodos.ToDictionary(m => m.IdMetodoPago, m => m.Tipo);

        Pagos.Clear();

        foreach (var pago in todosPagos.Where(p => misIdsPagos.Contains(p.IdPago)))
        {
            var nombreMetodo = dictMetodos.ContainsKey(pago.MetodoPago) ? dictMetodos[pago.MetodoPago] : "Desconocido";
            var sub = misSuscripciones.FirstOrDefault(s => s.IdPago == pago.IdPago);
            
            Pagos.Add(new PagoSocioVista
            {
                Codigo = pago.IdPago.ToString(),
                Concepto = pago.Tipo ?? "-",
                Tipo = sub != null ? sub.TipoPlan : "Membresía",
                Metodo = nombreMetodo,
                Monto = pago.Monto.ToString("0.00"),
                Fecha = pago.FechaPagoTexto,
                Estado = pago.Activo ? "pagado" : "pendiente"
            });
        }
    }

    private string ObtenerClaseEstado(string estado)
    {
        if (estado == "pagado")
        {
            return "socio-payment-status paid";
        }

        if (estado == "pendiente")
        {
            return "socio-payment-status pending";
        }

        return "socio-payment-status expired";
    }

    private class PagoSocioVista
    {
        public string Codigo { get; set; } = "";
        public string Concepto { get; set; } = "";
        public string Tipo { get; set; } = "";
        public string Metodo { get; set; } = "";
        public string Monto { get; set; } = "";
        public string Fecha { get; set; } = "";
        public string Estado { get; set; } = "";
    }
}