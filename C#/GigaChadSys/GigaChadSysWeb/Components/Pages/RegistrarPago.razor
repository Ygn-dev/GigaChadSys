@page "/admin/pagos/registrar"
@using GigaChadSys.Servicios
@using GigaChadSys.Servicios.DTO
@inject NavigationManager Navigation
@inject SocioServicio SocioService
@inject SuscripcionServicio SuscripcionService
@inject PagoServicio PagoService

<div class="admin-shell">
    <!-- ===== SIDEBAR ===== -->
    <aside class="admin-sidebar">
        <div>
            <div class="admin-logo">
                <div class="logo-mark">GC</div>
                <div>
                    <h2 style="color:#F5F5F5; font-weight:900; letter-spacing:2px; margin:0;">GIGACHAD</h2>
                    <span>Admin Panel</span>
                </div>
            </div>

            <nav class="admin-nav">
                <a href="/admin/dashboard">Inicio</a>

                <div class="nav-section">USUARIOS</div>
                <a href="/admin/socios">Socios</a>
                <a href="/admin/entrenadores">Entrenadores</a>

                <div class="nav-section">MEMBRESÍAS</div>
                <a href="/admin/membresias">Membresías</a>
                <a href="/admin/suscripciones">Suscripciones</a>

                <div class="nav-section">OPERACIONES</div>
                <a href="/admin/clases">Clases</a>
                <a href="/admin/sesiones">Sesiones</a>
                <a href="/admin/reservas">Reservas</a>
                <a href="/admin/pagos" class="active">Pagos</a>

                <div class="nav-section">INFRAESTRUCTURA</div>
                <a href="/admin/salones">Salones</a>
                <a href="/admin/maquinas">Máquinas</a>

                <div class="nav-section">ANÁLISIS</div>
                <a href="/admin/reportes">Reportes</a>

                <div class="nav-section">CUENTA</div>
                <a href="/admin/perfil">Mi Perfil</a>
            </nav>
        </div>

        <div class="admin-bottom">
            <div class="admin-profile">
                <div class="profile-avatar">A</div>
                <div>
                    <strong>Administrador</strong>
                    <span>admin@gigachad.com</span>
                </div>
            </div>
            <a href="/logout" class="admin-logout">Cerrar Sesión</a>
        </div>
    </aside>

    <!-- ===== CONTENT AREA ===== -->
    <div class="admin-content-area">
        <!-- Topbar -->
        <header class="gp-topbar">
            <div class="topbar-actions">
                <button class="topbar-btn">🔔</button>
                <button class="topbar-btn">🔍</button>
                <a href="/logout" class="topbar-btn topbar-logout">🚪 Salir</a>
            </div>
        </header>

        <!-- Main -->
        <main class="admin-main">
            <div class="rp-page">

                <!-- Breadcrumb -->
                <nav class="breadcrumb-nav">
                    <a href="/admin/dashboard">Inicio</a>
                    <span class="breadcrumb-sep">/</span>
                    <a href="/admin/pagos">Pagos</a>
                    <span class="breadcrumb-sep">/</span>
                    <span class="breadcrumb-current">Registrar Pago</span>
                </nav>

                <!-- Page header -->
                <div class="rp-header">
                    <h1>Registrar Nuevo Pago</h1>
                    <p class="rp-subtitle">Registre un pago asociado a una suscripción activa</p>
                </div>

                <!-- Layout: form col + info cards col -->
                <div class="rp-layout">

                    <!-- ── FORM COLUMN ── -->
                    <div class="rp-form-col">

                        <!-- 1. Información del Socio -->
                        <div class="sf-section-card">
                            <div class="sf-section-head">
                                <span class="sf-section-icon">👤</span>
                                Informacion del Socio
                                <span style="color:#666; font-size:12px; font-weight:400; margin-left:4px;">Busque y seleccione el socio</span>
                            </div>
                            <div class="rp-socio-search-wrapper">
                                <span class="rp-socio-search-icon">🔍</span>
                                <input type="text"
                                       class="rp-socio-search"
                                       placeholder="Buscar por DNI, nombre o correo..."
                                       @bind="SocioBusqueda"
                                       @bind:event="oninput"
                                       @onfocus="() => MostrarDropdown = true"
                                       @onblur="CerrarDropdownConDelay" />
                            </div>

                            @if (MostrarDropdown && SociosFiltrados.Any())
                            {
                                <div class="rp-socio-dropdown">
                                    @foreach (var s in SociosFiltrados)
                                    {
                                        <div class="rp-socio-option" @onmousedown="() => SeleccionarSocio(s)">
                                            <div class="rp-socio-avatar">@s.Iniciales</div>
                                            <div>
                                                <strong>@s.Nombre</strong>
                                                <span>@s.Dni</span>
                                            </div>
                                        </div>
                                    }
                                </div>
                            }

                            @if (SocioSeleccionado != null)
                            {
                                <div class="rp-socio-selected">
                                    <div class="rp-socio-avatar">@SocioSeleccionado.Iniciales</div>
                                    <div>
                                        <strong>@SocioSeleccionado.Nombre</strong>
                                        <span>@SocioSeleccionado.Dni · @SocioSeleccionado.Email</span>
                                    </div>
                                    <button class="rp-socio-clear" @onclick="LimpiarSocio" title="Quitar socio">✕</button>
                                </div>
                            }
                        </div>

                        <!-- 2. Información del Pago -->
                        <div class="sf-section-card">
                            <div class="sf-section-head">
                                <span class="sf-section-icon">💳</span>
                                Informacion del Pago
                                <span style="color:#666; font-size:12px; font-weight:400; margin-left:4px;">Detalles de la transaccion</span>
                            </div>

                            <!-- Tipo de pago -->
                            <div class="sf-form-group" style="margin-bottom:20px;">
                                <label class="sf-label">TIPO DE PAGO <span class="rp-req">*</span></label>
                                <div class="rp-radio-group">
                                    <button class="rp-radio-btn @(TipoPago == "mensualidad" ? "rp-radio-active" : "")"
                                            @onclick='() => TipoPago = "mensualidad"'>
                                        📅 Mensualidad
                                    </button>
                                    <button class="rp-radio-btn @(TipoPago == "inscripcion" ? "rp-radio-active" : "")"
                                            @onclick='() => TipoPago = "inscripcion"'>
                                        👤 Inscripción
                                    </button>
                                    <button class="rp-radio-btn @(TipoPago == "renovacion" ? "rp-radio-active" : "")"
                                            @onclick='() => TipoPago = "renovacion"'>
                                        🔄 Renovación
                                    </button>
                                </div>
                            </div>

                            <!-- Método de pago -->
                            <div class="sf-form-group" style="margin-bottom:20px;">
                                <label class="sf-label">METODO DE PAGO <span class="rp-req">*</span></label>
                                <div class="rp-radio-group">
                                    <button class="rp-radio-btn @(MetodoPago == "efectivo" ? "rp-radio-active" : "")"
                                            @onclick='() => MetodoPago = "efectivo"'>
                                        💵 Efectivo
                                    </button>
                                    <button class="rp-radio-btn @(MetodoPago == "debito" ? "rp-radio-active" : "")"
                                            @onclick='() => MetodoPago = "debito"'>
                                        💳 Tarjeta Débito
                                    </button>
                                    <button class="rp-radio-btn @(MetodoPago == "credito" ? "rp-radio-active" : "")"
                                            @onclick='() => MetodoPago = "credito"'>
                                        💳 Tarjeta Crédito
                                    </button>
                                </div>
                            </div>

                            <!-- Monto + Fecha -->
                            <div class="rp-row-2">
                                <div class="sf-form-group">
                                    <label class="sf-label">MONTO (S/) <span class="rp-req">*</span></label>
                                    <div class="rp-monto-wrapper">
                                        <span class="rp-monto-prefix">S/</span>
                                        <input type="number"
                                               class="rp-monto-input"
                                               placeholder="0.00"
                                               min="0"
                                               step="0.01"
                                               @bind="Monto" />
                                    </div>
                                </div>
                                <div class="sf-form-group">
                                    <label class="sf-label">FECHA DE PAGO <span class="rp-req">*</span></label>
                                    <input type="date"
                                           class="rp-date-input"
                                           @bind="FechaPago" />
                                </div>
                            </div>

                            <!-- Concepto -->
                            <div class="sf-form-group">
                                <label class="sf-label">CONCEPTO <span class="rp-req">*</span></label>
                                <input type="text"
                                       class="rp-text-input"
                                       placeholder="Ej: Membresía Black - Mayo 2025"
                                       @bind="Concepto" />
                            </div>
                        </div>

                        <!-- 3. Mini info cards (monto sugerido / membresía / último pago) -->
                        <div class="rp-info-trio">
                            <div class="rp-info-card">
                                <div class="rp-info-icon rp-icon-red">💰</div>
                                <div class="rp-info-label">MONTO SUGERIDO</div>
                                <div class="rp-info-val">@(SocioSeleccionado != null ? MontoSugerido : "--")</div>
                            </div>
                            <div class="rp-info-card">
                                <div class="rp-info-icon rp-icon-green">👑</div>
                                <div class="rp-info-label">MEMBRESÍA ACTUAL</div>
                                <div class="rp-info-val">@(SocioSeleccionado != null ? SocioSeleccionado.Membresia : "--")</div>
                            </div>
                            <div class="rp-info-card">
                                <div class="rp-info-icon rp-icon-yellow">🕐</div>
                                <div class="rp-info-label">ÚLTIMO PAGO</div>
                                <div class="rp-info-val">@(SocioSeleccionado != null ? SocioSeleccionado.UltimoPago : "--")</div>
                            </div>
                        </div>

                        <!-- 4. Estado del Pago -->
                        <div class="sf-section-card">
                            <div class="sf-section-head">
                                <span class="sf-section-icon">✅</span>
                                Estado del Pago
                                <span style="color:#666; font-size:12px; font-weight:400; margin-left:4px;">Define el estado actual de la transaccion</span>
                            </div>
                            <div class="rp-radio-group">
                                <button class="rp-radio-btn rp-radio-green @(EstadoPago == "pagado" ? "rp-radio-active-green" : "")"
                                        @onclick='() => EstadoPago = "pagado"'>
                                    ✅ Pagado
                                </button>
                                <button class="rp-radio-btn @(EstadoPago == "pendiente" ? "rp-radio-active" : "")"
                                        @onclick='() => EstadoPago = "pendiente"'>
                                    ⏳ Pendiente
                                </button>
                            </div>
                        </div>

                        <!-- Actions -->
                        <div class="rp-actions">
                            <button class="rp-btn-primary" @onclick="Registrar" disabled="@(!FormularioValido)">
                                ✔ Registrar Pago
                            </button>
                            <button class="rp-btn-secondary" @onclick="Cancelar">
                                Cancelar
                            </button>
                            <a href="/admin/pagos" class="rp-btn-back">← Volver al listado</a>
                        </div>

                        @if (!string.IsNullOrEmpty(MensajeExito))
                        {
                            <div class="socios-toast socios-toast-ok">@MensajeExito</div>
                        }
                        @if (!string.IsNullOrEmpty(MensajeError))
                        {
                            <div class="socios-toast socios-toast-err">@MensajeError</div>
                        }

                    </div>
                    <!-- end rp-form-col -->

                </div>
                <!-- end rp-layout -->

            </div>
        </main>
    </div>
</div>

@code {

    /* ── Estado del formulario ── */
    private string SocioBusqueda { get; set; } = "";
    private bool MostrarDropdown { get; set; } = false;
    private SocioDto? SocioSeleccionado { get; set; }

    private string TipoPago   { get; set; } = "mensualidad";
    private string MetodoPago  { get; set; } = "efectivo";
    private string EstadoPago  { get; set; } = "pagado";
    private decimal Monto      { get; set; } = 0;
    private DateTime FechaPago { get; set; } = DateTime.Today;
    private string Concepto    { get; set; } = "";

    private string MensajeExito { get; set; } = "";
    private string MensajeError { get; set; } = "";

    /* ── Validación ── */
    private bool FormularioValido =>
        SocioSeleccionado != null &&
        !string.IsNullOrWhiteSpace(TipoPago) &&
        !string.IsNullOrWhiteSpace(MetodoPago) &&
        Monto > 0 &&
        !string.IsNullOrWhiteSpace(Concepto);

    /* ── Monto sugerido derivado de membresía ── */
    private string MontoSugerido => SocioSeleccionado?.Membresia switch
    {
        "Black" => "S/149",
        "Basic" => "S/79",
        _       => "--"
    };

    /* ── Modelo socio ── */
    private class SocioDto
    {
        public int Id { get; set; }
        public string Nombre    { get; set; } = "";
        public string Dni       { get; set; } = "";
        public string Email     { get; set; } = "";
        public string Iniciales { get; set; } = "";
        public string Membresia { get; set; } = "";
        public string UltimoPago{ get; set; } = "";
    }

    /* ── Datos Reales del Backend ── */
    private List<SocioDto> TodosLosSocios = new();

    protected override async Task OnInitializedAsync()
    {
        var socios = await SocioService.ListarSociosAsync();
        var suscripciones = await SuscripcionService.ListarSuscripcionesAsync();
        var pagos = await PagoService.ListarPagosAsync();

        foreach (var s in socios)
        {
            var sub = suscripciones.FirstOrDefault(x => x.IdUsuario == s.IdUsuario && x.Activo);
            var pagoAsociado = sub != null ? pagos.FirstOrDefault(p => p.IdPago == sub.IdPago) : null;
            
            string membresia = sub != null ? sub.TipoPlan : "Sin membresía";
            string ultimoPago = pagoAsociado != null ? pagoAsociado.FechaPagoTexto : "N/A";

            TodosLosSocios.Add(new SocioDto
            {
                Id = s.IdUsuario,
                Nombre = $"{s.Nombres} {s.ApellidoPaterno}",
                Dni = s.Dni.ToString(),
                Email = s.CorreoElectronico,
                Iniciales = s.Nombres.Length > 0 ? s.Nombres[0].ToString().ToUpper() : "S",
                Membresia = membresia,
                UltimoPago = ultimoPago
            });
        }
    }

    private IEnumerable<SocioDto> SociosFiltrados =>
        string.IsNullOrWhiteSpace(SocioBusqueda)
            ? Enumerable.Empty<SocioDto>()
            : TodosLosSocios.Where(s =>
                s.Nombre.Contains(SocioBusqueda, StringComparison.OrdinalIgnoreCase) ||
                s.Dni.Contains(SocioBusqueda) ||
                s.Email.Contains(SocioBusqueda, StringComparison.OrdinalIgnoreCase));

    /* ── Interacción del buscador ── */
    private void SeleccionarSocio(SocioDto socio)
    {
        SocioSeleccionado = socio;
        SocioBusqueda     = socio.Nombre;
        MostrarDropdown   = false;
        // Auto-rellenar monto y concepto si están vacíos
        if (Monto == 0)
            Monto = socio.Membresia == "Black" ? 149 : 79;
        if (string.IsNullOrWhiteSpace(Concepto))
            Concepto = $"Membresía {socio.Membresia} - {DateTime.Today:MMMM yyyy}";
    }

    private void LimpiarSocio()
    {
        SocioSeleccionado = null;
        SocioBusqueda     = "";
        Monto             = 0;
        Concepto          = "";
    }

    private async Task CerrarDropdownConDelay()
    {
        await Task.Delay(150);
        MostrarDropdown = false;
    }

    /* ── Registrar pago ── */
    private async Task Registrar()
    {
        MensajeError  = "";
        MensajeExito  = "";

        if (!FormularioValido)
        {
            MensajeError = "Complete todos los campos requeridos.";
            return;
        }

        int idMetodo = MetodoPago == "efectivo" ? 1 : MetodoPago == "debito" ? 2 : 3;

        var nuevoPago = new PagoDTO
        {
            FechaPago = FechaPago,
            Monto = (double)Monto,
            Tipo = Concepto,
            MetodoPago = idMetodo,
            Activo = EstadoPago == "pagado"
        };

        var resultado = await PagoService.RegistrarAsync(nuevoPago);

        if (!resultado.StartsWith("Error") && !resultado.ToLower().Contains("error"))
        {
            MensajeExito = $"✅ Pago de {Concepto} registrado correctamente.";
            await Task.Delay(1500);
            Navigation.NavigateTo("/admin/pagos");
        }
        else
        {
            MensajeError = resultado;
        }
    }

    private void Cancelar()
    {
        Navigation.NavigateTo("/admin/pagos");
    }
}
