@page "/admin/socios/editar/{Id:int}"
@using GigaChadSysWeb.Components.Layout
@layout AdminLayout
@rendermode InteractiveServer
@using GigaChadSys.Servicios
@using GigaChadSys.Servicios.DTO
@inject SocioServicio SocioService
@inject NavigationManager Nav

<section class="container-fluid py-4">

    <nav class="sf-breadcrumb">
        <a href="/admin/socios">Socios</a>
        <span class="sf-bc-sep">›</span>
        <span class="sf-bc-current">Editar</span>
    </nav>

    <div class="sf-page-header">
        <div>
            <h1>Editar Socio</h1>
            <p class="sf-page-subtitle">Actualiza los datos del socio y su membresía</p>
        </div>
    </div>

    @if (cargando)
    {
        <div class="sf-section-card" style="min-height:220px;display:flex;align-items:center;justify-content:center;text-align:center;">
            <div>
                <div class="sf-section-icon icon-red" style="margin:0 auto 18px auto;">
                    <i class="bi bi-hourglass-split"></i>
                </div>

                <h3>Cargando socio...</h3>
                <p style="color:#aaa;margin:0;">Obteniendo datos desde el servidor.</p>
            </div>
        </div>
    }
    else
    {
        <div class="row g-4">
            <div class="sf-form-col">

                <div class="sf-section-card">
                    <div class="sf-section-title">
                        <div class="sf-section-icon icon-red">
                            <i class="bi bi-person"></i>
                        </div>
                        <div>
                            <h3>Información Personal</h3>
                            <span>Datos básicos del socio</span>
                        </div>
                    </div>

                    <div class="sf-form-grid">
                        <div class="sf-form-group">
                            <label>DNI <span class="sf-req">*</span></label>
                            <input type="text"
                                   @bind="form.Dni"
                                   placeholder="40234123"
                                   maxlength="8"
                                   class="@(errores.ContainsKey("dni") ? "sf-input-error" : "")" />
                            @if (errores.ContainsKey("dni"))
                            {
                                <span class="sf-error-msg">@errores["dni"]</span>
                            }
                        </div>

                        <div class="sf-form-group">
                            <label>Nombres <span class="sf-req">*</span></label>
                            <input type="text"
                                   @bind="form.Nombres"
                                   placeholder="Lucia Maria"
                                   class="@(errores.ContainsKey("nombres") ? "sf-input-error" : "")" />
                            @if (errores.ContainsKey("nombres"))
                            {
                                <span class="sf-error-msg">@errores["nombres"]</span>
                            }
                        </div>

                        <div class="sf-form-group">
                            <label>Apellido paterno <span class="sf-req">*</span></label>
                            <input type="text"
                                   @bind="form.ApellidoPaterno"
                                   placeholder="Torres"
                                   class="@(errores.ContainsKey("apellidoPaterno") ? "sf-input-error" : "")" />
                            @if (errores.ContainsKey("apellidoPaterno"))
                            {
                                <span class="sf-error-msg">@errores["apellidoPaterno"]</span>
                            }
                        </div>

                        <div class="sf-form-group">
                            <label>Apellido materno <span class="sf-req">*</span></label>
                            <input type="text"
                                   @bind="form.ApellidoMaterno"
                                   placeholder="García"
                                   class="@(errores.ContainsKey("apellidoMaterno") ? "sf-input-error" : "")" />
                            @if (errores.ContainsKey("apellidoMaterno"))
                            {
                                <span class="sf-error-msg">@errores["apellidoMaterno"]</span>
                            }
                        </div>

                        <div class="sf-form-group">
                            <label>Fecha de nacimiento</label>
                            <input type="date" @bind="form.FechaNacimiento" />
                            <span class="sf-error-msg" style="color:#777;">
                                Opcional. Si la dejas vacía, se conserva la edad actual.
                            </span>
                        </div>

                        <div class="sf-form-group">
                            <label>Teléfono <span class="sf-req">*</span></label>
                            <input type="text"
                                   @bind="form.Telefono"
                                   placeholder="987654321"
                                   maxlength="9"
                                   class="@(errores.ContainsKey("telefono") ? "sf-input-error" : "")" />
                            @if (errores.ContainsKey("telefono"))
                            {
                                <span class="sf-error-msg">@errores["telefono"]</span>
                            }
                        </div>

                        <div class="sf-form-group">
                            <label>Correo electrónico <span class="sf-req">*</span></label>
                            <input type="email"
                                   @bind="form.Email"
                                   placeholder="lucia@email.com"
                                   class="@(errores.ContainsKey("email") ? "sf-input-error" : "")" />
                            @if (errores.ContainsKey("email"))
                            {
                                <span class="sf-error-msg">@errores["email"]</span>
                            }
                        </div>

                        <div class="sf-form-group">
                            <label>Estado del socio <span class="sf-req">*</span></label>
                            <select @bind="form.EstadoSocio">
                                <option value="Activo">Activo</option>
                                <option value="Inactivo">Inactivo</option>
                            </select>
                        </div>
                    </div>
                </div>

                <div class="sf-section-card">
                    <div class="sf-section-title">
                        <div class="sf-section-icon icon-blue">
                            <i class="bi bi-lock"></i>
                        </div>
                        <div>
                            <h3>Cuenta de Acceso</h3>
                            <span>Credenciales para el sistema</span>
                        </div>
                    </div>

                    <div class="sf-form-grid">
                        <div class="sf-form-group sf-form-full">
                            <label>Correo electrónico <span class="sf-req">*</span></label>
                            <input type="email" @bind="form.Email" placeholder="lucia@email.com" />
                        </div>

                        <div class="sf-form-group">
                            <label>Nueva contraseña</label>
                            <div class="sf-input-pass">
                                <input type="@(verPass ? "text" : "password")"
                                       @bind="form.Contrasenia"
                                       placeholder="Dejar vacío si no se cambia" />
                                <button type="button" class="sf-eye-btn" @onclick="() => verPass = !verPass">
                                    <i class="bi @(verPass ? "bi-eye-slash" : "bi-eye")"></i>
                                </button>
                            </div>
                            @if (errores.ContainsKey("contrasenia"))
                            {
                                <span class="sf-error-msg">@errores["contrasenia"]</span>
                            }
                        </div>

                        <div class="sf-form-group">
                            <label>Confirmar contraseña</label>
                            <div class="sf-input-pass">
                                <input type="@(verConfirm ? "text" : "password")"
                                       @bind="form.ConfirmarContrasenia"
                                       placeholder="Repite la nueva contraseña"
                                       class="@(errores.ContainsKey("confirmar") ? "sf-input-error" : "")" />
                                <button type="button" class="sf-eye-btn" @onclick="() => verConfirm = !verConfirm">
                                    <i class="bi @(verConfirm ? "bi-eye-slash" : "bi-eye")"></i>
                                </button>
                            </div>
                            @if (errores.ContainsKey("confirmar"))
                            {
                                <span class="sf-error-msg">@errores["confirmar"]</span>
                            }
                        </div>
                    </div>
                </div>

                <div class="sf-section-card">
                    <div class="sf-section-title">
                        <div class="sf-section-icon icon-yellow">
                            <i class="bi bi-gem"></i>
                        </div>
                        <div>
                            <h3>Membresía del Socio</h3>
                            <span>Gestiona la membresía y el estado del socio</span>
                        </div>
                    </div>

                    <p class="sf-sublabel">Plan de membresía</p>

                    <div class="sf-plan-grid">
                        <div class="sf-plan-card @(form.PlanSeleccionado == "basic" ? "sf-plan-selected" : "")"
                             @onclick='() => form.PlanSeleccionado = "basic"'>
                            <div class="sf-plan-radio @(form.PlanSeleccionado == "basic" ? "sf-radio-sel" : "")"></div>
                            <div class="sf-plan-body">
                                <h4>Membresía Basic</h4>
                                <div class="sf-plan-precio">
                                    <span class="sf-precio-val">S/ 79</span>
                                    <span class="sf-precio-per">/ mes</span>
                                </div>
                                <ul class="sf-plan-features">
                                    <li><span class="sf-chk">✓</span> Acceso a sala de musculación</li>
                                    <li><span class="sf-chk">✓</span> Acceso a cardio</li>
                                    <li><span class="sf-chk">✓</span> Vestuario incluido</li>
                                    <li><span class="sf-chk">✓</span> App móvil</li>
                                </ul>
                            </div>
                        </div>

                        <div class="sf-plan-card sf-plan-premium @(form.PlanSeleccionado == "black" ? "sf-plan-selected sf-plan-premium-sel" : "")"
                             @onclick='() => form.PlanSeleccionado = "black"'>
                            <div class="sf-plan-radio @(form.PlanSeleccionado == "black" ? "sf-radio-sel sf-radio-red" : "")"></div>
                            <div class="sf-plan-body">
                                <span class="sf-plan-badge-premium">PREMIUM</span>
                                <h4>Membresía Black</h4>
                                <div class="sf-plan-precio">
                                    <span class="sf-precio-val">S/ 149</span>
                                    <span class="sf-precio-per">/ mes</span>
                                </div>
                                <ul class="sf-plan-features">
                                    <li><span class="sf-chk">✓</span> Todo lo de Basic</li>
                                    <li><span class="sf-chk">✓</span> Clases grupales ilimitadas</li>
                                    <li><span class="sf-chk">✓</span> Acceso 24/7</li>
                                    <li><span class="sf-chk">✓</span> Zona de spa</li>
                                </ul>
                            </div>
                        </div>
                    </div>

                    <div class="sf-form-grid sf-mt-16">
                        <div class="sf-form-group">
                            <label>Fecha de Inicio</label>
                            <input type="date" @bind="form.FechaInicio" />
                        </div>

                        <div class="sf-form-group">
                            <label>Fecha de Vencimiento</label>
                            <input type="date" @bind="form.FechaVencimiento" />
                        </div>

                        <div class="sf-form-group">
                            <label>Estado de membresía</label>
                            <select @bind="form.EstadoMembresia">
                                <option value="Activa">Activa</option>
                                <option value="Suspendida">Suspendida</option>
                                <option value="Vencida">Vencida</option>
                            </select>
                        </div>

                        <div class="sf-form-group"></div>

                        <div class="sf-form-group sf-form-full">
                            <label>Motivo / Observación</label>
                            <textarea @bind="form.Motivo" rows="3" placeholder="Corrección administrativa…"></textarea>
                        </div>
                    </div>

                    <button class="sf-btn-quitar" type="button" @onclick="QuitarMembresia">
                        <i class="bi bi-dash-circle"></i>
                        Quitar membresía
                    </button>
                </div>

                <div class="sf-form-actions">
                    <button class="sf-btn-primary" @onclick="GuardarCambios" disabled="@guardando">
                        @if (guardando)
                        {
                            <span><i class="bi bi-hourglass-split"></i></span>
                            <span>Guardando...</span>
                        }
                        else
                        {
                            <span><i class="bi bi-save"></i></span>
                            <span>Guardar cambios</span>
                        }
                    </button>

                    <a class="sf-btn-secondary" href="/admin/socios">Cancelar</a>

                    <span class="sf-back-link">
                        <a href="/admin/socios">← Volver al listado</a>
                    </span>
                </div>
            </div>

            <aside class="sf-resumen-col">
                <div class="sf-resumen-card">
                    <h4>Resumen</h4>

                    <div class="sf-resumen-rows">
                        <div class="sf-resumen-row">
                            <span>Socio</span>
                            <strong>@NombreCompletoVista</strong>
                        </div>

                        <div class="sf-resumen-row">
                            <span>DNI</span>
                            <strong>@(string.IsNullOrWhiteSpace(form.Dni) ? "—" : form.Dni)</strong>
                        </div>

                        <div class="sf-resumen-row">
                            <span>Plan actual</span>
                            <strong>@TextoPlanActual</strong>
                        </div>

                        <div class="sf-resumen-row">
                            <span>Estado membresía</span>
                            <strong class="@(form.EstadoMembresia == "Activa" ? "rsm-activo" : "rsm-inactivo")">
                                @form.EstadoMembresia
                            </strong>
                        </div>

                        <div class="sf-resumen-row">
                            <span>Estado socio</span>
                            <strong class="@(form.EstadoSocio == "Activo" ? "rsm-activo" : "rsm-inactivo")">
                                @form.EstadoSocio
                            </strong>
                        </div>

                        <div class="sf-resumen-row">
                            <span>Vencimiento</span>
                            <strong>@(form.FechaVencimiento.HasValue ? form.FechaVencimiento.Value.ToString("yyyy-MM-dd") : "—")</strong>
                        </div>

                        <div class="sf-resumen-row">
                            <span>Motivo</span>
                            <strong>@(string.IsNullOrWhiteSpace(form.Motivo) ? "—" : form.Motivo)</strong>
                        </div>
                    </div>
                </div>

                <div class="sf-admin-nota">
                    <span class="sf-nota-icon">
                        <i class="bi bi-exclamation-triangle"></i>
                    </span>
                    <p>Desde aquí puedes modificar, suspender o retirar la membresía del socio por motivos administrativos y disciplinarios.</p>
                </div>
            </aside>
        </div>
    }
</section>

@if (mostrarToast)
{
    <div class="socios-toast socios-toast-show">
        <span><i class="bi bi-check-circle"></i></span>
        <span>@mensajeToast</span>
    </div>
}

@code {
    [Parameter]
    public int Id { get; set; }

    private bool verPass = false;
    private bool verConfirm = false;
    private bool mostrarToast = false;
    private bool cargando = true;
    private bool guardando = false;

    private string mensajeToast = "";
    private Dictionary<string, string> errores = new();
    private FormEditarSocio form = new();

    private string NombreCompletoVista
    {
        get
        {
            string nombre = $"{form.Nombres} {form.ApellidoPaterno} {form.ApellidoMaterno}".Trim();
            return string.IsNullOrWhiteSpace(nombre) ? "—" : nombre;
        }
    }

    private string TextoPlanActual =>
        form.PlanSeleccionado switch
        {
            "black" => "Membresía Black",
            "basic" => "Membresía Basic",
            _ => "Sin membresía"
        };

    protected override async Task OnInitializedAsync()
    {
        try
        {
            cargando = true;

            var socio = await SocioService.ObtenerPorIdAsync(Id);

            if (socio != null)
            {
                form = new FormEditarSocio
                {
                    Dni = socio.Dni.ToString(),
                    Nombres = socio.Nombres ?? "",
                    ApellidoPaterno = socio.ApellidoPaterno ?? "",
                    ApellidoMaterno = socio.ApellidoMaterno ?? "",
                    EdadOriginal = socio.Edad,
                    Telefono = socio.Telefono.ToString(),
                    Email = socio.Email ?? "",
                    ContraseniaOriginal = socio.Contrasenia ?? "",
                    RolOriginal = string.IsNullOrWhiteSpace(socio.Rol) ? "Socio" : socio.Rol,
                    PlanSeleccionado = socio.EstadoMembresia ? "basic" : "",
                    EstadoMembresia = socio.EstadoMembresia ? "Activa" : "Vencida",
                    EstadoSocio = socio.Activo ? "Activo" : "Inactivo"
                };
            }
        }
        finally
        {
            cargando = false;
        }
    }

    private async Task GuardarCambios()
    {
        errores.Clear();

        int dniConvertido = 0;
        int telefonoConvertido = 0;

        bool dniValido = int.TryParse(form.Dni, out dniConvertido);
        bool telefonoValido = int.TryParse(form.Telefono, out telefonoConvertido);

        if (string.IsNullOrWhiteSpace(form.Dni) ||
            form.Dni.Length != 8 ||
            !dniValido)
        {
            errores["dni"] = "El DNI debe tener 8 dígitos numéricos.";
        }

        if (string.IsNullOrWhiteSpace(form.Nombres))
        {
            errores["nombres"] = "El nombre es obligatorio.";
        }

        if (string.IsNullOrWhiteSpace(form.ApellidoPaterno))
        {
            errores["apellidoPaterno"] = "El apellido paterno es obligatorio.";
        }

        if (string.IsNullOrWhiteSpace(form.ApellidoMaterno))
        {
            errores["apellidoMaterno"] = "El apellido materno es obligatorio.";
        }

        if (string.IsNullOrWhiteSpace(form.Email))
        {
            errores["email"] = "El correo es obligatorio.";
        }

        if (!string.IsNullOrWhiteSpace(form.Email) &&
            (!form.Email.Contains("@") || !form.Email.Contains(".")))
        {
            errores["email"] = "Ingrese un correo válido.";
        }

        if (string.IsNullOrWhiteSpace(form.Telefono) ||
            form.Telefono.Length != 9 ||
            !telefonoValido)
        {
            errores["telefono"] = "El teléfono debe tener 9 dígitos numéricos.";
        }

        if (!string.IsNullOrWhiteSpace(form.Contrasenia) &&
            form.Contrasenia.Length < 6)
        {
            errores["contrasenia"] = "La nueva contraseña debe tener mínimo 6 caracteres.";
        }

        if (!string.IsNullOrWhiteSpace(form.Contrasenia) &&
            form.Contrasenia != form.ConfirmarContrasenia)
        {
            errores["confirmar"] = "Las contraseñas no coinciden.";
        }

        if (errores.Any())
        {
            StateHasChanged();
            return;
        }

        int edadFinal = form.EdadOriginal;

        if (form.FechaNacimiento.HasValue)
        {
            edadFinal = CalcularEdad(form.FechaNacimiento.Value);
        }

        if (edadFinal <= 0)
        {
            edadFinal = form.EdadOriginal > 0 ? form.EdadOriginal : 18;
        }

        string contraseniaFinal = string.IsNullOrWhiteSpace(form.Contrasenia)
            ? form.ContraseniaOriginal
            : form.Contrasenia.Trim();

        if (string.IsNullOrWhiteSpace(contraseniaFinal))
        {
            contraseniaFinal = "123456";
        }

        string rolFinal = string.IsNullOrWhiteSpace(form.RolOriginal)
            ? "Socio"
            : form.RolOriginal;

        var dto = new SocioDTO
        {
            IdUsuario = Id,
            Dni = dniConvertido,
            Nombres = form.Nombres.Trim(),
            ApellidoPaterno = form.ApellidoPaterno.Trim(),
            ApellidoMaterno = form.ApellidoMaterno.Trim(),
            Edad = edadFinal,
            Telefono = telefonoConvertido,
            Email = form.Email.Trim(),
            Contrasenia = contraseniaFinal,
            Rol = rolFinal,
            Activo = form.EstadoSocio == "Activo",
            EstadoMembresia = form.EstadoMembresia == "Activa"
        };

        try
        {
            guardando = true;

            var resultado = await SocioService.ActualizarAsync(Id, dto);

            if (!resultado.StartsWith("Error", StringComparison.OrdinalIgnoreCase) &&
                !resultado.ToLower().Contains("error"))
            {
                mensajeToast = "Cambios guardados correctamente.";
                mostrarToast = true;
                StateHasChanged();

                await Task.Delay(1000);

                mostrarToast = false;
                Nav.NavigateTo("/admin/socios", forceLoad: true);
            }
            else
            {
                errores["dni"] = resultado;
                StateHasChanged();
            }
        }
        finally
        {
            guardando = false;
        }
    }

    private void QuitarMembresia()
    {
        form.PlanSeleccionado = "";
        form.EstadoMembresia = "Vencida";
    }

    private static int CalcularEdad(DateTime fechaNacimiento)
    {
        var hoy = DateTime.Today;
        var edad = hoy.Year - fechaNacimiento.Year;

        if (fechaNacimiento.Date > hoy.AddYears(-edad))
        {
            edad--;
        }

        return edad;
    }

    private class FormEditarSocio
    {
        public string Dni { get; set; } = "";
        public string Nombres { get; set; } = "";
        public string ApellidoPaterno { get; set; } = "";
        public string ApellidoMaterno { get; set; } = "";
        public DateTime? FechaNacimiento { get; set; }
        public int EdadOriginal { get; set; }
        public string Telefono { get; set; } = "";
        public string Email { get; set; } = "";

        public string Contrasenia { get; set; } = "";
        public string ConfirmarContrasenia { get; set; } = "";
        public string ContraseniaOriginal { get; set; } = "";
        public string RolOriginal { get; set; } = "Socio";

        public string PlanSeleccionado { get; set; } = "basic";
        public DateTime? FechaInicio { get; set; }
        public DateTime? FechaVencimiento { get; set; }
        public string EstadoMembresia { get; set; } = "Activa";
        public string Motivo { get; set; } = "";
        public string EstadoSocio { get; set; } = "Activo";
    }
}