@page "/"
@page "/login"
@using GigaChadSysWeb.Components.Layout
@using GigaChadSys.Servicios
@using GigaChadSys.Servicios.DTO
@layout AuthLayout
@rendermode InteractiveServer
@inject AuthServicio AuthService
@inject SessionServicio Session
@inject NavigationManager Nav

<div class="auth-page">
    <!-- Decorative corner lines -->
    <div class="auth-corner auth-corner-tl"></div>
    <div class="auth-corner auth-corner-br"></div>

    <div class="auth-container">
        <!-- Logo -->
        <div class="auth-logo">
            <div class="auth-logo-icon">
                <img src="/img/logo-gigachad.png" alt="GigaChad Logo" class="auth-logo-img" />
            </div>
            <h1 class="auth-brand">
                <span class="brand-giga">GYGA</span><span class="brand-chad">CHAD</span>
            </h1>
            <p class="auth-tagline">ENTRENA · SUPÉRATE · VIVE</p>
        </div>

        <!-- Title -->
        <h2 class="auth-title">Iniciar Sesión</h2>
        <p class="auth-desc">Bienvenido de vuelta a GigaChad</p>

        <!-- Error Message -->
        @if (!string.IsNullOrEmpty(mensajeError))
        {
            <div class="auth-error-msg">
                <span>⚠️</span> @mensajeError
            </div>
        }

        <!-- Form Card -->
        <div class="auth-card">
            <div class="auth-form-group">
                <label>CORREO ELECTRÓNICO</label>
                <div class="auth-input-wrapper">
                    <span class="auth-input-icon">✉️</span>
                    <input type="email" @bind="correo" placeholder="Ej: juan@email.com" disabled="@cargando" />
                </div>
            </div>

            <div class="auth-form-group">
                <label>CONTRASEÑA</label>
                <div class="auth-input-wrapper">
                    <span class="auth-input-icon">🔒</span>
                    <input type="@(mostrarPass ? "text" : "password")" @bind="password" placeholder="Ingresa tu contraseña" disabled="@cargando" />
                    <button class="auth-eye-btn" @onclick="() => mostrarPass = !mostrarPass" type="button">
                        @(mostrarPass ? "🙈" : "👁️")
                    </button>
                </div>
            </div>

            <button class="auth-submit-btn" @onclick="IniciarSesion" disabled="@cargando">
                @if (cargando)
                {
                    <span>Iniciando sesión...</span>
                }
                else
                {
                    <span>Iniciar Sesión</span>
                }
            </button>
        </div>

        <!-- Link -->
        <p class="auth-link-text">
            ¿No tienes cuenta?
        </p>
        <a class="auth-link" href="/registro">Crear cuenta aquí  ›</a>
    </div>
</div>

@code {
    private string correo = "";
    private string password = "";
    private bool mostrarPass = false;
    private bool cargando = false;
    private string mensajeError = "";

    private async Task IniciarSesion()
    {
        mensajeError = "";
        cargando = true;
        StateHasChanged();

        try
        {
            var resultado = await AuthService.LoginAsync(correo, password);

            if (resultado.Exito)
            {
                // Guardar el usuario en la sesión para que lo usen todas las páginas
                Session.IniciarSesion(resultado);

                // Navegar según el rol del usuario
                switch (resultado.Rol)
                {
                    case "Administrador":
                        Nav.NavigateTo("/admin/inicio");
                        break;
                    case "Entrenador":
                        Nav.NavigateTo("/entrenador/inicio");
                        break;
                    case "Socio":
                        Nav.NavigateTo("/socio/inicio");
                        break;
                    default:
                        Nav.NavigateTo("/");
                        break;
                }
            }
            else
            {
                mensajeError = resultado.Mensaje;
            }
        }
        catch (Exception ex)
        {
            mensajeError = $"Error de conexión: {ex.Message}";
        }
        finally
        {
            cargando = false;
            StateHasChanged();
        }
    }
}