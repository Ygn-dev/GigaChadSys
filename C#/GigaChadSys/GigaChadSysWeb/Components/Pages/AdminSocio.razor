@page "/admin/socios"
@using GigaChadSysWeb.Components.Layout
@using GigaChadSys.Servicios
@using GigaChadSys.Servicios.DTO
@layout AdminLayout
@rendermode InteractiveServer
@inject NavigationManager Nav
@inject SocioServicio SocioService
@inject ToastService ToastService

<section class="socios-page">

    <!-- Page Header -->
    <div class="socios-page-header">
        <div>
            <h1>Gestión de Socios</h1>
            <p class="socios-subtitle">Administra los socios del gimnasio</p>
        </div>
        <button class="btn-socios-primary" @onclick='() => Nav.NavigateTo("/admin/socios/nuevo")'>
            <i class="bi bi-plus-lg"></i>
            <span>Nuevo Socio</span>
        </button>

    </div>

    <!-- Stats Row -->
    <div class="socios-stats-row">
        <div class="socios-stat-card">
            <div class="socios-stat-icon icon-red">
                <i class="bi bi-people-fill"></i>
            </div>
            <div class="socios-stat-body">
                <span class="socios-stat-label">TOTAL SOCIOS</span>
                <span class="socios-stat-value">@socios.Count</span>
                <span class="socios-stat-hint">Registrados</span>
            </div>
        </div>

        <div class="socios-stat-card">
            <div class="socios-stat-icon icon-green">
                <i class="bi bi-check-circle-fill"></i>
            </div>
            <div class="socios-stat-body">
                <span class="socios-stat-label">ACTIVOS</span>
                <span class="socios-stat-value">@socios.Count(s => s.Activo)</span>
                <span class="socios-stat-hint">En el sistema</span>
            </div>
        </div>

        <div class="socios-stat-card">
            <div class="socios-stat-icon icon-yellow">
                <i class="bi bi-pause-circle-fill"></i>
            </div>
            <div class="socios-stat-body">
                <span class="socios-stat-label">INACTIVOS</span>
                <span class="socios-stat-value">@socios.Count(s => !s.Activo)</span>
                <span class="socios-stat-hint">Deshabilitados</span>
            </div>
        </div>

        <div class="socios-stat-card">
            <div class="socios-stat-icon icon-blue">
                <i class="bi bi-gem"></i>
            </div>
            <div class="socios-stat-body">
                <span class="socios-stat-label">CON MEMBRESÍA</span>
                <span class="socios-stat-value">@socios.Count(s => s.EstadoMembresia)</span>
                <span class="socios-stat-hint">Membresía pagada</span>
            </div>
        </div>
    </div>

    <!-- Toolbar -->
    <div class="socios-toolbar">
        <div class="socios-search-box">
            <span class="search-icon-s">
                <i class="bi bi-search"></i>
            </span>
            <input type="text"
                   placeholder="Buscar por DNI, nombre o correo..."
                   @bind="textoBusqueda"
                   @bind:event="oninput" />
        </div>
        <div class="socios-filter-tabs">
            <button class="socios-filter-tab @(filtroActivo == "todos" ? "tab-sel" : "")"
                    @onclick='() => filtroActivo = "todos"'>Todos</button>
            <button class="socios-filter-tab @(filtroActivo == "activo" ? "tab-sel" : "")"
                    @onclick='() => filtroActivo = "activo"'>Activos</button>
            <button class="socios-filter-tab @(filtroActivo == "inactivo" ? "tab-sel" : "")"
                    @onclick='() => filtroActivo = "inactivo"'>Inactivos</button>
        </div>
    </div>

    <!-- Table Card -->
    <div class="socios-table-card">
        <div class="socios-table-header">
            <h3>Lista de Socios</h3>
            <span class="socios-table-count">@SociosFiltrados.Count() socios</span>
        </div>

        <div class="socios-table-wrapper">
            <table class="socios-table">
                <thead>
                    <tr>
                        <th>DNI</th>
                        <th>Nombre</th>
                        <th>Contacto</th>
                        <th>Suscripción</th>
                        <th>Estado</th>
                        <th>Último Pago</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var socio in SociosPaginados)
                    {
                        <tr>
                            <td class="td-s-dni">@socio.Dni</td>
                            <td>
                                <div class="td-s-name-cell">
                                    <div class="td-s-avatar">@Iniciales(socio.NombreCompleto)</div>
                                    <div>
                                        <strong>@socio.NombreCompleto</strong>
                                        <span>@socio.Email</span>
                                    </div>
                                </div>
                            </td>
                            <td>@socio.Telefono</td>
                            <td>
                                @if (socio.EstadoMembresia)
                                {
                                    <span class="badge-s badge-s-black">
                                        <i class="bi bi-gem"></i>
                                        Activa
                                    </span>
                                }
                                else
                                {
                                    <span class="badge-s badge-s-basic">
                                        <i class="bi bi-info-circle"></i>
                                        Inactiva
                                    </span>
                                }
                            </td>
                            <td>
                                @if (socio.Activo)
                                {
                                    <span class="badge-s badge-s-activo">
                                        <span class="bdot bdot-green"></span> Activo
                                    </span>
                                }
                                else
                                {
                                    <span class="badge-s badge-s-inactivo">
                                        <span class="bdot bdot-red"></span> Inactivo
                                    </span>
                                }
                            </td>
                            <td class="td-s-pago">—</td>
                            <td>
                                <div class="td-s-actions">
                                    <button class="btn-s-action" title="Editar"
                                            @onclick="() => AbrirModalEditar(socio)">
                                        <i class="bi bi-pencil-fill"></i>
                                    </button>
                                    @if (socio.Activo)
                                    {
                                        <button class="btn-s-action" title="Desactivar" style="color: #dc3545;"
                                                @onclick="() => CambiarEstadoSocio(socio, false)">
                                            <i class="bi bi-person-x-fill"></i>
                                        </button>
                                    }
                                    else
                                    {
                                        <button class="btn-s-action" title="Activar" style="color: #28a745;"
                                                @onclick="() => CambiarEstadoSocio(socio, true)">
                                            <i class="bi bi-person-check-fill"></i>
                                        </button>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

            @if (!SociosFiltrados.Any())
            {
                <div class="socios-empty">
                    @(cargando ? "Cargando socios..." : "No se encontraron socios.")
                </div>
            }
        </div>

        <div class="socios-pagination">
            <span class="pagination-s-info">
                Mostrando
                @(((paginaActual - 1) * elementosPorPagina) + 1)
                -
                @Math.Min(paginaActual * elementosPorPagina, SociosFiltrados.Count())
                de @SociosFiltrados.Count() socios
            </span>

            <div class="pagination-s-btns">

                <button class="pgbtn"
                        disabled="@(paginaActual == 1)"
                        @onclick="PaginaAnterior">
                    ‹
                </button>

                @for (int i = 1; i <= TotalPaginas; i++)
                {
                    int pagina = i;

                    <button class="pgbtn @(paginaActual == pagina ? "pgbtn-active" : "")"
                            @onclick="() => IrAPagina(pagina)">
                        @pagina
                    </button>
                }

                <button class="pgbtn"
                        disabled="@(paginaActual == TotalPaginas)"
                        @onclick="PaginaSiguiente">
                    ›
                </button>

            </div>
        </div>
    </div>

</section>

@code {
    private List<SocioDTO> socios = new();
    private bool cargando = true;

    // ── Paginación ──
    private int paginaActual = 1;
    private int elementosPorPagina = 10;

    // ── Filtros / búsqueda ──
    private string _textoBusqueda = "";
    private string textoBusqueda
    {
        get => _textoBusqueda;
        set
        {
            if (_textoBusqueda != value)
            {
                _textoBusqueda = value;
                paginaActual = 1;
            }
        }
    }

    private string _filtroActivo = "todos";
    private string filtroActivo
    {
        get => _filtroActivo;
        set
        {
            if (_filtroActivo != value)
            {
                _filtroActivo = value;
                paginaActual = 1;
            }
        }
    }

    private IEnumerable<SocioDTO> SociosFiltrados => socios
        .Where(s => filtroActivo == "todos" ||
                    (filtroActivo == "activo"
                        ? s.Activo
                        : !s.Activo))
        .Where(s =>
            string.IsNullOrWhiteSpace(textoBusqueda)
            || s.Dni.ToString().Contains(textoBusqueda)
            || s.NombreCompleto.Contains(textoBusqueda, StringComparison.OrdinalIgnoreCase)
            || s.Email.Contains(textoBusqueda, StringComparison.OrdinalIgnoreCase));

    private IEnumerable<SocioDTO> SociosPaginados =>
        SociosFiltrados
            .Skip((paginaActual - 1) * elementosPorPagina)
            .Take(elementosPorPagina);

    private int TotalPaginas =>
        Math.Max(1,
            (int)Math.Ceiling(
                SociosFiltrados.Count() / (double)elementosPorPagina));

    protected override async Task OnInitializedAsync()
    {
        await CargarSocios();
    }

    private async Task CargarSocios()
    {
        cargando = true;

        try
        {
            socios = await SocioService.ListarSociosAsync();
        }
        catch (Exception ex)
        {
            ToastService.ShowError("Error al cargar socios: " + ex.Message);
        }
        finally
        {
            cargando = false;
        }
    }

    private void PaginaAnterior()
    {
        if (paginaActual > 1)
            paginaActual--;
    }

    private void PaginaSiguiente()
    {
        if (paginaActual < TotalPaginas)
            paginaActual++;
    }

    private void IrAPagina(int pagina)
    {
        paginaActual = pagina;
    }

    private void AbrirModalEditar(SocioDTO s)
    {
        Nav.NavigateTo($"/admin/socios/editar/{s.IdUsuario}");
    }

    private async Task CambiarEstadoSocio(SocioDTO socio, bool nuevoEstado)
    {
        socio.Activo = nuevoEstado;
        var resultado = await SocioService.ActualizarAsync(socio.IdUsuario, socio);

        if (!resultado.StartsWith("Error") && !resultado.ToLower().Contains("error"))
        {
            ToastService.ShowSuccess($"Socio {(nuevoEstado ? "activado" : "desactivado")} correctamente.");
        }
        else
        {
            ToastService.ShowError(resultado);
            socio.Activo = !nuevoEstado; // Revertir visualmente si falló
        }
    }

    // ── Helpers ──
    private static string Iniciales(string nombre)
    {
        if (string.IsNullOrWhiteSpace(nombre))
            return "??";

        var parts = nombre.Split(' ', StringSplitOptions.RemoveEmptyEntries);

        return parts.Length >= 2
            ? $"{parts[0][0]}{parts[1][0]}".ToUpper()
            : nombre[..Math.Min(2, nombre.Length)].ToUpper();
    }
}
