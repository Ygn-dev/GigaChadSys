@page "/admin/socios"
@using GigaChadSysModel
@using GigaChadSysWeb.Components.Layout
@using System.Text.Json.Serialization
@layout AdminLayout
@rendermode InteractiveServer
@inject NavigationManager Nav
@using GigaChadSys_Business_Logic



<section class="socios-page">

    <!-- Page Header -->
    <div class="socios-page-header">
        <div>
            <h1>Gestión de Socios</h1>
            <p class="socios-subtitle">Administra los socios del gimnasio</p>
        </div>
        <button class="btn-socios-primary" @onclick='() => Nav.NavigateTo("/admin/socios/nuevo")'>
            ＋ Nuevo Socio
        </button>

    </div>

    <!-- Stats Row -->
    <div class="socios-stats-row">
        <div class="socios-stat-card">
            <div class="socios-stat-icon icon-red">👥</div>
            <div class="socios-stat-body">
                <span class="socios-stat-label">TOTAL SOCIOS</span>
                <span class="socios-stat-value">@socios.Count</span>
                <span class="socios-stat-hint">Registrados</span>
            </div>
        </div>
        <div class="socios-stat-card">
            <div class="socios-stat-icon icon-green">✅</div>
            <div class="socios-stat-body">
                <span class="socios-stat-label">ACTIVOS</span>
                <span class="socios-stat-value">@socios.Count(s => s.Estado == "Activo")</span>
                <span class="socios-stat-hint">Con membresía vigente</span>
            </div>
        </div>
        <div class="socios-stat-card">
            <div class="socios-stat-icon icon-yellow">⏸</div>
            <div class="socios-stat-body">
                <span class="socios-stat-label">INACTIVOS</span>
                <span class="socios-stat-value">@socios.Count(s => s.Estado == "Inactivo")</span>
                <span class="socios-stat-hint">Sin membresía activa</span>
            </div>
        </div>
        <div class="socios-stat-card">
            <div class="socios-stat-icon icon-blue">♛</div>
            <div class="socios-stat-body">
                <span class="socios-stat-label">MEMBRESÍA BLACK</span>
                <span class="socios-stat-value">@socios.Count(s => s.Membresia.Contains("Black"))</span>
                <span class="socios-stat-hint">Plan premium</span>
            </div>
        </div>
    </div>

    <!-- Toolbar -->
    <div class="socios-toolbar">
        <div class="socios-search-box">
            <span class="search-icon-s">🔍</span>
            <input type="text"
                   placeholder="Buscar por DNI, nombre o correo..."
                   @bind="textoBusqueda"
                   @bind:event="oninput" />
        </div>
        <div class="socios-filter-tabs">
            <button class="socios-filter-tab @(filtroActivo == "todos" ? "tab-sel" : "")"
                    @onclick='() => filtroActivo = "todos"'>Todos</button>
            <button class="socios-filter-tab @(filtroActivo == "activo" ? "tab-sel" : "")"
                    @onclick='() => filtroActivo = "activo"'>Activos</button>
            <button class="socios-filter-tab @(filtroActivo == "inactivo" ? "tab-sel" : "")"
                    @onclick='() => filtroActivo = "inactivo"'>Inactivos</button>
        </div>
    </div>

    <!-- Table Card -->
    <div class="socios-table-card">
        <div class="socios-table-header">
            <h3>Lista de Socios</h3>
            <span class="socios-table-count">@SociosFiltrados.Count() socios</span>
        </div>

        <div class="socios-table-wrapper">
            <table class="socios-table">
                <thead>
                    <tr>
                        <th>DNI</th>
                        <th>Nombre</th>
                        <th>Contacto</th>
                        <th>Membresía</th>
                        <th>Estado</th>
                        <th>Último Pago</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var socio in SociosFiltrados)
                    {
                        <tr>
                            <td class="td-s-dni">@socio.Dni</td>
                            <td>
                                <div class="td-s-name-cell">
                                    <div class="td-s-avatar">@Iniciales(socio.Nombre)</div>
                                    <div>
                                        <strong>@socio.Nombre</strong>
                                        <span>@socio.Email</span>
                                    </div>
                                </div>
                            </td>
                            <td>@socio.Telefono</td>
                            <td>
                                @if (socio.Membresia.Contains("Black"))
                                {
                                    <span class="badge-s badge-s-black">♛ @socio.Membresia</span>
                                }
                                else
                                {
                                    <span class="badge-s badge-s-basic">◎ @socio.Membresia</span>
                                }
                            </td>
                            <td>
                                @if (socio.Estado == "Activo")
                                {
                                    <span class="badge-s badge-s-activo">
                                        <span class="bdot bdot-green"></span> Activo
                                    </span>
                                }
                                else
                                {
                                    <span class="badge-s badge-s-inactivo">
                                        <span class="bdot bdot-red"></span> Inactivo
                                    </span>
                                }
                            </td>
                            <td class="td-s-pago">@socio.UltimoPago</td>
                            <td>
                                <div class="td-s-actions">
                                    <button class="btn-s-action" title="Editar"
                                            @onclick="() => AbrirModalEditar(socio)">✏️</button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

            @if (!SociosFiltrados.Any())
            {
                <div class="socios-empty">No se encontraron socios.</div>
            }
        </div>

        <div class="socios-pagination">
            <span class="pagination-s-info">
                Mostrando @SociosFiltrados.Count() de @socios.Count socios
            </span>
            <div class="pagination-s-btns">
                <button class="pgbtn">‹</button>
                <button class="pgbtn pgbtn-active">1</button>
                <button class="pgbtn">›</button>
            </div>
        </div>
    </div>

</section>

<!-- ── MODAL NUEVO / EDITAR ── -->
@if (mostrarModal)
{
    <div class="socios-modal-overlay" @onclick="CerrarModal">
        <div class="socios-modal" @onclick:stopPropagation="true">
            <div class="socios-modal-header">
                <h3>@(modoEditar ? "Editar Socio" : "Nuevo Socio")</h3>
                <button class="socios-modal-close" @onclick="CerrarModal">✕</button>
            </div>

            <div class="socios-form-grid">
                <div class="socios-form-group">
                    <label>NOMBRE COMPLETO</label>
                    <input type="text" @bind="form.Nombre" placeholder="Ej: Juan Pérez" />
                </div>
                <div class="socios-form-group">
                    <label>DNI</label>
                    <input type="text" @bind="form.Dni" placeholder="12345678" maxlength="8" />
                </div>
                <div class="socios-form-group socios-form-full">
                    <label>CORREO ELECTRÓNICO</label>
                    <input type="email" @bind="form.Email" placeholder="juan@email.com" />
                </div>
                <div class="socios-form-group">
                    <label>TELÉFONO</label>
                    <input type="text" @bind="form.Telefono" placeholder="987654321" maxlength="9" />
                </div>
                <div class="socios-form-group">
                    <label>MEMBRESÍA</label>
                    <select @bind="form.Membresia">
                        <option value="">Sin membresía</option>
                        <option value="Membresía Basic">Membresía Basic</option>
                        <option value="Membresía Black">Membresía Black</option>
                    </select>
                </div>
                @if (!modoEditar)
                {
                    <div class="socios-form-group socios-form-full">
                        <label>CONTRASEÑA INICIAL</label>
                        <input type="password" placeholder="Mínimo 6 caracteres" />
                    </div>
                }
            </div>

            @if (!string.IsNullOrEmpty(mensajeError))
            {
                <p class="socios-form-error">⚠ @mensajeError</p>
            }

            <div class="socios-modal-footer">
                <button class="btn-s-cancel" @onclick="CerrarModal">Cancelar</button>
                <button class="btn-socios-primary" @onclick="GuardarSocio">
                    @(modoEditar ? "Guardar Cambios" : "Guardar Socio")
                </button>
            </div>
        </div>
    </div>
}

<!-- ── TOAST ── -->
@if (mostrarToast)
{
    <div class="socios-toast socios-toast-show">
        <span>@iconoToast</span>
        <span>@mensajeToast</span>
    </div>
}

@code {

    // ── Modelo interno ──
    private class SocioItem
    {
        [JsonPropertyName("dni")]
        public string Dni { get; set; } = "";
        
        [JsonPropertyName("nombres")]
        public string Nombre { get; set; } = "";
        
        [JsonPropertyName("email")]
        public string Email { get; set; } = "";
        
        [JsonPropertyName("telefono")]
        public string Telefono { get; set; } = "";
        
        [JsonPropertyName("membresia")]
        public string Membresia { get; set; } = "";
        
        [JsonPropertyName("activo")]
        public string Estado { get; set; } = "";
        
        [JsonPropertyName("ultimoPago")]
        public string UltimoPago { get; set; } = "";
    }

    // ── Datos hardcodeados ──
    private List<SocioItem> socios = new()
    {
        new() { Dni="40234123", Nombre="Lucia Torres",   Email="lucia@email.com",    Telefono="987654321", Membresia="Membresía Black", Estado="Activo",   UltimoPago="2025-05-01" },
        new() { Dni="40123123", Nombre="Juan Perez",     Email="juan@email.com",     Telefono="987123456", Membresia="Membresía Basic", Estado="Activo",   UltimoPago="2025-05-03" },
        new() { Dni="40345234", Nombre="Ana Garcia",     Email="ana@email.com",      Telefono="986543210", Membresia="Membresía Black", Estado="Activo",   UltimoPago="2025-04-28" },
        new() { Dni="40567234", Nombre="Diego Ramos",    Email="diego@email.com",    Telefono="985678901", Membresia="Membresía Basic", Estado="Inactivo", UltimoPago="2025-03-01" },
        new() { Dni="40678345", Nombre="Sofia Mendez",   Email="sofia@email.com",    Telefono="984567012", Membresia="Membresía Black", Estado="Activo",   UltimoPago="2025-05-05" },
        new() { Dni="40789456", Nombre="Roberto Diaz",   Email="roberto@email.com",  Telefono="983456123", Membresia="Membresía Basic", Estado="Activo",   UltimoPago="2025-05-02" },
        new() { Dni="40890567", Nombre="Camila Flores",  Email="camila@email.com",   Telefono="982345234", Membresia="Membresía Basic", Estado="Inactivo", UltimoPago="2025-02-01" },
        new() { Dni="40901678", Nombre="Fernando Loza",  Email="fernando@email.com", Telefono="981234345", Membresia="Membresía Black", Estado="Activo",   UltimoPago="2025-05-04" },
    };

    // ── Filtros / búsqueda ──
    private string textoBusqueda = "";
    private string filtroActivo = "todos";

    private IEnumerable<SocioItem> SociosFiltrados => socios
        .Where(s => filtroActivo == "todos" || s.Estado.ToLower() == filtroActivo)
        .Where(s => string.IsNullOrWhiteSpace(textoBusqueda)
            || s.Dni.Contains(textoBusqueda, StringComparison.OrdinalIgnoreCase)
            || s.Nombre.Contains(textoBusqueda, StringComparison.OrdinalIgnoreCase)
            || s.Email.Contains(textoBusqueda, StringComparison.OrdinalIgnoreCase));

    // ── Modal ──
    private bool mostrarModal = false;
    private bool modoEditar = false;
    private SocioItem form = new();
    private SocioItem? socioEditando = null;
    private string mensajeError = "";

    private void AbrirModalNuevo()
    {
        Nav.NavigateTo($"/admin/socios/nuevo");
    }

    private void AbrirModalEditar(SocioItem s)
    {
        Nav.NavigateTo($"/admin/socios/editar");
    }

    private void CerrarModal() => mostrarModal = false;

    private void GuardarSocio()
    {
        if (string.IsNullOrWhiteSpace(form.Nombre))   { mensajeError = "El nombre es obligatorio."; return; }
        if (string.IsNullOrWhiteSpace(form.Email))    { mensajeError = "El correo es obligatorio."; return; }
        if (string.IsNullOrWhiteSpace(form.Dni) || form.Dni.Length != 8) { mensajeError = "El DNI debe tener 8 dígitos."; return; }

        if (modoEditar && socioEditando != null)
        {
            socioEditando.Nombre    = form.Nombre;
            socioEditando.Email     = form.Email;
            socioEditando.Telefono  = form.Telefono;
            socioEditando.Membresia = form.Membresia;
        }
        else
        {
            socios.Insert(0, new SocioItem
            {
                Dni       = form.Dni,
                Nombre    = form.Nombre,
                Email     = form.Email,
                Telefono  = form.Telefono,
                Membresia = form.Membresia,
                Estado    = "Activo",
                UltimoPago = "—"
            });
        }

        CerrarModal();
        MostrarToast("✅", modoEditar ? "Socio actualizado correctamente" : "Socio registrado correctamente");
    }

    // ── Toast ──
    private bool mostrarToast = false;
    private string mensajeToast = "";
    private string iconoToast = "✅";

    private async void MostrarToast(string icono, string msg)
    {
        iconoToast   = icono;
        mensajeToast = msg;
        mostrarToast = true;
        StateHasChanged();
        await Task.Delay(2800);
        mostrarToast = false;
        StateHasChanged();
    }

    // ── Helpers ──
    private static string Iniciales(string nombre) =>
        string.Concat(nombre.Split(' ').Take(2).Select(p => p[0])).ToUpper();
}

