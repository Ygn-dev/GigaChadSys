@page "/admin/socios"
@using GigaChadSysWeb.Components.Layout
@using GigaChadSys.Servicios
@using GigaChadSys.Servicios.DTO
@layout AdminLayout
@rendermode InteractiveServer
@inject NavigationManager Nav
@inject SocioServicio SocioService

<section class="socios-page">

    <!-- Page Header -->
    <div class="socios-page-header">
        <div>
            <h1>Gestión de Socios</h1>
            <p class="socios-subtitle">Administra los socios del gimnasio</p>
        </div>
        <button class="btn-socios-primary" @onclick='() => Nav.NavigateTo("/admin/socios/nuevo")'>
            ＋ Nuevo Socio
        </button>

    </div>

    <!-- Stats Row -->
    <div class="socios-stats-row">
        <div class="socios-stat-card">
            <div class="socios-stat-icon icon-red">👥</div>
            <div class="socios-stat-body">
                <span class="socios-stat-label">TOTAL SOCIOS</span>
                <span class="socios-stat-value">@socios.Count</span>
                <span class="socios-stat-hint">Registrados</span>
            </div>
        </div>
        <div class="socios-stat-card">
            <div class="socios-stat-icon icon-green">✅</div>
            <div class="socios-stat-body">
                <span class="socios-stat-label">ACTIVOS</span>
                <span class="socios-stat-value">@socios.Count(s => s.Activo)</span>
                <span class="socios-stat-hint">En el sistema</span>
            </div>
        </div>
        <div class="socios-stat-card">
            <div class="socios-stat-icon icon-yellow">⏸</div>
            <div class="socios-stat-body">
                <span class="socios-stat-label">INACTIVOS</span>
                <span class="socios-stat-value">@socios.Count(s => !s.Activo)</span>
                <span class="socios-stat-hint">Deshabilitados</span>
            </div>
        </div>
        <div class="socios-stat-card">
            <div class="socios-stat-icon icon-blue">♛</div>
            <div class="socios-stat-body">
                <span class="socios-stat-label">CON MEMBRESÍA</span>
                <span class="socios-stat-value">@socios.Count(s => s.EstadoMembresia)</span>
                <span class="socios-stat-hint">Membresía pagada</span>
            </div>
        </div>
    </div>

    <!-- Toolbar -->
    <div class="socios-toolbar">
        <div class="socios-search-box">
            <span class="search-icon-s">🔍</span>
            <input type="text"
                   placeholder="Buscar por DNI, nombre o correo..."
                   @bind="textoBusqueda"
                   @bind:event="oninput" />
        </div>
        <div class="socios-filter-tabs">
            <button class="socios-filter-tab @(filtroActivo == "todos" ? "tab-sel" : "")"
                    @onclick='() => filtroActivo = "todos"'>Todos</button>
            <button class="socios-filter-tab @(filtroActivo == "activo" ? "tab-sel" : "")"
                    @onclick='() => filtroActivo = "activo"'>Activos</button>
            <button class="socios-filter-tab @(filtroActivo == "inactivo" ? "tab-sel" : "")"
                    @onclick='() => filtroActivo = "inactivo"'>Inactivos</button>
        </div>
    </div>

    <!-- Table Card -->
    <div class="socios-table-card">
        <div class="socios-table-header">
            <h3>Lista de Socios</h3>
            <span class="socios-table-count">@SociosFiltrados.Count() socios</span>
        </div>

        <div class="socios-table-wrapper">
            <table class="socios-table">
                <thead>
                    <tr>
                        <th>DNI</th>
                        <th>Nombre</th>
                        <th>Contacto</th>
                        <th>Suscripción</th>
                        <th>Estado</th>
                        <th>Último Pago</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var socio in SociosFiltrados)
                    {
                        <tr>
                            <td class="td-s-dni">@socio.Dni</td>
                            <td>
                                <div class="td-s-name-cell">
                                    <div class="td-s-avatar">@Iniciales(socio.NombreCompleto)</div>
                                    <div>
                                        <strong>@socio.NombreCompleto</strong>
                                        <span>@socio.Email</span>
                                    </div>
                                </div>
                            </td>
                            <td>@socio.Telefono</td>
                            <td>
                                @if (socio.EstadoMembresia)
                                {
                                    <span class="badge-s badge-s-black">♛ Activa</span>
                                }
                                else
                                {
                                    <span class="badge-s badge-s-basic">◎ Inactiva</span>
                                }
                            </td>
                            <td>
                                @if (socio.Activo)
                                {
                                    <span class="badge-s badge-s-activo">
                                        <span class="bdot bdot-green"></span> Activo
                                    </span>
                                }
                                else
                                {
                                    <span class="badge-s badge-s-inactivo">
                                        <span class="bdot bdot-red"></span> Inactivo
                                    </span>
                                }
                            </td>
                            <td class="td-s-pago">—</td>
                            <td>
                                <div class="td-s-actions">
                                    <button class="btn-s-action" title="Editar"
                                            @onclick="() => AbrirModalEditar(socio)">✏️</button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

            @if (!SociosFiltrados.Any())
            {
                <div class="socios-empty">
                    @(cargando ? "Cargando socios..." : "No se encontraron socios.")
                </div>
            }
        </div>

        <div class="socios-pagination">
            <span class="pagination-s-info">
                Mostrando @SociosFiltrados.Count() de @socios.Count socios
            </span>
            <div class="pagination-s-btns">
                <button class="pgbtn">‹</button>
                <button class="pgbtn pgbtn-active">1</button>
                <button class="pgbtn">›</button>
            </div>
        </div>
    </div>

</section>

<!-- ── TOAST ── -->
@if (mostrarToast)
{
    <div class="socios-toast socios-toast-show">
        <span>@iconoToast</span>
        <span>@mensajeToast</span>
    </div>
}

@code {
    private List<SocioDTO> socios = new();
    private bool cargando = true;

    // ── Filtros / búsqueda ──
    private string textoBusqueda = "";
    private string filtroActivo = "todos";

    private IEnumerable<SocioDTO> SociosFiltrados => socios
        .Where(s => filtroActivo == "todos" || (filtroActivo == "activo" ? s.Activo : !s.Activo))
        .Where(s => string.IsNullOrWhiteSpace(textoBusqueda)
            || s.Dni.ToString().Contains(textoBusqueda)
            || s.NombreCompleto.Contains(textoBusqueda, StringComparison.OrdinalIgnoreCase)
            || s.Email.Contains(textoBusqueda, StringComparison.OrdinalIgnoreCase));

    protected override async Task OnInitializedAsync()
    {
        await CargarSocios();
    }

    private async Task CargarSocios()
    {
        cargando = true;
        try
        {
            socios = await SocioService.ListarSociosAsync();
        }
        catch (Exception ex)
        {
            MostrarToast("❌", "Error al cargar socios: " + ex.Message);
        }
        finally
        {
            cargando = false;
        }
    }

    private void AbrirModalEditar(SocioDTO s)
    {
        Nav.NavigateTo($"/admin/socios/editar/{s.IdUsuario}");
    }

    // ── Toast ──
    private bool mostrarToast = false;
    private string mensajeToast = "";
    private string iconoToast = "✅";

    private async void MostrarToast(string icono, string msg)
    {
        iconoToast = icono;
        mensajeToast = msg;
        mostrarToast = true;
        StateHasChanged();
        await Task.Delay(2800);
        mostrarToast = false;
        StateHasChanged();
    }

    // ── Helpers ──
    private static string Iniciales(string nombre)
    {
        if (string.IsNullOrWhiteSpace(nombre)) return "??";
        var parts = nombre.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return parts.Length >= 2 
            ? $"{parts[0][0]}{parts[1][0]}".ToUpper() 
            : nombre[..Math.Min(2, nombre.Length)].ToUpper();
    }
}
