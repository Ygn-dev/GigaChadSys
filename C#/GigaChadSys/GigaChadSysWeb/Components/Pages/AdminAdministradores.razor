@page "/admin/administradores"
@layout AdminLayout
@rendermode InteractiveServer
@using GigaChadSys.Servicios
@using GigaChadSys.Servicios.DTO
@inject AdministradorServicio AdministradorService

<section class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1>Gestión de Administradores</h1>
            <p>Administra el personal administrativo del sistema.</p>
        </div>

        <a class="btn btn-danger fw-bold text-uppercase px-4" href="/admin/administradores/nuevo">
            + Nuevo Administrador
        </a>
    </div>

    <div class="d-flex flex-wrap justify-content-between align-items-center mb-4 gap-3 bg-dark p-3 rounded border border-secondary">
        <input class="form-control bg-black text-white border-secondary"
               type="text"
               placeholder="Buscar por DNI, nombre o cargo..."
               @bind="TextoBusqueda"
               @bind:event="oninput" />

        <div class="btn-group">
            <button class="@FiltroClaseTodos" @onclick="MostrarTodos">Todos</button>
            <button class="@FiltroClaseActivos" @onclick="MostrarActivos">Activos</button>
            <button class="@FiltroClaseInactivos" @onclick="MostrarInactivos">Inactivos</button>
        </div>
    </div>

    @{
        var administradores = AdministradoresPaginados.ToList();
    }

    <div class="table-responsive bg-dark border border-secondary rounded shadow">
        <table class="table table-dark table-hover table-striped align-middle mb-0 table-dark table-hover table-striped align-middle mb-0">
            <thead>
                <tr>
                    <th>DNI</th>
                    <th>Nombre</th>
                    <th>Sede</th>
                    <th>Cargo</th>
                    <th>Sueldo</th>
                    <th>Estado</th>
                    <th>Acciones</th>
                </tr>
            </thead>

            <tbody>
                @if (Cargando)
                {
                    <tr>
                        <td colspan="7" class="empty-row">
                            Cargando administradores...
                        </td>
                    </tr>
                }
                else if (administradores.Count == 0)
                {
                    <tr>
                        <td colspan="7" class="empty-row">
                            No se encontraron administradores.
                        </td>
                    </tr>
                }
                else
                {
                    @foreach (var admin in administradores)
                    {
                        <tr>
                            <td>@admin.Dni</td>

                            <td>
                                <div class="d-flex align-items-center gap-3">
                                    <div class="bg-danger text-white rounded-circle d-flex align-items-center justify-content-center fw-bold" style="width:40px; height:40px;">
                                        @InicialAdmin(admin)
                                    </div>

                                    <div>
                                        <strong>@admin.NombreCompleto</strong>
                                        <span>@admin.Email</span>
                                    </div>
                                </div>
                            </td>

                            <td>@MostrarTexto(admin.Sede)</td>
                            <td>@MostrarTexto(admin.Cargo)</td>
                            <td>S/ @admin.Sueldo.ToString("0.00")</td>

                            <td>
                                @if (admin.Activo)
                                {
                                    <span class="badge bg-success rounded-pill px-3 py-2">Activo</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary rounded-pill px-3 py-2">Inactivo</span>
                                }
                            </td>

                            <td>
                                <a class="btn btn-sm btn-outline-light"
                                   href="@($"/admin/administradores/editar/{admin.IdUsuario}")">
                                    ✎
                                </a>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
    
    <div class="d-flex flex-wrap justify-content-between align-items-center mt-4 bg-dark p-3 rounded border border-secondary">
        <span class="text-muted small">
            Mostrando @(((PaginaActual - 1) * ElementosPorPagina) + 1) - @Math.Min(PaginaActual * ElementosPorPagina, AdministradoresFiltrados.Count()) de @AdministradoresFiltrados.Count() administradores
        </span>
        <div class="d-flex gap-2">
            <button class="btn btn-sm btn-outline-secondary" disabled="@(PaginaActual == 1)" @onclick="PaginaAnterior">‹</button>
            @for (int i = 1; i <= TotalPaginas; i++)
            {
                int pagina = i;
                <button class="pgbtn @(PaginaActual == pagina ? "btn-danger" : "")" @onclick="() => IrAPagina(pagina)">@pagina</button>
            }
            <button class="btn btn-sm btn-outline-secondary" disabled="@(PaginaActual == TotalPaginas)" @onclick="PaginaSiguiente">›</button>
        </div>
    </div>
</section>

@code {
    private string _textoBusqueda = "";
    private string TextoBusqueda
    {
        get => _textoBusqueda;
        set
        {
            if (_textoBusqueda != value)
            {
                _textoBusqueda = value;
                PaginaActual = 1;
            }
        }
    }

    private string _filtroEstado = "Todos";
    private string FiltroEstado
    {
        get => _filtroEstado;
        set
        {
            if (_filtroEstado != value)
            {
                _filtroEstado = value;
                PaginaActual = 1;
            }
        }
    }
    
    private bool Cargando { get; set; } = true;
    private int PaginaActual = 1;
    private int ElementosPorPagina = 10;

    private List<AdministradorDTO> Administradores = new();

    private string FiltroClaseTodos => FiltroEstado == "Todos" ? "btn btn-danger" : "btn btn-outline-secondary";
    private string FiltroClaseActivos => FiltroEstado == "Activos" ? "btn btn-danger" : "btn btn-outline-secondary";
    private string FiltroClaseInactivos => FiltroEstado == "Inactivos" ? "btn btn-danger" : "btn btn-outline-secondary";

    protected override async Task OnInitializedAsync()
    {
        await CargarAdministradores();
    }

    private async Task CargarAdministradores()
    {
        Cargando = true;
        try
        {
            Administradores = await AdministradorService.ListarAdministradoresAsync();
        }
        finally
        {
            Cargando = false;
        }
    }

    private void MostrarTodos() { FiltroEstado = "Todos"; }
    private void MostrarActivos() { FiltroEstado = "Activos"; }
    private void MostrarInactivos() { FiltroEstado = "Inactivos"; }

    private void PaginaAnterior() { if (PaginaActual > 1) PaginaActual--; }
    private void PaginaSiguiente() { if (PaginaActual < TotalPaginas) PaginaActual++; }
    private void IrAPagina(int pagina) { PaginaActual = pagina; }

    private IEnumerable<AdministradorDTO> AdministradoresFiltrados
    {
        get
        {
            IEnumerable<AdministradorDTO> resultado = Administradores;

            if (FiltroEstado == "Activos")
                resultado = resultado.Where(e => e.Activo);
            else if (FiltroEstado == "Inactivos")
                resultado = resultado.Where(e => !e.Activo);

            if (!string.IsNullOrWhiteSpace(TextoBusqueda))
            {
                string texto = TextoBusqueda.Trim();
                resultado = resultado.Where(e =>
                    e.Dni.ToString().Contains(texto) ||
                    e.NombreCompleto.Contains(texto, StringComparison.OrdinalIgnoreCase) ||
                    (!string.IsNullOrWhiteSpace(e.Cargo) && e.Cargo.Contains(texto, StringComparison.OrdinalIgnoreCase))
                );
            }

            return resultado;
        }
    }

    private IEnumerable<AdministradorDTO> AdministradoresPaginados =>
        AdministradoresFiltrados.Skip((PaginaActual - 1) * ElementosPorPagina).Take(ElementosPorPagina);

    private int TotalPaginas =>
        Math.Max(1, (int)Math.Ceiling(AdministradoresFiltrados.Count() / (double)ElementosPorPagina));

    private static string MostrarTexto(string? texto)
    {
        return string.IsNullOrWhiteSpace(texto) ? "—" : texto;
    }

    private static string InicialAdmin(AdministradorDTO admin)
    {
        if (!string.IsNullOrWhiteSpace(admin.Nombres))
            return admin.Nombres[0].ToString();
        if (!string.IsNullOrWhiteSpace(admin.NombreCompleto))
            return admin.NombreCompleto[0].ToString();
        return "A";
    }
}
