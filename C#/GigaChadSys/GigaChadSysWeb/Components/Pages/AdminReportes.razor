@page "/admin/reportes"
@layout AdminLayout
@rendermode InteractiveServer
@using System.Globalization
@using System.Linq
@using Microsoft.AspNetCore.Components
@using Microsoft.JSInterop
@using GigaChadSys.Servicios
@using GigaChadSys.Servicios.DTO
@inject SocioServicio SocioService
@inject SuscripcionServicio SuscripcionService
@inject PagoServicio PagoService
@inject ReporteServicio ReporteService
@inject IJSRuntime JS

<section class="container-fluid py-4">

    <div class="reports-header">
        <h1>Reportes</h1>
        <p>Visualiza métricas y estadísticas del gimnasio.</p>
    </div>

    <div style="display:flex; justify-content:flex-end; margin-bottom:20px;">
        <button type="button"
                class="admin-report-button"
                @onclick="DescargarReportePagos"
                disabled="@DescargandoReporte">
            @if (DescargandoReporte)
            {
                <span>
                    <i class="bi bi-hourglass-split"></i>
                    Generando PDF...
                </span>
            }
            else
            {
                <span>
                    <i class="bi bi-file-earmark-pdf"></i>
                    Descargar reporte de pagos
                </span>
            }
        </button>
    </div>

    <div class="reports-tabs">
        <button class="@ClaseTabSocios" @onclick="MostrarReporteSocios">
            Reporte de Socios
        </button>

        <button class="@ClaseTabRecaudacion" @onclick="MostrarReporteRecaudacion">
            Reporte de Recaudación
        </button>
    </div>

    @if (ReporteActual == "Socios")
    {
        <div class="reports-stats-grid">
            <div class="report-stat-card">
                <div class="report-stat-icon green">
                    <i class="bi bi-person-check"></i>
                </div>
                <span>Socios activos</span>
                <strong>@SociosActivos</strong>
                <p>@Porcentaje(SociosActivos, TotalSocios)</p>
            </div>

            <div class="report-stat-card">
                <div class="report-stat-icon red">
                    <i class="bi bi-person-x"></i>
                </div>
                <span>Socios inactivos</span>
                <strong>@SociosInactivos</strong>
                <p>@Porcentaje(SociosInactivos, TotalSocios)</p>
            </div>

            <div class="report-stat-card">
                <div class="report-stat-icon yellow">
                    <i class="bi bi-cash-coin"></i>
                </div>
                <span>Pendiente por cobrar</span>
                <strong>@PagosPendientesSociosTotal</strong>
                <p>S/ @DeudaPendienteSocios en deuda de socios</p>
            </div>

            <div class="report-stat-card">
                <div class="report-stat-icon blue">
                    <i class="bi bi-people"></i>
                </div>
                <span>Total socios</span>
                <strong>@TotalSocios</strong>
                <p>Registrados en el sistema</p>
            </div>
        </div>

        <div class="reports-content-grid">
            <div class="report-panel">
                <h2>Distribución por Membresía</h2>

                <div class="membership-bar-row">
                    <div class="membership-bar-header">
                        <span>Membresía Basic</span>
                        <strong>@SociosBasic socios</strong>
                    </div>
                    <div class="membership-bar-track">
                        <div class="membership-bar-fill basic" style="width: @PorcentajeAncho(SociosBasic, TotalSocios)"></div>
                    </div>
                </div>

                <div class="membership-bar-row">
                    <div class="membership-bar-header">
                        <span>Membresía Black</span>
                        <strong>@SociosBlack socios</strong>
                    </div>
                    <div class="membership-bar-track">
                        <div class="membership-bar-fill black" style="width: @PorcentajeAncho(SociosBlack, TotalSocios)"></div>
                    </div>
                </div>

                <div class="report-legend">
                    <span><i class="legend-basic"></i> Basic</span>
                    <span><i class="legend-black"></i> Black</span>
                </div>
            </div>

            <div class="report-panel">
                <h2>Estado de Membresías</h2>

                <div class="report-member-list">
                    @foreach (var socio in Socios)
                    {
                        <div class="report-member-row">
                            <div class="member-avatar-small">
                                <i class="bi bi-person-circle"></i>
                            </div>

                            <div class="member-info-report">
                                <strong>@socio.Nombre</strong>
                                <span>@socio.Membresia</span>
                            </div>

                            @if (socio.Activo)
                            {
                                <span class="report-status active">Activo</span>
                            }
                            else
                            {
                                <span class="report-status inactive">Inactivo</span>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="revenue-filter-row">
            <button class="@ClasePeriodoMes" @onclick="MostrarUltimoMes">Último Mes</button>
            <button class="@ClasePeriodoTrimestre" @onclick="MostrarUltimoTrimestre">Último Trimestre</button>
            <button class="@ClasePeriodoAnio" @onclick="MostrarUltimoAnio">Último Año</button>
        </div>

        <div class="revenue-kpi-grid revenue-kpi-grid-six">
            <div class="revenue-kpi-card">
                <div>
                    <span>Ingresos brutos</span>
                    <strong class="green-money">S/ @IngresosBrutos</strong>
                    <p>Dinero real cobrado</p>
                </div>

                <div class="revenue-kpi-icon green">
                    <i class="bi bi-arrow-up-right"></i>
                </div>
            </div>

            <div class="revenue-kpi-card">
                <div>
                    <span>Egresos totales</span>
                    <strong class="red-money">-S/ @EgresosTotales</strong>
                    <p>Sueldos y salidas pagadas</p>
                </div>

                <div class="revenue-kpi-icon red">
                    <i class="bi bi-arrow-down-left"></i>
                </div>
            </div>

            <div class="revenue-kpi-card">
                <div>
                    <span>Balance neto</span>
                    <strong class="@ClaseBalance">@BalanceNetoTexto</strong>
                    <p>Ingresos menos egresos</p>
                </div>

                <div class="revenue-kpi-icon neutral">
                    <i class="bi bi-calculator"></i>
                </div>
            </div>

            <div class="revenue-kpi-card">
                <div>
                    <span>Por cobrar socios</span>
                    <strong class="yellow-money">S/ @PorCobrarSocios</strong>
                    <p>@PagosPendientesSociosTotal pagos pendientes</p>
                </div>

                <div class="revenue-kpi-icon yellow">
                    <i class="bi bi-hourglass-split"></i>
                </div>
            </div>

            <div class="revenue-kpi-card">
                <div>
                    <span>Por pagar staff</span>
                    <strong class="orange-money">-S/ @PorPagarStaff</strong>
                    <p>@PagosPendientesStaffTotal pagos pendientes</p>
                </div>

                <div class="revenue-kpi-icon orange">
                    <i class="bi bi-clock-history"></i>
                </div>
            </div>

            <div class="revenue-kpi-card">
                <div>
                    <span>Total movimientos</span>
                    <strong>S/ @TotalMovimientosTexto</strong>
                    <p>@TotalTransacciones movimientos registrados</p>
                </div>

                <div class="revenue-kpi-icon neutral">
                    <i class="bi bi-list-check"></i>
                </div>
            </div>
        </div>

        <div class="revenue-chart-card">
            <div class="chart-title-row">
                <h2>Ingresos vs Egresos Mensuales (S/)</h2>

                <div class="chart-legend-inline">
                    <span><i class="dot green"></i>Ingresos</span>
                    <span><i class="dot red"></i>Egresos</span>
                </div>
            </div>

            <div class="fake-line-chart">
                <div class="chart-y-label y1200">@GraficoLabel100</div>
                <div class="chart-y-label y900">@GraficoLabel75</div>
                <div class="chart-y-label y600">@GraficoLabel50</div>
                <div class="chart-y-label y300">@GraficoLabel25</div>
                <div class="chart-y-label y0">0</div>

                <div class="chart-grid-line line1200"></div>
                <div class="chart-grid-line line900"></div>
                <div class="chart-grid-line line600"></div>
                <div class="chart-grid-line line300"></div>
                <div class="chart-grid-line line0"></div>

                <svg class="chart-svg" viewBox="0 0 1000 260" preserveAspectRatio="none">
                    <defs>
                        <linearGradient id="greenArea" x1="0" x2="0" y1="0" y2="1">
                            <stop offset="0%" stop-color="#22C55E" stop-opacity="0.30" />
                            <stop offset="100%" stop-color="#22C55E" stop-opacity="0.02" />
                        </linearGradient>
                    </defs>

                    <polygon points="@ChartIngresosAreaPoints" fill="url(#greenArea)" />

                    <polyline points="@ChartIngresosLinePoints"
                              fill="none"
                              stroke="#22C55E"
                              stroke-width="5"
                              stroke-linecap="round"
                              stroke-linejoin="round" />

                    <polyline points="@ChartEgresosLinePoints"
                              fill="none"
                              stroke="#EF3131"
                              stroke-width="5"
                              stroke-linecap="round"
                              stroke-linejoin="round" />

                    @foreach (var punto in PuntosGrafico)
                    {
                        <circle cx="@punto.X"
                                cy="@punto.YIngresos"
                                r="7"
                                fill="#F5F5F5"
                                stroke="#22C55E"
                                stroke-width="4" />

                        <circle cx="@punto.X"
                                cy="@punto.YEgresos"
                                r="7"
                                fill="#F5F5F5"
                                stroke="#EF3131"
                                stroke-width="4" />

                        @if (punto.Ingresos > 0)
                        {
                            @((MarkupString)$"<text x='{punto.X}' y='{punto.LabelYIngresos}' text-anchor='middle' class='chart-income-label'>{punto.ValorIngresos}</text>")
                        }

                        @if (punto.Egresos > 0)
                        {
                            @((MarkupString)$"<text x='{punto.X}' y='{punto.LabelYEgresos}' text-anchor='middle' class='chart-expense-label'>-{punto.ValorEgresos}</text>")
                        }
                    }
                </svg>

                <div class="chart-months">
                    @foreach (var punto in PuntosGrafico)
                    {
                        <span>@punto.Mes</span>
                    }
                </div>
            </div>
        </div>

        <div class="revenue-bottom-grid">
            <div class="revenue-panel">
                <h2>Métodos de Pago Utilizados</h2>

                <div class="row g-4">
                    <div class="donut-card payment-donut" style="@MetodoPagoDonutStyle">
                        <div class="donut-center">
                            <strong>@TotalTransacciones</strong>
                            <span>Movimientos</span>
                        </div>
                    </div>

                    <div class="donut-list">
                        <div class="donut-row">
                            <span><i class="dot red"></i>Efectivo</span>
                            <strong>@PagosEfectivo (@Porcentaje(PagosEfectivo, TotalTransaccionesEntero))</strong>
                        </div>

                        <div class="donut-row">
                            <span><i class="dot blue"></i>Tarjeta</span>
                            <strong>@PagosTarjeta (@Porcentaje(PagosTarjeta, TotalTransaccionesEntero))</strong>
                        </div>

                        <div class="donut-row">
                            <span><i class="dot green"></i>Yape</span>
                            <strong>@PagosYape (@Porcentaje(PagosYape, TotalTransaccionesEntero))</strong>
                        </div>

                        <div class="donut-row">
                            <span><i class="dot orange"></i>Plin</span>
                            <strong>@PagosPlin (@Porcentaje(PagosPlin, TotalTransaccionesEntero))</strong>
                        </div>

                        <p class="donut-total">Total: @TotalTransacciones movimientos</p>
                    </div>
                </div>
            </div>

            <div class="revenue-panel">
                <h2>Estado Financiero</h2>

                <div class="row g-4">
                    <div class="donut-card status-donut" style="@EstadoPagoDonutStyle">
                        <div class="donut-center">
                            <strong>@TotalPagosEstado</strong>
                            <span>Total</span>
                        </div>
                    </div>

                    <div class="donut-list">
                        <div class="donut-row">
                            <span><i class="dot green"></i>Ingresos pagados</span>
                            <strong>@IngresosPagadosCount (@Porcentaje(IngresosPagadosCount, TotalPagosEstado))</strong>
                        </div>

                        <div class="donut-row">
                            <span><i class="dot red"></i>Egresos pagados</span>
                            <strong>@EgresosPagadosCount (@Porcentaje(EgresosPagadosCount, TotalPagosEstado))</strong>
                        </div>

                        <div class="donut-row">
                            <span><i class="dot orange"></i>Pendientes</span>
                            <strong>@PagosPendientes (@Porcentaje(PagosPendientes, TotalPagosEstado))</strong>
                        </div>

                        <div class="pending-box">
                            <span>Por cobrar socios</span>
                            <strong>S/ @PorCobrarSocios ›</strong>
                        </div>

                        <div class="pending-box pending-box-staff">
                            <span>Por pagar staff</span>
                            <strong>-S/ @PorPagarStaff ›</strong>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }

</section>

<style>
    .revenue-kpi-grid-six {
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 18px;
    }

    .red-money {
        color: #ff4d4d !important;
    }

    .orange-money {
        color: #ff9f43 !important;
    }

    .revenue-kpi-icon.red {
        background: rgba(239, 49, 49, 0.13);
        color: #ff4d4d;
    }

    .revenue-kpi-icon.orange {
        background: rgba(255, 159, 67, 0.13);
        color: #ff9f43;
    }

    .chart-title-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 18px;
        margin-bottom: 10px;
    }

        .chart-title-row h2 {
            margin: 0;
        }

    .chart-legend-inline {
        display: flex;
        align-items: center;
        gap: 18px;
        color: #cfcfcf;
        font-weight: 800;
        font-size: 13px;
    }

        .chart-legend-inline span {
            display: inline-flex;
            align-items: center;
            gap: 7px;
        }

    .chart-income-label {
        fill: #22C55E;
        font-size: 14px;
        font-weight: 900;
    }

    .chart-expense-label {
        fill: #EF3131;
        font-size: 14px;
        font-weight: 900;
    }

    .pending-box-staff {
        margin-top: 10px;
        border-color: rgba(239, 49, 49, 0.18) !important;
    }

        .pending-box-staff strong {
            color: #ff4d4d !important;
        }

    @@media (max-width: 1180px) {
        .revenue-kpi-grid-six {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }
    }

    @@media (max-width: 760px) {
        .revenue-kpi-grid-six {
            grid-template-columns: 1fr;
        }

        .chart-title-row {
            flex-direction: column;
            align-items: flex-start;
        }
    }
</style>

@code {
    private string ReporteActual { get; set; } = "Socios";
    private string PeriodoActual { get; set; } = "Mes";

    private string ClaseTabSocios =>
        ReporteActual == "Socios" ? "report-tab active" : "report-tab";

    private string ClaseTabRecaudacion =>
        ReporteActual == "Recaudacion" ? "report-tab active" : "report-tab";

    private string ClasePeriodoMes =>
        PeriodoActual == "Mes" ? "revenue-period-button active" : "revenue-period-button";

    private string ClasePeriodoTrimestre =>
        PeriodoActual == "Trimestre" ? "revenue-period-button active" : "revenue-period-button";

    private string ClasePeriodoAnio =>
        PeriodoActual == "Anio" ? "revenue-period-button active" : "revenue-period-button";

    private void MostrarReporteSocios()
    {
        ReporteActual = "Socios";
    }

    private void MostrarReporteRecaudacion()
    {
        ReporteActual = "Recaudacion";
    }

    private void MostrarUltimoMes()
    {
        PeriodoActual = "Mes";
    }

    private void MostrarUltimoTrimestre()
    {
        PeriodoActual = "Trimestre";
    }

    private void MostrarUltimoAnio()
    {
        PeriodoActual = "Anio";
    }

    private bool DescargandoReporte = false;

    private async Task DescargarReportePagos()
    {
        try
        {
            DescargandoReporte = true;

            var bytes = await ReporteService.DescargarReportePagosAdministradorAsync();
            var base64 = Convert.ToBase64String(bytes);

            await JS.InvokeVoidAsync(
                "downloadFileFromBytes",
                "reporte_pagos_administrador.pdf",
                "application/pdf",
                base64
            );
        }
        finally
        {
            DescargandoReporte = false;
        }
    }

    protected override async Task OnInitializedAsync()
    {
        var sociosTask = SocioService.ListarSociosAsync();
        var suscripcionesTask = SuscripcionService.ListarSuscripcionesAsync();
        var pagosTask = PagoService.ListarPagosAsync();

        await Task.WhenAll(sociosTask, suscripcionesTask, pagosTask);

        TodosLosSocios = sociosTask.Result;
        TodasLasSuscripciones = suscripcionesTask.Result;
        TodosLosPagos = pagosTask.Result;

        TotalSocios = TodosLosSocios.Count;
        SociosActivos = TodosLosSocios.Count(s => s.Activo);
        SociosInactivos = TotalSocios - SociosActivos;

        var pagosPendientesSocios = TodosLosPagos
            .Where(p => !p.Activo && !EsPagoEgreso(p))
            .ToList();

        PagosPendientesSociosTotal = pagosPendientesSocios.Count;
        DeudaPendienteSocios = pagosPendientesSocios
            .Sum(p => (decimal)p.Monto)
            .ToString("0.00", CultureInfo.InvariantCulture);

        SociosBasic = TodasLasSuscripciones.Count(s => s.Activo && s.IdMembresiaBasic != null);
        SociosBlack = TodasLasSuscripciones.Count(s => s.Activo && s.IdMembresiaBlack != null);

        Socios.Clear();
        foreach (var s in TodosLosSocios)
        {
            var suscripcion = TodasLasSuscripciones.FirstOrDefault(sus => sus.IdUsuario == s.IdUsuario && sus.Activo);

            string membresia = "Sin plan";

            if (suscripcion != null)
            {
                if (suscripcion.IdMembresiaBlack != null)
                {
                    membresia = "Membresía Black";
                }
                else if (suscripcion.IdMembresiaBasic != null)
                {
                    membresia = "Membresía Basic";
                }
            }

            Socios.Add(new SocioReporte
            {
                Nombre = $"{s.Nombres} {s.ApellidoPaterno}",
                Membresia = membresia,
                Activo = s.Activo
            });
        }
    }

    private List<SocioDTO> TodosLosSocios = new();
    private List<SuscripcionDTO> TodasLasSuscripciones = new();
    private List<PagoDTO> TodosLosPagos = new();

    private int SociosActivos = 0;
    private int SociosInactivos = 0;
    private int TotalSocios = 0;
    private int PagosPendientesSociosTotal = 0;
    private string DeudaPendienteSocios = "0.00";
    private int SociosBasic = 0;
    private int SociosBlack = 0;

    private decimal IngresosBrutosNumero =>
        TodosLosPagos
            .Where(p => p.Activo && !EsPagoEgreso(p))
            .Sum(p => (decimal)p.Monto);

    private decimal EgresosTotalesNumero =>
        TodosLosPagos
            .Where(p => p.Activo && EsPagoEgreso(p))
            .Sum(p => (decimal)p.Monto);

    private decimal BalanceNetoNumero =>
        IngresosBrutosNumero - EgresosTotalesNumero;

    private decimal PorCobrarSociosNumero =>
        TodosLosPagos
            .Where(p => !p.Activo && !EsPagoEgreso(p))
            .Sum(p => (decimal)p.Monto);

    private decimal PorPagarStaffNumero =>
        TodosLosPagos
            .Where(p => !p.Activo && EsPagoEgreso(p))
            .Sum(p => (decimal)p.Monto);

    private decimal TotalMovimientosNumero =>
        IngresosBrutosNumero + EgresosTotalesNumero;

    private int TotalTransaccionesEntero =>
        TodosLosPagos.Count;

    private int PagosPendientes =>
        TodosLosPagos.Count(p => !p.Activo);

    private int IngresosPagadosCount =>
        TodosLosPagos.Count(p => p.Activo && !EsPagoEgreso(p));

    private int EgresosPagadosCount =>
        TodosLosPagos.Count(p => p.Activo && EsPagoEgreso(p));

    private int PagosPagados =>
        IngresosPagadosCount + EgresosPagadosCount;

    private int TotalPagosEstado =>
        PagosPagados + PagosPendientes;

    private int PagosPendientesStaffTotal =>
        TodosLosPagos.Count(p => !p.Activo && EsPagoEgreso(p));

    private string IngresosBrutos =>
        IngresosBrutosNumero.ToString("0.00", CultureInfo.InvariantCulture);

    private string EgresosTotales =>
        EgresosTotalesNumero.ToString("0.00", CultureInfo.InvariantCulture);

    private string PorCobrarSocios =>
        PorCobrarSociosNumero.ToString("0.00", CultureInfo.InvariantCulture);

    private string PorPagarStaff =>
        PorPagarStaffNumero.ToString("0.00", CultureInfo.InvariantCulture);

    private string TotalMovimientosTexto =>
        TotalMovimientosNumero.ToString("0.00", CultureInfo.InvariantCulture);

    private string BalanceNetoTexto =>
        BalanceNetoNumero < 0
            ? $"-S/ {Math.Abs(BalanceNetoNumero).ToString("0.00", CultureInfo.InvariantCulture)}"
            : $"S/ {BalanceNetoNumero.ToString("0.00", CultureInfo.InvariantCulture)}";

    private string ClaseBalance =>
        BalanceNetoNumero < 0
            ? "red-money"
            : "green-money";

    private string TotalTransacciones =>
        TotalTransaccionesEntero.ToString();

    private int PagosEfectivo =>
        TodosLosPagos.Count(p => p.MetodoPago == 1);

    private int PagosTarjeta =>
        TodosLosPagos.Count(p => p.MetodoPago == 2);

    private int PagosYape =>
        TodosLosPagos.Count(p => p.MetodoPago == 3);

    private int PagosPlin =>
        TodosLosPagos.Count(p => p.MetodoPago == 4);

    private string MetodoPagoDonutStyle
    {
        get
        {
            int efectivo = CalcularGrados(PagosEfectivo, TotalTransaccionesEntero);
            int tarjeta = CalcularGrados(PagosTarjeta, TotalTransaccionesEntero);
            int yape = CalcularGrados(PagosYape, TotalTransaccionesEntero);

            int finTarjeta = efectivo + tarjeta;
            int finYape = finTarjeta + yape;

            return $"background: conic-gradient(#E53935 0deg {efectivo}deg, #1976D2 {efectivo}deg {finTarjeta}deg, #4CAF50 {finTarjeta}deg {finYape}deg, #FF9800 {finYape}deg 360deg);";
        }
    }

    private string EstadoPagoDonutStyle
    {
        get
        {
            int ingresos = CalcularGrados(IngresosPagadosCount, TotalPagosEstado);
            int egresos = CalcularGrados(EgresosPagadosCount, TotalPagosEstado);

            int finEgresos = ingresos + egresos;

            return $"background: conic-gradient(#4CAF50 0deg {ingresos}deg, #EF3131 {ingresos}deg {finEgresos}deg, #FF9800 {finEgresos}deg 360deg);";
        }
    }

    private int CalcularGrados(int cantidad, int total)
    {
        if (total == 0)
        {
            return 0;
        }

        return Convert.ToInt32(Math.Round(360.0 * cantidad / total));
    }

    private string PorcentajeAncho(int cantidad, int total)
    {
        if (total == 0)
        {
            return "0%";
        }

        return (100.0 * cantidad / total).ToString("0.0", CultureInfo.InvariantCulture) + "%";
    }

    private string Porcentaje(int cantidad, int total)
    {
        if (total == 0)
        {
            return "0.0%";
        }

        double porcentaje = 100.0 * cantidad / total;
        return porcentaje.ToString("0.0", CultureInfo.InvariantCulture) + "%";
    }

    private static bool EsPagoEgreso(PagoDTO pago)
    {
        if (string.IsNullOrWhiteSpace(pago.Tipo))
        {
            return false;
        }

        string tipo = pago.Tipo.Trim().ToLower();

        return tipo.Contains("sueldo") ||
               tipo.Contains("bono") ||
               tipo.Contains("entrenador");
    }

    private int MesesPeriodo =>
        PeriodoActual == "Anio"
            ? 12
            : PeriodoActual == "Trimestre"
                ? 3
                : 5;

    private DateTime FechaBaseGrafico
    {
        get
        {
            var fechas = TodosLosPagos
                .Where(p => p.FechaPago != null)
                .Select(p => p.FechaPago!.Value)
                .ToList();

            if (fechas.Count == 0)
            {
                return DateTime.Today;
            }

            return fechas.Max();
        }
    }

    private decimal MaxGrafico
    {
        get
        {
            var puntos = ConstruirPuntosGrafico(false);

            decimal max = puntos
                .SelectMany(p => new[] { p.Ingresos, p.Egresos })
                .DefaultIfEmpty(0)
                .Max();

            if (max <= 0)
            {
                return 100;
            }

            decimal redondeado = Math.Ceiling(max / 100m) * 100m;

            return redondeado < 100 ? 100 : redondeado;
        }
    }

    private string GraficoLabel100 => MaxGrafico.ToString("0", CultureInfo.InvariantCulture);
    private string GraficoLabel75 => (MaxGrafico * 0.75m).ToString("0", CultureInfo.InvariantCulture);
    private string GraficoLabel50 => (MaxGrafico * 0.50m).ToString("0", CultureInfo.InvariantCulture);
    private string GraficoLabel25 => (MaxGrafico * 0.25m).ToString("0", CultureInfo.InvariantCulture);

    private List<PuntoGrafico> PuntosGrafico =>
        ConstruirPuntosGrafico(true);

    private List<PuntoGrafico> ConstruirPuntosGrafico(bool calcularCoordenadas)
    {
        int meses = MesesPeriodo;

        DateTime fechaInicio = new DateTime(
            FechaBaseGrafico.Year,
            FechaBaseGrafico.Month,
            1
        ).AddMonths(-(meses - 1));

        decimal max = calcularCoordenadas ? MaxGrafico : 1;

        var lista = new List<PuntoGrafico>();

        for (int i = 0; i < meses; i++)
        {
            DateTime mes = fechaInicio.AddMonths(i);

            decimal ingresos = TodosLosPagos
                .Where(p => p.Activo &&
                            !EsPagoEgreso(p) &&
                            p.FechaPago != null &&
                            p.FechaPago.Value.Year == mes.Year &&
                            p.FechaPago.Value.Month == mes.Month)
                .Sum(p => (decimal)p.Monto);

            decimal egresos = TodosLosPagos
                .Where(p => p.Activo &&
                            EsPagoEgreso(p) &&
                            p.FechaPago != null &&
                            p.FechaPago.Value.Year == mes.Year &&
                            p.FechaPago.Value.Month == mes.Month)
                .Sum(p => (decimal)p.Monto);

            double x = meses == 1
                ? 500
                : 80 + (840.0 * i / (meses - 1));

            double yIngresos = calcularCoordenadas ? CalcularY(ingresos, max) : 0;
            double yEgresos = calcularCoordenadas ? CalcularY(egresos, max) : 0;

            lista.Add(new PuntoGrafico
            {
                Mes = mes.ToString("MMM", new CultureInfo("es-ES")),
                Ingresos = ingresos,
                Egresos = egresos,
                ValorIngresos = ingresos.ToString("0", CultureInfo.InvariantCulture),
                ValorEgresos = egresos.ToString("0", CultureInfo.InvariantCulture),
                X = x.ToString("0", CultureInfo.InvariantCulture),
                YIngresos = yIngresos.ToString("0", CultureInfo.InvariantCulture),
                YEgresos = yEgresos.ToString("0", CultureInfo.InvariantCulture),
                LabelYIngresos = Math.Max(18, yIngresos - 14).ToString("0", CultureInfo.InvariantCulture),
                LabelYEgresos = Math.Min(250, yEgresos + 20).ToString("0", CultureInfo.InvariantCulture)
            });
        }

        return lista;
    }

    private static double CalcularY(decimal valor, decimal max)
    {
        if (max <= 0)
        {
            return 230;
        }

        double proporcion = (double)(valor / max);
        double y = 230 - (proporcion * 180);

        if (y < 35)
        {
            y = 35;
        }

        if (y > 230)
        {
            y = 230;
        }

        return y;
    }

    private string ChartIngresosLinePoints =>
        string.Join(" ", PuntosGrafico.Select(p => $"{p.X},{p.YIngresos}"));

    private string ChartEgresosLinePoints =>
        string.Join(" ", PuntosGrafico.Select(p => $"{p.X},{p.YEgresos}"));

    private string ChartIngresosAreaPoints
    {
        get
        {
            if (!PuntosGrafico.Any())
            {
                return "";
            }

            var primero = PuntosGrafico.First();
            var ultimo = PuntosGrafico.Last();

            return $"{ChartIngresosLinePoints} {ultimo.X},250 {primero.X},250";
        }
    }

