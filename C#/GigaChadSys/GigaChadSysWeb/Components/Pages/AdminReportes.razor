@page "/admin/reportes"
@layout AdminLayout
@rendermode InteractiveServer

@using System.Globalization
@using GigaChadSys.Servicios
@using GigaChadSys.Servicios.DTO

@inject SocioServicio SocioService
@inject EntrenadorServicio EntrenadorService
@inject PagoServicio PagoService
@inject NavigationManager Navigation

<section class="reportes-hub-page">

    <div class="reportes-hub-header">
        <div>
            <span class="reportes-hub-kicker">Panel de análisis</span>
            <h1>Reportes</h1>
            <p>Visualiza métricas y estadísticas del gimnasio.</p>
        </div>
    </div>

    @if (Cargando)
    {
        <div class="reportes-loading-card">
            <i class="bi bi-hourglass-split"></i>
            <span>Cargando resumen de reportes...</span>
        </div>
    }
    else if (!string.IsNullOrWhiteSpace(MensajeError))
    {
        <div class="reportes-error-card">
            <i class="bi bi-exclamation-triangle"></i>
            <span>@MensajeError</span>
        </div>
    }
    else
    {
        <div class="reportes-summary-grid">

            <div class="reportes-summary-card">
                <div class="reportes-summary-icon green">
                    <i class="bi bi-person-check"></i>
                </div>

                <div class="reportes-summary-info">
                    <span>Socios activos</span>
                    <strong>@SociosActivos</strong>
                    <p>Clientes actualmente habilitados</p>
                </div>
            </div>

            <div class="reportes-summary-card">
                <div class="reportes-summary-icon blue">
                    <i class="bi bi-person-badge"></i>
                </div>

                <div class="reportes-summary-info">
                    <span>Entrenadores activos</span>
                    <strong>@EntrenadoresActivos</strong>
                    <p>Personal disponible del gimnasio</p>
                </div>
            </div>

            <div class="reportes-summary-card">
                <div class="reportes-summary-icon purple">
                    <i class="bi bi-people"></i>
                </div>

                <div class="reportes-summary-info">
                    <span>Comunidad activa</span>
                    <strong>@ComunidadActiva</strong>
                    <p>Socios y entrenadores habilitados</p>
                </div>
            </div>

            <div class="reportes-summary-card">
                <div class="reportes-summary-icon green">
                    <i class="bi bi-graph-up-arrow"></i>
                </div>

                <div class="reportes-summary-info">
                    <span>Ingresos totales</span>
                    <strong>S/ @FormatoMoneda(IngresosTotales)</strong>
                    <p>Pagos cobrados de socios</p>
                </div>
            </div>

            <div class="reportes-summary-card">
                <div class="reportes-summary-icon red">
                    <i class="bi bi-graph-down-arrow"></i>
                </div>

                <div class="reportes-summary-info">
                    <span>Egresos totales</span>
                    <strong>-S/ @FormatoMoneda(EgresosTotales)</strong>
                    <p>Pagos realizados al staff</p>
                </div>
            </div>

            <div class="reportes-summary-card">
                <div class="reportes-summary-icon @(BalanceNeto < 0 ? "red" : "green")">
                    <i class="bi bi-calculator"></i>
                </div>

                <div class="reportes-summary-info">
                    <span>Balance neto</span>
                    <strong class="@(BalanceNeto < 0 ? "text-red" : "text-green")">
                        @BalanceNetoTexto
                    </strong>
                    <p>Ingresos menos egresos</p>
                </div>
            </div>

        </div>

        <div class="reportes-access-section">
            <div class="reportes-section-title">
                <span>Acceder a reportes</span>
                <h2>Selecciona el reporte que deseas revisar</h2>
            </div>

            <div class="reportes-access-grid">

                <button type="button"
                        class="reportes-access-card"
                        @onclick="IrAReporteSocios">
                    <div class="reportes-access-icon">
                        <i class="bi bi-people"></i>
                    </div>

                    <div class="reportes-access-content">
                        <h3>Reporte de Socios</h3>
                        <p>Membresías, estado y distribución de socios.</p>
                    </div>

                    <div class="reportes-access-arrow">
                        <i class="bi bi-arrow-right"></i>
                    </div>
                </button>

                <button type="button"
                        class="reportes-access-card"
                        @onclick="IrAReporteEntrenadores">
                    <div class="reportes-access-icon">
                        <i class="bi bi-person-workspace"></i>
                    </div>

                    <div class="reportes-access-content">
                        <h3>Reporte de Entrenadores</h3>
                        <p>Staff activo, sueldos y carga de clases.</p>
                    </div>

                    <div class="reportes-access-arrow">
                        <i class="bi bi-arrow-right"></i>
                    </div>
                </button>

                <button type="button"
                        class="reportes-access-card"
                        @onclick="IrAReporteRecaudacion">
                    <div class="reportes-access-icon">
                        <i class="bi bi-cash-stack"></i>
                    </div>

                    <div class="reportes-access-content">
                        <h3>Reporte de Recaudación</h3>
                        <p>Ingresos, egresos y balance financiero.</p>
                    </div>

                    <div class="reportes-access-arrow">
                        <i class="bi bi-arrow-right"></i>
                    </div>
                </button>

            </div>
        </div>
    }

</section>

<style>
    .reportes-hub-page {
        width: 100%;
        min-height: 100%;
        padding: 28px 36px 48px;
        color: #f5f5f5;
        background: #0b0b0b;
    }

    .reportes-hub-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 24px;
        margin-bottom: 26px;
        padding-bottom: 22px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    }

    .reportes-hub-kicker {
        display: inline-block;
        margin-bottom: 8px;
        color: #E53935;
        font-size: 13px;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: 0.08em;
    }

    .reportes-hub-header h1 {
        margin: 0;
        color: #ffffff;
        font-size: 42px;
        font-weight: 900;
        line-height: 1.05;
    }

    .reportes-hub-header p {
        margin: 10px 0 0;
        color: #b9b9b9;
        font-size: 16px;
        font-weight: 500;
    }

    .reportes-loading-card,
    .reportes-error-card {
        display: flex;
        align-items: center;
        gap: 12px;
        width: 100%;
        padding: 18px 20px;
        border-radius: 14px;
        background: #171717;
        border: 1px solid rgba(255, 255, 255, 0.08);
        color: #f5f5f5;
        font-weight: 700;
    }

        .reportes-loading-card i {
            color: #E53935;
            font-size: 20px;
        }

    .reportes-error-card {
        border-color: rgba(229, 57, 53, 0.35);
        color: #ffb4b4;
    }

        .reportes-error-card i {
            color: #E53935;
            font-size: 20px;
        }

    .reportes-summary-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 18px;
        margin-bottom: 36px;
    }

    .reportes-summary-card {
        display: flex;
        align-items: center;
        gap: 16px;
        min-height: 128px;
        padding: 20px;
        border-radius: 16px;
        background: #151515;
        border: 1px solid rgba(255, 255, 255, 0.08);
        transition: background 0.18s ease, border-color 0.18s ease;
    }

        .reportes-summary-card:hover {
            background: #1a1a1a;
            border-color: rgba(229, 57, 53, 0.35);
        }

    .reportes-summary-icon {
        width: 52px;
        height: 52px;
        min-width: 52px;
        display: grid;
        place-items: center;
        border-radius: 14px;
        font-size: 23px;
    }

        .reportes-summary-icon.green {
            background: rgba(34, 197, 94, 0.12);
            color: #22C55E;
        }

        .reportes-summary-icon.red {
            background: rgba(239, 49, 49, 0.13);
            color: #EF3131;
        }

        .reportes-summary-icon.blue {
            background: rgba(59, 130, 246, 0.12);
            color: #60A5FA;
        }

        .reportes-summary-icon.purple {
            background: rgba(168, 85, 247, 0.13);
            color: #A855F7;
        }

    .reportes-summary-info {
        min-width: 0;
    }

        .reportes-summary-info span {
            display: block;
            margin-bottom: 5px;
            color: #a5a5a5;
            font-size: 13px;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }

        .reportes-summary-info strong {
            display: block;
            color: #ffffff;
            font-size: 28px;
            font-weight: 950;
            line-height: 1.1;
        }

        .reportes-summary-info p {
            margin: 8px 0 0;
            color: #bdbdbd;
            font-size: 13px;
            font-weight: 500;
        }

    .text-green {
        color: #22C55E !important;
    }

    .text-red {
        color: #EF3131 !important;
    }

    .reportes-access-section {
        margin-top: 12px;
    }

    .reportes-section-title {
        margin-bottom: 18px;
    }

        .reportes-section-title span {
            display: inline-block;
            margin-bottom: 6px;
            color: #E53935;
            font-size: 12px;
            font-weight: 900;
            text-transform: uppercase;
            letter-spacing: 0.08em;
        }

        .reportes-section-title h2 {
            margin: 0;
            color: #ffffff;
            font-size: 24px;
            font-weight: 900;
        }

    .reportes-access-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 18px;
    }

    .reportes-access-card {
        position: relative;
        display: flex;
        align-items: center;
        gap: 18px;
        width: 100%;
        min-height: 170px;
        padding: 24px;
        text-align: left;
        color: #ffffff;
        background: #151515;
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-left: 3px solid transparent;
        border-radius: 16px;
        cursor: pointer;
        transition: background 0.18s ease, border-color 0.18s ease, transform 0.18s ease;
    }

        .reportes-access-card:hover {
            background: #1b1b1b;
            border-left-color: #E53935;
            border-top-color: rgba(229, 57, 53, 0.26);
            border-right-color: rgba(229, 57, 53, 0.26);
            border-bottom-color: rgba(229, 57, 53, 0.26);
            transform: translateY(-2px);
        }

    .reportes-access-icon {
        width: 62px;
        height: 62px;
        min-width: 62px;
        display: grid;
        place-items: center;
        border-radius: 16px;
        background: rgba(229, 57, 53, 0.11);
        color: #E53935;
        font-size: 30px;
    }

    .reportes-access-content {
        flex: 1;
        min-width: 0;
    }

        .reportes-access-content h3 {
            margin: 0 0 8px;
            color: #ffffff;
            font-size: 22px;
            font-weight: 900;
        }

        .reportes-access-content p {
            margin: 0;
            color: #bdbdbd;
            font-size: 14px;
            font-weight: 500;
            line-height: 1.45;
        }

    .reportes-access-arrow {
        color: #8f8f8f;
        font-size: 21px;
        transition: color 0.18s ease, transform 0.18s ease;
    }

    .reportes-access-card:hover .reportes-access-arrow {
        color: #E53935;
        transform: translateX(4px);
    }

    @@media (max-width: 1180px) {
        .reportes-summary-grid,
        .reportes-access-grid {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }
    }

    @@media (max-width: 760px) {
        .reportes-hub-page {
            padding: 22px 18px 38px;
        }

        .reportes-hub-header h1 {
            font-size: 34px;
        }

        .reportes-summary-grid,
        .reportes-access-grid {
            grid-template-columns: 1fr;
        }

        .reportes-access-card {
            min-height: 150px;
        }
    }
</style>

@code {
    private bool Cargando = true;
    private string MensajeError = "";

    private List<SocioDTO> TodosLosSocios = new();
    private List<EntrenadorDTO> TodosLosEntrenadores = new();
    private List<PagoDTO> TodosLosPagos = new();

    private int SociosActivos = 0;
    private int EntrenadoresActivos = 0;
    private int ComunidadActiva = 0;

    private decimal IngresosTotales = 0;
    private decimal EgresosTotales = 0;
    private decimal BalanceNeto = 0;

    private string BalanceNetoTexto =>
        BalanceNeto < 0
            ? $"-S/ {FormatoMoneda(Math.Abs(BalanceNeto))}"
            : $"S/ {FormatoMoneda(BalanceNeto)}";

    protected override async Task OnInitializedAsync()
    {
        try
        {
            Cargando = true;
            MensajeError = "";

            var sociosTask = SocioService.ListarSociosAsync();
            var entrenadoresTask = EntrenadorService.ListarEntrenadoresAsync();
            var pagosTask = PagoService.ListarPagosAsync();

            await Task.WhenAll(sociosTask, entrenadoresTask, pagosTask);

            TodosLosSocios = sociosTask.Result ?? new List<SocioDTO>();
            TodosLosEntrenadores = entrenadoresTask.Result ?? new List<EntrenadorDTO>();
            TodosLosPagos = pagosTask.Result ?? new List<PagoDTO>();

            CalcularResumen();
        }
        catch (Exception ex)
        {
            MensajeError = $"No se pudo cargar el resumen de reportes: {ex.Message}";
        }
        finally
        {
            Cargando = false;
        }
    }

    private void CalcularResumen()
    {
        SociosActivos = TodosLosSocios.Count(s => s.Activo);
        EntrenadoresActivos = TodosLosEntrenadores.Count(e => e.Activo);
        ComunidadActiva = SociosActivos + EntrenadoresActivos;

        IngresosTotales = TodosLosPagos
            .Where(p => p.Activo && !EsPagoEgreso(p))
            .Sum(p => (decimal)p.Monto);

        EgresosTotales = TodosLosPagos
            .Where(p => p.Activo && EsPagoEgreso(p))
            .Sum(p => (decimal)p.Monto);

        BalanceNeto = IngresosTotales - EgresosTotales;
    }

    private void IrAReporteSocios()
    {
        Navigation.NavigateTo("/admin/reportes/socios");
    }

    private void IrAReporteEntrenadores()
    {
        Navigation.NavigateTo("/admin/reportes/entrenadores");
    }

    private void IrAReporteRecaudacion()
    {
        Navigation.NavigateTo("/admin/reportes/recaudacion");
    }

    private static bool EsPagoEgreso(PagoDTO pago)
    {
        if (string.IsNullOrWhiteSpace(pago.Tipo))
        {
            return false;
        }

        string tipo = pago.Tipo.Trim().ToLower();

        return tipo.Contains("sueldo") ||
               tipo.Contains("bono") ||
               tipo.Contains("entrenador");
    }

    private static string FormatoMoneda(decimal valor)
    {
        return valor.ToString("0.00", CultureInfo.InvariantCulture);
    }
}