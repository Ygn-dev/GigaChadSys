@page "/admin/reportes"
@layout AdminLayout
@rendermode InteractiveServer
@using System.Globalization
@using System.Linq
@using Microsoft.AspNetCore.Components

<section class="reports-page">

    <div class="reports-header">
        <h1>Reportes</h1>
        <p>Visualiza métricas y estadísticas del gimnasio.</p>
    </div>

    <div class="reports-tabs">
        <button class="@ClaseTabSocios" @onclick="MostrarReporteSocios">
            Reporte de Socios
        </button>

        <button class="@ClaseTabRecaudacion" @onclick="MostrarReporteRecaudacion">
            Reporte de Recaudación
        </button>
    </div>

    @if (ReporteActual == "Socios")
    {
        <div class="reports-stats-grid">
            <div class="report-stat-card">
                <div class="report-stat-icon green">♙</div>
                <span>Socios activos</span>
                <strong>6</strong>
                <p>75% del total</p>
            </div>

            <div class="report-stat-card">
                <div class="report-stat-icon red">♙</div>
                <span>Socios inactivos</span>
                <strong>2</strong>
                <p>25% del total</p>
            </div>

            <div class="report-stat-card">
                <div class="report-stat-icon yellow">◷</div>
                <span>Pagos pendientes</span>
                <strong>1</strong>
                <p>S/ 79.00 en total</p>
            </div>

            <div class="report-stat-card">
                <div class="report-stat-icon blue">◎</div>
                <span>Total socios</span>
                <strong>8</strong>
                <p>Registrados en el sistema</p>
            </div>
        </div>

        <div class="reports-content-grid">
            <div class="report-panel">
                <h2>Distribución por Membresía</h2>

                <div class="membership-bar-row">
                    <div class="membership-bar-header">
                        <span>Membresía Basic</span>
                        <strong>4 socios</strong>
                    </div>
                    <div class="membership-bar-track">
                        <div class="membership-bar-fill basic"></div>
                    </div>
                </div>

                <div class="membership-bar-row">
                    <div class="membership-bar-header">
                        <span>Membresía Black</span>
                        <strong>4 socios</strong>
                    </div>
                    <div class="membership-bar-track">
                        <div class="membership-bar-fill black"></div>
                    </div>
                </div>

                <div class="report-legend">
                    <span><i class="legend-basic"></i> Basic</span>
                    <span><i class="legend-black"></i> Black</span>
                </div>
            </div>

            <div class="report-panel">
                <h2>Estado de Membresías</h2>

                <div class="report-member-list">
                    @foreach (var socio in Socios)
                    {
                        <div class="report-member-row">
                            <div class="member-avatar-small">◎</div>

                            <div class="member-info-report">
                                <strong>@socio.Nombre</strong>
                                <span>@socio.Membresia</span>
                            </div>

                            @if (socio.Activo)
                            {
                                <span class="report-status active">Activo</span>
                            }
                            else
                            {
                                <span class="report-status inactive">Inactivo</span>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="revenue-filter-row">
            <button class="@ClasePeriodoMes" @onclick="MostrarUltimoMes">Último Mes</button>
            <button class="@ClasePeriodoTrimestre" @onclick="MostrarUltimoTrimestre">Último Trimestre</button>
            <button class="@ClasePeriodoAnio" @onclick="MostrarUltimoAnio">Último Año</button>
        </div>

        <div class="revenue-kpi-grid">
            <div class="revenue-kpi-card">
                <div>
                    <span>Total recaudado</span>
                    <strong class="green-money">S/ @TotalRecaudado</strong>
                    <p>@TotalTransacciones transacciones</p>
                </div>

                <div class="revenue-kpi-icon green">↗</div>
            </div>

            <div class="revenue-kpi-card">
                <div>
                    <span>Total pendiente</span>
                    <strong class="yellow-money">S/ @TotalPendiente</strong>
                    <p>@PagosPendientes pagos pendientes</p>
                </div>

                <div class="revenue-kpi-icon yellow">▧</div>
            </div>

            <div class="revenue-kpi-card">
                <div>
                    <span>Promedio por pago</span>
                    <strong>S/ @PromedioPago</strong>
                    <p>Por transacción pagada</p>
                </div>

                <div class="revenue-kpi-icon neutral">◷</div>
            </div>
        </div>

        <div class="revenue-chart-card">
            <h2>Recaudación Mensual (S/)</h2>

            <div class="fake-line-chart">
                <div class="chart-y-label y1200">1,200</div>
                <div class="chart-y-label y900">900</div>
                <div class="chart-y-label y600">600</div>
                <div class="chart-y-label y300">300</div>
                <div class="chart-y-label y0">0</div>

                <div class="chart-grid-line line1200"></div>
                <div class="chart-grid-line line900"></div>
                <div class="chart-grid-line line600"></div>
                <div class="chart-grid-line line300"></div>
                <div class="chart-grid-line line0"></div>

                <svg class="chart-svg" viewBox="0 0 1000 260" preserveAspectRatio="none">
                    <defs>
                        <linearGradient id="redArea" x1="0" x2="0" y1="0" y2="1">
                            <stop offset="0%" stop-color="#E53935" stop-opacity="0.35" />
                            <stop offset="100%" stop-color="#E53935" stop-opacity="0.02" />
                        </linearGradient>
                    </defs>

                    <polygon points="@ChartAreaPoints" fill="url(#redArea)" />

                    <polyline points="@ChartLinePoints"
                              fill="none"
                              stroke="#E53935"
                              stroke-width="5"
                              stroke-linecap="round"
                              stroke-linejoin="round" />

                    @foreach (var punto in PuntosGrafico)
                    {
                        <circle cx="@punto.X"
                                cy="@punto.Y"
                                r="7"
                                fill="#F5F5F5"
                                stroke="#E53935"
                                stroke-width="4" />

                        @((MarkupString)$"<text x='{punto.X}' y='{punto.LabelY}' text-anchor='middle' class='chart-value-label'>{punto.Valor}</text>")
                    }
                </svg>

                <div class="chart-months">
                    @foreach (var punto in PuntosGrafico)
                    {
                        <span>@punto.Mes</span>
                    }
                </div>
            </div>
        </div>

        <div class="revenue-bottom-grid">
            <div class="revenue-panel">
                <h2>Métodos de Pago Utilizados</h2>

                <div class="donut-layout">
                    <div class="donut-card payment-donut" style="@MetodoPagoDonutStyle">
                        <div class="donut-center">
                            <strong>@TotalTransacciones</strong>
                            <span>Transacciones</span>
                        </div>
                    </div>

                    <div class="donut-list">
                        <div class="donut-row">
                            <span><i class="dot red"></i>Efectivo</span>
                            <strong>@PagosEfectivo (@Porcentaje(PagosEfectivo, TotalTransaccionesEntero))</strong>
                        </div>

                        <div class="donut-row">
                            <span><i class="dot blue"></i>Tarjeta Débito</span>
                            <strong>@PagosDebito (@Porcentaje(PagosDebito, TotalTransaccionesEntero))</strong>
                        </div>

                        <div class="donut-row">
                            <span><i class="dot green"></i>Tarjeta Crédito</span>
                            <strong>@PagosCredito (@Porcentaje(PagosCredito, TotalTransaccionesEntero))</strong>
                        </div>

                        <p class="donut-total">Total: @TotalTransacciones transacciones</p>
                    </div>
                </div>
            </div>

            <div class="revenue-panel">
                <h2>Estado de Pagos</h2>

                <div class="donut-layout">
                    <div class="donut-card status-donut" style="@EstadoPagoDonutStyle">
                        <div class="donut-center">
                            <strong>@TotalPagosEstado</strong>
                            <span>Total</span>
                        </div>
                    </div>

                    <div class="donut-list">
                        <div class="donut-row">
                            <span><i class="dot green"></i>Pagos Pagados</span>
                            <strong>@PagosPagados (@Porcentaje(PagosPagados, TotalPagosEstado))</strong>
                        </div>

                        <div class="donut-row">
                            <span><i class="dot orange"></i>Pagos Pendientes</span>
                            <strong>@PagosPendientes (@Porcentaje(PagosPendientes, TotalPagosEstado))</strong>
                        </div>

                        <div class="pending-box">
                            <span>Pendiente por cobrar</span>
                            <strong>S/ @TotalPendiente ›</strong>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }

</section>

@code {
    private string ReporteActual { get; set; } = "Socios";
    private string PeriodoActual { get; set; } = "Mes";

    private string ClaseTabSocios =>
        ReporteActual == "Socios" ? "report-tab active" : "report-tab";

    private string ClaseTabRecaudacion =>
        ReporteActual == "Recaudacion" ? "report-tab active" : "report-tab";

    private string ClasePeriodoMes =>
        PeriodoActual == "Mes" ? "revenue-period-button active" : "revenue-period-button";

    private string ClasePeriodoTrimestre =>
        PeriodoActual == "Trimestre" ? "revenue-period-button active" : "revenue-period-button";

    private string ClasePeriodoAnio =>
        PeriodoActual == "Anio" ? "revenue-period-button active" : "revenue-period-button";

    private void MostrarReporteSocios()
    {
        ReporteActual = "Socios";
    }

    private void MostrarReporteRecaudacion()
    {
        ReporteActual = "Recaudacion";
    }

    private void MostrarUltimoMes()
    {
        PeriodoActual = "Mes";
    }

    private void MostrarUltimoTrimestre()
    {
        PeriodoActual = "Trimestre";
    }

    private void MostrarUltimoAnio()
    {
        PeriodoActual = "Anio";
    }

    private decimal TotalRecaudadoNumero =>
        PeriodoActual == "Mes" ? 982.00m :
        PeriodoActual == "Trimestre" ? 2350.00m :
        8920.00m;

    private decimal TotalPendienteNumero =>
        PeriodoActual == "Mes" ? 79.00m :
        PeriodoActual == "Trimestre" ? 237.00m :
        553.00m;

    private int TotalTransaccionesEntero =>
        PeriodoActual == "Mes" ? 8 :
        PeriodoActual == "Trimestre" ? 18 :
        70;

    private int PagosPendientes =>
        PeriodoActual == "Mes" ? 1 :
        PeriodoActual == "Trimestre" ? 3 :
        7;

    private int PagosPagados =>
        TotalTransaccionesEntero - PagosPendientes;

    private int TotalPagosEstado =>
        PagosPagados + PagosPendientes;

    private string TotalRecaudado =>
        TotalRecaudadoNumero.ToString("0.00", CultureInfo.InvariantCulture);

    private string TotalPendiente =>
        TotalPendienteNumero.ToString("0.00", CultureInfo.InvariantCulture);

    private string PromedioPago =>
        (TotalRecaudadoNumero / TotalTransaccionesEntero).ToString("0.00", CultureInfo.InvariantCulture);

    private string TotalTransacciones =>
        TotalTransaccionesEntero.ToString();

    private int PagosEfectivo =>
        PeriodoActual == "Mes" ? 5 :
        PeriodoActual == "Trimestre" ? 12 :
        42;

    private int PagosDebito =>
        PeriodoActual == "Mes" ? 2 :
        PeriodoActual == "Trimestre" ? 4 :
        18;

    private int PagosCredito =>
        PeriodoActual == "Mes" ? 1 :
        PeriodoActual == "Trimestre" ? 2 :
        10;

    private string MetodoPagoDonutStyle
    {
        get
        {
            int efectivoGrados = CalcularGrados(PagosEfectivo, TotalTransaccionesEntero);
            int debitoGrados = CalcularGrados(PagosDebito, TotalTransaccionesEntero);
            int finDebito = efectivoGrados + debitoGrados;

            return $"background: conic-gradient(#E53935 0deg {efectivoGrados}deg, #1976D2 {efectivoGrados}deg {finDebito}deg, #4CAF50 {finDebito}deg 360deg);";
        }
    }

    private string EstadoPagoDonutStyle
    {
        get
        {
            int pagadosGrados = CalcularGrados(PagosPagados, TotalPagosEstado);

            return $"background: conic-gradient(#4CAF50 0deg {pagadosGrados}deg, #FF9800 {pagadosGrados}deg 360deg);";
        }
    }

    private int CalcularGrados(int cantidad, int total)
    {
        if (total == 0)
        {
            return 0;
        }

        return Convert.ToInt32(Math.Round(360.0 * cantidad / total));
    }

    private string Porcentaje(int cantidad, int total)
    {
        if (total == 0)
        {
            return "0.0%";
        }

        double porcentaje = 100.0 * cantidad / total;
        return porcentaje.ToString("0.0", CultureInfo.InvariantCulture) + "%";
    }

    private List<PuntoGrafico> PuntosGrafico
    {
        get
        {
            if (PeriodoActual == "Trimestre")
            {
                return new List<PuntoGrafico>
                {
                    new PuntoGrafico { Mes = "Mar", Valor = "720", X = "80", Y = "115", LabelY = "95" },
                    new PuntoGrafico { Mes = "Abr", Valor = "680", X = "500", Y = "125", LabelY = "105" },
                    new PuntoGrafico { Mes = "May", Valor = "982", X = "920", Y = "70", LabelY = "50" }
                };
            }

            if (PeriodoActual == "Anio")
            {
                return new List<PuntoGrafico>
                {
                    new PuntoGrafico { Mes = "Jun", Valor = "520", X = "80", Y = "165", LabelY = "145" },
                    new PuntoGrafico { Mes = "Jul", Valor = "610", X = "156", Y = "148", LabelY = "128" },
                    new PuntoGrafico { Mes = "Ago", Valor = "690", X = "232", Y = "132", LabelY = "112" },
                    new PuntoGrafico { Mes = "Sep", Valor = "740", X = "308", Y = "120", LabelY = "100" },
                    new PuntoGrafico { Mes = "Oct", Valor = "810", X = "384", Y = "108", LabelY = "88" },
                    new PuntoGrafico { Mes = "Nov", Valor = "760", X = "460", Y = "118", LabelY = "98" },
                    new PuntoGrafico { Mes = "Dic", Valor = "900", X = "536", Y = "90", LabelY = "70" },
                    new PuntoGrafico { Mes = "Ene", Valor = "580", X = "612", Y = "155", LabelY = "135" },
                    new PuntoGrafico { Mes = "Feb", Valor = "650", X = "688", Y = "140", LabelY = "120" },
                    new PuntoGrafico { Mes = "Mar", Valor = "720", X = "764", Y = "128", LabelY = "108" },
                    new PuntoGrafico { Mes = "Abr", Valor = "680", X = "840", Y = "136", LabelY = "116" },
                    new PuntoGrafico { Mes = "May", Valor = "982", X = "920", Y = "70", LabelY = "50" }
                };
            }

            return new List<PuntoGrafico>
            {
                new PuntoGrafico { Mes = "Ene", Valor = "580", X = "80", Y = "150", LabelY = "130" },
                new PuntoGrafico { Mes = "Feb", Valor = "650", X = "280", Y = "130", LabelY = "110" },
                new PuntoGrafico { Mes = "Mar", Valor = "720", X = "500", Y = "115", LabelY = "95" },
                new PuntoGrafico { Mes = "Abr", Valor = "680", X = "700", Y = "125", LabelY = "105" },
                new PuntoGrafico { Mes = "May", Valor = "982", X = "920", Y = "70", LabelY = "50" }
            };
        }
    }

    private string ChartLinePoints =>
        string.Join(" ", PuntosGrafico.Select(p => $"{p.X},{p.Y}"));

    private string ChartAreaPoints
    {
        get
        {
            var primero = PuntosGrafico.First();
            var ultimo = PuntosGrafico.Last();

            return $"{ChartLinePoints} {ultimo.X},250 {primero.X},250";
        }
    }

    private List<SocioReporte> Socios { get; set; } = new()
    {
        new SocioReporte { Nombre = "Lucia Torres", Membresia = "Membresía Black", Activo = true },
        new SocioReporte { Nombre = "Juan Perez", Membresia = "Membresía Basic", Activo = true },
        new SocioReporte { Nombre = "Ana Garcia", Membresia = "Membresía Black", Activo = true },
        new SocioReporte { Nombre = "Diego Ramos", Membresia = "Membresía Basic", Activo = false },
        new SocioReporte { Nombre = "Sofia Mendez", Membresia = "Membresía Black", Activo = true },
        new SocioReporte { Nombre = "Roberto Diaz", Membresia = "Membresía Basic", Activo = true },
        new SocioReporte { Nombre = "Camila Flores", Membresia = "Membresía Basic", Activo = false }
    };

    private class PuntoGrafico
    {
        public string Mes { get; set; } = "";
        public string Valor { get; set; } = "";
        public string X { get; set; } = "";
        public string Y { get; set; } = "";
        public string LabelY { get; set; } = "";
    }

    private class SocioReporte
    {
        public string Nombre { get; set; } = "";
        public string Membresia { get; set; } = "";
        public bool Activo { get; set; }
    }
}