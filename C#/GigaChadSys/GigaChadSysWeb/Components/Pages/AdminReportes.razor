        public string ValorEgresos { get; set; } = "";
        public string X { get; set; } = "";
        public string YIngresos { get; set; } = "";
        public string YEgresos { get; set; } = "";
        public string LabelYIngresos { get; set; } = "";
        public string LabelYEgresos { get; set; } = "";
