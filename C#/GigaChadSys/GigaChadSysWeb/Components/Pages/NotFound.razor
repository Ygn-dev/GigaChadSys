@page "/not-found"
@using GigaChadSysWeb.Components.Layout
@layout AuthLayout
@rendermode InteractiveServer

<div class="notfound-page">
    <div class="notfound-card">
        <div class="notfound-code">404</div>

        <h1>Ruta no encontrada</h1>

        <p>
            La página que intentas abrir no existe o todavía no ha sido implementada en GigaChadSys.
        </p>

        <div class="notfound-actions">
            <a class="btn-primary-link" href="/login">Volver al inicio</a>
            <a class="btn-secondary-link" href="javascript:history.back()">Regresar</a>
        </div>
    </div>
</div>