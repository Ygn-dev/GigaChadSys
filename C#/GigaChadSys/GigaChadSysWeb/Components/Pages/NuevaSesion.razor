@page "/admin/sesiones/nuevo"
@using Components.Layout
@using GigaChadSys.Servicios
@using GigaChadSys.Servicios.DTO
@inject SesionClaseServicio SesionService
@inject ClaseGrupalServicio ClaseService
@inject EntrenadorServicio EntrenadorService
@inject SalonServicio SalonService
@inject NavigationManager Navigation
@layout AdminLayout
@rendermode InteractiveServer

<section class="admin-form-page">

    <div class="admin-breadcrumb">
        <a href="/admin/inicio">Inicio</a>
        <span>/</span>
        <a href="/admin/sesiones">Sesiones</a>
        <span>/</span>
        <span class="breadcrumb-active">Nueva Sesión</span>
    </div>

    <h1 class="admin-form-title">Registrar Nueva Sesión</h1>
    <p class="admin-form-subtitle">Programe una sesión de clase para los socios del gimnasio</p>

    @if (Cargando)
    {
        <p>Cargando información necesaria...</p>
    }
    else
    {
        <div class="sesion-form-layout">

            <!-- COLUMNA IZQUIERDA -->
            <div class="sesion-form-left">

                <!-- Información de la Clase -->
                <div class="form-card">
                    <div class="form-card-header">
                        <span class="form-card-icon">📅</span>
                        <h2>Información de la Clase</h2>
                    </div>
                    <div class="form-card-body">
                        <div class="form-group">
                            <label class="form-label">Clase grupal <span class="required">*</span></label>
                            <select class="form-select" @bind="ClaseId">
                                <option value="0">Seleccione una clase grupal</option>
                                @foreach (var c in ClasesDisponibles)
                                {
                                    <option value="@c.IdClase">@c.NombreDisciplina</option>
                                }
                            </select>
                        </div>
                    </div>
                </div>

                <!-- Asignación -->
                <div class="form-card">
                    <div class="form-card-header">
                        <span class="form-card-icon">👤</span>
                        <h2>Asignación</h2>
                    </div>
                    <div class="form-card-body">
                        <div class="form-row">
                            <div class="form-group">
                                <label class="form-label">Entrenador <span class="required">*</span></label>
                                <select class="form-select" @bind="EntrenadorId">
                                    <option value="0">Seleccione un entrenador</option>
                                    @foreach (var e in EntrenadoresDisponibles)
                                    {
                                    <option value="@e.IdUsuario">@e.NombreCompleto</option>
                                    }
                                </select>
                            </div>
                            <div class="form-group">
                                <label class="form-label">Salón <span class="required">*</span></label>
                                <select class="form-select" @bind="SalonId">
                                    <option value="0">Seleccione un salón</option>
                                    @foreach (var s in SalonesDisponibles)
                                    {
                                        <option value="@s.IdSalon">@s.NombreSalon (Aforo: @s.AforoMaximo)</option>
                                    }
                                </select>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Programación -->
                <div class="form-card">
                    <div class="form-card-header">
                        <span class="form-card-icon">🕐</span>
                        <h2>Programación</h2>
                    </div>
                    <div class="form-card-body">
                        <div class="form-row">
                            <div class="form-group">
                                <label class="form-label">Fecha <span class="required">*</span></label>
                                <input class="form-input" type="date" @bind="Fecha" />
                            </div>
                            <div class="form-group">
                                <label class="form-label">Capacidad máxima <span class="required">*</span></label>
                                <input class="form-input" type="number" placeholder="Opcional (se usará aforo salón)" @bind="CapacidadMaxima" min="1" />
                            </div>
                        </div>
                        <div class="form-row">
                            <div class="form-group">
                                <label class="form-label">Hora de inicio <span class="required">*</span></label>
                                <input class="form-input" type="time"
                                       value="@(HoraInicio?.ToString("HH:mm"))"
                                       @onchange="e => HoraInicio = TimeOnly.TryParse(e.Value?.ToString(), out var t) ? t : null" />
                            </div>
                            <div class="form-group">
                                <label class="form-label">Hora de fin <span class="required">*</span></label>
                                <input class="form-input" type="time"
                                       value="@(HoraFin?.ToString("HH:mm"))"
                                       @onchange="e => HoraFin = TimeOnly.TryParse(e.Value?.ToString(), out var t) ? t : null" />
                            </div>
                        </div>
                    </div>
                </div>

            </div>

            <!-- COLUMNA DERECHA: Vista previa -->
            <div class="sesion-form-right">
                <div class="form-card sesion-preview-card">
                    <div class="form-card-header">
                        <span class="form-card-icon">🔴</span>
                        <h2>Vista Previa de Sesión</h2>
                    </div>
                    <div class="form-card-body">
                        @if (FormularioIncompleto)
                        {
                            <div class="preview-empty">
                                <span class="preview-empty-icon">🕐</span>
                                <p>Complete el formulario para ver la vista previa de la sesión</p>
                            </div>
                        }
                        else
                        {
                            <div class="sesion-preview">
                                <div class="preview-row">
                                    <span class="preview-label">Clase</span>
                                    <span class="preview-value">@ClasesDisponibles.FirstOrDefault(c => c.IdClase == ClaseId)?.NombreDisciplina</span>
                                </div>
                                <div class="preview-row">
                                    <span class="preview-label">Entrenador</span>
                                    <span class="preview-value">@EntrenadoresDisponibles.FirstOrDefault(e => e.IdUsuario == EntrenadorId)?.NombreCompleto</span>
                                </div>
                                <div class="preview-row">
                                    <span class="preview-label">Salón</span>
                                    <span class="preview-value">@SalonesDisponibles.FirstOrDefault(s => s.IdSalon == SalonId)?.NombreSalon</span>
                                </div>
                                <div class="preview-row">
                                    <span class="preview-label">Fecha</span>
                                    <span class="preview-value">@Fecha?.ToString("dd/MM/yyyy")</span>
                                </div>
                                <div class="preview-row">
                                    <span class="preview-label">Horario</span>
                                    <span class="preview-value">@HoraInicioTexto - @HoraFinTexto</span>
                                </div>
                                <div class="preview-row">
                                    <span class="preview-label">Capacidad Max</span>
                                    <span class="preview-value">@(CapacidadMaxima ?? SalonesDisponibles.FirstOrDefault(s => s.IdSalon == SalonId)?.AforoMaximo ?? 0) cupos</span>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>

        </div>

        <!-- BOTONES -->
        <div class="form-actions">
            <button class="btn-primary" @onclick="Registrar">✔ Registrar Sesión</button>
            <button class="btn-secondary" @onclick="Cancelar">✕ Cancelar</button>
            <a class="btn-ghost" href="/admin/sesiones">← Volver al listado</a>
        </div>
    }

</section>

@code {
    private int ClaseId { get; set; }
    private int EntrenadorId { get; set; }
    private int SalonId { get; set; }
    private DateTime? Fecha { get; set; } = null;
    private TimeOnly? HoraInicio { get; set; } = null;
    private TimeOnly? HoraFin { get; set; } = null;
    private int? CapacidadMaxima { get; set; } = null;

    private List<ClaseGrupalDTO> ClasesDisponibles = new();
    private List<EntrenadorDTO> EntrenadoresDisponibles = new();
    private List<SalonDTO> SalonesDisponibles = new();
    private bool Cargando = true;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var taskClases = ClaseService.ListarClasesGrupalesAsync();
            var taskEntrenadores = EntrenadorService.ListarEntrenadoresAsync();
            var taskSalones = SalonService.ListarSalonesAsync();

            await Task.WhenAll(taskClases, taskEntrenadores, taskSalones);

            ClasesDisponibles = await taskClases;
            EntrenadoresDisponibles = await taskEntrenadores;
            SalonesDisponibles = await taskSalones;
        }
        finally
        {
            Cargando = false;
        }
    }

    private string HoraInicioTexto => HoraInicio?.ToString("HH:mm") ?? "";
    private string HoraFinTexto => HoraFin?.ToString("HH:mm") ?? "";

    private bool FormularioIncompleto =>
        ClaseId <= 0 ||
        EntrenadorId <= 0 ||
        SalonId <= 0 ||
        Fecha == null ||
        HoraInicio == null ||
        HoraFin == null;

    private async Task Registrar()
    {
        if (FormularioIncompleto) return;

        var selectedSalon = SalonesDisponibles.FirstOrDefault(s => s.IdSalon == SalonId);
        var selectedClase = ClasesDisponibles.FirstOrDefault(c => c.IdClase == ClaseId);
        var selectedEntrenador = EntrenadoresDisponibles.FirstOrDefault(e => e.IdUsuario == EntrenadorId);

        if (selectedSalon == null || selectedClase == null || selectedEntrenador == null) return;

        var fechaInicio = Fecha!.Value.AddTicks(HoraInicio!.Value.Ticks);
        var fechaFin = Fecha!.Value.AddTicks(HoraFin!.Value.Ticks);
        
        int cuposDisp = CapacidadMaxima ?? selectedSalon.AforoMaximo;

        var nuevaSesion = new SesionClaseDTO
        {
            FechaSesion = Fecha.Value,
            HoraInicio = fechaInicio,
            HoraFin = fechaFin,
            CuposDisponibles = cuposDisp,
            ClaseGrupal = new ClaseGrupalDTO { IdClase = ClaseId },
            Entrenador = new EntrenadorDTO { IdUsuario = EntrenadorId },
            Salon = new SalonDTO { IdSalon = SalonId }
        };

        await SesionService.RegistrarAsync(nuevaSesion);
        Navigation.NavigateTo("/admin/sesiones");
    }

    private void Cancelar()
    {
        Navigation.NavigateTo("/admin/sesiones");
    }
}