@page "/entrenador/pagos"
@using GigaChadSysWeb.Components.Layout
@layout EntrenadorLayout
@rendermode InteractiveServer

<section class="pagos-page">
    <div class="pagos-header">
        <h1>Mis Pagos</h1>
        <p class="pagos-subtitle">Historial de pagos de tu sueldo como entrenador</p>
    </div>

    <!-- Stats Cards -->
    <div class="pagos-stats-grid">
        <div class="pagos-stat-card">
            <div class="pagos-stat-icon icon-green">
                <span>💰</span>
            </div>
            <div class="pagos-stat-info">
                <span class="pagos-stat-label">TOTAL COBRADO</span>
                <span class="pagos-stat-value">S/@totalCobrado.ToString("N0")</span>
                <span class="pagos-stat-hint">Últimos @pagos.Count(p => p.Estado == "Pagado") pagos</span>
            </div>
        </div>

        <div class="pagos-stat-card">
            <div class="pagos-stat-icon icon-yellow">
                <span>⏳</span>
            </div>
            <div class="pagos-stat-info">
                <span class="pagos-stat-label">PENDIENTE</span>
                <span class="pagos-stat-value">S/@totalPendiente.ToString("N0")</span>
                <span class="pagos-stat-hint">@(totalPendiente == 0 ? "Sin pagos pendientes" : "Pagos por cobrar")</span>
            </div>
        </div>

        <div class="pagos-stat-card">
            <div class="pagos-stat-icon icon-blue">
                <span>📊</span>
            </div>
            <div class="pagos-stat-info">
                <span class="pagos-stat-label">PROMEDIO MENSUAL</span>
                <span class="pagos-stat-value">S/@promedioMensual.ToString("N0")</span>
                <span class="pagos-stat-hint">Por mes</span>
            </div>
        </div>

        <div class="pagos-stat-card">
            <div class="pagos-stat-icon icon-red">
                <span>📅</span>
            </div>
            <div class="pagos-stat-info">
                <span class="pagos-stat-label">ÚLTIMO PAGO</span>
                <span class="pagos-stat-value">S/@ultimoPagoMonto.ToString("N0")</span>
                <span class="pagos-stat-hint">@ultimoPagoFecha</span>
            </div>
        </div>
    </div>

    <!-- Content: Table + Info Panel -->
    <div class="pagos-content-grid">
        <!-- Historial de Pagos Table -->
        <div class="pagos-table-card">
            <h3>Historial de Pagos</h3>

            <div class="pagos-table-wrapper">
                <table class="pagos-table">
                    <thead>
                        <tr>
                            <th>CONCEPTO</th>
                            <th>TIPO</th>
                            <th>MÉTODO</th>
                            <th>MONTO</th>
                            <th>FECHA</th>
                            <th>ESTADO</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var pago in pagos)
                        {
                            <tr>
                                <td class="td-concepto">@pago.Concepto</td>
                                <td>@pago.Tipo</td>
                                <td>@pago.Metodo</td>
                                <td class="td-monto">S/@pago.Monto.ToString("N0")</td>
                                <td>@pago.Fecha.ToString("yyyy-MM-dd")</td>
                                <td>
                                    <span class="pagos-estado estado-@pago.Estado.ToLower()">
                                        <span class="estado-dot"></span>
                                        @pago.Estado
                                    </span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Info Panel -->
        <div class="pagos-info-panel">
            <h3>Información</h3>
            <p class="pagos-info-text">
                Los pagos del entrenador son registrados por la administración del gimnasio y se depositan mensualmente.
            </p>

            <div class="pagos-info-items">
                <div class="pagos-info-item">
                    <div class="pagos-info-icon icon-red">
                        <span>💪</span>
                    </div>
                    <div>
                        <span class="pagos-info-label">ESPECIALIDAD</span>
                        <strong>CrossFit y Musculación</strong>
                    </div>
                </div>

                <div class="pagos-info-item">
                    <div class="pagos-info-icon icon-blue">
                        <span>🏦</span>
                    </div>
                    <div>
                        <span class="pagos-info-label">FORMA DE PAGO</span>
                        <strong>Transferencia bancaria</strong>
                    </div>
                </div>

                <div class="pagos-info-item">
                    <div class="pagos-info-icon icon-green">
                        <span>✓</span>
                    </div>
                    <div>
                        <span class="pagos-info-label">ESTADO ACTUAL</span>
                        <strong class="estado-al-dia">Al día</strong>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@code {
    private List<PagoEntrenador> pagos = new();
    private decimal totalCobrado => pagos.Where(p => p.Estado == "Pagado").Sum(p => p.Monto);
    private decimal totalPendiente => pagos.Where(p => p.Estado == "Pendiente").Sum(p => p.Monto);
    private decimal promedioMensual => pagos.Where(p => p.Estado == "Pagado").Any()
        ? pagos.Where(p => p.Estado == "Pagado" && p.Tipo == "Sueldo").Average(p => p.Monto)
        : 0;
    private decimal ultimoPagoMonto => pagos.Where(p => p.Estado == "Pagado").Any()
        ? pagos.Where(p => p.Estado == "Pagado").OrderByDescending(p => p.Fecha).First().Monto
        : 0;
    private string ultimoPagoFecha => pagos.Where(p => p.Estado == "Pagado").Any()
        ? pagos.Where(p => p.Estado == "Pagado").OrderByDescending(p => p.Fecha).First().Fecha.ToString("yyyy-MM-dd")
        : "---";

    protected override void OnInitialized()
    {
        // Datos mock - se conectará con BL después
        pagos = new List<PagoEntrenador>
        {
            new PagoEntrenador
            {
                Concepto = "Sueldo Abril 2025",
                Tipo = "Sueldo",
                Metodo = "Transferencia",
                Monto = 2200,
                Fecha = new DateTime(2025, 4, 1),
                Estado = "Pagado"
            },
            new PagoEntrenador
            {
                Concepto = "Sueldo Mayo 2025",
                Tipo = "Sueldo",
                Metodo = "Transferencia",
                Monto = 2200,
                Fecha = new DateTime(2025, 5, 1),
                Estado = "Pagado"
            },
            new PagoEntrenador
            {
                Concepto = "Bono por clases extra",
                Tipo = "Bono",
                Metodo = "Transferencia",
                Monto = 450,
                Fecha = new DateTime(2025, 5, 10),
                Estado = "Pagado"
            },
            new PagoEntrenador
            {
                Concepto = "Sueldo Junio 2025",
                Tipo = "Sueldo",
                Metodo = "Transferencia",
                Monto = 2200,
                Fecha = new DateTime(2025, 6, 1),
                Estado = "Pendiente"
            }
        };
    }

    private class PagoEntrenador
    {
        public string Concepto { get; set; } = "";
        public string Tipo { get; set; } = "";
        public string Metodo { get; set; } = "";
        public decimal Monto { get; set; }
        public DateTime Fecha { get; set; }
        public string Estado { get; set; } = "";
    }
}
