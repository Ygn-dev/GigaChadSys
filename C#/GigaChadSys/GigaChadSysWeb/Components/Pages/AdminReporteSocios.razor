@code {
    private bool Cargando = true;
    private bool DescargandoReporte = false;
    private string MensajeError = "";
    private string MensajeDescarga = "";

    private List<SocioDTO> TodosLosSocios = new();
    private List<SuscripcionDTO> TodasLasSuscripciones = new();
    private List<PagoDTO> TodosLosPagos = new();

    private List<SocioReporteItem> SociosReporte = new();
    private List<MembresiaResumenItem> Membresias = new();

    private int TotalSocios = 0;
    private int SociosActivos = 0;
    private int SociosInactivos = 0;
    private int SociosPendientes = 0;
    private decimal PendientePorCobrar = 0;

    private string EstadoDonutStyle
    {
        get
        {
            if (TotalSocios == 0)
            {
                return "background:#242424;";
            }

            int activos = CalcularGrados(SociosActivos, TotalSocios);
            int pendientes = CalcularGrados(SociosPendientes, TotalSocios);

            int finActivos = activos;
            int finPendientes = activos + pendientes;

            return $"background: conic-gradient(#22C55E 0deg {finActivos}deg, #FACC15 {finActivos}deg {finPendientes}deg, #EF3131 {finPendientes}deg 360deg);";
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await CargarReporte();
    }

    private async Task CargarReporte()
    {
        try
        {
            Cargando = true;
            MensajeError = "";

            var sociosTask = SocioService.ListarSociosAsync();
            var suscripcionesTask = SuscripcionService.ListarSuscripcionesAsync();
            var pagosTask = PagoService.ListarPagosAsync();

            await Task.WhenAll(sociosTask, suscripcionesTask, pagosTask);

            TodosLosSocios = sociosTask.Result ?? new List<SocioDTO>();
            TodasLasSuscripciones = suscripcionesTask.Result ?? new List<SuscripcionDTO>();
            TodosLosPagos = pagosTask.Result ?? new List<PagoDTO>();

            ConstruirReporte();
        }
        catch (Exception ex)
        {
            MensajeError = $"No se pudo cargar el reporte de socios: {ex.Message}";
        }
        finally
        {
            Cargando = false;
        }
    }

    private void ConstruirReporte()
    {
        SociosReporte.Clear();

        foreach (var socio in TodosLosSocios)
        {
            var suscripcion = ObtenerSuscripcionPrincipal(socio.IdUsuario);
            var pago = suscripcion == null
                ? null
                : TodosLosPagos.FirstOrDefault(p => p.IdPago == suscripcion.IdPago);

            bool tienePagoPendiente = pago != null && !pago.Activo && !EsPagoEgreso(pago);
            decimal montoPendiente = tienePagoPendiente ? (decimal)pago!.Monto : 0;

            string membresia = ObtenerNombreMembresia(suscripcion);
            string estado = ObtenerEstadoSocio(socio, tienePagoPendiente);
            string estadoCss = estado.ToLowerInvariant();

            SociosReporte.Add(new SocioReporteItem
            {
                IdUsuario = socio.IdUsuario,
                NombreCompleto = ObtenerNombreCompleto(socio),
                Iniciales = ObtenerIniciales(socio),
                Email = socio.Email,
                Dni = socio.Dni == 0 ? "—" : socio.Dni.ToString(),
                Membresia = membresia,
                Estado = estado,
                EstadoCss = estadoCss,
                MontoPendiente = montoPendiente
            });
        }

        TotalSocios = SociosReporte.Count;
        SociosActivos = SociosReporte.Count(s => s.Estado == "Activo");
        SociosInactivos = SociosReporte.Count(s => s.Estado == "Inactivo");
        SociosPendientes = SociosReporte.Count(s => s.Estado == "Pendiente");
        PendientePorCobrar = SociosReporte.Sum(s => s.MontoPendiente);

        ConstruirDistribucionMembresias();
    }

    private void ConstruirDistribucionMembresias()
    {
        int basic = SociosReporte.Count(s => s.Membresia.Contains("Basic", StringComparison.OrdinalIgnoreCase));
        int black = SociosReporte.Count(s => s.Membresia.Contains("Black", StringComparison.OrdinalIgnoreCase));
        int sinPlan = SociosReporte.Count(s => s.Membresia.Contains("Sin plan", StringComparison.OrdinalIgnoreCase));

        Membresias = new List<MembresiaResumenItem>
        {
            new()
            {
                Nombre = "Membresía Basic",
                Cantidad = basic,
                CssClass = "basic",
                PorcentajeAncho = PorcentajeAncho(basic, TotalSocios)
            },
            new()
            {
                Nombre = "Membresía Black",
                Cantidad = black,
                CssClass = "black",
                PorcentajeAncho = PorcentajeAncho(black, TotalSocios)
            },
            new()
            {
                Nombre = "Sin plan asignado",
                Cantidad = sinPlan,
                CssClass = "sinplan",
                PorcentajeAncho = PorcentajeAncho(sinPlan, TotalSocios)
            }
        };
    }

    private SuscripcionDTO? ObtenerSuscripcionPrincipal(int idUsuario)
    {
        return TodasLasSuscripciones
            .Where(s => s.IdUsuario == idUsuario)
            .OrderByDescending(s => s.Activo)
            .ThenByDescending(s => s.FechaFinMembresia ?? DateTime.MinValue)
            .FirstOrDefault();
    }

    private static string ObtenerNombreMembresia(SuscripcionDTO? suscripcion)
    {
        if (suscripcion == null)
        {
            return "Sin plan";
        }

        if (suscripcion.IdMembresiaBlack.HasValue)
        {
            return "Membresía Black";
        }

        if (suscripcion.IdMembresiaBasic.HasValue)
        {
            return "Membresía Basic";
        }

        return "Sin plan";
    }

    private static string ObtenerEstadoSocio(SocioDTO socio, bool tienePagoPendiente)
    {
        if (!socio.Activo)
        {
            return "Inactivo";
        }

        if (tienePagoPendiente)
        {
            return "Pendiente";
        }

        return "Activo";
    }

    private async Task DescargarReporteSocios()
    {
        try
        {
            DescargandoReporte = true;
            MensajeDescarga = "";

            var bytes = await Http.GetByteArrayAsync("reportes/estado-socios");
            var base64 = Convert.ToBase64String(bytes);

            await JS.InvokeVoidAsync(
                "downloadFileFromBytes",
                "reporte_estado_socios.pdf",
                "application/pdf",
                base64
            );
        }
        catch
        {
            MensajeDescarga = "La pantalla ya está lista. Falta conectar el endpoint Java del PDF: reportes/estado-socios.";
        }
        finally
        {
            DescargandoReporte = false;
        }
    }

    private void VolverAReportes()
    {
        Navigation.NavigateTo("/admin/reportes");
    }

    private static bool EsPagoEgreso(PagoDTO pago)
    {
        if (string.IsNullOrWhiteSpace(pago.Tipo))
        {
            return false;
        }

        string tipo = pago.Tipo.Trim().ToLowerInvariant();

        return tipo.Contains("sueldo") ||
               tipo.Contains("bono") ||
               tipo.Contains("entrenador");
    }

    private static string ObtenerNombreCompleto(SocioDTO socio)
    {
        string nombre = $"{socio.Nombres} {socio.ApellidoPaterno} {socio.ApellidoMaterno}".Trim();
        return string.IsNullOrWhiteSpace(nombre) ? "Socio sin nombre" : nombre;
    }

    private static string ObtenerIniciales(SocioDTO socio)
    {
        string nombres = socio.Nombres?.Trim() ?? "";
        string apellido = socio.ApellidoPaterno?.Trim() ?? "";

        string inicial1 = !string.IsNullOrWhiteSpace(nombres) ? nombres[0].ToString().ToUpperInvariant() : "S";
        string inicial2 = !string.IsNullOrWhiteSpace(apellido) ? apellido[0].ToString().ToUpperInvariant() : "";

        return inicial1 + inicial2;
    }

    private static string FormatoMoneda(decimal valor)
    {
        return valor.ToString("0.00", CultureInfo.InvariantCulture);
    }

    private static string Porcentaje(int cantidad, int total)
    {
        if (total == 0)
        {
            return "0.0%";
        }

        double porcentaje = 100.0 * cantidad / total;
        return porcentaje.ToString("0.0", CultureInfo.InvariantCulture) + "%";
    }

    private static string PorcentajeAncho(int cantidad, int total)
    {
        if (total == 0)
        {
            return "0%";
        }

        double porcentaje = 100.0 * cantidad / total;
        return porcentaje.ToString("0.0", CultureInfo.InvariantCulture) + "%";
    }

    private static int CalcularGrados(int cantidad, int total)
    {
        if (total == 0)
        {
            return 0;
        }

        return Convert.ToInt32(Math.Round(360.0 * cantidad / total));
    }

