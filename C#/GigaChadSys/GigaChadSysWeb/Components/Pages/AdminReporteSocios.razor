@page "/admin/reportes/socios"
@layout AdminLayout
@rendermode InteractiveServer

@using System.Globalization
@using Microsoft.JSInterop
@using GigaChadSys.Servicios
@using GigaChadSys.Servicios.DTO

@inject SocioServicio SocioService
@inject SuscripcionServicio SuscripcionService
@inject PagoServicio PagoService
@inject HttpClient Http
@inject IJSRuntime JS
@inject NavigationManager Navigation

<section class="reporte-socios-page">

    <div class="rs-breadcrumb">
        <button type="button" @onclick="VolverAReportes">
            <i class="bi bi-arrow-left"></i>
            Reportes
        </button>
        <span>/</span>
        <strong>Socios</strong>
    </div>

    <div class="rs-header">
        <div>
            <span class="rs-kicker">Reporte administrativo</span>
            <h1>Reporte de Socios</h1>
            <p>Consulta el estado de membresías, distribución de planes y pagos pendientes de los socios.</p>
        </div>

        <button type="button"
                class="rs-download-btn"
                @onclick="DescargarReporteSocios"
                disabled="@DescargandoReporte">
            @if (DescargandoReporte)
            {
                <span>
                    <i class="bi bi-hourglass-split"></i>
                    Generando PDF...
                </span>
            }
            else
            {
                <span>
                    <i class="bi bi-file-earmark-pdf"></i>
                    Descargar reporte de socios
                </span>
            }
        </button>
    </div>

    @if (!string.IsNullOrWhiteSpace(MensajeDescarga))
    {
        <div class="rs-alert">
            <i class="bi bi-info-circle"></i>
            <span>@MensajeDescarga</span>
        </div>
    }

    @if (Cargando)
    {
        <div class="rs-loading">
            <i class="bi bi-hourglass-split"></i>
            <span>Cargando reporte de socios...</span>
        </div>
    }
    else if (!string.IsNullOrWhiteSpace(MensajeError))
    {
        <div class="rs-error">
            <i class="bi bi-exclamation-triangle"></i>
            <span>@MensajeError</span>
        </div>
    }
    else
    {
        <div class="rs-kpi-grid">

            <div class="rs-kpi-card">
                <div class="rs-kpi-icon green">
                    <i class="bi bi-person-check"></i>
                </div>
                <div>
                    <span>Socios activos</span>
                    <strong>@SociosActivos</strong>
                    <p>@Porcentaje(SociosActivos, TotalSocios) del total</p>
                </div>
            </div>

            <div class="rs-kpi-card">
                <div class="rs-kpi-icon red">
                    <i class="bi bi-person-x"></i>
                </div>
                <div>
                    <span>Socios inactivos</span>
                    <strong>@SociosInactivos</strong>
                    <p>@Porcentaje(SociosInactivos, TotalSocios) del total</p>
                </div>
            </div>

            <div class="rs-kpi-card">
                <div class="rs-kpi-icon yellow">
                    <i class="bi bi-cash-coin"></i>
                </div>
                <div>
                    <span>Pendiente por cobrar</span>
                    <strong>S/ @FormatoMoneda(PendientePorCobrar)</strong>
                    <p>@SociosPendientes socios con pago pendiente</p>
                </div>
            </div>

            <div class="rs-kpi-card">
                <div class="rs-kpi-icon blue">
                    <i class="bi bi-people"></i>
                </div>
                <div>
                    <span>Total socios</span>
                    <strong>@TotalSocios</strong>
                    <p>Registrados en el sistema</p>
                </div>
            </div>

        </div>

        <div class="rs-main-grid">

            <div class="rs-panel">
                <div class="rs-panel-header">
                    <div>
                        <h2>Distribución por membresía</h2>
                        <p>Comparación de socios según el plan asociado.</p>
                    </div>
                </div>

                <div class="rs-membership-list">
                    @foreach (var membresia in Membresias)
                    {
                        <div class="rs-bar-row">
                            <div class="rs-bar-head">
                                <span>@membresia.Nombre</span>
                                <strong>@membresia.Cantidad socios</strong>
                            </div>

                            <div class="rs-bar-track">
                                <div class="rs-bar-fill @membresia.CssClass"
                                     style="width:@membresia.PorcentajeAncho">
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>

            <div class="rs-panel">
                <div class="rs-panel-header">
                    <div>
                        <h2>Estado de socios</h2>
                        <p>Resumen visual de activos, inactivos y pendientes.</p>
                    </div>
                </div>

                <div class="rs-state-content">
                    <div class="rs-donut" style="@EstadoDonutStyle">
                        <div class="rs-donut-center">
                            <strong>@TotalSocios</strong>
                            <span>Socios</span>
                        </div>
                    </div>

                    <div class="rs-donut-list">
                        <div class="rs-donut-row">
                            <span><i class="dot green"></i>Activos</span>
                            <strong>@SociosActivos (@Porcentaje(SociosActivos, TotalSocios))</strong>
                        </div>

                        <div class="rs-donut-row">
                            <span><i class="dot red"></i>Inactivos</span>
                            <strong>@SociosInactivos (@Porcentaje(SociosInactivos, TotalSocios))</strong>
                        </div>

                        <div class="rs-donut-row">
                            <span><i class="dot yellow"></i>Pendientes</span>
                            <strong>@SociosPendientes (@Porcentaje(SociosPendientes, TotalSocios))</strong>
                        </div>
                    </div>
                </div>
            </div>

        </div>

        <div class="rs-table-panel">
            <div class="rs-panel-header">
                <div>
                    <h2>Estado de membresías</h2>
                    <p>Listado detallado de socios, membresía asociada y deuda pendiente.</p>
                </div>
            </div>

            <div class="rs-table-wrapper">
                <table class="rs-table">
                    <thead>
                        <tr>
                            <th>Socio</th>
                            <th>DNI</th>
                            <th>Membresía</th>
                            <th>Estado</th>
                            <th>Pago pendiente</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var socio in SociosReporte)
                        {
                            <tr>
                                <td>
                                    <div class="rs-user-cell">
                                        <div class="rs-avatar">@socio.Iniciales</div>
                                        <div>
                                            <strong>@socio.NombreCompleto</strong>
                                            <span>@socio.Email</span>
                                        </div>
                                    </div>
                                </td>

                                <td>@socio.Dni</td>
                                <td>@socio.Membresia</td>

                                <td>
                                    <span class="rs-status @socio.EstadoCss">
                                        @socio.Estado
                                    </span>
                                </td>

                                <td>
                                    @if (socio.MontoPendiente > 0)
                                    {
                                        <strong class="rs-money-yellow">
                                            S/ @FormatoMoneda(socio.MontoPendiente)
                                        </strong>
                                    }
                                    else
                                    {
                                        <span class="rs-muted">—</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }

</section>

