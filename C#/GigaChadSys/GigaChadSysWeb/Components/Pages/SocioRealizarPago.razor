@page "/socio/pagos/realizar/{CodigoPago}"
@using GigaChadSys.Servicios
@using GigaChadSys.Servicios.DTO
@layout SocioLayout
@rendermode InteractiveServer
@inject SessionServicio Session
@inject PagoServicio PagoService
@inject SuscripcionServicio SuscripcionService
@inject SocioServicio SocioService
@inject NavigationManager Navigation

<section class="socio-pay-process-page">

    <div class="pay-breadcrumb">
        <a href="/socio/pagos">Mis Pagos</a>
        <span>/</span>
        <strong>Realizar Pago</strong>
    </div>

    <div class="pay-process-header">
        <h1>Realizar Pago</h1>
        <p>Completa el pago pendiente de tu membresía.</p>
    </div>

    @if (!string.IsNullOrWhiteSpace(Mensaje))
    {
        <div class="@ClaseMensaje">
            @Mensaje
        </div>
    }

    <div class="pay-process-layout">

        <div class="pay-process-main">

            <div class="pay-detail-card">
                <h2>Detalle del Pago</h2>

                <div class="pay-detail-row">
                    <span>Concepto</span>
                    <strong>@Concepto</strong>
                </div>

                <div class="pay-detail-row">
                    <span>Tipo</span>
                    <strong>▭ @TipoPago</strong>
                </div>

                <div class="pay-detail-row">
                    <span>Socio</span>
                    <strong>@NombreUsuario</strong>
                </div>

                <div class="pay-detail-row">
                    <span>Fecha</span>
                    <strong>@FechaPago</strong>
                </div>

                <div class="pay-detail-row">
                    <span>Estado</span>
                    <strong class="@ClaseEstado">@EstadoTexto</strong>
                </div>

                <div class="pay-detail-row total">
                    <span>Monto a pagar</span>
                    <strong>S/@MontoPago.ToString("0.00")</strong>
                </div>
            </div>

            <div class="pay-method-card">
                <h2>Método de Pago</h2>

                <div class="pay-method-options">
                    <button type="button"
                            class="@ClaseDebito"
                            @onclick="SeleccionarDebito">
                        <span class="pay-card-icon">▭</span>
                        <strong>Tarjeta Débito</strong>
                    </button>

                    <button type="button"
                            class="@ClaseCredito"
                            @onclick="SeleccionarCredito">
                        <span class="pay-card-icon">▭</span>
                        <strong>Tarjeta Crédito</strong>
                    </button>
                </div>

                <p class="pay-note">
                    ⓘ Los datos del pago fueron cargados automáticamente según tu cuota pendiente.
                </p>
            </div>

            <div class="pay-process-actions">
                <button type="button"
                        class="confirm-pay-button"
                        @onclick="ConfirmarPago">
                    ▭ Confirmar Pago
                </button>

                <a class="cancel-pay-button" href="/socio/pagos">
                    × Cancelar
                </a>

                <a class="back-pay-link" href="/socio/pagos">
                    ← Volver a Mis Pagos
                </a>
            </div>

        </div>

        <aside class="pay-summary-side">
            <div class="pay-summary-card">
                <h2>Resumen</h2>

                <div class="summary-pay-row">
                    <span>Concepto</span>
                    <strong>@Concepto</strong>
                </div>

                <div class="summary-pay-row">
                    <span>Fecha</span>
                    <strong>@FechaPago</strong>
                </div>

                <div class="summary-pay-row">
                    <span>Monto</span>
                    <strong>S/@MontoPago.ToString("0.00")</strong>
                </div>

                <div class="summary-pay-row">
                    <span>Estado actual</span>
                    <strong class="@ClaseEstado">@EstadoTexto</strong>
                </div>

                <div class="summary-pay-total">
                    <span>Total a pagar</span>
                    <strong>S/@MontoPago.ToString("0.00")</strong>
                </div>
            </div>

            <div class="pending-alert-card">
                <div class="pending-alert-icon">◷</div>

                <div>
                    <h3>@TituloAlerta</h3>
                    <p>
                        Tu cuota por @Concepto se encuentra @EstadoTexto.ToLower().
                        Realiza el pago para mantener tu acceso y seguir disfrutando
                        de todos los beneficios.
                    </p>
                </div>
            </div>
        </aside>

    </div>

</section>

@code {
    [Parameter]
    public string CodigoPago { get; set; } = "";

    private string MetodoSeleccionado { get; set; } = "Debito";
    private string Mensaje { get; set; } = "";
    private string ClaseMensaje { get; set; } = "";

    private PagoDTO? pagoActual;
    private string Concepto => pagoActual?.Tipo ?? "-";
    private string TipoPago => pagoActual?.Tipo ?? "-";
    private string FechaPago => pagoActual?.FechaPagoTexto ?? "-";
    private decimal MontoPago => pagoActual != null ? (decimal)pagoActual.Monto : 0;
    private bool Activo => pagoActual?.Activo ?? false;

    private string EstadoTexto => Activo ? "Pagado" : "Pendiente";
    private string TituloAlerta => Activo ? "Pago al día" : "Pago pendiente detectado";
    private string ClaseEstado => Activo ? "pay-status paid" : "pay-status pending";
    
    private string NombreUsuario => Session.EstaAutenticado ? Session.Nombres : "Socio Invitado"; // Session.Nombres (no NombreUsuario)

    private string ClaseDebito =>
        MetodoSeleccionado == "Debito" ? "pay-method-option selected" : "pay-method-option";

    private string ClaseCredito =>
        MetodoSeleccionado == "Credito" ? "pay-method-option selected" : "pay-method-option";

    protected override async Task OnInitializedAsync()
    {
        if (int.TryParse(CodigoPago, out int idPago))
        {
            pagoActual = await PagoService.ObtenerPorIdAsync(idPago);
            if (pagoActual == null)
            {
                Mensaje = "No se encontró el pago especificado.";
                ClaseMensaje = "pay-process-message error";
            }
        }
    }

    private void SeleccionarDebito()
    {
        MetodoSeleccionado = "Debito";
    }

    private void SeleccionarCredito()
    {
        MetodoSeleccionado = "Credito";
    }

    private async Task ConfirmarPago()
    {
        if (pagoActual == null) return;
        if (Activo)
        {
            Mensaje = "Este pago ya fue realizado.";
            ClaseMensaje = "pay-process-message warning";
            return;
        }

        // Metodo: 1 Efectivo, 2 Debito, 3 Credito
        pagoActual.MetodoPago = MetodoSeleccionado == "Debito" ? 2 : 3;
        pagoActual.Activo = true;

        var resultado = await PagoService.ActualizarAsync(pagoActual.IdPago, pagoActual);

        if (!resultado.StartsWith("Error") && !resultado.ToLower().Contains("error"))
        {
            // Activar la suscripción correspondiente
            var suscripciones = await SuscripcionService.ListarSuscripcionesAsync();
            var sub = suscripciones.FirstOrDefault(s => s.IdPago == pagoActual.IdPago);
            if (sub != null)
            {
                sub.EstadoMembresia = "activa";
                await SuscripcionService.ActualizarAsync(sub.IdSuscripcion, sub);
            }

            // Actualizar estadoMembresia del Socio
            if (Session.EstaAutenticado)
            {
                var socioActual = await SocioService.ObtenerPorIdAsync(Session.IdUsuario);
                if (socioActual != null)
                {
                    socioActual.EstadoMembresia = true;
                    await SocioService.ActualizarAsync(socioActual.IdUsuario, socioActual);
                }
            }

            Mensaje = $"¡Pago confirmado correctamente con tarjeta {MetodoSeleccionado}!";
            ClaseMensaje = "pay-process-message success";
            await Task.Delay(1500);
            Navigation.NavigateTo("/socio/pagos");
        }
        else
        {
            Mensaje = resultado;
            ClaseMensaje = "pay-process-message error";
        }
    }
}