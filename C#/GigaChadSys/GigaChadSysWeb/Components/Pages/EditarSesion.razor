@page "/admin/sesiones/editar/{Id:int}"
@using System.Globalization
@using GigaChadSys.Servicios
@using GigaChadSys.Servicios.DTO
@inject SesionClaseServicio SesionService
@inject ClaseGrupalServicio ClaseService
@inject EntrenadorServicio EntrenadorService
@inject SalonServicio SalonService
@inject NavigationManager Navigation
@layout AdminLayout
@rendermode InteractiveServer

<div class="socio-form-page">

    <nav class="sf-breadcrumb">
        <a href="/admin/sesiones">Sesiones</a>
        <span class="sf-bc-sep">›</span>
        <span class="sf-bc-current">Editar</span>
    </nav>

    <div class="sf-page-header">
        <h1>Editar Sesión</h1>
        <p class="sf-page-subtitle">Modifica los datos de la sesión programada</p>
    </div>

    @if (!string.IsNullOrWhiteSpace(MensajeFormulario))
    {
        <div class="@ClaseMensajeFormulario">
            @MensajeFormulario
        </div>
    }

    @if (Cargando)
    {
        <p>Cargando información de la sesión...</p>
    }
    else if (sesionOriginal == null)
    {
        <p>Sesión no encontrada.</p>
    }
    else
    {
        <div class="sf-edit-layout">

            <div>

                <div class="sf-section-card">
                    <div class="sf-section-title">
                        <div class="sf-section-icon icon-blue">📅</div>
                        <div>
                            <h3>Datos de la Sesión</h3>
                            <span>Clase, fecha, hora y lugar</span>
                        </div>
                    </div>

                    <div class="sf-form-grid">

                        <div class="sf-form-group">
                            <label>CLASE <span class="sf-req">*</span></label>
                            <select @bind="claseId" class="@(errores.ContainsKey("claseId") ? "sf-input-error" : "")">
                                <option value="0">Seleccionar clase...</option>
                                @foreach (var c in clasesDisponibles)
                                {
                                    <option value="@c.IdClase">@c.NombreDisciplina</option>
                                }
                            </select>
                            @if (errores.ContainsKey("claseId"))
                            {
                                <span class="sf-error-msg">@errores["claseId"]</span>
                            }
                        </div>

                        <div class="sf-form-group">
                            <label>ENTRENADOR <span class="sf-req">*</span></label>
                            <select @bind="entrenadorId" class="@(errores.ContainsKey("entrenadorId") ? "sf-input-error" : "")">
                                <option value="0">Seleccionar entrenador...</option>
                                @foreach (var e in entrenadoresDisponibles)
                                {
                                    <option value="@e.IdUsuario">@e.NombreCompleto</option>
                                }
                            </select>
                            @if (errores.ContainsKey("entrenadorId"))
                            {
                                <span class="sf-error-msg">@errores["entrenadorId"]</span>
                            }
                        </div>

                        <div class="sf-form-group">
                            <label>SALÓN <span class="sf-req">*</span></label>
                            <select @bind="salonId" class="@(errores.ContainsKey("salonId") ? "sf-input-error" : "")">
                                <option value="0">Seleccionar salón...</option>
                                @foreach (var s in salonesDisponibles)
                                {
                                    <option value="@s.IdSalon">@s.NombreSalon (Aforo: @s.AforoMaximo)</option>
                                }
                            </select>
                            @if (errores.ContainsKey("salonId"))
                            {
                                <span class="sf-error-msg">@errores["salonId"]</span>
                            }
                        </div>

                        <div class="sf-form-group">
                            <label>CUPOS DISPONIBLES <span class="sf-req">*</span></label>
                            <input type="number"
                                   value="@CuposDisponiblesInput"
                                   @oninput="CambiarCuposDisponiblesInput"
                                   @onchange="CambiarCuposDisponiblesInput"
                                   min="0"
                                   max="200"
                                   class="@(errores.ContainsKey("cuposDisponibles") ? "sf-input-error" : "")" />
                            @if (errores.ContainsKey("cuposDisponibles"))
                            {
                                <span class="sf-error-msg">@errores["cuposDisponibles"]</span>
                            }
                        </div>

                        <div class="sf-form-group">
                            <label>FECHA <span class="sf-req">*</span></label>
                            <input type="date"
                                   value="@FechaInput"
                                   @oninput="CambiarFechaInput"
                                   @onchange="CambiarFechaInput"
                                   class="@(errores.ContainsKey("fecha") ? "sf-input-error" : "")" />
                            @if (errores.ContainsKey("fecha"))
                            {
                                <span class="sf-error-msg">@errores["fecha"]</span>
                            }
                        </div>

                        <div class="sf-form-group"></div>

                        <div class="sf-form-group">
                            <label>HORA DE INICIO <span class="sf-req">*</span></label>
                            <input type="time"
                                   value="@HoraInicioInput"
                                   @oninput="CambiarHoraInicioInput"
                                   @onchange="CambiarHoraInicioInput"
                                   class="@(errores.ContainsKey("horaInicio") ? "sf-input-error" : "")" />
                            @if (errores.ContainsKey("horaInicio"))
                            {
                                <span class="sf-error-msg">@errores["horaInicio"]</span>
                            }
                        </div>

                        <div class="sf-form-group">
                            <label>HORA DE FIN <span class="sf-req">*</span></label>
                            <input type="time"
                                   value="@HoraFinInput"
                                   @oninput="CambiarHoraFinInput"
                                   @onchange="CambiarHoraFinInput"
                                   class="@(errores.ContainsKey("horaFin") ? "sf-input-error" : "")" />
                            @if (errores.ContainsKey("horaFin"))
                            {
                                <span class="sf-error-msg">@errores["horaFin"]</span>
                            }
                        </div>

                    </div>
                </div>

                <div class="sf-section-card">
                    <div class="sf-section-title">
                        <div class="sf-section-icon icon-green">✅</div>
                        <div>
                            <h3>Estado de la Sesión</h3>
                            <span>Controla si la sesión está disponible o cancelada</span>
                        </div>
                    </div>

                    <p class="sf-sublabel">ESTADO ADMINISTRATIVO</p>

                    <div class="sf-estado-row">
                        <button type="button"
                                class="sf-estado-btn @(estadoAdministrativo == "Programada" ? "sf-estado-activo" : "")"
                                @onclick='() => estadoAdministrativo = "Programada"'>
                            <span class="sf-estado-dot dot-green"></span> Programada
                        </button>

                        <button type="button"
                                class="sf-estado-btn @(estadoAdministrativo == "Cancelada" ? "sf-estado-inactivo" : "")"
                                @onclick='() => estadoAdministrativo = "Cancelada"'>
                            <span class="sf-estado-dot dot-red"></span> Cancelada
                        </button>
                    </div>

                    <p style="margin-top:12px;color:#aaa;font-size:13px;">
                        Si la fecha y hora ya pasaron, se mostrará como Finalizada automáticamente.
                    </p>
                </div>

                <div class="sf-form-actions">
                    <button class="sf-btn-primary" @onclick="GuardarCambios" disabled="@guardando">
                        @if (guardando)
                        {
                            <span>⏳</span> <span>Guardando...</span>
                        }
                        else
                        {
                            <span>💾</span> <span>Guardar Cambios</span>
                        }
                    </button>

                    <button class="sf-btn-secondary" @onclick="Cancelar">Cancelar</button>

                    <div class="sf-back-link">
                        <a href="/admin/sesiones">← Volver a Sesiones</a>
                    </div>
                </div>

            </div>

            <div class="sf-resumen-col">
                <div class="sf-resumen-card">
                    <h4>Resumen</h4>

                    <div class="sf-resumen-rows">
                        <div class="sf-resumen-row">
                            <span>Clase</span>
                            <strong>@NombreClase</strong>
                        </div>

                        <div class="sf-resumen-row">
                            <span>Entrenador</span>
                            <strong>@NombreEntrenador</strong>
                        </div>

                        <div class="sf-resumen-row">
                            <span>Salón</span>
                            <strong>@NombreSalon</strong>
                        </div>

                        <div class="sf-resumen-row">
                            <span>Fecha</span>
                            <strong>@FechaResumen</strong>
                        </div>

                        <div class="sf-resumen-row">
                            <span>Horario</span>
                            <strong>@HoraInicioInput - @HoraFinInput</strong>
                        </div>

                        <div class="sf-resumen-row">
                            <span>Cupos disponibles</span>
                            <strong>@CuposDisponiblesInput</strong>
                        </div>

                        <div class="sf-resumen-row">
                            <span>Estado visual</span>
                            <strong class="@EstadoClass">@EstadoVisual</strong>
                        </div>
                    </div>
                </div>

                <div class="sf-admin-nota">
                    <span class="sf-nota-icon">⚠️</span>
                    <p>Modificar la fecha u horario puede afectar las reservas actuales de los socios.</p>
                </div>
            </div>

        </div>
    }
</div>

@code {
    [Parameter]
    public int Id { get; set; }

    private SesionClaseDTO? sesionOriginal;

    private int claseId = 0;
    private int entrenadorId = 0;
    private int salonId = 0;

    private string FechaInput { get; set; } = "";
    private string HoraInicioInput { get; set; } = "";
    private string HoraFinInput { get; set; } = "";
    private string CuposDisponiblesInput { get; set; } = "0";

    private string estadoAdministrativo = "Programada";

    private bool guardando = false;
    private bool Cargando = true;

    private string MensajeFormulario = "";
    private string ClaseMensajeFormulario = "";

    private Dictionary<string, string> errores = new();

    private List<ClaseGrupalDTO> clasesDisponibles = new();
    private List<EntrenadorDTO> entrenadoresDisponibles = new();
    private List<SalonDTO> salonesDisponibles = new();

    private static readonly string[] FormatosHora =
    {
        "HH:mm",
        "H:mm",
        "HH:mm:ss",
        "H:mm:ss"
    };

    private string NombreClase => clasesDisponibles.FirstOrDefault(c => c.IdClase == claseId)?.NombreDisciplina ?? "—";
    private string NombreEntrenador => entrenadoresDisponibles.FirstOrDefault(e => e.IdUsuario == entrenadorId)?.NombreCompleto ?? "—";
    private string NombreSalon => salonesDisponibles.FirstOrDefault(s => s.IdSalon == salonId)?.NombreSalon ?? "—";

    private string FechaResumen
    {
        get
        {
            if (DateTime.TryParseExact(
                    FechaInput,
                    "yyyy-MM-dd",
                    CultureInfo.InvariantCulture,
                    DateTimeStyles.None,
                    out var fecha
                ))
            {
                return fecha.ToString("dd/MM/yyyy");
            }

            return "—";
        }
    }

    private string EstadoVisual
    {
        get
        {
            if (estadoAdministrativo == "Cancelada")
                return "Cancelada";

            if (DateTime.TryParseExact(
                    FechaInput,
                    "yyyy-MM-dd",
                    CultureInfo.InvariantCulture,
                    DateTimeStyles.None,
                    out var fecha
                ) &&
                TryParseHora(HoraFinInput, out var horaFin))
            {
                var fechaHoraFin = fecha.Date.Add(horaFin.ToTimeSpan());

                if (fechaHoraFin < DateTime.Now)
                    return "Finalizada";
            }

            return "Programada";
        }
    }

    private string EstadoClass => EstadoVisual switch
    {
        "Programada" => "rsm-activo",
        "Cancelada" => "rsm-inactivo",
        "Finalizada" => "rsm-finalizada",
        _ => ""
    };

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var taskClases = ClaseService.ListarClasesGrupalesAsync();
            var taskEntrenadores = EntrenadorService.ListarEntrenadoresAsync();
            var taskSalones = SalonService.ListarSalonesAsync();
            var taskSesion = SesionService.ObtenerPorIdAsync(Id);

            await Task.WhenAll(taskClases, taskEntrenadores, taskSalones, taskSesion);

            clasesDisponibles = await taskClases;
            entrenadoresDisponibles = await taskEntrenadores;
            salonesDisponibles = await taskSalones;
            sesionOriginal = await taskSesion;

            if (sesionOriginal != null)
            {
                claseId = sesionOriginal.ClaseGrupal?.IdClase ?? 0;
                entrenadorId = sesionOriginal.Entrenador?.IdUsuario ?? 0;
                salonId = sesionOriginal.Salon?.IdSalon ?? 0;

                CuposDisponiblesInput = sesionOriginal.CuposDisponibles.ToString();

                FechaInput = sesionOriginal.FechaSesion == default
                    ? DateTime.Today.ToString("yyyy-MM-dd")
                    : sesionOriginal.FechaSesion.ToString("yyyy-MM-dd");

                HoraInicioInput = NormalizarHoraParaInput(sesionOriginal.HoraInicio);
                HoraFinInput = NormalizarHoraParaInput(sesionOriginal.HoraFin);

                estadoAdministrativo = sesionOriginal.Activo ? "Programada" : "Cancelada";
            }
        }
        finally
        {
            Cargando = false;
        }
    }

    private void CambiarFechaInput(ChangeEventArgs e)
    {
        FechaInput = e.Value?.ToString() ?? "";
        errores.Remove("fecha");
    }

    private void CambiarHoraInicioInput(ChangeEventArgs e)
    {
        HoraInicioInput = NormalizarHoraTexto(e.Value?.ToString() ?? "");
        errores.Remove("horaInicio");
    }

    private void CambiarHoraFinInput(ChangeEventArgs e)
    {
        HoraFinInput = NormalizarHoraTexto(e.Value?.ToString() ?? "");
        errores.Remove("horaFin");
    }

    private void CambiarCuposDisponiblesInput(ChangeEventArgs e)
    {
        CuposDisponiblesInput = e.Value?.ToString() ?? "";
        errores.Remove("cuposDisponibles");
    }

    private bool Validar(out DateTime fechaSesion, out TimeOnly horaInicio, out TimeOnly horaFin, out int cuposDisponibles)
    {
        errores.Clear();

        fechaSesion = default;
        horaInicio = default;
        horaFin = default;
        cuposDisponibles = 0;

        FechaInput = FechaInput?.Trim() ?? "";
        HoraInicioInput = NormalizarHoraTexto(HoraInicioInput);
        HoraFinInput = NormalizarHoraTexto(HoraFinInput);
        CuposDisponiblesInput = CuposDisponiblesInput?.Trim() ?? "";

        if (claseId == 0)
            errores["claseId"] = "Selecciona una clase.";

        if (entrenadorId == 0)
            errores["entrenadorId"] = "Selecciona un entrenador.";

        if (salonId == 0)
            errores["salonId"] = "Selecciona un salón.";

        if (!int.TryParse(CuposDisponiblesInput, out cuposDisponibles))
            errores["cuposDisponibles"] = "Los cupos disponibles deben ser numéricos.";
        else if (cuposDisponibles < 0)
            errores["cuposDisponibles"] = "Los cupos disponibles no pueden ser negativos.";

        if (!DateTime.TryParseExact(
                FechaInput,
                "yyyy-MM-dd",
                CultureInfo.InvariantCulture,
                DateTimeStyles.None,
                out fechaSesion
            ))
        {
            errores["fecha"] = "La fecha es obligatoria.";
        }

        bool horaInicioValida = TryParseHora(HoraInicioInput, out horaInicio);
        bool horaFinValida = TryParseHora(HoraFinInput, out horaFin);

        if (!horaInicioValida)
            errores["horaInicio"] = "La hora de inicio es obligatoria.";

        if (!horaFinValida)
            errores["horaFin"] = "La hora de fin es obligatoria.";

        if (horaInicioValida && horaFinValida && horaFin <= horaInicio)
            errores["horaFin"] = "La hora de fin debe ser mayor a la de inicio.";

        return errores.Count == 0;
    }

    private async Task GuardarCambios()
    {
        MensajeFormulario = "";
        ClaseMensajeFormulario = "";

        if (!Validar(out var fechaSesion, out var horaInicio, out var horaFin, out var cuposDisponibles))
            return;

        guardando = true;

        var fechaInicio = fechaSesion.Date.Add(horaInicio.ToTimeSpan());
        var fechaFin = fechaSesion.Date.Add(horaFin.ToTimeSpan());

        var sesionEditada = new SesionClaseDTO
        {
            IdSesion = Id,

            // Al mediodía para evitar desfase de fecha por zona horaria en Java/MySQL.
            FechaSesion = fechaSesion.Date.AddHours(12),

            HoraInicio = fechaInicio,
            HoraFin = fechaFin,
            CuposDisponibles = cuposDisponibles,
            Activo = estadoAdministrativo == "Programada",
            ClaseGrupal = new ClaseGrupalDTO { IdClase = claseId },
            Entrenador = new EntrenadorDTO { IdUsuario = entrenadorId },
            Salon = new SalonDTO { IdSalon = salonId }
        };

        var resultado = await SesionService.ActualizarAsync(Id, sesionEditada);

        guardando = false;

        if (!resultado.StartsWith("Error") && !resultado.ToLower().Contains("error"))
        {
            MostrarExito("Sesión actualizada correctamente.");
            await Task.Delay(800);
            Navigation.NavigateTo("/admin/sesiones");
        }
        else
        {
            MostrarError(resultado);
        }
    }

    private void Cancelar()
    {
        Navigation.NavigateTo("/admin/sesiones");
    }

    private static bool TryParseHora(string valor, out TimeOnly hora)
    {
        valor = NormalizarHoraTexto(valor);

        return TimeOnly.TryParseExact(
            valor,
            FormatosHora,
            CultureInfo.InvariantCulture,
            DateTimeStyles.None,
            out hora
        );
    }

    private static string NormalizarHoraParaInput(DateTime hora)
    {
        if (hora == default)
            return "";

        return hora.ToString("HH:mm");
    }

    private static string NormalizarHoraTexto(string valor)
    {
        if (string.IsNullOrWhiteSpace(valor))
            return "";

        valor = valor.Trim();

        if (TimeOnly.TryParseExact(
                valor,
                FormatosHora,
                CultureInfo.InvariantCulture,
                DateTimeStyles.None,
                out var hora
            ))
        {
            return hora.ToString("HH:mm");
        }

        return valor;
    }

    private void MostrarError(string mensaje)
    {
        MensajeFormulario = mensaje;
        ClaseMensajeFormulario = "trainer-message error";
    }

    private void MostrarExito(string mensaje)
    {
        MensajeFormulario = mensaje;
        ClaseMensajeFormulario = "trainer-message success";
    }
}