@page "/socio/membresia/renovar"
@using System.Globalization
@using GigaChadSys.Servicios
@using GigaChadSys.Servicios.DTO
@layout SocioLayout
@rendermode InteractiveServer
@inject SessionServicio Session
@inject SuscripcionServicio SuscripcionService
@inject MembresiaBasicServicio MembresiaBasicService
@inject MembresiaBlackServicio MembresiaBlackService
@inject PagoServicio PagoService
@inject SocioServicio SocioService
@inject NavigationManager Navigation
@inject ToastService ToastService

<section class="renew-membership-page">

    <div class="renew-header">
        <h1>Renovar Membresía</h1>
        <p>Elige tu plan y confirma la renovación de tu membresía.</p>
    </div>

    <div class="renew-current-card">
        <div class="renew-current-plan">
            <div class="renew-current-icon">♛</div>

            <div>
                <span>Plan actual</span>
                <strong>@NombrePlanActual</strong>
            </div>
        </div>

        <div class="renew-current-info">
            <span>Estado</span>
            <strong class="@ClaseEstadoActual">@EstadoActual</strong>
        </div>

        <div class="renew-current-info">
            <span>Fecha de vencimiento</span>
            <strong>@FechaVencimientoActual</strong>
        </div>

        <div class="renew-current-info">
            <span>Último pago</span>
            <strong>@UltimoPagoTexto</strong>
        </div>
    </div>

    <h2 class="renew-step-title">1. Selecciona tu nuevo plan</h2>

    <div class="renew-plan-layout">

        <div class="renew-plans-grid">

            <button type="button"
                    class="@ClasePlanBasic"
                    @onclick="SeleccionarBasic">

                <div class="renew-plan-top">
                    <div class="renew-plan-icon basic">♕</div>

                    <div>
                        <h3>Membresía Basic</h3>
                        <div>
                            <strong>S/@PrecioBasic</strong>
                            <span>/mes</span>
                        </div>
                    </div>
                </div>

                <ul>
                    <li>Acceso a sala de musculación</li>
                    <li>Acceso a cardio</li>
                    <li>Vestuario incluido</li>
                </ul>

                <div class="renew-radio-circle">
                    @if (PlanSeleccionado == "basic")
                    {
                        <span></span>
                    }
                </div>
            </button>

            <button type="button"
                    class="@ClasePlanBlack"
                    @onclick="SeleccionarBlack">

                <span class="recommended-badge">Plan recomendado</span>

                <div class="renew-plan-top">
                    <div class="renew-plan-icon black">♛</div>

                    <div>
                        <h3>Membresía Black</h3>
                        <div>
                            <strong>S/@PrecioBlack</strong>
                            <span>/mes</span>
                        </div>
                    </div>
                </div>

                <ul>
                    <li>Todo lo de Basic</li>
                    <li>Clases grupales ilimitadas</li>
                    <li>Acceso 24/7</li>
                    <li>Zona de spa</li>
                    <li>Entrenador personal 2x/mes</li>
                </ul>

                <div class="renew-radio-circle">
                    @if (PlanSeleccionado == "black")
                    {
                        <span></span>
                    }
                </div>
            </button>

        </div>

        <aside class="renew-summary-card">
            <h2>Resumen de pago</h2>

            <div class="renew-summary-row">
                <span>Plan seleccionado</span>
                <strong>@NombrePlanSeleccionado</strong>
            </div>

            <div class="renew-summary-row">
                <span>Precio mensual</span>
                <strong>S/@PrecioSeleccionado</strong>
            </div>

            <div class="renew-summary-total">
                <span>Total a pagar</span>
                <strong>S/@PrecioSeleccionado</strong>
            </div>

            <div class="renew-summary-row">
                <span>Nueva fecha de vencimiento</span>
                <strong>@NuevaFechaVencimiento</strong>
            </div>
        </aside>

    </div>

    <h2 class="renew-step-title">2. Detalles de renovación</h2>

    <div class="renew-details-grid">

        <div class="renew-detail-card">
            <label>Fecha de inicio</label>

            <input type="date"
                   value="@FechaInicio"
                   @oninput="CambiarFechaInicio"
                   @onchange="CambiarFechaInicio"
                   class="@(IntentoGuardar && !DateTime.TryParseExact(FechaInicio, "yyyy-MM-dd", CultureInfo.InvariantCulture, DateTimeStyles.None, out _) ? "input-error" : "")" />
        </div>

        <div class="renew-detail-card">
            <label>Método de pago</label>

            <div class="renew-methods">
                <button type="button"
                        class="@ClaseMetodoTarjeta"
                        @onclick="SeleccionarTarjeta">
                    ▭ Tarjeta
                </button>

                <button type="button"
                        class="@ClaseMetodoEfectivo"
                        @onclick="SeleccionarEfectivo">
                    ⊙ Efectivo
                </button>

                <button type="button"
                        class="@ClaseMetodoDebito"
                        @onclick="SeleccionarDebito">
                    ▭ Débito
                </button>
            </div>
        </div>

        <div class="renew-auto-card">
            <div>
                <strong>Renovación automática</strong>
                <p>Renovar automáticamente al finalizar el período.</p>
            </div>

            <button type="button"
                    class="@ClaseSwitch"
                    @onclick="CambiarRenovacionAutomatica">
                <span></span>
            </button>
        </div>

    </div>

    <div class="renew-actions">
        <a class="renew-cancel-button" href="/socio/membresia">
            Cancelar
        </a>

        <button type="button"
                class="renew-confirm-button"
                disabled="@Procesando"
                @onclick="ConfirmarRenovacion">
            @(Procesando ? "Procesando..." : "Confirmar Renovación")
        </button>
    </div>

</section>

@code {
    private string PlanSeleccionado { get; set; } = "black";
    private string MetodoPago { get; set; } = "Tarjeta";
    private bool RenovacionAutomatica { get; set; } = false;
    private bool Procesando { get; set; } = false;
    private bool IntentoGuardar { get; set; } = false;

    private string FechaInicio { get; set; } = DateTime.Today.ToString("yyyy-MM-dd", CultureInfo.InvariantCulture);
    private string NuevaFechaVencimiento { get; set; } = DateTime.Today.AddMonths(1).ToString("yyyy-MM-dd", CultureInfo.InvariantCulture);

    private int IdBasic = 1;
    private int IdBlack = 1;
    private string PrecioBasic = "79.00";
    private string PrecioBlack = "119.00";

    private string NombrePlanActual = "Sin plan";
    private string EstadoActual = "Inactiva";
    private string ClaseEstadoActual = "renew-inactive-dot";
    private string FechaVencimientoActual = "—";
    private string UltimoPagoTexto = "—";

    private string NombrePlanSeleccionado =>
        PlanSeleccionado == "black" ? "Membresía Black" : "Membresía Basic";

    private string PrecioSeleccionado =>
        PlanSeleccionado == "black" ? PrecioBlack : PrecioBasic;

    private string ClasePlanBasic =>
        PlanSeleccionado == "basic" ? "renew-plan-card selected" : "renew-plan-card";

    private string ClasePlanBlack =>
        PlanSeleccionado == "black" ? "renew-plan-card selected recommended" : "renew-plan-card recommended";

    private string ClaseMetodoTarjeta =>
        MetodoPago == "Tarjeta" ? "renew-method selected" : "renew-method";

    private string ClaseMetodoEfectivo =>
        MetodoPago == "Efectivo" ? "renew-method selected" : "renew-method";

    private string ClaseMetodoDebito =>
        MetodoPago == "Debito" ? "renew-method selected" : "renew-method";

    private string ClaseSwitch =>
        RenovacionAutomatica ? "renew-switch active" : "renew-switch";

    protected override async Task OnInitializedAsync()
    {
        await CargarDatosIniciales();
    }

    private async Task CargarDatosIniciales()
    {
        var basicos = await MembresiaBasicService.ListarMembresiasBasicAsync();
        var basic = basicos.FirstOrDefault();

        if (basic != null)
        {
            IdBasic = basic.IdMembresiaBasic;
            PrecioBasic = basic.CostoMantenimientoMensual.ToString("0.00", CultureInfo.InvariantCulture);
        }

        var blacks = await MembresiaBlackService.ListarMembresiasBlackAsync();
        var black = blacks.FirstOrDefault();

        if (black != null)
        {
            IdBlack = black.IdMembresiaBlack;
            PrecioBlack = (black.CostoMantenimientoAnual / 12.0).ToString("0.00", CultureInfo.InvariantCulture);
        }

        if (!Session.EstaAutenticado)
            return;

        var suscripciones = await SuscripcionService.ListarSuscripcionesAsync();

        var suscripcionActual = suscripciones
            .Where(s => s.IdUsuario == Session.IdUsuario && s.Activo && s.EsActiva)
            .OrderByDescending(s => s.FechaFinMembresia ?? DateTime.MinValue)
            .ThenByDescending(s => s.IdSuscripcion)
            .FirstOrDefault();

        if (suscripcionActual != null)
        {
            NombrePlanActual = $"Membresía {suscripcionActual.TipoPlan}";
            EstadoActual = "Activa";
            ClaseEstadoActual = "renew-active-dot";
            FechaVencimientoActual = suscripcionActual.FechaFinTexto;

            if (suscripcionActual.FechaFinMembresia.HasValue)
            {
                var inicio = suscripcionActual.FechaFinMembresia.Value.Date.AddDays(1);
                FechaInicio = inicio.ToString("yyyy-MM-dd", CultureInfo.InvariantCulture);
                NuevaFechaVencimiento = inicio.AddMonths(1).ToString("yyyy-MM-dd", CultureInfo.InvariantCulture);
            }

            var pagos = await PagoService.ListarPagosAsync();
            var pago = pagos.FirstOrDefault(p => p.IdPago == suscripcionActual.IdPago);

            if (pago != null)
            {
                UltimoPagoTexto = pago.FechaPagoTexto;
            }
        }
    }

    private void SeleccionarBasic()
    {
        PlanSeleccionado = "basic";
    }

    private void SeleccionarBlack()
    {
        PlanSeleccionado = "black";
    }

    private void SeleccionarTarjeta()
    {
        MetodoPago = "Tarjeta";
    }

    private void SeleccionarEfectivo()
    {
        MetodoPago = "Efectivo";
    }

    private void SeleccionarDebito()
    {
        MetodoPago = "Debito";
    }

    private void CambiarRenovacionAutomatica()
    {
        RenovacionAutomatica = !RenovacionAutomatica;
    }

    private void CambiarFechaInicio(ChangeEventArgs e)
    {
        string valor = e.Value?.ToString() ?? "";

        if (DateTime.TryParseExact(
                valor,
                "yyyy-MM-dd",
                CultureInfo.InvariantCulture,
                DateTimeStyles.None,
                out DateTime dt
            ))
        {
            FechaInicio = dt.ToString("yyyy-MM-dd", CultureInfo.InvariantCulture);
            NuevaFechaVencimiento = dt.AddMonths(1).ToString("yyyy-MM-dd", CultureInfo.InvariantCulture);
        }
    }

    private async Task ConfirmarRenovacion()
    {
        IntentoGuardar = true;

        if (Procesando)
            return;

        if (!Session.EstaAutenticado)
        {
            ToastService.ShowError("Debes iniciar sesión para renovar.");
            return;
        }

        if (!DateTime.TryParseExact(
                FechaInicio,
                "yyyy-MM-dd",
                CultureInfo.InvariantCulture,
                DateTimeStyles.None,
                out DateTime dtInicio
            ))
        {
            ToastService.ShowError("Debes seleccionar una fecha de inicio válida.");
            return;
        }

        Procesando = true;

        try
        {
            dtInicio = dtInicio.Date;
            DateTime dtFin = dtInicio.AddMonths(1).Date;

            int idMetodo = MetodoPago == "Efectivo" ? 1 : MetodoPago == "Debito" ? 2 : 3;

            var nuevoPago = new PagoDTO
            {
                FechaPago = DateTime.Today,
                Monto = double.Parse(PrecioSeleccionado, CultureInfo.InvariantCulture),
                Tipo = $"Renovación {NombrePlanSeleccionado}",
                MetodoPago = idMetodo,
                Activo = true
            };

            var resultadoPago = await PagoService.RegistrarAsync(nuevoPago);
            string mensajePago = resultadoPago.Mensaje ?? "";

            if (mensajePago.StartsWith("Error") || mensajePago.ToLower().Contains("error"))
            {
                ToastService.ShowError("Error al registrar el pago: " + mensajePago);
                return;
            }

            int idPagoGenerado = resultadoPago.IdPago ?? 0;

            if (idPagoGenerado <= 0)
            {
                idPagoGenerado = await BuscarUltimoPagoCreado(nuevoPago);
            }

            if (idPagoGenerado <= 0)
            {
                ToastService.ShowError("No se pudo obtener el ID del pago generado.");
                return;
            }

            var nuevaSuscripcion = new SuscripcionDTO
            {
                IdUsuario = Session.IdUsuario,
                EstadoMembresia = "activa",
                FechaIngreso = dtInicio,
                FechaFinMembresia = dtFin,
                FechaIngresoTexto = dtInicio.ToString("yyyy-MM-dd", CultureInfo.InvariantCulture),
                FechaFinMembresiaTexto = dtFin.ToString("yyyy-MM-dd", CultureInfo.InvariantCulture),
                Activo = true,
                IdPago = idPagoGenerado
            };

            if (PlanSeleccionado == "black")
            {
                nuevaSuscripcion.IdMembresiaBlack = IdBlack;
                nuevaSuscripcion.IdMembresiaBasic = null;
            }
            else
            {
                nuevaSuscripcion.IdMembresiaBasic = IdBasic;
                nuevaSuscripcion.IdMembresiaBlack = null;
            }

            var resultadoSub = await SuscripcionService.RegistrarAsync(nuevaSuscripcion);

            if (resultadoSub.StartsWith("Error") || resultadoSub.ToLower().Contains("error"))
            {
                ToastService.ShowError("Error al registrar la suscripción: " + resultadoSub);
                return;
            }

            await DesactivarSuscripcionesAnteriores(idPagoGenerado);

            var socioActual = await SocioService.ObtenerPorIdAsync(Session.IdUsuario);

            if (socioActual != null)
            {
                socioActual.EstadoMembresia = true;
                await SocioService.ActualizarAsync(socioActual.IdUsuario, socioActual);
            }

            ToastService.ShowSuccess($"¡Renovación confirmada para {NombrePlanSeleccionado}!");

            Navigation.NavigateTo("/socio/membresia");
        }
        finally
        {
            Procesando = false;
        }
    }

    private async Task DesactivarSuscripcionesAnteriores(int idPagoNuevo)
    {
        var suscripciones = await SuscripcionService.ListarSuscripcionesAsync();

        var nueva = suscripciones
            .Where(s =>
                s.IdUsuario == Session.IdUsuario &&
                s.IdPago == idPagoNuevo)
            .OrderByDescending(s => s.IdSuscripcion)
            .FirstOrDefault();

        int idNuevaSuscripcion = nueva?.IdSuscripcion ?? 0;

        var anteriores = suscripciones
            .Where(s =>
                s.IdUsuario == Session.IdUsuario &&
                s.Activo &&
                s.IdSuscripcion != idNuevaSuscripcion)
            .ToList();

        foreach (var anterior in anteriores)
        {
            anterior.Activo = false;
            anterior.EstadoMembresia = "inactiva";

            if (anterior.FechaIngreso.HasValue)
            {
                anterior.FechaIngresoTexto = anterior.FechaIngreso.Value.ToString("yyyy-MM-dd", CultureInfo.InvariantCulture);
            }

            if (anterior.FechaFinMembresia.HasValue)
            {
                anterior.FechaFinMembresiaTexto = anterior.FechaFinMembresia.Value.ToString("yyyy-MM-dd", CultureInfo.InvariantCulture);
            }

            await SuscripcionService.ActualizarAsync(anterior.IdSuscripcion, anterior);
        }
    }

    private async Task<int> BuscarUltimoPagoCreado(PagoDTO pagoReferencia)
    {
        var pagos = await PagoService.ListarPagosAsync();

        var pagoEncontrado = pagos
            .Where(p =>
                p.Activo &&
                Math.Abs(p.Monto - pagoReferencia.Monto) < 0.01 &&
                p.MetodoPago == pagoReferencia.MetodoPago &&
                string.Equals(p.Tipo, pagoReferencia.Tipo, StringComparison.OrdinalIgnoreCase)
            )
            .OrderByDescending(p => p.IdPago)
            .FirstOrDefault();

        return pagoEncontrado?.IdPago ?? 0;
    }

}