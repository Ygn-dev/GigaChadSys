@page "/socio/membresia/renovar"
@using GigaChadSys.Servicios
@using GigaChadSys.Servicios.DTO
@layout SocioLayout
@rendermode InteractiveServer
@inject SessionServicio Session
@inject SuscripcionServicio SuscripcionService
@inject MembresiaBasicServicio MembresiaBasicService
@inject MembresiaBlackServicio MembresiaBlackService
@inject PagoServicio PagoService
@inject NavigationManager Navigation

<section class="renew-membership-page">

    <div class="renew-header">
        <h1>Renovar Membresía</h1>
        <p>Elige tu plan y confirma la renovación de tu membresía.</p>
    </div>

    @if (!string.IsNullOrWhiteSpace(Mensaje))
    {
        <div class="@ClaseMensaje">
            @Mensaje
        </div>
    }

    <div class="renew-current-card">
        <div class="renew-current-plan">
            <div class="renew-current-icon">♛</div>

            <div>
                <span>Plan actual</span>
                <strong>@NombrePlanActual</strong>
            </div>
        </div>

        <div class="renew-current-info">
            <span>Estado</span>
            <strong class="@ClaseEstadoActual">@EstadoActual</strong>
        </div>

        <div class="renew-current-info">
            <span>Fecha de vencimiento</span>
            <strong>@FechaVencimientoActual</strong>
        </div>

        <div class="renew-current-info">
            <span>Último pago</span>
            <strong>@UltimoPagoTexto</strong>
        </div>
    </div>

    <h2 class="renew-step-title">1. Selecciona tu nuevo plan</h2>

    <div class="renew-plan-layout">

        <div class="renew-plans-grid">

            <button type="button"
                    class="@ClasePlanBasic"
                    @onclick="SeleccionarBasic">

                <div class="renew-plan-top">
                    <div class="renew-plan-icon basic">♕</div>

                    <div>
                        <h3>Membresía Basic</h3>
                        <div>
                            <strong>S/@PrecioBasic</strong>
                            <span>/mes</span>
                        </div>
                    </div>
                </div>

                <ul>
                    <li>Acceso a sala de musculación</li>
                    <li>Acceso a cardio</li>
                    <li>Vestuario incluido</li>
                </ul>

                <div class="renew-radio-circle">
                    @if (PlanSeleccionado == "basic")
                    {
                        <span></span>
                    }
                </div>
            </button>

            <button type="button"
                    class="@ClasePlanBlack"
                    @onclick="SeleccionarBlack">

                <span class="recommended-badge">Plan recomendado</span>

                <div class="renew-plan-top">
                    <div class="renew-plan-icon black">♛</div>

                    <div>
                        <h3>Membresía Black</h3>
                        <div>
                            <strong>S/@PrecioBlack</strong>
                            <span>/mes</span>
                        </div>
                    </div>
                </div>

                <ul>
                    <li>Todo lo de Basic</li>
                    <li>Clases grupales ilimitadas</li>
                    <li>Acceso 24/7</li>
                    <li>Zona de spa</li>
                    <li>Entrenador personal 2x/mes</li>
                </ul>

                <div class="renew-radio-circle">
                    @if (PlanSeleccionado == "black")
                    {
                        <span></span>
                    }
                </div>
            </button>

        </div>

        <aside class="renew-summary-card">
            <h2>Resumen de pago</h2>

            <div class="renew-summary-row">
                <span>Plan seleccionado</span>
                <strong>@NombrePlanSeleccionado</strong>
            </div>

            <div class="renew-summary-row">
                <span>Precio mensual</span>
                <strong>S/@PrecioSeleccionado</strong>
            </div>

            <div class="renew-summary-total">
                <span>Total a pagar</span>
                <strong>S/@PrecioSeleccionado</strong>
            </div>

            <div class="renew-summary-row">
                <span>Nueva fecha de vencimiento</span>
                <strong>@NuevaFechaVencimiento</strong>
            </div>
        </aside>

    </div>

    <h2 class="renew-step-title">2. Detalles de renovación</h2>

    <div class="renew-details-grid">

        <div class="renew-detail-card">
            <label>Fecha de inicio</label>

            <input type="date"
                   value="@FechaInicio"
                   @onchange="CambiarFechaInicio" />
        </div>

        <div class="renew-detail-card">
            <label>Método de pago</label>

            <div class="renew-methods">
                <button type="button"
                        class="@ClaseMetodoTarjeta"
                        @onclick="SeleccionarTarjeta">
                    ▭ Tarjeta
                </button>

                <button type="button"
                        class="@ClaseMetodoEfectivo"
                        @onclick="SeleccionarEfectivo">
                    ⊙ Efectivo
                </button>

                <button type="button"
                        class="@ClaseMetodoDebito"
                        @onclick="SeleccionarDebito">
                    ▭ Débito
                </button>
            </div>
        </div>

        <div class="renew-auto-card">
            <div>
                <strong>Renovación automática</strong>
                <p>Renovar automáticamente al finalizar el período.</p>
            </div>

            <button type="button"
                    class="@ClaseSwitch"
                    @onclick="CambiarRenovacionAutomatica">
                <span></span>
            </button>
        </div>

    </div>

    <div class="renew-actions">
        <a class="renew-cancel-button" href="/socio/membresia">
            Cancelar
        </a>

        <button type="button"
                class="renew-confirm-button"
                @onclick="ConfirmarRenovacion">
            Confirmar Renovación
        </button>
    </div>

</section>

@code {
    private string PlanSeleccionado { get; set; } = "black";
    private string MetodoPago { get; set; } = "Tarjeta";
    private bool RenovacionAutomatica { get; set; } = false;

    private string FechaInicio { get; set; } = DateTime.Today.ToString("yyyy-MM-dd");
    private string NuevaFechaVencimiento { get; set; } = DateTime.Today.AddMonths(1).ToString("yyyy-MM-dd");

    private string Mensaje { get; set; } = "";
    private string ClaseMensaje { get; set; } = "";

    // Planes backend
    private int IdBasic = 1;
    private int IdBlack = 1;
    private string PrecioBasic = "0.00";
    private string PrecioBlack = "0.00";

    // Plan actual
    private string NombrePlanActual = "Sin plan";
    private string EstadoActual = "Inactiva";
    private string ClaseEstadoActual = "renew-inactive-dot";
    private string FechaVencimientoActual = "—";
    private string UltimoPagoTexto = "—";
    private bool TienePlanActivo = false;

    private string NombrePlanSeleccionado =>
        PlanSeleccionado == "black" ? "Membresía Black" : "Membresía Basic";

    private string PrecioSeleccionado =>
        PlanSeleccionado == "black" ? PrecioBlack : PrecioBasic;

    private string ClasePlanBasic =>
        PlanSeleccionado == "basic" ? "renew-plan-card selected" : "renew-plan-card";

    private string ClasePlanBlack =>
        PlanSeleccionado == "black" ? "renew-plan-card selected recommended" : "renew-plan-card recommended";

    private string ClaseMetodoTarjeta =>
        MetodoPago == "Tarjeta" ? "renew-method selected" : "renew-method";

    private string ClaseMetodoEfectivo =>
        MetodoPago == "Efectivo" ? "renew-method selected" : "renew-method";

    private string ClaseMetodoDebito =>
        MetodoPago == "Debito" ? "renew-method selected" : "renew-method";

    private string ClaseSwitch =>
        RenovacionAutomatica ? "renew-switch active" : "renew-switch";

    protected override async Task OnInitializedAsync()
    {
        // Cargar membresias
        var basicos = await MembresiaBasicService.ListarMembresiasBasicAsync();
        var basic = basicos.FirstOrDefault();
        if (basic != null)
        {
            IdBasic = basic.IdMembresiaBasic;
            PrecioBasic = basic.CostoMantenimientoMensual.ToString("0.00");
        }

        var blacks = await MembresiaBlackService.ListarMembresiasBlackAsync();
        var black = blacks.FirstOrDefault();
        if (black != null)
        {
            IdBlack = black.IdMembresiaBlack;
            PrecioBlack = (black.CostoMantenimientoAnual / 12.0).ToString("0.00");
        }

        if (Session.EstaAutenticado)
        {
            var suscripciones = await SuscripcionService.ListarSuscripcionesAsync();
            var suscripcion = suscripciones.FirstOrDefault(s => s.IdUsuario == Session.IdUsuario && s.Activo);

            if (suscripcion != null)
            {
                TienePlanActivo = true;
                NombrePlanActual = $"Membresía {suscripcion.TipoPlan}";
                EstadoActual = "Activa";
                ClaseEstadoActual = "renew-active-dot";
                FechaVencimientoActual = suscripcion.FechaFinTexto;
                
                // Fecha por defecto al renovar (el día siguiente al vencimiento)
                if (suscripcion.FechaFinMembresia.HasValue)
                {
                    FechaInicio = suscripcion.FechaFinMembresia.Value.AddDays(1).ToString("yyyy-MM-dd");
                    NuevaFechaVencimiento = suscripcion.FechaFinMembresia.Value.AddMonths(1).ToString("yyyy-MM-dd");
                }

                // Obtener pago
                var pagos = await PagoService.ListarPagosAsync();
                var pago = pagos.FirstOrDefault(p => p.IdPago == suscripcion.IdPago);
                if (pago != null) UltimoPagoTexto = pago.FechaPagoTexto;
            }
        }
    }

    private void SeleccionarBasic()
    {
        PlanSeleccionado = "basic";
    }

    private void SeleccionarBlack()
    {
        PlanSeleccionado = "black";
    }

    private void SeleccionarTarjeta()
    {
        MetodoPago = "Tarjeta";
    }

    private void SeleccionarEfectivo()
    {
        MetodoPago = "Efectivo";
    }

    private void SeleccionarDebito()
    {
        MetodoPago = "Debito";
    }

    private void CambiarRenovacionAutomatica()
    {
        RenovacionAutomatica = !RenovacionAutomatica;
    }

    private void CambiarFechaInicio(ChangeEventArgs e)
    {
        if (DateTime.TryParse(e.Value?.ToString(), out DateTime dt))
        {
            FechaInicio = dt.ToString("yyyy-MM-dd");
            NuevaFechaVencimiento = dt.AddMonths(1).ToString("yyyy-MM-dd");
        }
    }

    private async Task ConfirmarRenovacion()
    {
        if (!Session.EstaAutenticado)
        {
            Mensaje = "Debes iniciar sesión para renovar.";
            ClaseMensaje = "renew-message error";
            return;
        }

        if (!DateTime.TryParse(FechaInicio, out DateTime dtInicio))
        {
            Mensaje = "Debes seleccionar una fecha de inicio válida.";
            ClaseMensaje = "renew-message error";
            return;
        }
        
        DateTime dtFin = dtInicio.AddMonths(1);

        int idMetodo = MetodoPago == "Efectivo" ? 1 : MetodoPago == "Debito" ? 2 : 3;

        var nuevoPago = new PagoDTO
        {
            FechaPago = DateTime.Now,
            Monto = double.Parse(PrecioSeleccionado),
            Tipo = $"Renovación {NombrePlanSeleccionado}",
            MetodoPago = idMetodo,
            Activo = true
        };

        var resultadoPago = await PagoService.RegistrarAsync(nuevoPago);
        if (resultadoPago.StartsWith("Error") || resultadoPago.ToLower().Contains("error"))
        {
            Mensaje = "Error al registrar el pago: " + resultadoPago;
            ClaseMensaje = "renew-message error";
            return;
        }

        // Recuperar ID de pago recién creado
        var pagos = await PagoService.ListarPagosAsync();
        var ultimoPago = pagos.OrderByDescending(p => p.IdPago).FirstOrDefault();
        int idPagoGenerado = ultimoPago?.IdPago ?? 1;

        var nuevaSuscripcion = new SuscripcionDTO
        {
            IdUsuario = Session.IdUsuario,
            EstadoMembresia = "activa",
            FechaIngreso = dtInicio,
            FechaFinMembresia = dtFin,
            Activo = true,
            IdPago = idPagoGenerado
        };

        if (PlanSeleccionado == "black")
            nuevaSuscripcion.IdMembresiaBlack = IdBlack;
        else
            nuevaSuscripcion.IdMembresiaBasic = IdBasic;

        var resultadoSub = await SuscripcionService.RegistrarAsync(nuevaSuscripcion);

        if (!resultadoSub.StartsWith("Error") && !resultadoSub.ToLower().Contains("error"))
        {
            Mensaje = $"¡Renovación confirmada para {NombrePlanSeleccionado}!";
            ClaseMensaje = "renew-message success";
            await Task.Delay(1500);
            Navigation.NavigateTo("/socio/membresia");
        }
        else
        {
            Mensaje = "Error al registrar la suscripción: " + resultadoSub;
            ClaseMensaje = "renew-message error";
        }
    }
}