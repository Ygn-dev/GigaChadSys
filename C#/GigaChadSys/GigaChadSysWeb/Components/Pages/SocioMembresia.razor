@page "/socio/membresia"
@using System.Globalization
@using GigaChadSys.Servicios
@using GigaChadSys.Servicios.DTO
@layout SocioLayout
@rendermode InteractiveServer
@inject SessionServicio Session
@inject SuscripcionServicio SuscripcionService
@inject PagoServicio PagoService
@inject MembresiaBasicServicio MembresiaBasicService
@inject MembresiaBlackServicio MembresiaBlackService

<section class="container-fluid py-4">

    <div class="sm-header">
        <h1>Mi Membresía</h1>
        <p>Detalles de tu plan y beneficios</p>
    </div>

    @if (Cargando)
    {
        <div class="sm-card sm-loading-card">
            <div class="sm-loading-icon">
                <i class="bi bi-hourglass-split"></i>
            </div>

            <div>
                <h2>Cargando membresía...</h2>
                <p>Obteniendo información actualizada desde el servidor.</p>
            </div>
        </div>
    }
    else
    {
        @if (SuscripcionActual == null)
        {
            <div class="sm-card sm-empty-card">

                <div class="sm-empty-left">
                    <div class="sm-icon">
                        <i class="bi bi-gem"></i>
                    </div>

                    <div>
                        <h2>Aún no tienes una membresía activa</h2>
                        <p>Suscríbete a un plan para comenzar a reservar clases y acceder a los servicios del gimnasio.</p>

                        <a class="sm-main-button" href="/socio/membresia/renovar">
                            <i class="bi bi-plus-circle"></i>
                            Adquirir membresía
                        </a>
                    </div>
                </div>

                <div class="sm-empty-grid">
                    <div class="sm-info-box">
                        <span>Plan actual</span>
                        <strong>No disponible</strong>
                    </div>

                    <div class="sm-info-box">
                        <span>Estado</span>
                        <strong class="sm-red">Sin membresía</strong>
                    </div>

                    <div class="sm-info-box">
                        <span>Fecha de inicio</span>
                        <strong>—</strong>
                    </div>

                    <div class="sm-info-box">
                        <span>Fecha de vencimiento</span>
                        <strong>—</strong>
                    </div>

                    <div class="sm-info-box sm-wide">
                        <span>Último pago</span>
                        <strong>—</strong>
                    </div>
                </div>

            </div>

            <div class="sm-card">
                <h2>¿Qué puedes hacer con una membresía?</h2>

                <div class="sm-help-grid">
                    <div class="sm-help-item">
                        <div class="sm-help-icon">
                            <i class="bi bi-calendar-plus"></i>
                        </div>
                        <strong>Reservar clases grupales</strong>
                        <p>Reserva tus clases favoritas y asegura tu cupo.</p>
                    </div>

                    <div class="sm-help-item">
                        <div class="sm-help-icon">
                            <i class="bi bi-building"></i>
                        </div>
                        <strong>Acceso a instalaciones del gimnasio</strong>
                        <p>Disfruta de todas nuestras áreas y equipos.</p>
                    </div>

                    <div class="sm-help-item">
                        <div class="sm-help-icon">
                            <i class="bi bi-receipt"></i>
                        </div>
                        <strong>Historial de pagos y suscripciones</strong>
                        <p>Consulta tus pagos y descarga tus comprobantes.</p>
                    </div>

                    <div class="sm-help-item">
                        <div class="sm-help-icon">
                            <i class="bi bi-stars"></i>
                        </div>
                        <strong>Beneficios según el plan elegido</strong>
                        <p>Más ventajas y servicios exclusivos para ti.</p>
                    </div>
                </div>
            </div>
        }
        else
        {
            <div class="sm-card sm-active-card">

                <div class="sm-top">
                    <div>
                        <div class="sm-plan-title">
                            <div class="sm-icon">
                                <i class="bi bi-gem"></i>
                            </div>

                            <div>
                                <span>Plan actual</span>
                                <h2>@NombrePlanActual</h2>
                            </div>
                        </div>

                        <div class="sm-price">
                            S/@PrecioActual <span>/mes</span>
                        </div>
                    </div>

                    <span class="sm-status-active">Activa</span>
                </div>

                <div class="sm-info-grid">
                    <div class="sm-info-box">
                        <span>Fecha de inicio</span>
                        <strong>@SuscripcionActual.FechaInicioTexto</strong>
                    </div>

                    <div class="sm-info-box">
                        <span>Fecha de fin</span>
                        <strong>@SuscripcionActual.FechaFinTexto</strong>
                    </div>

                    <div class="sm-info-box">
                        <span>Último pago</span>
                        <strong>@UltimoPagoTexto</strong>
                    </div>

                    <div class="sm-info-box">
                        <span>Estado de membresía</span>
                        <strong class="sm-green">
                            <i class="bi bi-circle-fill sm-dot"></i>
                            Activa
                        </strong>
                    </div>
                </div>

                <h3>Beneficios Incluidos</h3>

                <div class="sm-benefits-grid">
                    @foreach (var beneficio in Beneficios)
                    {
                        <div class="sm-benefit sm-positive">
                            <i class="bi bi-check-lg"></i>
                            @beneficio
                        </div>
                    }
                </div>

                <h3>Características</h3>

                <div class="sm-benefits-grid">
                    @foreach (var caracteristica in Caracteristicas)
                    {
                        <div class="sm-benefit @(SuscripcionActual.EsBlack ? "sm-positive" : "sm-negative")">
                            @if (SuscripcionActual.EsBlack)
                            {
                                <i class="bi bi-check-lg"></i>
                            }
                            else
                            {
                                <i class="bi bi-x-circle"></i>
                            }

                            @caracteristica
                        </div>
                    }
                </div>

                <a class="sm-main-button sm-full-button" href="/socio/membresia/renovar">
                    <i class="bi bi-arrow-repeat"></i>
                    Renovar Membresía
                </a>
            </div>
        }

        <h2 class="sm-plans-title">Conoce los Planes</h2>

        <div class="sm-plans-grid">

            <div class="sm-plan-card">
                <div class="sm-plan-title">
                    <div class="sm-icon small">
                        <i class="bi bi-bullseye"></i>
                    </div>

                    <div>
                        <h3>Membresía Basic</h3>
                        <div class="sm-plan-price">
                            S/@PrecioBasic <span>/mes</span>
                        </div>
                    </div>
                </div>

                <ul>
                    <li class="good">
                        <i class="bi bi-check-lg"></i>
                        Acceso a sala de musculación
                    </li>
                    <li class="good">
                        <i class="bi bi-check-lg"></i>
                        Acceso a cardio
                    </li>
                    <li class="good">
                        <i class="bi bi-check-lg"></i>
                        Vestuario incluido
                    </li>
                    <li class="good">
                        <i class="bi bi-check-lg"></i>
                        App móvil
                    </li>
                    <li class="bad">
                        <i class="bi bi-x-circle"></i>
                        Sin clases grupales
                    </li>
                    <li class="bad">
                        <i class="bi bi-x-circle"></i>
                        Acceso limitado a horario diurno
                    </li>
                    <li class="bad">
                        <i class="bi bi-x-circle"></i>
                        Sin zona de spa
                    </li>
                </ul>
            </div>

            <div class="sm-plan-card premium">
                <span class="sm-premium-badge">Premium</span>

                <div class="sm-plan-title">
                    <div class="sm-icon small">
                        <i class="bi bi-gem"></i>
                    </div>

                    <div>
                        <h3>Membresía Black</h3>
                        <div class="sm-plan-price">
                            S/@PrecioBlack <span>/mes</span>
                        </div>
                    </div>
                </div>

                <ul>
                    <li class="good">
                        <i class="bi bi-check-lg"></i>
                        Todo lo de Basic
                    </li>
                    <li class="good">
                        <i class="bi bi-check-lg"></i>
                        Clases grupales ilimitadas
                    </li>
                    <li class="good">
                        <i class="bi bi-check-lg"></i>
                        Acceso 24/7
                    </li>
                    <li class="good">
                        <i class="bi bi-check-lg"></i>
                        Zona de spa
                    </li>
                    <li class="good">
                        <i class="bi bi-check-lg"></i>
                        Entrenador personal 2x/mes
                    </li>
                </ul>
            </div>

        </div>
    }

</section>

