@code {
    private bool Cargando { get; set; } = true;

    private SuscripcionDTO? SuscripcionActual { get; set; }

    private string PrecioBasic { get; set; } = "—";
    private string PrecioBlack { get; set; } = "—";
    private string PrecioActual { get; set; } = "—";
    private string UltimoPagoTexto { get; set; } = "—";

    private string NombrePlanActual =>
        SuscripcionActual == null
            ? "Sin membresía"
            : $"Membresía {SuscripcionActual.TipoPlan}";

    private List<string> Beneficios { get; set; } = new();
    private List<string> Caracteristicas { get; set; } = new();

    protected override async Task OnInitializedAsync()
    {
        await CargarDatos();
    }

    private async Task CargarDatos()
    {
        Cargando = true;

        try
        {
            await CargarPrecios();
            await CargarSuscripcionActual();
            CargarBeneficios();
        }
        finally
        {
            Cargando = false;
        }
    }

    private async Task CargarPrecios()
    {
        var basicas = await MembresiaBasicService.ListarMembresiasBasicAsync();

        var basic = basicas
            .OrderByDescending(b => b.IdMembresiaBasic)
            .FirstOrDefault();

        if (basic != null)
        {
            PrecioBasic = basic.CostoMantenimientoMensual.ToString("0.00", CultureInfo.InvariantCulture);
        }

        var blacks = await MembresiaBlackService.ListarMembresiasBlackAsync();

        var black = blacks
            .OrderByDescending(b => b.IdMembresiaBlack)
            .FirstOrDefault();

        if (black != null)
        {
            PrecioBlack = (black.CostoMantenimientoAnual / 12.0).ToString("0.00", CultureInfo.InvariantCulture);
        }
    }

    private async Task CargarSuscripcionActual()
    {
        if (!Session.EstaAutenticado)
        {
            SuscripcionActual = null;
            PrecioActual = "—";
            UltimoPagoTexto = "—";
            return;
        }

        var suscripciones = await SuscripcionService.ListarSuscripcionesAsync();

        SuscripcionActual = suscripciones
            .Where(s => s.IdUsuario == Session.IdUsuario && s.Activo && s.EsActiva)
            .OrderByDescending(s => s.FechaFinMembresia ?? DateTime.MinValue)
            .ThenByDescending(s => s.IdSuscripcion)
            .FirstOrDefault();

        if (SuscripcionActual == null)
        {
            PrecioActual = "—";
            UltimoPagoTexto = "—";
            return;
        }

        PrecioActual = SuscripcionActual.EsBlack ? PrecioBlack : PrecioBasic;

        var pagos = await PagoService.ListarPagosAsync();
        var pago = pagos.FirstOrDefault(p => p.IdPago == SuscripcionActual.IdPago);

        UltimoPagoTexto = pago?.FechaPagoTexto ?? "—";
    }

    private void CargarBeneficios()
    {
        Beneficios.Clear();
        Caracteristicas.Clear();

        if (SuscripcionActual == null)
            return;

        if (SuscripcionActual.EsBlack)
        {
            Beneficios.Add("Todo lo de Basic");
            Beneficios.Add("Clases grupales ilimitadas");
            Beneficios.Add("Acceso 24/7");
            Beneficios.Add("Zona de spa");
            Beneficios.Add("Entrenador personal 2x/mes");

            Caracteristicas.Add("Plan premium");
            Caracteristicas.Add("Acceso completo");
        }
        else
        {
            Beneficios.Add("Acceso a sala de musculación");
            Beneficios.Add("Acceso a cardio");
            Beneficios.Add("Vestuario incluido");
            Beneficios.Add("App móvil");

            Caracteristicas.Add("Sin clases grupales");
            Caracteristicas.Add("Acceso limitado a horario diurno");
            Caracteristicas.Add("Sin zona de spa");
        }
    }
}