@page "/socio/reserva-confirmada"
@page "/socio/reservar/confirmada/{CodigoClase}"
@layout SocioLayout
@rendermode InteractiveServer

<section class="confirmada-page">

    <div class="confirmada-header">
        <div>
            <h1>Reserva Confirmada</h1>
            <p>Tu reserva de clase se registró correctamente.</p>
        </div>

        <a class="confirmada-header-link" href="/socio/reservas">
            Ver Mis Reservas
        </a>
    </div>

    <div class="confirmada-banner">
        <div class="confirmada-check">
            ✓
        </div>

        <div>
            <span class="confirmada-eyebrow">Reserva exitosa</span>
            <h2>¡Todo listo, Lucía!</h2>
            <p>Tu lugar en la clase está asegurado. Te esperamos para que sigas alcanzando tus objetivos.</p>
        </div>
    </div>

    <div class="confirmada-main-grid">

        <div class="confirmada-detalles-card">
            <div class="confirmada-card-title">
                <div class="confirmada-title-icon">▣</div>
                <h3>Detalles de la reserva</h3>
            </div>

            <div class="detalle-lista">

                <div class="detalle-row">
                    <div class="detalle-left">
                        <span class="detalle-icon">🏋️</span>
                        <span>Clase</span>
                    </div>
                    <strong>@NombreClase</strong>
                </div>

                <div class="detalle-row">
                    <div class="detalle-left">
                        <span class="detalle-icon">🎯</span>
                        <span>Disciplina</span>
                    </div>
                    <strong class="detalle-red">@Disciplina</strong>
                </div>

                <div class="detalle-row">
                    <div class="detalle-left">
                        <span class="detalle-icon">📅</span>
                        <span>Fecha</span>
                    </div>
                    <strong>@Fecha</strong>
                </div>

                <div class="detalle-row">
                    <div class="detalle-left">
                        <span class="detalle-icon">🕐</span>
                        <span>Hora</span>
                    </div>
                    <strong>@Horario</strong>
                </div>

                <div class="detalle-row">
                    <div class="detalle-left">
                        <span class="detalle-icon">👤</span>
                        <span>Entrenador</span>
                    </div>
                    <strong>@Entrenador</strong>
                </div>

                <div class="detalle-row">
                    <div class="detalle-left">
                        <span class="detalle-icon">📍</span>
                        <span>Salón</span>
                    </div>
                    <strong>@Salon</strong>
                </div>

                <div class="detalle-row">
                    <div class="detalle-left">
                        <span class="detalle-icon">🎟️</span>
                        <span>Cupos restantes</span>
                    </div>
                    <strong class="detalle-green">@CuposRestantes cupos</strong>
                </div>

                <div class="detalle-divider"></div>

                <div class="detalle-row">
                    <div class="detalle-left">
                        <span class="detalle-icon">✅</span>
                        <span>Estado de reserva</span>
                    </div>
                    <span class="confirmada-status">Confirmada</span>
                </div>

                <div class="detalle-row">
                    <div class="detalle-left">
                        <span class="detalle-icon">♛</span>
                        <span>Membresía utilizada</span>
                    </div>
                    <strong>Membresía Black</strong>
                </div>

                <div class="detalle-row">
                    <div class="detalle-left">
                        <span class="detalle-icon">👤</span>
                        <span>Socio</span>
                    </div>
                    <strong>Lucía Torres</strong>
                </div>

            </div>
        </div>

        <div class="confirmada-side">

            <div class="confirmada-summary-card">
                <h3>Resumen rápido</h3>

                <div class="summary-mini-row">
                    <span>Clase</span>
                    <strong>@NombreClase</strong>
                </div>

                <div class="summary-mini-row">
                    <span>Horario</span>
                    <strong>@Horario</strong>
                </div>

                <div class="summary-mini-row">
                    <span>Salón</span>
                    <strong>@Salon</strong>
                </div>

                <div class="summary-mini-total">
                    <span>Estado</span>
                    <strong>Confirmada</strong>
                </div>
            </div>

            <div class="confirmada-pasos-card">
                <div class="confirmada-card-title">
                    <div class="confirmada-title-icon red">!</div>
                    <h3>Próximos pasos</h3>
                </div>

                <div class="pasos-lista">

                    <div class="paso-item">
                        <div class="paso-icon">⏰</div>
                        <div>
                            <strong>Llega 10 minutos antes</strong>
                            <p>Te recomendamos llegar con anticipación para prepararte y disfrutar al máximo tu clase.</p>
                        </div>
                    </div>

                    <div class="paso-item">
                        <div class="paso-icon">🎒</div>
                        <div>
                            <strong>Trae lo necesario</strong>
                            <p>No olvides tu toalla, botella de agua y toda la energía para dar lo mejor de ti.</p>
                        </div>
                    </div>

                    <div class="paso-item">
                        <div class="paso-icon">📋</div>
                        <div>
                            <strong>Revisa tus reservas</strong>
                            <p>Puedes ver los detalles de esta y todas tus reservas en la sección Mis Reservas.</p>
                        </div>
                    </div>

                </div>

                <div class="paso-nota">
                    <span>ⓘ</span>
                    <p>Si no puedes asistir, recuerda cancelar tu reserva con anticipación para liberar tu cupo.</p>
                </div>
            </div>

        </div>

    </div>

    <div class="confirmada-actions">
        <a href="/socio/reservas" class="btn-confirmada-primary">
            Ver Mis Reservas
        </a>

        <a href="/socio/reservar" class="btn-confirmada-secondary">
            Explorar Más Clases
        </a>
    </div>

</section>

@code {
    [Parameter]
    public string CodigoClase { get; set; } = "yoga-matutino";

    private string NombreClase =>
        CodigoClase == "crossfit-intenso" || CodigoClase == "crossfit-intenso-2" ? "CrossFit Intenso" :
        CodigoClase == "spinning-power" ? "Spinning Power" :
        CodigoClase == "boxeo-amateur" ? "Boxeo Amateur" :
        CodigoClase == "pilates-core" ? "Pilates Core" :
        "Yoga Matutino";

    private string Disciplina =>
        CodigoClase == "crossfit-intenso" || CodigoClase == "crossfit-intenso-2" ? "CrossFit" :
        CodigoClase == "spinning-power" ? "Spinning" :
        CodigoClase == "boxeo-amateur" ? "Boxeo" :
        CodigoClase == "pilates-core" ? "Pilates" :
        "Yoga";

    private string Fecha =>
        CodigoClase == "crossfit-intenso-2" || CodigoClase == "pilates-core" ? "2025-05-13" :
        "2025-05-12";

    private string Horario =>
        CodigoClase == "crossfit-intenso" || CodigoClase == "crossfit-intenso-2" ? "07:00 - 08:00" :
        CodigoClase == "spinning-power" ? "18:30 - 19:15" :
        CodigoClase == "boxeo-amateur" ? "19:00 - 20:00" :
        CodigoClase == "pilates-core" ? "18:00 - 18:50" :
        "08:00 - 08:45";

    private string Entrenador =>
        CodigoClase == "crossfit-intenso" || CodigoClase == "crossfit-intenso-2" ? "Marco Ruiz" :
        CodigoClase == "spinning-power" ? "Laura Gomez" :
        CodigoClase == "boxeo-amateur" ? "Carlos Diaz" :
        CodigoClase == "pilates-core" ? "Ana Flores" :
        "Pedro Sanchez";

    private string Salon =>
        CodigoClase == "crossfit-intenso" || CodigoClase == "crossfit-intenso-2" ? "Sala Principal" :
        CodigoClase == "spinning-power" ? "Sala Ciclo" :
        CodigoClase == "boxeo-amateur" ? "Sala Box" :
        CodigoClase == "pilates-core" ? "Sala Yoga" :
        "Sala Yoga";

    private int CuposRestantes =>
        CodigoClase == "crossfit-intenso" ? 2 :
        CodigoClase == "crossfit-intenso-2" ? 5 :
        CodigoClase == "spinning-power" ? 3 :
        CodigoClase == "boxeo-amateur" ? 2 :
        CodigoClase == "pilates-core" ? 1 :
        3;
}