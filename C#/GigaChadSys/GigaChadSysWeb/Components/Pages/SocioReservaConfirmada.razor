@code {
    [Parameter]
    public string CodigoClase { get; set; } = "";

    private bool Cargando { get; set; } = true;

    private string NombreClase = "Clase";
    private string Disciplina = "—";
    private string Fecha = "—";
    private string Horario = "—";
    private string Entrenador = "Sin asignar";
    private string Salon = "Sin asignar";
    private int CuposRestantes = 0;
    private string NombreSocio = "Socio";
    private string TipoMembresia = "Sin membresía";

    protected override async Task OnInitializedAsync()
    {
        Cargando = true;

        try
        {
            await CargarSocioYMembresia();
            await CargarSesion();
        }
        finally
        {
            Cargando = false;
        }
    }

    private async Task CargarSocioYMembresia()
    {
        if (!Session.EstaAutenticado)
        {
            NombreSocio = "Socio";
            TipoMembresia = "Sin membresía";
            return;
        }

        NombreSocio = !string.IsNullOrWhiteSpace(Session.Nombres)
            ? Session.Nombres
            : "Socio";

        var suscripciones = await SuscripcionService.ListarSuscripcionesAsync();

        var suscripcion = suscripciones
            .Where(s => s.IdUsuario == Session.IdUsuario && s.Activo && s.EsActiva)
            .OrderByDescending(s => s.FechaFinMembresia ?? DateTime.MinValue)
            .ThenByDescending(s => s.IdSuscripcion)
            .FirstOrDefault();

        if (suscripcion != null)
        {
            TipoMembresia = $"Membresía {suscripcion.TipoPlan}";
        }
    }

    private async Task CargarSesion()
    {
        if (!int.TryParse(CodigoClase, out int idSesion) || idSesion <= 0)
        {
            NombreClase = "Reserva registrada";
            return;
        }

        var sesiones = await SesionClaseService.ListarSesionesAsync();
        var sesion = sesiones.FirstOrDefault(s => s.IdSesion == idSesion);

        if (sesion == null)
        {
            NombreClase = "Reserva registrada";
            return;
        }

        string nombreDisciplinaCompleto = sesion.ClaseGrupal?.NombreDisciplina ?? "Clase General";

        NombreClase = ObtenerNombreClase(nombreDisciplinaCompleto);
        Disciplina = ObtenerDisciplina(nombreDisciplinaCompleto);

        Fecha = sesion.FechaSesion == default
            ? "—"
            : sesion.FechaSesion.ToString("yyyy-MM-dd");

        Horario = sesion.HoraInicio == default || sesion.HoraFin == default
            ? "—"
            : $"{sesion.HoraInicio:HH:mm} - {sesion.HoraFin:HH:mm}";

        Entrenador = sesion.Entrenador != null
            ? $"{sesion.Entrenador.Nombres} {sesion.Entrenador.ApellidoPaterno}".Trim()
            : "Sin asignar";

        Salon = sesion.Salon?.NombreSalon ?? "Sin asignar";

        var reservas = await ReservaService.ListarReservasAsync();

        int inscritos = reservas.Count(r =>
            r.Activo &&
            r.SesionClase?.IdSesion == idSesion);

        int capacidad = sesion.Salon?.AforoMaximo ?? 0;

        CuposRestantes = capacidad > 0
            ? Math.Max(0, capacidad - inscritos)
            : Math.Max(0, sesion.CuposDisponibles);
    }

    private static string ObtenerDisciplina(string texto)
    {
        if (string.IsNullOrWhiteSpace(texto))
            return "—";

        if (texto.Contains(" - "))
        {
            var partes = texto.Split(new[] { " - " }, 2, StringSplitOptions.None);
            return partes[0].Trim();
        }

        return texto.Trim();
    }

    private static string ObtenerNombreClase(string texto)
    {
        if (string.IsNullOrWhiteSpace(texto))
            return "Clase";

        if (texto.Contains(" - "))
        {
            var partes = texto.Split(new[] { " - " }, 2, StringSplitOptions.None);
            return partes[1].Trim();
        }

        return texto.Trim();
    }
}