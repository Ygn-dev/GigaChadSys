@page "/socio/reserva-confirmada"
@page "/socio/reservar/confirmada/{CodigoClase}"
@using GigaChadSys.Servicios
@using GigaChadSys.Servicios.DTO
@layout SocioLayout
@rendermode InteractiveServer
@inject SessionServicio Session
@inject SesionClaseServicio SesionClaseService
@inject ReservaServicio ReservaService
@inject SuscripcionServicio SuscripcionService

<section class="confirmada-page">

    <div class="confirmada-header">
        <div>
            <h1>Reserva Confirmada</h1>
            <p>Tu reserva de clase se registró correctamente.</p>
        </div>

        <a class="confirmada-header-link" href="/socio/reservas">
            Ver Mis Reservas
        </a>
    </div>

    <div class="confirmada-banner">
        <div class="confirmada-check">
            ✓
        </div>

        <div>
            <span class="confirmada-eyebrow">Reserva exitosa</span>
            <h2>¡Todo listo, @(Session.EstaAutenticado ? Session.Nombres : "Socio")!</h2>
            <p>Tu lugar en la clase está asegurado. Te esperamos para que sigas alcanzando tus objetivos.</p>
        </div>
    </div>

    <div class="confirmada-main-grid">

        <div class="confirmada-detalles-card">
            <div class="confirmada-card-title">
                <div class="confirmada-title-icon">▣</div>
                <h3>Detalles de la reserva</h3>
            </div>

            <div class="detalle-lista">

                <div class="detalle-row">
                    <div class="detalle-left">
                        <span class="detalle-icon">🏋️</span>
                        <span>Clase</span>
                    </div>
                    <strong>@NombreClase</strong>
                </div>

                <div class="detalle-row">
                    <div class="detalle-left">
                        <span class="detalle-icon">🎯</span>
                        <span>Disciplina</span>
                    </div>
                    <strong class="detalle-red">@Disciplina</strong>
                </div>

                <div class="detalle-row">
                    <div class="detalle-left">
                        <span class="detalle-icon">📅</span>
                        <span>Fecha</span>
                    </div>
                    <strong>@Fecha</strong>
                </div>

                <div class="detalle-row">
                    <div class="detalle-left">
                        <span class="detalle-icon">🕐</span>
                        <span>Hora</span>
                    </div>
                    <strong>@Horario</strong>
                </div>

                <div class="detalle-row">
                    <div class="detalle-left">
                        <span class="detalle-icon">👤</span>
                        <span>Entrenador</span>
                    </div>
                    <strong>@Entrenador</strong>
                </div>

                <div class="detalle-row">
                    <div class="detalle-left">
                        <span class="detalle-icon">📍</span>
                        <span>Salón</span>
                    </div>
                    <strong>@Salon</strong>
                </div>

                <div class="detalle-row">
                    <div class="detalle-left">
                        <span class="detalle-icon">🎟️</span>
                        <span>Cupos restantes</span>
                    </div>
                    <strong class="detalle-green">@CuposRestantes cupos</strong>
                </div>

                <div class="detalle-divider"></div>

                <div class="detalle-row">
                    <div class="detalle-left">
                        <span class="detalle-icon">✅</span>
                        <span>Estado de reserva</span>
                    </div>
                    <span class="confirmada-status">Confirmada</span>
                </div>

                <div class="detalle-row">
                    <div class="detalle-left">
                        <span class="detalle-icon">♛</span>
                        <span>Membresía utilizada</span>
                    </div>
                    <strong>@TipoMembresia</strong>
                </div>

                <div class="detalle-row">
                    <div class="detalle-left">
                        <span class="detalle-icon">👤</span>
                        <span>Socio</span>
                    </div>
                    <strong>@NombreSocio</strong>
                </div>

            </div>
        </div>

        <div class="confirmada-side">

            <div class="confirmada-summary-card">
                <h3>Resumen rápido</h3>

                <div class="summary-mini-row">
                    <span>Clase</span>
                    <strong>@NombreClase</strong>
                </div>

                <div class="summary-mini-row">
                    <span>Horario</span>
                    <strong>@Horario</strong>
                </div>

                <div class="summary-mini-row">
                    <span>Salón</span>
                    <strong>@Salon</strong>
                </div>

                <div class="summary-mini-total">
                    <span>Estado</span>
                    <strong>Confirmada</strong>
                </div>
            </div>

            <div class="confirmada-pasos-card">
                <div class="confirmada-card-title">
                    <div class="confirmada-title-icon red">!</div>
                    <h3>Próximos pasos</h3>
                </div>

                <div class="pasos-lista">

                    <div class="paso-item">
                        <div class="paso-icon">⏰</div>
                        <div>
                            <strong>Llega 10 minutos antes</strong>
                            <p>Te recomendamos llegar con anticipación para prepararte y disfrutar al máximo tu clase.</p>
                        </div>
                    </div>

                    <div class="paso-item">
                        <div class="paso-icon">🎒</div>
                        <div>
                            <strong>Trae lo necesario</strong>
                            <p>No olvides tu toalla, botella de agua y toda la energía para dar lo mejor de ti.</p>
                        </div>
                    </div>

                    <div class="paso-item">
                        <div class="paso-icon">📋</div>
                        <div>
                            <strong>Revisa tus reservas</strong>
                            <p>Puedes ver los detalles de esta y todas tus reservas en la sección Mis Reservas.</p>
                        </div>
                    </div>

                </div>

                <div class="paso-nota">
                    <span>ⓘ</span>
                    <p>Si no puedes asistir, recuerda cancelar tu reserva con anticipación para liberar tu cupo.</p>
                </div>
            </div>

        </div>

    </div>

    <div class="confirmada-actions">
        <a href="/socio/reservas" class="btn-confirmada-primary">
            Ver Mis Reservas
        </a>

        <a href="/socio/reservar" class="btn-confirmada-secondary">
            Explorar Más Clases
        </a>
    </div>

</section>

@code {
    [Parameter]
    public string CodigoClase { get; set; } = "";

    private string NombreClase = "Cargando...";
    private string Disciplina = "-";
    private string Fecha = "-";
    private string Horario = "-";
    private string Entrenador = "Sin asignar";
    private string Salon = "Sin asignar";
    private int CuposRestantes = 0;
    private string NombreSocio = "Socio";
    private string TipoMembresia = "Sin membresía";

    protected override async Task OnInitializedAsync()
    {
        // Nombre del socio
        if (Session.EstaAutenticado)
        {
            NombreSocio = Session.Nombres;

            // Obtener tipo de membresía
            var suscripciones = await SuscripcionService.ListarSuscripcionesAsync();
            var suscripcion = suscripciones.FirstOrDefault(s => s.IdUsuario == Session.IdUsuario && s.Activo);
            if (suscripcion != null)
            {
                TipoMembresia = $"Membresía {suscripcion.TipoPlan}";
            }
        }

        // Cargar datos de la sesión de clase
        if (int.TryParse(CodigoClase, out int idSesion) && idSesion > 0)
        {
            var sesiones = await SesionClaseService.ListarSesionesAsync();
            var sesionDTO = sesiones.FirstOrDefault(s => s.IdSesion == idSesion);

            if (sesionDTO != null)
            {
                NombreClase = sesionDTO.ClaseGrupal?.NombreDisciplina ?? "Clase General";
                Disciplina = sesionDTO.ClaseGrupal?.NombreDisciplina ?? "-";
                Fecha = sesionDTO.FechaSesion.ToString("yyyy-MM-dd");
                Horario = $"{sesionDTO.HoraInicio:HH:mm} - {sesionDTO.HoraFin:HH:mm}";
                Entrenador = sesionDTO.Entrenador != null
                    ? $"{sesionDTO.Entrenador.Nombres} {sesionDTO.Entrenador.ApellidoPaterno}"
                    : "Sin asignar";
                Salon = sesionDTO.Salon?.NombreSalon ?? "Sin asignar";

                // Calcular cupos restantes
                var reservas = await ReservaService.ListarReservasAsync();
                int inscritos = reservas.Count(r => r.SesionClase?.IdSesion == idSesion);
                int capacidad = sesionDTO.Salon?.AforoMaximo ?? 0;
                CuposRestantes = capacidad > 0 ? capacidad - inscritos : sesionDTO.CuposDisponibles;
            }
        }
    }
}