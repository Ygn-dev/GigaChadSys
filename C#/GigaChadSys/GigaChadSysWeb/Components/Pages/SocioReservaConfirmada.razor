@page "/socio/reserva-confirmada"
@page "/socio/reservar/confirmada/{CodigoClase}"
@using GigaChadSys.Servicios
@using GigaChadSys.Servicios.DTO
@layout SocioLayout
@rendermode InteractiveServer
@inject SessionServicio Session
@inject SesionClaseServicio SesionClaseService
@inject ReservaServicio ReservaService
@inject SuscripcionServicio SuscripcionService

<section class="container-fluid py-4">

    <div class="rc-header">
        <h1>Reserva Confirmada</h1>
        <p>Tu reserva de clase se registró correctamente</p>
    </div>

    @if (Cargando)
    {
        <div class="rc-banner">
            <div class="rc-check">
                <i class="bi bi-hourglass-split"></i>
            </div>

            <div>
                <h2>Cargando reserva...</h2>
                <p>Estamos obteniendo los detalles actualizados de tu reserva.</p>
            </div>
        </div>
    }
    else
    {
        <div class="rc-banner">
            <div class="rc-check">
                <i class="bi bi-check-lg"></i>
            </div>

            <div>
                <h2>¡Todo listo, @NombreSocio!</h2>
                <p>Tu lugar en la clase está asegurado. Te esperamos para que sigas alcanzando tus objetivos.</p>
            </div>
        </div>

        <div class="rc-main-grid">

            <div class="rc-card">
                <h3>Detalles de la reserva</h3>

                <div class="rc-detail-list">

                    <div class="rc-detail-row">
                        <div class="rc-detail-label">
                            <i class="bi bi-person-workspace"></i>
                            <span>Clase</span>
                        </div>
                        <strong>@NombreClase</strong>
                    </div>

                    <div class="rc-detail-row">
                        <div class="rc-detail-label">
                            <i class="bi bi-activity"></i>
                            <span>Disciplina</span>
                        </div>
                        <strong class="rc-red">@Disciplina</strong>
                    </div>

                    <div class="rc-detail-row">
                        <div class="rc-detail-label">
                            <i class="bi bi-calendar-event"></i>
                            <span>Fecha</span>
                        </div>
                        <strong>@Fecha</strong>
                    </div>

                    <div class="rc-detail-row">
                        <div class="rc-detail-label">
                            <i class="bi bi-clock"></i>
                            <span>Hora</span>
                        </div>
                        <strong>@Horario</strong>
                    </div>

                    <div class="rc-detail-row">
                        <div class="rc-detail-label">
                            <i class="bi bi-person-badge"></i>
                            <span>Entrenador</span>
                        </div>
                        <strong>@Entrenador</strong>
                    </div>

                    <div class="rc-detail-row">
                        <div class="rc-detail-label">
                            <i class="bi bi-geo-alt"></i>
                            <span>Salón</span>
                        </div>
                        <strong>@Salon</strong>
                    </div>

                    <div class="rc-detail-row">
                        <div class="rc-detail-label">
                            <i class="bi bi-people"></i>
                            <span>Cupos restantes</span>
                        </div>
                        <strong class="rc-green">@CuposRestantes cupos</strong>
                    </div>

                    <div class="rc-divider"></div>

                    <div class="rc-detail-row">
                        <div class="rc-detail-label">
                            <i class="bi bi-shield-check"></i>
                            <span>Estado de reserva</span>
                        </div>
                        <span class="rc-status">
                            <i class="bi bi-check-circle"></i>
                            Confirmada
                        </span>
                    </div>

                    <div class="rc-detail-row">
                        <div class="rc-detail-label">
                            <i class="bi bi-gem"></i>
                            <span>Membresía utilizada</span>
                        </div>
                        <strong>@TipoMembresia</strong>
                    </div>

                    <div class="rc-detail-row">
                        <div class="rc-detail-label">
                            <i class="bi bi-person"></i>
                            <span>Socio</span>
                        </div>
                        <strong>@NombreSocio</strong>
                    </div>

                </div>
            </div>

            <div class="rc-card rc-steps-card">
                <h3>Próximos pasos</h3>

                <div class="rc-step-list">

                    <div class="rc-step-item">
                        <div class="rc-step-icon">
                            <i class="bi bi-clock"></i>
                        </div>

                        <div>
                            <strong>Llega 10 minutos antes</strong>
                            <p>Te recomendamos llegar con anticipación para prepararte y disfrutar al máximo tu clase.</p>
                        </div>
                    </div>

                    <div class="rc-step-item">
                        <div class="rc-step-icon">
                            <i class="bi bi-droplet"></i>
                        </div>

                        <div>
                            <strong>Trae lo necesario</strong>
                            <p>No olvides tu toalla, botella de agua y toda la energía para dar lo mejor de ti.</p>
                        </div>
                    </div>

                    <div class="rc-step-item">
                        <div class="rc-step-icon">
                            <i class="bi bi-calendar-check"></i>
                        </div>

                        <div>
                            <strong>Revisa tus reservas</strong>
                            <p>Puedes ver los detalles de esta y todas tus reservas en la sección Mis Reservas.</p>
                        </div>
                    </div>

                </div>

                <div class="rc-note">
                    <i class="bi bi-info-circle"></i>
                    <span>Si no puedes asistir, recuerda cancelar tu reserva con anticipación para liberar tu cupo.</span>
                </div>
            </div>

        </div>

        <div class="rc-actions">
            <a href="/socio/reservas" class="rc-btn-primary">
                <i class="bi bi-clipboard-check"></i>
                Ver Mis Reservas
            </a>

            <a href="/socio/reservar" class="rc-btn-secondary">
                <i class="bi bi-search"></i>
                Explorar Más Clases
            </a>
        </div>
    }

</section>

