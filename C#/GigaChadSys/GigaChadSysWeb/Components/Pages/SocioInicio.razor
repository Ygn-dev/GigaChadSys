@page "/socio/inicio"
@using GigaChadSys.Servicios
@using GigaChadSysWeb.Components.Layout
@layout SocioLayout
@rendermode InteractiveServer

@inject SessionServicio Session

<section class="role-home socio-home">

    <div class="role-hero socio-hero">
        <div>
            <div class="role-label">Panel de Socio</div>

            <h1>¡Bienvenido/a, @NombreSocio!</h1>

            <div class="role-red-line"></div>

            <p>Desde aquí puedes gestionar tu experiencia en GigaChad.</p>
        </div>
    </div>

    <div class="role-grid socio-grid">

        <a class="role-card socio-card" href="/socio/membresia">
            <div class="role-card-icon">
                <i class="bi bi-gem"></i>
            </div>

            <div class="role-card-body">
                <h3>Mi Membresía</h3>
                <p>Consulta los detalles de tu membresía actual, vigencia y beneficios.</p>
                <span>Ver Membresía</span>
            </div>
        </a>

        <a class="role-card socio-card" href="/socio/reservar">
            <div class="role-card-icon">
                <i class="bi bi-calendar-plus"></i>
            </div>

            <div class="role-card-body">
                <h3>Reservar Clase</h3>
                <p>Explora las clases disponibles y reserva tu cupo fácilmente.</p>
                <span>Reservar Ahora</span>
            </div>
        </a>

        <a class="role-card socio-card" href="/socio/reservas">
            <div class="role-card-icon">
                <i class="bi bi-calendar-check"></i>
            </div>

            <div class="role-card-body">
                <h3>Mis Reservas</h3>
                <p>Consulta tus reservas confirmadas y tu historial de clases.</p>
                <span>Ver Reservas</span>
            </div>
        </a>

        <a class="role-card socio-card" href="/socio/pagos">
            <div class="role-card-icon">
                <i class="bi bi-cash-coin"></i>
            </div>

            <div class="role-card-body">
                <h3>Mis Pagos</h3>
                <p>Revisa tu historial de pagos y comprobantes.</p>
                <span>Ver Pagos</span>
            </div>
        </a>

        <a class="role-card socio-card" href="/socio/perfil">
            <div class="role-card-icon">
                <i class="bi bi-person-circle"></i>
            </div>

            <div class="role-card-body">
                <h3>Mi Perfil</h3>
                <p>Actualiza tu información personal y configuración de cuenta.</p>
                <span>Editar Perfil</span>
            </div>
        </a>

        <div class="role-card socio-card motivacion-card">
            <div class="role-card-icon">
                <i class="bi bi-lightning-charge"></i>
            </div>

            <div class="role-card-body">
                <h3>¡Sigue entrenando!</h3>
                <p>La constancia de hoy son los resultados de mañana.</p>
            </div>
        </div>

    </div>

</section>

@code {
    private string NombreSocio =>
        Session.EstaAutenticado && !string.IsNullOrWhiteSpace(Session.Nombres)
            ? Session.Nombres
            : "Socio";
}