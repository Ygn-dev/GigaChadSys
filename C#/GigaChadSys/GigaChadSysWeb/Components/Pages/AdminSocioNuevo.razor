@page "/admin/socios/nuevo"
@using GigaChadSysWeb.Components.Layout
@layout AdminLayout
@rendermode InteractiveServer
@using GigaChadSys.Servicios
@using GigaChadSys.Servicios.DTO
@inject SocioServicio SocioService
@inject NavigationManager Nav

<section class="container-fluid py-4">

    <!-- Breadcrumb -->
    <nav class="sf-breadcrumb">
        <a href="/admin/socios">Socios</a>
        <span class="sf-bc-sep">›</span>
        <span class="sf-bc-current">Nuevo Socio</span>
    </nav>

    <!-- Page Header -->
    <div class="sf-page-header">
        <div>
            <h1>Registrar Nuevo Socio</h1>
            <p class="sf-page-subtitle">Complete la información del nuevo socio del gimnasio</p>
        </div>
    </div>

    <div class="row g-4">
        <!-- Left: Form -->
        <div class="sf-form-col">

            <!-- Sección 1: Información Personal -->
            <div class="sf-section-card">
                <div class="sf-section-title">
                    <div class="sf-section-icon icon-red">👤</div>
                    <div>
                        <h3>Información Personal</h3>
                        <span>Datos básicos del socio</span>
                    </div>
                </div>

                <div class="sf-form-grid">
                    <div class="sf-form-group">
                        <label>DNI <span class="sf-req">*</span></label>
                        <input type="text"
                               @bind="form.Dni"
                               placeholder="40234123"
                               maxlength="8"
                               class="@(errores.ContainsKey("dni") ? "sf-input-error" : "")" />
                        @if (errores.ContainsKey("dni"))
                        {
                            <span class="sf-error-msg">@errores["dni"]</span>
                        }
                    </div>

                    <div class="sf-form-group">
                        <label>Nombres <span class="sf-req">*</span></label>
                        <input type="text"
                               @bind="form.Nombres"
                               placeholder="Lucia Maria"
                               class="@(errores.ContainsKey("nombres") ? "sf-input-error" : "")" />
                        @if (errores.ContainsKey("nombres"))
                        {
                            <span class="sf-error-msg">@errores["nombres"]</span>
                        }
                    </div>

                    <div class="sf-form-group">
                        <label>Apellido paterno <span class="sf-req">*</span></label>
                        <input type="text"
                               @bind="form.ApellidoPaterno"
                               placeholder="Torres"
                               class="@(errores.ContainsKey("apellidoPaterno") ? "sf-input-error" : "")" />
                        @if (errores.ContainsKey("apellidoPaterno"))
                        {
                            <span class="sf-error-msg">@errores["apellidoPaterno"]</span>
                        }
                    </div>

                    <div class="sf-form-group">
                        <label>Apellido materno <span class="sf-req">*</span></label>
                        <input type="text"
                               @bind="form.ApellidoMaterno"
                               placeholder="García"
                               class="@(errores.ContainsKey("apellidoMaterno") ? "sf-input-error" : "")" />
                        @if (errores.ContainsKey("apellidoMaterno"))
                        {
                            <span class="sf-error-msg">@errores["apellidoMaterno"]</span>
                        }
                    </div>

                    <div class="sf-form-group">
                        <label>Fecha de nacimiento <span class="sf-req">*</span></label>
                        <input type="date"
                               @bind="form.FechaNacimiento"
                               class="@(errores.ContainsKey("fechaNacimiento") ? "sf-input-error" : "")" />
                        @if (errores.ContainsKey("fechaNacimiento"))
                        {
                            <span class="sf-error-msg">@errores["fechaNacimiento"]</span>
                        }
                    </div>

                    <div class="sf-form-group">
                        <label>Teléfono <span class="sf-req">*</span></label>
                        <input type="text"
                               @bind="form.Telefono"
                               placeholder="987654321"
                               maxlength="9"
                               class="@(errores.ContainsKey("telefono") ? "sf-input-error" : "")" />
                        @if (errores.ContainsKey("telefono"))
                        {
                            <span class="sf-error-msg">@errores["telefono"]</span>
                        }
                    </div>

                    <div class="sf-form-group">
                        <label>Correo electrónico <span class="sf-req">*</span></label>
                        <input type="email"
                               @bind="form.Email"
                               placeholder="lucia@email.com"
                               class="@(errores.ContainsKey("email") ? "sf-input-error" : "")" />
                        @if (errores.ContainsKey("email"))
                        {
                            <span class="sf-error-msg">@errores["email"]</span>
                        }
                    </div>
                </div>
            </div>

            <!-- Sección 2: Cuenta de Acceso -->
            <div class="sf-section-card">
                <div class="sf-section-title">
                    <div class="sf-section-icon icon-blue">🔒</div>
                    <div>
                        <h3>Cuenta de Acceso</h3>
                        <span>Credenciales para el sistema</span>
                    </div>
                </div>

                <div class="sf-form-grid">
                    <div class="sf-form-group">
                        <label>Contraseña <span class="sf-req">*</span></label>
                        <div class="sf-input-pass">
                            <input type="@(verPass ? "text" : "password")"
                                   @bind="form.Contrasenia"
                                   placeholder="Mínimo 6 caracteres"
                                   class="@(errores.ContainsKey("contrasenia") ? "sf-input-error" : "")" />
                            <button type="button" class="sf-eye-btn" @onclick="() => verPass = !verPass">
                                @(verPass ? "🙈" : "👁️")
                            </button>
                        </div>
                        @if (errores.ContainsKey("contrasenia"))
                        {
                            <span class="sf-error-msg">@errores["contrasenia"]</span>
                        }
                    </div>

                    <div class="sf-form-group">
                        <label>Confirmar contraseña <span class="sf-req">*</span></label>
                        <div class="sf-input-pass">
                            <input type="@(verConfirm ? "text" : "password")"
                                   @bind="form.ConfirmarContrasenia"
                                   placeholder="Repite tu contraseña"
                                   class="@(errores.ContainsKey("confirmar") ? "sf-input-error" : "")" />
                            <button type="button" class="sf-eye-btn" @onclick="() => verConfirm = !verConfirm">
                                @(verConfirm ? "🙈" : "👁️")
                            </button>
                        </div>
                        @if (errores.ContainsKey("confirmar"))
                        {
                            <span class="sf-error-msg">@errores["confirmar"]</span>
                        }
                    </div>
                </div>
            </div>

            <!-- Sección 3: Membresía Inicial -->
            <div class="sf-section-card">
                <div class="sf-section-title">
                    <div class="sf-section-icon icon-yellow">♛</div>
                    <div>
                        <h3>Membresía Inicial</h3>
                        <span>Selecciona el plan para el nuevo socio</span>
                    </div>
                </div>

                <div class="sf-plan-grid">
                    <!-- Basic -->
                    <div class="sf-plan-card @(form.PlanSeleccionado == "basic" ? "sf-plan-selected" : "")"
                         @onclick='() => form.PlanSeleccionado = "basic"'>
                        <div class="sf-plan-radio @(form.PlanSeleccionado == "basic" ? "sf-radio-sel" : "")"></div>
                        <div class="sf-plan-body">
                            <h4>Membresía Basic</h4>
                            <div class="sf-plan-precio">
                                <span class="sf-precio-val">S/ 79</span>
                                <span class="sf-precio-per">/ mes</span>
                            </div>
                            <ul class="sf-plan-features">
                                <li><span class="sf-chk">✓</span> Acceso a sala de musculación</li>
                                <li><span class="sf-chk">✓</span> Acceso a cardio</li>
                                <li><span class="sf-chk">✓</span> Vestuario incluido</li>
                                <li><span class="sf-chk">✓</span> App móvil</li>
                            </ul>
                        </div>
                    </div>

                    <!-- Black -->
                    <div class="sf-plan-card sf-plan-premium @(form.PlanSeleccionado == "black" ? "sf-plan-selected sf-plan-premium-sel" : "")"
                         @onclick='() => form.PlanSeleccionado = "black"'>
                        <div class="sf-plan-radio @(form.PlanSeleccionado == "black" ? "sf-radio-sel sf-radio-red" : "")"></div>
                        <div class="sf-plan-body">
                            <span class="sf-plan-badge-premium">PREMIUM</span>
                            <h4>Membresía Black</h4>
                            <div class="sf-plan-precio">
                                <span class="sf-precio-val">S/ 149</span>
                                <span class="sf-precio-per">/ mes</span>
                            </div>
                            <ul class="sf-plan-features">
                                <li><span class="sf-chk">✓</span> Todo lo de Basic</li>
                                <li><span class="sf-chk">✓</span> Clases grupales ilimitadas</li>
                                <li><span class="sf-chk">✓</span> Acceso 24/7</li>
                                <li><span class="sf-chk">✓</span> Zona de spa</li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Sección 4: Estado del Socio -->
            <div class="sf-section-card">
                <div class="sf-section-title">
                    <div class="sf-section-icon icon-green">⚙</div>
                    <div>
                        <h3>Estado del Socio</h3>
                        <span>Estado inicial del registro</span>
                    </div>
                </div>

                <div class="sf-estado-row">
                    <button type="button"
                            class="sf-estado-btn @(form.Activo ? "sf-estado-activo" : "")"
                            @onclick='() => form.Activo = true'>
                        <span class="sf-estado-dot dot-green"></span> Activo
                    </button>
                    <button type="button"
                            class="sf-estado-btn @(!form.Activo ? "sf-estado-inactivo" : "")"
                            @onclick='() => form.Activo = false'>
                        <span class="sf-estado-dot dot-red"></span> Inactivo
                    </button>
                </div>
            </div>

            <!-- Acciones -->
            <div class="sf-form-actions">
                <button class="sf-btn-primary" @onclick="Registrar">
                    <span>👤</span> Registrar Socio
                </button>
                <a class="sf-btn-secondary" href="/admin/socios">Cancelar</a>
                <span class="sf-back-link">
                    <a href="/admin/socios">← Volver al listado</a>
                </span>
            </div>

        </div>
    </div>

</section>

<!-- Toast -->
@if (mostrarToast)
{
    <div class="socios-toast socios-toast-show">
        <span>✅</span>
        <span>@mensajeToast</span>
    </div>
}

@code {
    private bool verPass = false;
    private bool verConfirm = false;
    private bool mostrarToast = false;
    private string mensajeToast = "";
    private Dictionary<string, string> errores = new();

    private FormNuevoSocio form = new();

    private async Task Registrar()
    {
        errores.Clear();

        if (string.IsNullOrWhiteSpace(form.Dni) || form.Dni.Length != 8 || !int.TryParse(form.Dni, out _))
            errores["dni"] = "El DNI debe tener exactamente 8 dígitos numéricos.";

        if (string.IsNullOrWhiteSpace(form.Nombres))
            errores["nombres"] = "El nombre es obligatorio.";

        if (string.IsNullOrWhiteSpace(form.ApellidoPaterno))
            errores["apellidoPaterno"] = "El apellido paterno es obligatorio.";

        if (string.IsNullOrWhiteSpace(form.ApellidoMaterno))
            errores["apellidoMaterno"] = "El apellido materno es obligatorio.";

        if (!form.FechaNacimiento.HasValue)
            errores["fechaNacimiento"] = "La fecha de nacimiento es obligatoria.";

        if (string.IsNullOrWhiteSpace(form.Email))
            errores["email"] = "El correo es obligatorio.";

        if (!string.IsNullOrWhiteSpace(form.Email)
            && (!form.Email.Contains("@") || !form.Email.Contains(".")))
            errores["email"] = "Ingrese un correo válido.";

        if (string.IsNullOrWhiteSpace(form.Telefono)
            || form.Telefono.Length != 9
            || !int.TryParse(form.Telefono, out _))
            errores["telefono"] = "El teléfono debe tener 9 dígitos numéricos.";

        if (string.IsNullOrWhiteSpace(form.Contrasenia) || form.Contrasenia.Length < 6)
            errores["contrasenia"] = "La contraseña debe tener al menos 6 caracteres.";

        if (form.Contrasenia != form.ConfirmarContrasenia)
            errores["confirmar"] = "Las contraseñas no coinciden.";

        if (errores.Any())
        {
            StateHasChanged();
            return;
        }

        var nuevoSocio = new SocioDTO
        {
            Dni = int.Parse(form.Dni),
            Nombres = form.Nombres.Trim(),
            ApellidoPaterno = form.ApellidoPaterno.Trim(),
            ApellidoMaterno = form.ApellidoMaterno.Trim(),
            Edad = CalcularEdad(form.FechaNacimiento!.Value),
            Telefono = int.Parse(form.Telefono),
            Email = form.Email.Trim(),
            Contrasenia = form.Contrasenia.Trim(),
            Rol = "Socio",
            Activo = form.Activo,
            EstadoMembresia = form.PlanSeleccionado == "black" || form.PlanSeleccionado == "basic"
        };

        var resultado = await SocioService.RegistrarAsync(nuevoSocio);

        if (!resultado.StartsWith("Error") && !resultado.ToLower().Contains("error"))
        {
            mensajeToast = "Socio registrado correctamente.";
            mostrarToast = true;
            StateHasChanged();

            await Task.Delay(1500);

            mostrarToast = false;
            Nav.NavigateTo("/admin/socios");
        }
        else
        {
            errores["dni"] = resultado;
            StateHasChanged();
        }
    }

    private class FormNuevoSocio
    {
        public string Dni { get; set; } = "";
        public string Nombres { get; set; } = "";
        public string ApellidoPaterno { get; set; } = "";
        public string ApellidoMaterno { get; set; } = "";
        public DateTime? FechaNacimiento { get; set; }
        public string Telefono { get; set; } = "";
        public string Email { get; set; } = "";
        public string Contrasenia { get; set; } = "";
        public string ConfirmarContrasenia { get; set; } = "";
        public string PlanSeleccionado { get; set; } = "basic";
        public bool Activo { get; set; } = true;
    }

    private static int CalcularEdad(DateTime fechaNacimiento)
    {
        var hoy = DateTime.Today;
        var edad = hoy.Year - fechaNacimiento.Year;

        if (fechaNacimiento.Date > hoy.AddYears(-edad))
            edad--;

        return edad;
    }
}