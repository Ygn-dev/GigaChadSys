@page "/admin/clases"
@layout AdminLayout
@rendermode InteractiveServer
@using System.Text.Json.Serialization
@using GigaChadSys.Servicios
@using GigaChadSys.Servicios.DTO
@inject ClaseGrupalServicio ClaseService


<section class="admin-list-page">

    <!-- Header -->
    <div class="admin-list-header">
        <div>
            <h1>Clases Grupales</h1>
            <p>Gestiona las clases disponibles en el gimnasio</p>
        </div>
        <a class="new-button" href="/admin/clases/nueva">
            + Nueva Clase
        </a>
    </div>

    <!-- Toolbar: búsqueda + dropdown disciplina -->
    <div class="admin-list-toolbar" style="margin-bottom:28px;">
        <div class="gc-search-wrapper">
            <span class="gc-search-icon">🔍</span>
            <input class="admin-search"
                   style="border:none;background:transparent;padding-left:0;"
                   type="text"
                   placeholder="Buscar clase o disciplina..."
                   @bind="TextoBusqueda"
                   @bind:event="oninput" />
        </div>
        <div class="gc-discipline-select-wrapper">
            <select class="gc-discipline-select" @bind="DisciplinaFiltro">
                <option value="">Todas las disciplinas</option>
                @foreach (var d in Disciplinas)
                {
                    <option value="@d">@d</option>
                }
            </select>
            <span class="gc-select-arrow">▾</span>
        </div>
    </div>

    <!-- Grid de cards -->
    @{
        var clasesFiltradas = ClasesFiltradas.ToList();
    }

    @if (Cargando)
    {
        <div class="gc-empty">
            <span>⏳</span>
            <p>Cargando clases desde el servidor...</p>
        </div>
    }
    else if (clasesFiltradas.Count == 0)
    {
        <div class="gc-empty">
            <span>🏋️</span>
            <p>No se encontraron clases con los filtros actuales.</p>
        </div>
    }
    else
    {
        <div class="gc-grid">
            @foreach (var c in clasesFiltradas)
            {
                <div class="gc-card">
                    <!-- Top badges -->
                    <div class="gc-card-top">
                        <span class="gc-nivel-badge gc-nivel-@c.Nivel.ToLower()">@c.Nivel</span>
                        <span class="gc-activa-badge @(c.Activo ? "gc-badge-activa" : "gc-badge-inactiva")">
                            @(c.Activo ? "Activa" : "Inactiva")
                        </span>
                    </div>

                    <!-- Nombre -->
                    <h3 class="gc-card-nombre">@c.NombreDisciplina</h3>

                    <!-- Descripción -->
                    <p class="gc-card-desc">@c.Descripcion</p>

                    <!-- Duración -->
                    <div class="gc-card-duracion">
                        <span class="gc-clock-icon">🕐</span>
                        <span>@c.DuracionMinutos min</span>
                    </div>

                    <!-- Botones -->
                    <div class="gc-card-actions">
                        <a class="gc-btn-ver" href="/admin/clases/@c.IdClase">
                            👁 Ver
                        </a>
                        <a class="gc-btn-editar" href="/admin/clases/editar/@c.IdClase">
                            ✏ Editar
                        </a>
                    </div>
                </div>
            }
        </div>
    }

</section>

@code {
    private string TextoBusqueda   = "";
    private string DisciplinaFiltro = "";

    private List<string> Disciplinas = new()
    {
        "CrossFit", "Yoga", "Spinning", "Boxeo",
        "Zumba", "Pilates", "Musculacion", "HIIT"
    };

    private IEnumerable<ClaseGrupalDTO> ClasesFiltradas
    {
        get
        {
            IEnumerable<ClaseGrupalDTO> resultado = Clases;

            if (!string.IsNullOrWhiteSpace(DisciplinaFiltro))
                resultado = resultado.Where(c => c.NombreDisciplina.Contains(DisciplinaFiltro, StringComparison.OrdinalIgnoreCase));

            if (!string.IsNullOrWhiteSpace(TextoBusqueda))
            {
                string t = TextoBusqueda.Trim();
                resultado = resultado.Where(c =>
                    c.NombreDisciplina.Contains(t, StringComparison.OrdinalIgnoreCase) ||
                    c.Descripcion.Contains(t, StringComparison.OrdinalIgnoreCase));
            }

            return resultado;
        }
    }

    private List<ClaseGrupalDTO> Clases = new();
    private bool Cargando = true;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            Clases = await ClaseService.ListarClasesGrupalesAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error al cargar clases: {ex.Message}");
        }
        finally
        {
            Cargando = false;
        }
    }
}
