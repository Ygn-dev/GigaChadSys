@page "/admin/salones"
@using System.Text.Json.Serialization
@using GigaChadSys.Servicios
@using GigaChadSys.Servicios.DTO
@inject SalonServicio SalonService
@layout AdminLayout
@rendermode InteractiveServer

<section class="container-fluid py-4">

    <div class="salones-header">
        <div>
            <h1>Gestion de Salones</h1>
            <p>Administra los salones y espacios del gimnasio</p>
        </div>

        <NavLink href="/admin/salones/nuevo" class="salones-new-btn">
            <span>+</span>
            Nuevo Salon
        </NavLink>
    </div>

    <div class="salones-toolbar">
        <div class="salones-search">
            <span>⌕</span>
            <input type="text"
                   placeholder="Buscar salon..."
                   @bind="searchText"
                   @bind:event="oninput" />
        </div>
    </div>

    @if (cargando)
    {
        <p>Cargando salones...</p>
    }
    else
    {
        <div class="salones-grid">
            @foreach (var salon in SalonesFiltrados)
            {
                <article class="salon-card">
                    <div class="salon-card-top">
                        <div class="salon-icon">
                            ⊞
                        </div>

                        <span class="salon-status @GetSalonEstadoClass(salon.Estado)">
                            @(salon.Estado ? "Activo" : "Inactivo")
                        </span>
                    </div>

                    <div class="salon-info">
                        <h3>@salon.NombreSalon</h3>

                        <p>
                            <span class="salon-info-icon">♙</span>
                            Capacidad máxima:
                            <strong>@salon.AforoMaximo</strong>
                            personas
                        </p>
                    </div>

                    <div class="salon-actions">
                        <button type="button"
                                class="salon-btn salon-btn-view"
                                @onclick="() => AbrirDetalleSalon(salon)">
                            <span>⊙</span>
                            Ver
                        </button>

                        <NavLink href="@($"/admin/salones/editar/{salon.IdSalon}")"
                                 class="salon-btn salon-btn-edit">
                            <span>∠</span>
                            Editar
                        </NavLink>
                    </div>
                </article>
            }
        </div>
    }

    @if (salonSeleccionado is not null)
    {
        <div class="salon-modal-overlay" @onclick="CerrarDetalleSalon">
            <div class="salon-modal" @onclick:stopPropagation="true">

                <div class="salon-modal-header">
                    <h2>Detalle de Salon</h2>

                    <button type="button"
                            class="salon-modal-close"
                            @onclick="CerrarDetalleSalon">
                        ×
                    </button>
                </div>

                <div class="salon-modal-main">
                    <div class="salon-modal-icon">
                        ⊞
                    </div>

                    <div>
                        <h3>@salonSeleccionado.NombreSalon</h3>
                        <p>Espacio del gimnasio</p>
                    </div>
                </div>

                <div class="salon-modal-info-grid">
                    <div class="salon-modal-info">
                        <span>Estado</span>
                        <strong class="@GetSalonEstadoClass(salonSeleccionado.Estado)">
                            @(salonSeleccionado.Estado ? "Activo" : "Inactivo")
                        </strong>
                    </div>

                    <div class="salon-modal-info">
                        <span>Capacidad maxima</span>
                        <strong>@salonSeleccionado.AforoMaximo personas</strong>
                    </div>
                </div>

                <div class="salon-modal-actions">
                    <NavLink href="@($"/admin/salones/editar/{salonSeleccionado.IdSalon}")" class="salon-modal-edit" style="text-decoration:none;">
                        <span>∠</span>
                        Editar Salon
                    </NavLink>

                    <button type="button"
                            class="salon-modal-cancel"
                            @onclick="CerrarDetalleSalon">
                        Cerrar
                    </button>
                </div>

            </div>
        </div>
    }

</section>

@code {
    private string searchText = string.Empty;
    private SalonDTO? salonSeleccionado;
    private List<SalonDTO> Salones = new();
    private bool cargando = true;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            Salones = await SalonService.ListarSalonesAsync();
        }
        finally
        {
            cargando = false;
        }
    }

    private IEnumerable<SalonDTO> SalonesFiltrados =>
        string.IsNullOrWhiteSpace(searchText)
            ? Salones
            : Salones.Where(s =>
                s.NombreSalon.Contains(searchText, StringComparison.OrdinalIgnoreCase));

    private void AbrirDetalleSalon(SalonDTO salon)
    {
        salonSeleccionado = salon;
    }

    private void CerrarDetalleSalon()
    {
        salonSeleccionado = null;
    }

    private string GetSalonEstadoClass(bool estado)
    {
        return estado ? "salon-estado-activo" : "salon-estado-inactivo";
    }
}