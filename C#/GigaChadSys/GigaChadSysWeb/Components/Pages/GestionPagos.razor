@page "/admin/pagos"
@using System.Globalization
@using System.Text.Json.Serialization
@layout AdminLayout
@rendermode InteractiveServer
@using GigaChadSys.Servicios
@using GigaChadSys.Servicios.DTO
@inject PagoServicio PagoService
@inject SuscripcionServicio SuscripcionService
@inject SocioServicio SocioService
@inject MetodoPagoServicio MetodoPagoService
@inject NavigationManager Navigation

<div class="admin-list-page">

    <div class="admin-list-header">
        <div>
            <h1>Gestión de Pagos</h1>
            <p>Registra y consulta los pagos de los socios</p>
        </div>

        <a href="/admin/pagos/registrar" class="new-button">
            ＋ Registrar Pago
        </a>
    </div>

    <div class="gp-stats-row">
        <div class="gp-stat-card">
            <div class="gp-stat-label">TOTAL RECAUDADO</div>
            <div class="gp-stat-value">S/@TotalRecaudado.ToString("0.00")</div>
        </div>

        <div class="gp-stat-card">
            <div class="gp-stat-label">TOTAL PENDIENTE</div>
            <div class="gp-stat-value gp-stat-yellow">S/@TotalPendiente.ToString("0.00")</div>
        </div>

        <div class="gp-stat-card">
            <div class="gp-stat-label">TOTAL TRANSACCIONES</div>
            <div class="gp-stat-value">@Pagos.Count</div>
        </div>
    </div>

    <div class="admin-list-toolbar">
        <input type="text"
               class="admin-search"
               placeholder="🔍  Buscar por socio, DNI o concepto..."
               @bind="SearchTerm"
               @bind:event="oninput" />

        <select class="gp-filter-select" @bind="EstadoFiltro">
            <option value="">Todos los estados</option>
            <option value="pagado">Pagado</option>
            <option value="pendiente">Pendiente</option>
        </select>

        <select class="gp-filter-select" @bind="MetodoFiltro">
            <option value="">Todos los métodos</option>
            @foreach (var metodo in MetodosDisponibles)
            {
                <option value="@metodo">@metodo</option>
            }
        </select>
    </div>

    @if (Cargando)
    {
        <div class="admin-table-card">
            <div class="empty-row">
                Cargando pagos...
            </div>
        </div>
    }
    else
    {
        <div class="admin-table-card">
            <table class="admin-table">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Socio</th>
                        <th>Concepto</th>
                        <th>Monto</th>
                        <th>Método</th>
                        <th>Fecha</th>
                        <th>Estado</th>
                        <th>Acciones</th>
                    </tr>
                </thead>

                <tbody>
                    @if (!PagosFiltrados.Any())
                    {
                        <tr>
                            <td colspan="8" class="empty-row">
                                No se encontraron pagos.
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var pago in PagosPaginados)
                        {
                            <tr>
                                <td style="color:#666; font-size:12px;">
                                    #@pago.Id
                                </td>

                                <td>
                                    <div class="trainer-cell">
                                        <div class="trainer-avatar">@pago.Iniciales</div>

                                        <div>
                                            <strong>@pago.SocioNombre</strong>
                                            <span>@pago.SocioDni</span>
                                        </div>
                                    </div>
                                </td>

                                <td style="color:#F5F5F5; font-weight:600;">
                                    @pago.Concepto
                                </td>

                                <td class="td-monto">
                                    @pago.MontoTexto
                                </td>

                                <td style="color:#B0B0B0;">
                                    @pago.Metodo
                                </td>

                                <td style="color:#B0B0B0;">
                                    @pago.Fecha
                                </td>

                                <td>
                                    @if (pago.Estado == "pagado")
                                    {
                                        <span class="pagos-estado estado-pagado">
                                            <span class="estado-dot"></span> pagado
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="pagos-estado estado-pendiente">
                                            <span class="estado-dot"></span> pendiente
                                        </span>
                                    }
                                </td>

                                <td>
                                    <button class="action-button"
                                            title="Ver detalle"
                                            @onclick="() => AbrirDetallePago(pago)">
                                        👁
                                    </button>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
            @if (PagosFiltrados.Any())
            {
                <div class="socios-pagination">

                    <span class="pagination-s-info">
                        Mostrando
                        @(((paginaActual - 1) * elementosPorPagina) + 1)
                        -
                        @Math.Min(
                            paginaActual * elementosPorPagina,
                            PagosFiltrados.Count())
                        de @PagosFiltrados.Count() pagos
                    </span>

                    <div class="pagination-s-btns">

                        <button class="pgbtn"
                                disabled="@(paginaActual == 1)"
                                @onclick="PaginaAnterior">
                            ‹
                        </button>

                        @for (int i = 1; i <= TotalPaginas; i++)
                        {
                            int pagina = i;

                            <button class="pgbtn @(paginaActual == pagina ? "pgbtn-active" : "")"
                                    @onclick="() => IrAPagina(pagina)">
                                @pagina
                            </button>
                        }

                        <button class="pgbtn"
                                disabled="@(paginaActual == TotalPaginas)"
                                @onclick="PaginaSiguiente">
                            ›
                        </button>

                    </div>

                </div>
            }

        </div>
    }

    @if (PagoSeleccionado is not null)
    {
        <div class="salon-modal-overlay" @onclick="CerrarDetallePago">
            <div class="salon-modal" @onclick:stopPropagation="true">

                <div class="salon-modal-header">
                    <h2>Detalle de Pago</h2>

                    <button type="button"
                            class="salon-modal-close"
                            @onclick="CerrarDetallePago">
                        ×
                    </button>
                </div>

                <div class="salon-modal-main">
                    <div class="trainer-avatar">
                        @PagoSeleccionado.Iniciales
                    </div>

                    <div>
                        <h3>@PagoSeleccionado.SocioNombre</h3>
                        <p>@PagoSeleccionado.Concepto</p>
                    </div>
                </div>

                <div class="salon-modal-info-grid">

                    <div class="salon-modal-info">
                        <span>ID Pago</span>
                        <strong>#@PagoSeleccionado.Id</strong>
                    </div>

                    <div class="salon-modal-info">
                        <span>DNI</span>
                        <strong>@PagoSeleccionado.SocioDni</strong>
                    </div>

                    <div class="salon-modal-info">
                        <span>Monto</span>
                        <strong>@PagoSeleccionado.MontoTexto</strong>
                    </div>

                    <div class="salon-modal-info">
                        <span>Método</span>
                        <strong>@PagoSeleccionado.Metodo</strong>
                    </div>

                    <div class="salon-modal-info">
                        <span>Fecha</span>
                        <strong>@PagoSeleccionado.Fecha</strong>
                    </div>

                    <div class="salon-modal-info">
                        <span>Estado</span>

                        <strong class="@(PagoSeleccionado.Estado == "pagado"
                                                        ? "salon-estado-activo"
                                                        : "salon-estado-inactivo")">

                            @(PagoSeleccionado.Estado == "pagado"
                                ? "Pagado"
                                : "Pendiente")

                        </strong>
                    </div>

                </div>

                <div class="salon-modal-actions">

                    <button type="button"
                            class="salon-modal-edit"
                            @onclick="() => VerDetalle(PagoSeleccionado.Id)">
                        Ver Completo
                    </button>

                    <button type="button"
                            class="salon-modal-cancel"
                            @onclick="CerrarDetallePago">
                        Cerrar
                    </button>

                </div>

            </div>
        </div>
    }

</div>

@code {
    private PagoItem? PagoSeleccionado;
    private string _searchTerm = "";
    private string SearchTerm
    {
        get => _searchTerm;
        set
        {
            if (_searchTerm != value)
            {
                _searchTerm = value;
                paginaActual = 1;
            }
        }
    }

    private string _estadoFiltro = "";
    private string EstadoFiltro
    {
        get => _estadoFiltro;
        set
        {
            if (_estadoFiltro != value)
            {
                _estadoFiltro = value;
                paginaActual = 1;
            }
        }
    }

    private string _metodoFiltro = "";
    private string MetodoFiltro
    {
        get => _metodoFiltro;
        set
        {
            if (_metodoFiltro != value)
            {
                _metodoFiltro = value;
                paginaActual = 1;
            }
        }
    }

    private bool Cargando { get; set; } = true;

    private List<PagoItem> Pagos { get; set; } = new();

    private void AbrirDetallePago(PagoItem pago)
    {
        PagoSeleccionado = pago;
    }

    private void CerrarDetallePago()
    {
        PagoSeleccionado = null;
    }

    // ── Paginación ──
    private int paginaActual = 1;
    private int elementosPorPagina = 10;

    private IEnumerable<string> MetodosDisponibles =>
        Pagos.Select(p => p.Metodo)
             .Where(m => !string.IsNullOrWhiteSpace(m))
             .Distinct()
             .OrderBy(m => m);

    protected override async Task OnInitializedAsync()
    {
        await CargarPagos();
    }

    private async Task CargarPagos()
    {
        Cargando = true;

        try
        {
            var pagosTask = PagoService.ListarPagosAsync();
            var suscripcionesTask = SuscripcionService.ListarSuscripcionesAsync();
            var sociosTask = SocioService.ListarSociosAsync();
            var metodosTask = MetodoPagoService.ListarMetodosDePagoAsync();

            await Task.WhenAll(
                pagosTask,
                suscripcionesTask,
                sociosTask,
                metodosTask);

            var pagosResult = pagosTask.Result;
            var suscripcionesResult = suscripcionesTask.Result;
            var sociosResult = sociosTask.Result;
            var metodosResult = metodosTask.Result;

            var dictSocios = sociosResult.ToDictionary(
                s => s.IdUsuario,
                s => s);

            var dictMetodos = metodosResult.ToDictionary(
                m => m.IdMetodoPago,
                m => m.Tipo);

            var dictSuscripciones = suscripcionesResult
                .Where(s => s.IdPago > 0)
                .GroupBy(s => s.IdPago)
                .ToDictionary(
                    g => g.Key,
                    g => g.OrderByDescending(x => x.Activo).First()
                );

            Pagos.Clear();

            foreach (var pago in pagosResult)
            {
                dictSuscripciones.TryGetValue(
                    pago.IdPago,
                    out var suscripcion);

                string socioNombre = "Sin socio";
                string socioDni = "-";
                string iniciales = "S";
                string concepto = pago.Tipo;

                if (suscripcion != null &&
                    dictSocios.TryGetValue(
                        suscripcion.IdUsuario,
                        out var socio))
                {
                    socioNombre = ObtenerNombreSocio(socio);
                    socioDni = socio.Dni.ToString();
                    iniciales = ObtenerIniciales(socio);
                    concepto = ObtenerConceptoPago(
                        pago,
                        suscripcion);
                }

                var nombreMetodo =
                    dictMetodos.TryGetValue(
                        pago.MetodoPago,
                        out var metodo)
                        ? metodo
                        : "Desconocido";

                Pagos.Add(new PagoItem
                {
                    Id = pago.IdPago,
                    SocioNombre = socioNombre,
                    SocioDni = socioDni,
                    Iniciales = iniciales,
                    Concepto = concepto,
                    Monto = (decimal)pago.Monto,
                    Metodo = nombreMetodo,
                    Fecha = pago.FechaPagoTexto,
                    Estado = pago.Activo ? "pagado" : "pendiente"
                });
            }

            paginaActual = 1;
        }
        finally
        {
            Cargando = false;
        }
    }

    private IEnumerable<PagoItem> PagosFiltrados
    {
        get
        {
            IEnumerable<PagoItem> resultado = Pagos;

            if (!string.IsNullOrWhiteSpace(SearchTerm))
            {
                string texto = SearchTerm.Trim();

                resultado = resultado.Where(p =>
                    p.SocioNombre.Contains(texto, StringComparison.OrdinalIgnoreCase) ||
                    p.SocioDni.Contains(texto, StringComparison.OrdinalIgnoreCase) ||
                    p.Concepto.Contains(texto, StringComparison.OrdinalIgnoreCase)
                );
            }

            if (!string.IsNullOrWhiteSpace(EstadoFiltro))
            {
                resultado = resultado.Where(p => p.Estado == EstadoFiltro);
            }

            if (!string.IsNullOrWhiteSpace(MetodoFiltro))
            {
                resultado = resultado.Where(p => p.Metodo == MetodoFiltro);
            }

            return resultado
                .OrderByDescending(p => p.Fecha)
                .ThenBy(p => p.SocioNombre);
        }
    }

    private IEnumerable<PagoItem> PagosPaginados =>
        PagosFiltrados
            .Skip((paginaActual - 1) * elementosPorPagina)
            .Take(elementosPorPagina);

    private int TotalPaginas =>
        Math.Max(
            1,
            (int)Math.Ceiling(
                PagosFiltrados.Count() /
                (double)elementosPorPagina));

    private decimal TotalRecaudado =>
        Pagos.Where(p => p.Estado == "pagado")
             .Sum(p => p.Monto);

    private decimal TotalPendiente =>
        Pagos.Where(p => p.Estado == "pendiente")
             .Sum(p => p.Monto);

    private void PaginaAnterior()
    {
        if (paginaActual > 1)
            paginaActual--;
    }

    private void PaginaSiguiente()
    {
        if (paginaActual < TotalPaginas)
            paginaActual++;
    }

    private void IrAPagina(int pagina)
    {
        paginaActual = pagina;
    }

    private void VerDetalle(int id)
    {
        Navigation.NavigateTo($"/admin/pagos/{id}");
    }

    private static string ObtenerNombreSocio(SocioDTO socio)
    {
        string nombre =
            $"{socio.Nombres} {socio.ApellidoPaterno} {socio.ApellidoMaterno}"
            .Trim();

        return string.IsNullOrWhiteSpace(nombre)
            ? "Socio sin nombre"
            : nombre;
    }

    private static string ObtenerIniciales(SocioDTO socio)
    {
        string nombres = socio.Nombres ?? "";
        string apellido = socio.ApellidoPaterno ?? "";

        string inicialNombre = !string.IsNullOrWhiteSpace(nombres)
            ? nombres.Trim()[0].ToString().ToUpper()
            : "";

        string inicialApellido = !string.IsNullOrWhiteSpace(apellido)
            ? apellido.Trim()[0].ToString().ToUpper()
            : "";

        string iniciales = $"{inicialNombre}{inicialApellido}";

        return string.IsNullOrWhiteSpace(iniciales)
            ? "S"
            : iniciales;
    }

    private static string ObtenerConceptoPago(
        PagoDTO pago,
        SuscripcionDTO suscripcion)
    {
        string tipoPlan = suscripcion.TipoPlan;

        if (string.IsNullOrWhiteSpace(tipoPlan) ||
            tipoPlan == "Sin plan")
        {
            tipoPlan = "Membresía";
        }
        else
        {
            tipoPlan = $"Membresía {tipoPlan}";
        }

        DateTime fechaReferencia =
            suscripcion.FechaIngreso ??
            pago.FechaPago ??
            DateTime.Today;

        string mes =
            fechaReferencia.ToString(
                "MMMM yyyy",
                new CultureInfo("es-ES"));

        if (!string.IsNullOrWhiteSpace(pago.Tipo) &&
            !pago.Tipo.Equals(
                "MENSUAL",
                StringComparison.OrdinalIgnoreCase))
        {
            return $"{tipoPlan} - {pago.Tipo} - {mes}";
        }

        return $"{tipoPlan} - {mes}";
    }

    private class PagoItem
    {
        [JsonPropertyName("idPago")]
        public int Id { get; set; }

        [JsonPropertyName("socioNombre")]
        public string SocioNombre { get; set; } = "";

        [JsonPropertyName("socioDni")]
        public string SocioDni { get; set; } = "";

        [JsonPropertyName("iniciales")]
        public string Iniciales { get; set; } = "";

        [JsonPropertyName("tipo")]
        public string Concepto { get; set; } = "";

        [JsonPropertyName("monto")]
        public decimal Monto { get; set; }

        [JsonPropertyName("metodoPago")]
        public string Metodo { get; set; } = "";

        [JsonPropertyName("fechaPago")]
        public string Fecha { get; set; } = "";

        [JsonPropertyName("estado")]
        public string Estado { get; set; } = "";

        public string MontoTexto => $"S/{Monto:0.00}";
    }
}