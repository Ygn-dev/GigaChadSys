@code {
    private PagoItem? PagoSeleccionado;

    private string _searchTerm = "";
    private string SearchTerm
    {
        get => _searchTerm;
        set
        {
            if (_searchTerm != value)
            {
                _searchTerm = value;
                paginaActual = 1;
            }
        }
    }

    private string _estadoFiltro = "";
    private string EstadoFiltro
    {
        get => _estadoFiltro;
        set
        {
            if (_estadoFiltro != value)
            {
                _estadoFiltro = value;
                paginaActual = 1;
            }
        }
    }

    private string _metodoFiltro = "";
    private string MetodoFiltro
    {
        get => _metodoFiltro;
        set
        {
            if (_metodoFiltro != value)
            {
                _metodoFiltro = value;
                paginaActual = 1;
            }
        }
    }

    private bool Cargando { get; set; } = true;

    private List<PagoItem> Pagos { get; set; } = new();

    private void AbrirDetallePago(PagoItem pago)
    {
        PagoSeleccionado = pago;
    }

    private void CerrarDetallePago()
    {
        PagoSeleccionado = null;
    }

    private int paginaActual = 1;
    private int elementosPorPagina = 10;

    private IEnumerable<string> MetodosDisponibles =>
        Pagos.Select(p => p.Metodo)
             .Where(m => !string.IsNullOrWhiteSpace(m))
             .Distinct()
             .OrderBy(m => m);

    protected override async Task OnInitializedAsync()
    {
        await CargarPagos();
    }

    private async Task CargarPagos()
    {
        Cargando = true;

        try
        {
            var pagosTask = PagoService.ListarPagosAsync();
            var suscripcionesTask = SuscripcionService.ListarSuscripcionesAsync();
            var sociosTask = SocioService.ListarSociosAsync();
            var entrenadoresTask = EntrenadorService.ListarEntrenadoresAsync();
            var metodosTask = MetodoPagoService.ListarMetodosDePagoAsync();

            await Task.WhenAll(
                pagosTask,
                suscripcionesTask,
                sociosTask,
                entrenadoresTask,
                metodosTask
            );

            var pagosResult = pagosTask.Result;
            var suscripcionesResult = suscripcionesTask.Result;
            var sociosResult = sociosTask.Result;
            var entrenadoresResult = entrenadoresTask.Result;
            var metodosResult = metodosTask.Result;

            var dictSocios = sociosResult.ToDictionary(s => s.IdUsuario, s => s);

            var dictMetodos = metodosResult.ToDictionary(m => m.IdMetodoPago, m => m.Tipo);

            var dictSuscripciones = suscripcionesResult
                .Where(s => s.IdPago > 0)
                .GroupBy(s => s.IdPago)
                .ToDictionary(g => g.Key, g => g.OrderByDescending(x => x.Activo).First());

            Pagos.Clear();

            foreach (var pago in pagosResult)
            {
                dictSuscripciones.TryGetValue(pago.IdPago, out var suscripcion);

                bool esEgreso = EsPagoEgreso(pago);
                bool esCapitalInicial = EsCapitalInicial(pago);

                string usuarioNombre = "Usuario no asociado";
                string usuarioDetalle = "-";
                string iniciales = "U";
                string concepto = pago.Tipo ?? "Pago";
                string rolUsuario = "Usuario";

                if (esCapitalInicial)
                {
                    usuarioNombre = "GigaChadSys";
                    usuarioDetalle = "Movimiento administrativo";
                    iniciales = "GC";
                    rolUsuario = "Administración";
                    concepto = pago.Tipo ?? "Capital inicial del gimnasio";
                    esEgreso = false;
                }
                else if (esEgreso)
                {
                    var entrenador = ObtenerEntrenadorDesdePago(pago, entrenadoresResult);

                    if (entrenador != null)
                    {
                        usuarioNombre = ObtenerNombreEntrenador(entrenador);
                        usuarioDetalle = entrenador.Dni.ToString();
                        iniciales = ObtenerInicialesEntrenador(entrenador);
                    }
                    else
                    {
                        usuarioNombre = ExtraerNombreEntrenadorDesdePago(pago);
                        usuarioDetalle = "";
                        iniciales = ObtenerInicialesTexto(usuarioNombre);
                    }

                    rolUsuario = "Entrenador";
                    concepto = pago.Tipo ?? "Sueldo de entrenador";
                }
                else if (suscripcion != null && dictSocios.TryGetValue(suscripcion.IdUsuario, out var socio))
                {
                    usuarioNombre = ObtenerNombreSocio(socio);
                    usuarioDetalle = socio.Dni.ToString();
                    iniciales = ObtenerIniciales(socio);
                    rolUsuario = "Socio";
                    concepto = ObtenerConceptoPago(pago, suscripcion);
                }
                else
                {
                    rolUsuario = "Sin asignar";
                }

                var nombreMetodo = dictMetodos.TryGetValue(pago.MetodoPago, out var metodo)
                    ? metodo
                    : "Desconocido";

                Pagos.Add(new PagoItem
                {
                    Id = pago.IdPago,
                    UsuarioNombre = usuarioNombre,
                    UsuarioDetalle = usuarioDetalle,
                    Iniciales = iniciales,
                    RolUsuario = rolUsuario,
                    EsEgreso = esEgreso,
                    Concepto = concepto,
                    Monto = (decimal)pago.Monto,
                    Metodo = nombreMetodo,
                    Fecha = pago.FechaPagoTexto,
                    Estado = pago.Activo ? "pagado" : "pendiente"
                });
            }

            paginaActual = 1;
        }
        finally
        {
            Cargando = false;
        }
    }

    private IEnumerable<PagoItem> PagosFiltrados
    {
        get
        {
            IEnumerable<PagoItem> resultado = Pagos;

            if (!string.IsNullOrWhiteSpace(SearchTerm))
            {
                string texto = SearchTerm.Trim();

                resultado = resultado.Where(p =>
                    p.UsuarioNombre.Contains(texto, StringComparison.OrdinalIgnoreCase) ||
                    p.UsuarioDetalle.Contains(texto, StringComparison.OrdinalIgnoreCase) ||
                    p.RolUsuario.Contains(texto, StringComparison.OrdinalIgnoreCase) ||
                    p.Concepto.Contains(texto, StringComparison.OrdinalIgnoreCase)
                );
            }

            if (!string.IsNullOrWhiteSpace(EstadoFiltro))
            {
                resultado = resultado.Where(p => p.Estado == EstadoFiltro);
            }

            if (!string.IsNullOrWhiteSpace(MetodoFiltro))
            {
                resultado = resultado.Where(p => p.Metodo == MetodoFiltro);
            }

            return resultado
                .OrderByDescending(p => p.Fecha)
                .ThenBy(p => p.EsEgreso)
                .ThenBy(p => p.UsuarioNombre);
        }
    }

    private IEnumerable<PagoItem> PagosPaginados =>
        PagosFiltrados
            .Skip((paginaActual - 1) * elementosPorPagina)
            .Take(elementosPorPagina);

    private int TotalPaginas =>
        Math.Max(1, (int)Math.Ceiling(PagosFiltrados.Count() / (double)elementosPorPagina));

    private decimal TotalIngresos =>
        Pagos.Where(p => p.Estado == "pagado" && !p.EsEgreso)
             .Sum(p => p.Monto);

    private decimal TotalEgresos =>
        Pagos.Where(p => p.Estado == "pagado" && p.EsEgreso)
             .Sum(p => p.Monto);

    private decimal BalanceNeto =>
        TotalIngresos - TotalEgresos;

    private decimal PendienteCobrarSocios =>
        Pagos.Where(p => p.Estado == "pendiente" && !p.EsEgreso)
             .Sum(p => p.Monto);

    private decimal PendientePagarEntrenadores =>
        Pagos.Where(p => p.Estado == "pendiente" && p.EsEgreso)
             .Sum(p => p.Monto);

    private string BalanceNetoTexto =>
        BalanceNeto < 0
            ? $"-S/{Math.Abs(BalanceNeto):0.00}"
            : $"S/{BalanceNeto:0.00}";

    private string ClaseBalance =>
        BalanceNeto < 0
            ? "gp-stat-value gp-stat-red"
            : "gp-stat-value";

    private void PaginaAnterior()
    {
        if (paginaActual > 1)
            paginaActual--;
    }

    private void PaginaSiguiente()
    {
        if (paginaActual < TotalPaginas)
            paginaActual++;
    }

    private void IrAPagina(int pagina)
    {
        paginaActual = pagina;
    }

    private static string ObtenerNombreSocio(SocioDTO socio)
    {
        string nombre = $"{socio.Nombres} {socio.ApellidoPaterno} {socio.ApellidoMaterno}".Trim();

        return string.IsNullOrWhiteSpace(nombre)
            ? "Socio sin nombre"
            : nombre;
    }

    private static string ObtenerIniciales(SocioDTO socio)
    {
        string nombres = socio.Nombres ?? "";
        string apellido = socio.ApellidoPaterno ?? "";

        string inicialNombre = !string.IsNullOrWhiteSpace(nombres)
            ? nombres.Trim()[0].ToString().ToUpper()
            : "";

        string inicialApellido = !string.IsNullOrWhiteSpace(apellido)
            ? apellido.Trim()[0].ToString().ToUpper()
            : "";

        string iniciales = $"{inicialNombre}{inicialApellido}";

        return string.IsNullOrWhiteSpace(iniciales) ? "S" : iniciales;
    }

    private static string ObtenerConceptoPago(PagoDTO pago, SuscripcionDTO suscripcion)
    {
        string tipoPlan = suscripcion.TipoPlan;

        if (string.IsNullOrWhiteSpace(tipoPlan) || tipoPlan == "Sin plan")
        {
            tipoPlan = "Membresía";
        }
        else
        {
            tipoPlan = $"Membresía {tipoPlan}";
        }

        DateTime fechaReferencia =
            suscripcion.FechaIngreso ??
            pago.FechaPago ??
            DateTime.Today;

        string mes = fechaReferencia.ToString("MMMM yyyy", new CultureInfo("es-ES"));

        if (!string.IsNullOrWhiteSpace(pago.Tipo) &&
            !pago.Tipo.Equals("MENSUAL", StringComparison.OrdinalIgnoreCase))
        {
            return $"{tipoPlan} - {pago.Tipo} - {mes}";
        }

        return $"{tipoPlan} - {mes}";
    }

    private static bool EsPagoEgreso(PagoDTO pago)
    {
        if (string.IsNullOrWhiteSpace(pago.Tipo))
            return false;

        string tipo = pago.Tipo.Trim().ToLower();

        return tipo.Contains("sueldo") ||
               tipo.Contains("bono") ||
               tipo.Contains("entrenador");
    }

    private static bool EsCapitalInicial(PagoDTO pago)
    {
        if (string.IsNullOrWhiteSpace(pago.Tipo))
            return false;

        string tipo = NormalizarTexto(pago.Tipo);

        return tipo.Contains("capital inicial") ||
               tipo.Contains("aporte inicial") ||
               tipo.Contains("capital del gimnasio");
    }

    private static EntrenadorDTO? ObtenerEntrenadorDesdePago(
        PagoDTO pago,
        List<EntrenadorDTO> entrenadores)
    {
        string nombreExtraido = ExtraerNombreEntrenadorDesdePago(pago);

        if (string.IsNullOrWhiteSpace(nombreExtraido))
            return null;

        string buscado = NormalizarTexto(nombreExtraido);

        return entrenadores.FirstOrDefault(e =>
        {
            string nombres = NormalizarTexto(e.Nombres);
            string completo = NormalizarTexto(ObtenerNombreEntrenador(e));

            return nombres == buscado ||
                   nombres.StartsWith(buscado) ||
                   completo.Contains(buscado);
        });
    }

    private static string ExtraerNombreEntrenadorDesdePago(PagoDTO pago)
    {
        if (string.IsNullOrWhiteSpace(pago.Tipo))
            return "Entrenador";

        string texto = pago.Tipo.Trim();

        texto = texto.Replace("Sueldo Entrenador", "", StringComparison.OrdinalIgnoreCase)
                     .Replace("Bono Entrenador", "", StringComparison.OrdinalIgnoreCase)
                     .Trim();

        if (texto.Contains(" - "))
        {
            texto = texto.Split(" - ")[0].Trim();
        }

        return string.IsNullOrWhiteSpace(texto) ? "Entrenador" : texto;
    }

    private static string ObtenerNombreEntrenador(EntrenadorDTO entrenador)
    {
        string nombre = $"{entrenador.Nombres} {entrenador.ApellidoPaterno} {entrenador.ApellidoMaterno}".Trim();

        return string.IsNullOrWhiteSpace(nombre)
            ? "Entrenador sin nombre"
            : nombre;
    }

    private static string ObtenerInicialesEntrenador(EntrenadorDTO entrenador)
    {
        string nombres = entrenador.Nombres ?? "";
        string apellido = entrenador.ApellidoPaterno ?? "";

        string inicialNombre = !string.IsNullOrWhiteSpace(nombres)
            ? nombres.Trim()[0].ToString().ToUpper()
            : "";

        string inicialApellido = !string.IsNullOrWhiteSpace(apellido)
            ? apellido.Trim()[0].ToString().ToUpper()
            : "";

        string iniciales = $"{inicialNombre}{inicialApellido}";

        return string.IsNullOrWhiteSpace(iniciales) ? "E" : iniciales;
    }

    private static string ObtenerInicialesTexto(string texto)
    {
        if (string.IsNullOrWhiteSpace(texto))
            return "U";

        var partes = texto.Trim()
            .Split(' ', StringSplitOptions.RemoveEmptyEntries);

        if (partes.Length == 1)
            return partes[0][0].ToString().ToUpper();

        return $"{partes[0][0]}{partes[1][0]}".ToUpper();
    }

    private static string NormalizarTexto(string? texto)
    {
        if (string.IsNullOrWhiteSpace(texto))
            return "";

        string normalizado = texto.Normalize(System.Text.NormalizationForm.FormD);
        var chars = normalizado
            .Where(c => System.Globalization.CharUnicodeInfo.GetUnicodeCategory(c) != System.Globalization.UnicodeCategory.NonSpacingMark)
            .ToArray();

        return new string(chars).Trim().ToLowerInvariant();
    }

    private class PagoItem
    {
        [JsonPropertyName("idPago")]
        public int Id { get; set; }

        [JsonPropertyName("usuarioNombre")]
        public string UsuarioNombre { get; set; } = "";

        [JsonPropertyName("usuarioDetalle")]
        public string UsuarioDetalle { get; set; } = "";

        [JsonPropertyName("iniciales")]
        public string Iniciales { get; set; } = "";

        [JsonPropertyName("rolUsuario")]
        public string RolUsuario { get; set; } = "";

        [JsonPropertyName("esEgreso")]
        public bool EsEgreso { get; set; }

        [JsonPropertyName("tipo")]
        public string Concepto { get; set; } = "";

        [JsonPropertyName("monto")]
        public decimal Monto { get; set; }

        [JsonPropertyName("metodoPago")]
        public string Metodo { get; set; } = "";

        [JsonPropertyName("fechaPago")]
        public string Fecha { get; set; } = "";

        [JsonPropertyName("estado")]
        public string Estado { get; set; } = "";

        public string ClaseRol =>
            RolUsuario == "Entrenador"
                ? "pagos-estado estado-pendiente"
                : RolUsuario == "Socio" || RolUsuario == "Administración"
                    ? "pagos-estado estado-pagado"
                    : "pagos-estado";
    }
