@page "/admin/pagos"
@using System.Globalization
@using System.Text.Json.Serialization
@layout AdminLayout
@rendermode InteractiveServer
@using GigaChadSys.Servicios
@using GigaChadSys.Servicios.DTO
@inject PagoServicio PagoService
@inject SuscripcionServicio SuscripcionService
@inject SocioServicio SocioService
@inject EntrenadorServicio EntrenadorService
@inject MetodoPagoServicio MetodoPagoService
@inject NavigationManager Navigation

<div class="admin-list-page">

    <div class="admin-list-header">
        <div>
            <h1>Gestión de Pagos</h1>
            <p>Registra y consulta los movimientos financieros del sistema</p>
        </div>

        <a href="/admin/pagos/registrar" class="new-button">
            <i class="bi bi-plus-lg"></i>
            Registrar Pago
        </a>
    </div>

    <div class="gp-finance-grid">

        <div class="gp-finance-card">
            <div class="gp-card-top">
                <div>
                    <div class="gp-stat-label">TOTAL INGRESOS</div>
                    <div class="gp-stat-value gp-stat-green">S/@TotalIngresos.ToString("0.00")</div>
                    <p>Dinero real cobrado</p>
                </div>

                <div class="gp-kpi-icon income">
                    <i class="bi bi-arrow-up-right"></i>
                </div>
            </div>
        </div>

        <div class="gp-finance-card">
            <div class="gp-card-top">
                <div>
                    <div class="gp-stat-label">TOTAL EGRESOS</div>
                    <div class="gp-stat-value gp-stat-red">-S/@TotalEgresos.ToString("0.00")</div>
                    <p>Dinero real pagado</p>
                </div>

                <div class="gp-kpi-icon expense">
                    <i class="bi bi-arrow-down-left"></i>
                </div>
            </div>
        </div>

        <div class="gp-finance-card">
            <div class="gp-card-top">
                <div>
                    <div class="gp-stat-label">BALANCE NETO</div>
                    <div class="@ClaseBalance">@BalanceNetoTexto</div>
                    <p>Ingresos menos egresos</p>
                </div>

                <div class="gp-kpi-icon balance">
                    <i class="bi bi-calculator"></i>
                </div>
            </div>
        </div>

        <div class="gp-finance-card">
            <div class="gp-card-top">
                <div>
                    <div class="gp-stat-label">PENDIENTE POR COBRAR</div>
                    <div class="gp-stat-value gp-stat-yellow">S/@PendienteCobrarSocios.ToString("0.00")</div>
                    <p>Deudas pendientes de socios</p>
                </div>

                <div class="gp-kpi-icon pending">
                    <i class="bi bi-hourglass-split"></i>
                </div>
            </div>
        </div>

        <div class="gp-finance-card">
            <div class="gp-card-top">
                <div>
                    <div class="gp-stat-label">PENDIENTE POR PAGAR</div>
                    <div class="gp-stat-value gp-stat-orange">-S/@PendientePagarEntrenadores.ToString("0.00")</div>
                    <p>Sueldos o egresos pendientes</p>
                </div>

                <div class="gp-kpi-icon payable">
                    <i class="bi bi-clock-history"></i>
                </div>
            </div>
        </div>

        <div class="gp-finance-card">
            <div class="gp-card-top">
                <div>
                    <div class="gp-stat-label">TOTAL TRANSACCIONES</div>
                    <div class="gp-stat-value">@Pagos.Count</div>
                    <p>Movimientos registrados</p>
                </div>

                <div class="gp-kpi-icon total">
                    <i class="bi bi-list-check"></i>
                </div>
            </div>
        </div>

    </div>

    <div class="admin-list-toolbar">
        <input type="text"
               class="admin-search"
               placeholder="Buscar por usuario, rol, DNI o concepto..."
               @bind="SearchTerm"
               @bind:event="oninput" />

        <select class="gp-filter-select" @bind="EstadoFiltro">
            <option value="">Todos los estados</option>
            <option value="pagado">Pagado</option>
            <option value="pendiente">Pendiente</option>
        </select>

        <select class="gp-filter-select" @bind="MetodoFiltro">
            <option value="">Todos los métodos</option>
            @foreach (var metodo in MetodosDisponibles)
            {
                <option value="@metodo">@metodo</option>
            }
        </select>
    </div>

    @if (Cargando)
    {
        <div class="admin-table-card">
            <div class="empty-row">
                Cargando pagos...
            </div>
        </div>
    }
    else
    {
        <div class="admin-table-card">
            <table class="admin-table">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>USUARIO</th>
                        <th>ROL</th>
                        <th>CONCEPTO</th>
                        <th>MONTO</th>
                        <th>MÉTODO</th>
                        <th>FECHA</th>
                        <th>ESTADO</th>
                        <th>ACCIONES</th>
                    </tr>
                </thead>

                <tbody>
                    @if (!PagosFiltrados.Any())
                    {
                        <tr>
                            <td colspan="9" class="empty-row">
                                No se encontraron pagos.
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var pago in PagosPaginados)
                        {
                            <tr>
                                <td style="color:#666; font-size:12px;">
                                    #@pago.Id
                                </td>

                                <td>
                                    <div class="trainer-cell">
                                        <div class="trainer-avatar">@pago.Iniciales</div>

                                        <div>
                                            <strong>@pago.UsuarioNombre</strong>

                                            @if (!string.IsNullOrWhiteSpace(pago.UsuarioDetalle))
                                            {
                                                <span>@pago.UsuarioDetalle</span>
                                            }
                                        </div>
                                    </div>
                                </td>

                                <td>
                                    <span class="@pago.ClaseRol">
                                        <span class="estado-dot"></span>
                                        @pago.RolUsuario
                                    </span>
                                </td>

                                <td style="color:#F5F5F5; font-weight:600;">
                                    @pago.Concepto
                                </td>

                                <td class="td-monto">
                                    @if (pago.EsEgreso)
                                    {
                                        <span class="gp-monto-wrap gp-monto-egreso">
                                            <span class="gp-monto-sign">-</span>
                                            <span class="gp-monto-value">S/@pago.Monto.ToString("0.00")</span>
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="gp-monto-wrap gp-monto-ingreso">
                                            <span class="gp-monto-value">S/@pago.Monto.ToString("0.00")</span>
                                        </span>
                                    }
                                </td>

                                <td style="color:#B0B0B0;">
                                    @pago.Metodo
                                </td>

                                <td style="color:#B0B0B0;">
                                    @pago.Fecha
                                </td>

                                <td>
                                    @if (pago.Estado == "pagado")
                                    {
                                        <span class="pagos-estado estado-pagado">
                                            <span class="estado-dot"></span> pagado
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="pagos-estado estado-pendiente">
                                            <span class="estado-dot"></span> pendiente
                                        </span>
                                    }
                                </td>

                                <td>
                                    <button class="action-button"
                                            title="Ver detalle"
                                            @onclick="() => AbrirDetallePago(pago)">
                                        <i class="bi bi-eye"></i>
                                    </button>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>

            @if (PagosFiltrados.Any())
            {
                <div class="socios-pagination">

                    <span class="pagination-s-info">
                        Mostrando
                        @(((paginaActual - 1) * elementosPorPagina) + 1)
                        -
                        @Math.Min(paginaActual * elementosPorPagina, PagosFiltrados.Count())
                        de @PagosFiltrados.Count() pagos
                    </span>

                    <div class="pagination-s-btns">

                        <button class="pgbtn"
                                disabled="@(paginaActual == 1)"
                                @onclick="PaginaAnterior">
                            ‹
                        </button>

                        @for (int i = 1; i <= TotalPaginas; i++)
                        {
                            int pagina = i;

                            <button class="pgbtn @(paginaActual == pagina ? "pgbtn-active" : "")"
                                    @onclick="() => IrAPagina(pagina)">
                                @pagina
                            </button>
                        }

                        <button class="pgbtn"
                                disabled="@(paginaActual == TotalPaginas)"
                                @onclick="PaginaSiguiente">
                            ›
                        </button>

                    </div>

                </div>
            }
        </div>
    }

    @if (PagoSeleccionado is not null)
    {
        <div class="salon-modal-overlay" @onclick="CerrarDetallePago">
            <div class="salon-modal" @onclick:stopPropagation="true">

                <div class="salon-modal-header">
                    <h2>Detalle de Pago</h2>

                    <button type="button"
                            class="salon-modal-close"
                            @onclick="CerrarDetallePago">
                        ×
                    </button>
                </div>

                <div class="salon-modal-main">
                    <div class="trainer-avatar">
                        @PagoSeleccionado.Iniciales
                    </div>

                    <div>
                        <h3>@PagoSeleccionado.UsuarioNombre</h3>
                        <p>@PagoSeleccionado.Concepto</p>
                    </div>
                </div>

                <div class="salon-modal-info-grid">

                    <div class="salon-modal-info">
                        <span>ID Pago</span>
                        <strong>#@PagoSeleccionado.Id</strong>
                    </div>

                    <div class="salon-modal-info">
                        <span>Rol</span>
                        <strong>@PagoSeleccionado.RolUsuario</strong>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(PagoSeleccionado.UsuarioDetalle))
                    {
                        <div class="salon-modal-info">
                            <span>DNI</span>
                            <strong>@PagoSeleccionado.UsuarioDetalle</strong>
                        </div>
                    }

                    <div class="salon-modal-info">
                        <span>Tipo movimiento</span>
                        <strong class="@(PagoSeleccionado.EsEgreso ? "gp-text-red" : "gp-text-green")">
                            @(PagoSeleccionado.EsEgreso ? "Egreso" : "Ingreso")
                        </strong>
                    </div>

                    <div class="salon-modal-info">
                        <span>Monto</span>
                        <strong class="@(PagoSeleccionado.EsEgreso ? "gp-text-red" : "")">
                            @(PagoSeleccionado.EsEgreso ? "-S/" : "S/")@PagoSeleccionado.Monto.ToString("0.00")
                        </strong>
                    </div>

                    <div class="salon-modal-info">
                        <span>Método</span>
                        <strong>@PagoSeleccionado.Metodo</strong>
                    </div>

                    <div class="salon-modal-info">
                        <span>Fecha</span>
                        <strong>@PagoSeleccionado.Fecha</strong>
                    </div>

                    <div class="salon-modal-info">
                        <span>Estado</span>
                        <strong class="@(PagoSeleccionado.Estado == "pagado" ? "salon-estado-activo" : "salon-estado-inactivo")">
                            @(PagoSeleccionado.Estado == "pagado" ? "Pagado" : "Pendiente")
                        </strong>
                    </div>

                </div>

                <div class="salon-modal-actions">

                    <button type="button"
                            class="salon-modal-cancel"
                            @onclick="CerrarDetallePago">
                        Cerrar
                    </button>

                </div>

            </div>
        </div>
    }

</div>

