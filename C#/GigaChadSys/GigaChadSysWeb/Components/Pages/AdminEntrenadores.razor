@page "/admin/entrenadores"
@layout AdminLayout
@rendermode InteractiveServer
@using GigaChadSys.Servicios
@using GigaChadSys.Servicios.DTO
@inject EntrenadorServicio EntrenadorService

<section class="admin-list-page">
    <div class="admin-list-header">
        <div>
            <h1>Gestión de Entrenadores</h1>
            <p>Administra los entrenadores del gimnasio.</p>
        </div>

        <a class="new-button" href="/admin/entrenadores/nuevo">
            + Nuevo Entrenador
        </a>
    </div>

    <div class="admin-list-toolbar">
        <input class="admin-search"
               type="text"
               placeholder="Buscar por DNI, nombre o especialidad..."
               @bind="TextoBusqueda"
               @bind:event="oninput" />

        <div class="admin-filter-group">
            <button class="@FiltroClaseTodos" @onclick="MostrarTodos">Todos</button>
            <button class="@FiltroClaseActivos" @onclick="MostrarActivos">Activos</button>
            <button class="@FiltroClaseInactivos" @onclick="MostrarInactivos">Inactivos</button>
        </div>
    </div>

    @{
        var entrenadores = EntrenadoresPaginados.ToList();
    }

    <div class="admin-table-card">
        <table class="admin-table">
            <thead>
                <tr>
                    <th>DNI</th>
                    <th>Nombre</th>
                    <th>Especialidad</th>
                    <th>Contacto</th>
                    <th>Tiempo</th>
                    <th>Sueldo</th>
                    <th>Estado</th>
                    <th>Acciones</th>
                </tr>
            </thead>

            <tbody>
                @if (Cargando)
                {
                    <tr>
                        <td colspan="8" class="empty-row">
                            Cargando entrenadores...
                        </td>
                    </tr>
                }
                else if (entrenadores.Count == 0)
                {
                    <tr>
                        <td colspan="8" class="empty-row">
                            No se encontraron entrenadores.
                        </td>
                    </tr>
                }
                else
                {
                    @foreach (var entrenador in entrenadores)
                    {
                        <tr>
                            <td>@entrenador.Dni</td>

                            <td>
                                <div class="trainer-cell">
                                    <div class="trainer-avatar">
                                        @InicialEntrenador(entrenador)
                                    </div>

                                    <div>
                                        <strong>@entrenador.NombreCompleto</strong>
                                        <span>@entrenador.Email</span>
                                    </div>
                                </div>
                            </td>

                            <td>@MostrarTexto(entrenador.Especialidad)</td>
                            <td>@entrenador.Telefono</td>
                            <td>@entrenador.TiempoTrabajoDescripcion</td>
                            <td>@entrenador.SueldoTexto</td>

                            <td>
                                @if (entrenador.Activo)
                                {
                                    <span class="status-badge active">Activo</span>
                                }
                                else
                                {
                                    <span class="status-badge inactive">Inactivo</span>
                                }
                            </td>

                            <td>
                                <a class="action-button"
                                   href="@($"/admin/entrenadores/editar/{entrenador.IdUsuario}")">
                                    ✎
                                </a>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
    <div class="socios-pagination">

        <span class="pagination-s-info">
            Mostrando
            @(((PaginaActual - 1) * ElementosPorPagina) + 1)
            -
            @Math.Min(
                PaginaActual * ElementosPorPagina,
                EntrenadoresFiltrados.Count()
            )
            de @EntrenadoresFiltrados.Count() entrenadores
        </span>

        <div class="pagination-s-btns">

            <button class="pgbtn"
                    disabled="@(PaginaActual == 1)"
                    @onclick="PaginaAnterior">
                ‹
            </button>

            @for (int i = 1; i <= TotalPaginas; i++)
            {
                int pagina = i;

                <button class="pgbtn @(PaginaActual == pagina ? "pgbtn-active" : "")"
                        @onclick="() => IrAPagina(pagina)">
                    @pagina
                </button>
            }

            <button class="pgbtn"
                    disabled="@(PaginaActual == TotalPaginas)"
                    @onclick="PaginaSiguiente">
                ›
            </button>

        </div>

    </div>
</section>

@code {
    private string _textoBusqueda = "";
    private string TextoBusqueda
    {
        get => _textoBusqueda;
        set
        {
            if (_textoBusqueda != value)
            {
                _textoBusqueda = value;
                PaginaActual = 1;
            }
        }
    }

    private string _filtroEstado = "Todos";
    private string FiltroEstado
    {
        get => _filtroEstado;
        set
        {
            if (_filtroEstado != value)
            {
                _filtroEstado = value;
                PaginaActual = 1;
            }
        }
    }
    private bool Cargando { get; set; } = true;
    private int PaginaActual = 1;
    private int ElementosPorPagina = 10;

    private List<EntrenadorDTO> Entrenadores = new();

    private string FiltroClaseTodos => FiltroEstado == "Todos" ? "filter-button active" : "filter-button";
    private string FiltroClaseActivos => FiltroEstado == "Activos" ? "filter-button active" : "filter-button";
    private string FiltroClaseInactivos => FiltroEstado == "Inactivos" ? "filter-button active" : "filter-button";

    protected override async Task OnInitializedAsync()
    {
        await CargarEntrenadores();
    }

    private async Task CargarEntrenadores()
    {
        Cargando = true;

        try
        {
            Entrenadores = await EntrenadorService.ListarEntrenadoresAsync();
        }
        finally
        {
            Cargando = false;
        }
    }

    private void MostrarTodos()
    {
        FiltroEstado = "Todos";
    }

    private void MostrarActivos()
    {
        FiltroEstado = "Activos";
    }

    private void MostrarInactivos()
    {
        FiltroEstado = "Inactivos";
    }

    private void PaginaAnterior()
    {
        if (PaginaActual > 1)
            PaginaActual--;
    }

    private void PaginaSiguiente()
    {
        if (PaginaActual < TotalPaginas)
            PaginaActual++;
    }

    private void IrAPagina(int pagina)
    {
        PaginaActual = pagina;
    }

    private IEnumerable<EntrenadorDTO> EntrenadoresFiltrados
    {
        get
        {
            IEnumerable<EntrenadorDTO> resultado = Entrenadores;

            if (FiltroEstado == "Activos")
            {
                resultado = resultado.Where(e => e.Activo);
            }
            else if (FiltroEstado == "Inactivos")
            {
                resultado = resultado.Where(e => !e.Activo);
            }

            if (!string.IsNullOrWhiteSpace(TextoBusqueda))
            {
                string texto = TextoBusqueda.Trim();

                resultado = resultado.Where(e =>
                    e.Dni.ToString().Contains(texto) ||
                    e.NombreCompleto.Contains(texto, StringComparison.OrdinalIgnoreCase) ||
                    (!string.IsNullOrWhiteSpace(e.Especialidad) &&
                     e.Especialidad.Contains(texto, StringComparison.OrdinalIgnoreCase))
                );
            }

            return resultado;
        }
    }

    private IEnumerable<EntrenadorDTO> EntrenadoresPaginados =>
    EntrenadoresFiltrados
        .Skip((PaginaActual - 1) * ElementosPorPagina)
        .Take(ElementosPorPagina);

    private int TotalPaginas =>
        Math.Max(
            1,
            (int)Math.Ceiling(
                EntrenadoresFiltrados.Count() /
                (double)ElementosPorPagina
            )
        );

    private static string MostrarTexto(string? texto)
    {
        return string.IsNullOrWhiteSpace(texto) ? "—" : texto;
    }

    private static string InicialEntrenador(EntrenadorDTO entrenador)
    {
        if (!string.IsNullOrWhiteSpace(entrenador.Nombres))
            return entrenador.Nombres[0].ToString();

        if (!string.IsNullOrWhiteSpace(entrenador.NombreCompleto))
            return entrenador.NombreCompleto[0].ToString();

        return "E";
    }
}