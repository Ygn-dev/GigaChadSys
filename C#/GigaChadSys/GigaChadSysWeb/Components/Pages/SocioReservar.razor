@page "/socio/reservar"
@using GigaChadSysWeb.Components.Layout
@layout SocioLayout
@rendermode InteractiveServer

<section class="reservar-page">
    <div class="reservar-top">
        <div>
            <h1>Reservar Clase</h1>
            <p class="reservar-subtitle">Encuentra y reserva tu siguiente sesión</p>
        </div>
        <a href="/socio/reservas" class="btn-ver-reservas">📋 Ver Mis Reservas</a>
    </div>

    <!-- Filtros -->
    <div class="filtros-card">
        <h4>Filtros</h4>
        <div class="filtros-grid">
            <div class="filtro-group">
                <label>DISCIPLINA</label>
                <select @bind="filtroDisciplina">
                    <option value="">Todas las disciplinas</option>
                    <option value="CrossFit">CrossFit</option>
                    <option value="Yoga">Yoga</option>
                    <option value="Spinning">Spinning</option>
                    <option value="Boxeo">Boxeo</option>
                    <option value="Pilates">Pilates</option>
                </select>
            </div>
            <div class="filtro-group">
                <label>FECHA</label>
                <input type="date" @bind="filtroFecha" />
            </div>
            <div class="filtro-group">
                <label>HORARIO</label>
                <input type="time" @bind="filtroHora" />
            </div>
        </div>
        <button class="btn-limpiar" @onclick="LimpiarFiltros">⟳ Limpiar filtros</button>
    </div>

    <!-- Grid de clases -->
    <div class="clases-grid">
        @foreach (var clase in clasesFiltradas)
        {
            <div class="clase-card">
                <div class="clase-card-top">
                    <span class="clase-disciplina">@clase.Disciplina.ToUpper()</span>
                    <span class="clase-cupos @(clase.CuposDisponibles <= 3 ? "cupos-pocos" : "")">@clase.CuposDisponibles cupos</span>
                </div>

                <h3>@clase.Nombre</h3>
                <p class="clase-desc">@clase.Descripcion</p>

                <div class="clase-detalles">
                    <span>📅 @clase.Fecha</span>
                    <span>🕐 @clase.Horario</span>
                    <span>👤 @clase.Entrenador</span>
                    <span>📍 @clase.Salon (Cap. @clase.Capacidad)</span>
                    <span>🎯 Nivel: @clase.Nivel | @clase.Duracion min</span>
                </div>

                <div class="clase-ocupacion">
                    <div class="ocupacion-info">
                        <span>Ocupación</span>
                        <span>@clase.Inscritos/@clase.Capacidad</span>
                    </div>
                    <div class="ocupacion-bar">
                        <div class="ocupacion-fill @(clase.PorcentajeOcupacion > 80 ? "fill-rojo" : clase.PorcentajeOcupacion > 60 ? "fill-amarillo" : "fill-verde")" 
                             style="width: @clase.PorcentajeOcupacion%"></div>
                    </div>
                </div>

                <button class="btn-reservar-clase" @onclick="() => ReservarClase(clase)">Reservar</button>
            </div>
        }
    </div>
</section>

@code {
    private string filtroDisciplina = "";
    private DateTime? filtroFecha;
    private TimeOnly? filtroHora;
    private List<ClaseDisponible> clases = new();

    private IEnumerable<ClaseDisponible> clasesFiltradas => clases
        .Where(c => string.IsNullOrEmpty(filtroDisciplina) || c.Disciplina == filtroDisciplina);

    protected override void OnInitialized()
    {
        clases = new List<ClaseDisponible>
        {
            new() { Nombre = "CrossFit Intenso", Disciplina = "CrossFit", Descripcion = "Entrenamiento funcional de alta intensidad con ejercicios variados.", Fecha = "2025-05-12", Horario = "07:00 - 08:00", Entrenador = "Marco Ruiz", Salon = "Sala Principal", Capacidad = 20, Inscritos = 18, Nivel = "avanzado", Duracion = 60, CuposDisponibles = 2 },
            new() { Nombre = "Yoga Matutino", Disciplina = "Yoga", Descripcion = "Sesión de yoga para mejorar flexibilidad y reducir estrés.", Fecha = "2025-05-12", Horario = "08:00 - 08:45", Entrenador = "Pedro Sanchez", Salon = "Sala Yoga", Capacidad = 15, Inscritos = 12, Nivel = "principiante", Duracion = 45, CuposDisponibles = 3 },
            new() { Nombre = "Spinning Power", Disciplina = "Spinning", Descripcion = "Clase de ciclismo indoor con música motivadora.", Fecha = "2025-05-12", Horario = "18:30 - 19:15", Entrenador = "Laura Gomez", Salon = "Sala Ciclo", Capacidad = 25, Inscritos = 22, Nivel = "intermedio", Duracion = 45, CuposDisponibles = 3 },
            new() { Nombre = "Boxeo Amateur", Disciplina = "Boxeo", Descripcion = "Técnicas básicas de boxeo y acondicionamiento físico.", Fecha = "2025-05-12", Horario = "19:00 - 20:00", Entrenador = "Carlos Diaz", Salon = "Sala Box", Capacidad = 15, Inscritos = 13, Nivel = "principiante", Duracion = 60, CuposDisponibles = 2 },
            new() { Nombre = "CrossFit Intenso", Disciplina = "CrossFit", Descripcion = "Entrenamiento funcional de alta intensidad con ejercicios variados.", Fecha = "2025-05-13", Horario = "07:00 - 08:00", Entrenador = "Marco Ruiz", Salon = "Sala Principal", Capacidad = 20, Inscritos = 15, Nivel = "avanzado", Duracion = 60, CuposDisponibles = 5 },
            new() { Nombre = "Pilates Core", Disciplina = "Pilates", Descripcion = "Fortalecimiento del core y control postural.", Fecha = "2025-05-13", Horario = "18:00 - 18:50", Entrenador = "Ana Flores", Salon = "Sala Yoga", Capacidad = 12, Inscritos = 11, Nivel = "intermedio", Duracion = 50, CuposDisponibles = 1 }
        };
    }

    private void LimpiarFiltros()
    {
        filtroDisciplina = "";
        filtroFecha = null;
        filtroHora = null;
    }

    private void ReservarClase(ClaseDisponible clase)
    {
        // Se conectará con BL después
    }

    private class ClaseDisponible
    {
        public string Nombre { get; set; } = "";
        public string Disciplina { get; set; } = "";
        public string Descripcion { get; set; } = "";
        public string Fecha { get; set; } = "";
        public string Horario { get; set; } = "";
        public string Entrenador { get; set; } = "";
        public string Salon { get; set; } = "";
        public int Capacidad { get; set; }
        public int Inscritos { get; set; }
        public string Nivel { get; set; } = "";
        public int Duracion { get; set; }
        public int CuposDisponibles { get; set; }
        public int PorcentajeOcupacion => Capacidad > 0 ? (Inscritos * 100 / Capacidad) : 0;
    }
}
