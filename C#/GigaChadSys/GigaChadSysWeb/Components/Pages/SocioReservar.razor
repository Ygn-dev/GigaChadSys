@page "/socio/reservar"
@layout SocioLayout
@rendermode InteractiveServer

<section class="reservar-page">

    <div class="reservar-top">
        <div>
            <h1>Reservar Clase</h1>
            <p class="reservar-subtitle">Encuentra y reserva tu siguiente sesión</p>
        </div>

        <a href="/socio/reservas" class="btn-ver-reservas">
            📋 Ver Mis Reservas
        </a>
    </div>

    <div class="filtros-card">
        <h4>Filtros</h4>

        <div class="filtros-grid">
            <div class="filtro-group">
                <label>DISCIPLINA</label>

                <select value="@FiltroDisciplina" @onchange="CambiarDisciplina">
                    <option value="">Todas las disciplinas</option>
                    <option value="CrossFit">CrossFit</option>
                    <option value="Yoga">Yoga</option>
                    <option value="Spinning">Spinning</option>
                    <option value="Boxeo">Boxeo</option>
                    <option value="Pilates">Pilates</option>
                </select>
            </div>

            <div class="filtro-group">
                <label>FECHA</label>

                <input type="date"
                       value="@FiltroFecha"
                       @onchange="CambiarFecha" />
            </div>

            <div class="filtro-group">
                <label>HORARIO</label>

                <input type="time"
                       value="@FiltroHora"
                       @onchange="CambiarHora" />
            </div>
        </div>

        <button type="button"
                class="btn-limpiar"
                @onclick="LimpiarFiltros">
            ⟳ Limpiar filtros
        </button>
    </div>

    <div class="clases-grid">
        @foreach (var clase in ClasesFiltradas)
        {
            <div class="clase-card">

                <div class="clase-card-top">
                    <span class="clase-disciplina">
                        @clase.Disciplina.ToUpper()
                    </span>

                    <span class="@ObtenerClaseCupos(clase.CuposDisponibles)">
                        @clase.CuposDisponibles cupos
                    </span>
                </div>

                <h3>@clase.Nombre</h3>

                <p class="clase-desc">
                    @clase.Descripcion
                </p>

                <div class="clase-detalles">
                    <span>📅 @clase.Fecha</span>
                    <span>🕐 @clase.Horario</span>
                    <span>👤 @clase.Entrenador</span>
                    <span>📍 @clase.Salon (Cap. @clase.Capacidad)</span>
                    <span>🎯 Nivel: @clase.Nivel | @clase.Duracion min</span>
                </div>

                <div class="clase-ocupacion">
                    <div class="ocupacion-info">
                        <span>Ocupación</span>
                        <span>@clase.Inscritos/@clase.Capacidad</span>
                    </div>

                    <div class="ocupacion-bar">
                        <div class="@ObtenerClaseOcupacion(clase.PorcentajeOcupacion)"
                             style="@($"width: {clase.PorcentajeOcupacion}%")">
                        </div>
                    </div>
                </div>

                <a class="reserve-class-button"
                   href="@($"/socio/reservar/confirmada/{clase.Codigo}")">
                    Reservar
                </a>

            </div>
        }
    </div>

</section>

@code {
    private string FiltroDisciplina { get; set; } = "";
    private string FiltroFecha { get; set; } = "";
    private string FiltroHora { get; set; } = "";

    private List<ClaseDisponible> Clases { get; set; } = new();

    private IEnumerable<ClaseDisponible> ClasesFiltradas
    {
        get
        {
            IEnumerable<ClaseDisponible> resultado = Clases;

            if (!string.IsNullOrWhiteSpace(FiltroDisciplina))
            {
                resultado = resultado.Where(c => c.Disciplina == FiltroDisciplina);
            }

            if (!string.IsNullOrWhiteSpace(FiltroFecha))
            {
                resultado = resultado.Where(c => c.Fecha == FiltroFecha);
            }

            if (!string.IsNullOrWhiteSpace(FiltroHora))
            {
                resultado = resultado.Where(c => c.Horario.StartsWith(FiltroHora));
            }

            return resultado;
        }
    }

