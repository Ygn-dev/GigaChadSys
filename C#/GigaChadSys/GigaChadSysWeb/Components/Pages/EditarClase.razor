@page "/admin/clases/editar/{Id:int}"
@layout AdminLayout
@rendermode InteractiveServer
@using GigaChadSys.Servicios
@using GigaChadSys.Servicios.DTO
@inject ClaseGrupalServicio ClaseService
@inject NavigationManager Navigation

<div class="container-fluid py-4">

    <nav class="sf-breadcrumb">
        <a href="/admin/clases">Clases</a>
        <span class="sf-bc-sep">›</span>
        <span class="sf-bc-current">Editar</span>
    </nav>

    <div class="sf-page-header">
        <h1>Editar Clase</h1>
        <p class="sf-page-subtitle">Actualiza los datos de la clase grupal</p>
    </div>

    <div class="socios-toast @(toastVisible ? "socios-toast-show" : "") @(toastIsError ? "socios-toast-err" : "socios-toast-ok")">
        @toastMessage
    </div>

    @if (cargando)
    {
        <div class="sf-section-card">
            <p>Cargando clase...</p>
        </div>
    }
    else
    {
        <div class="row g-4">

            <div>

                <div class="sf-section-card">
                    <div class="sf-section-title">
                        <div class="sf-section-icon icon-red">🏋️</div>
                        <div>
                            <h3>Información General</h3>
                            <span>Datos básicos de la clase</span>
                        </div>
                    </div>

                    <div class="sf-form-grid">
                        <div class="sf-form-group">
                            <label>NOMBRE <span class="sf-req">*</span></label>
                            <input type="text"
                                   @bind="nombre"
                                   @bind:event="oninput"
                                   placeholder="Ej. CrossFit Intenso"
                                   class="@(errores.ContainsKey("nombre") ? "sf-input-error" : "")" />

                            @if (errores.ContainsKey("nombre"))
                            {
                                <span class="sf-error-msg">@errores["nombre"]</span>
                            }
                        </div>

                        <div class="sf-form-group">
                            <label>DISCIPLINA <span class="sf-req">*</span></label>
                            <select @bind="disciplina">
                                <option value="">Seleccionar disciplina...</option>
                                <option value="CrossFit">CrossFit</option>
                                <option value="Yoga">Yoga</option>
                                <option value="Spinning">Spinning</option>
                                <option value="Boxeo">Boxeo</option>
                                <option value="Zumba">Zumba</option>
                                <option value="Pilates">Pilates</option>
                                <option value="Musculacion">Musculación</option>
                                <option value="HIIT">HIIT</option>
                                <option value="Otro">Otro</option>
                            </select>

                            @if (errores.ContainsKey("disciplina"))
                            {
                                <span class="sf-error-msg">@errores["disciplina"]</span>
                            }
                        </div>

                        <div class="sf-form-group">
                            <label>DURACIÓN (minutos) <span class="sf-req">*</span></label>
                            <input type="number"
                                   @bind="duracion"
                                   min="10"
                                   max="240"
                                   placeholder="60"
                                   class="@(errores.ContainsKey("duracion") ? "sf-input-error" : "")" />

                            @if (errores.ContainsKey("duracion"))
                            {
                                <span class="sf-error-msg">@errores["duracion"]</span>
                            }
                        </div>

                        <div class="sf-form-group">
                            <label>NIVEL</label>
                            <select @bind="nivel">
                                <option value="Principiante">Principiante</option>
                                <option value="Intermedio">Intermedio</option>
                                <option value="Avanzado">Avanzado</option>
                            </select>
                        </div>

                        <div class="sf-form-group sf-form-full">
                            <label>DESCRIPCIÓN</label>
                            <textarea @bind="descripcion"
                                      rows="3"
                                      placeholder="Describe brevemente la clase..."></textarea>
                        </div>
                    </div>
                </div>

                <div class="sf-section-card">
                    <div class="sf-section-title">
                        <div class="sf-section-icon icon-green">✅</div>
                        <div>
                            <h3>Estado de la Clase</h3>
                            <span>Controla la visibilidad y disponibilidad</span>
                        </div>
                    </div>

                    <p class="sf-sublabel">ESTADO ACTUAL</p>

                    <div class="sf-estado-row">
                        <button type="button"
                                class="sf-estado-btn @(estado == "Activa" ? "sf-estado-activo" : "")"
                                @onclick='() => estado = "Activa"'>
                            <span class="sf-estado-dot dot-green"></span> Activa
                        </button>

                        <button type="button"
                                class="sf-estado-btn @(estado == "Inactiva" ? "sf-estado-inactivo" : "")"
                                @onclick='() => estado = "Inactiva"'>
                            <span class="sf-estado-dot dot-red"></span> Inactiva
                        </button>
                    </div>
                </div>

                <div class="sf-form-actions">
                    <button class="sf-btn-primary" @onclick="GuardarCambios" disabled="@guardando">
                        @if (guardando)
                        {
                            <span>⏳</span> <span>Guardando...</span>
                        }
                        else
                        {
                            <span>💾</span> <span>Guardar Cambios</span>
                        }
                    </button>

                    <a href="/admin/clases" class="sf-btn-secondary">Cancelar</a>

                    <div class="sf-back-link">
                        <a href="/admin/clases">← Volver a Clases</a>
                    </div>
                </div>

            </div>

            <div class="sf-resumen-col">
                <div class="sf-resumen-card">
                    <h4>Resumen</h4>

                    <div class="sf-resumen-rows">
                        <div class="sf-resumen-row">
                            <span>Clase</span>
                            <strong>@(string.IsNullOrWhiteSpace(nombre) ? "—" : nombre)</strong>
                        </div>

                        <div class="sf-resumen-row">
                            <span>Disciplina</span>
                            <strong>@(string.IsNullOrWhiteSpace(disciplina) ? "—" : disciplina)</strong>
                        </div>

                        <div class="sf-resumen-row">
                            <span>Nivel</span>
                            <strong>@nivel</strong>
                        </div>

                        <div class="sf-resumen-row">
                            <span>Duración</span>
                            <strong>@(duracion > 0 ? $"{duracion} min" : "—")</strong>
                        </div>

                        <div class="sf-resumen-row">
                            <span>Estado</span>
                            <strong class="@(estado == "Activa" ? "rsm-activo" : "rsm-inactivo")">@estado</strong>
                        </div>
                    </div>
                </div>

                <div class="sf-admin-nota">
                    <span class="sf-nota-icon">⚠️</span>
                    <p>Modificar la clase afectará a todas las sesiones programadas que la utilicen. Las reservas existentes no se cancelarán automáticamente.</p>
                </div>
            </div>

        </div>
    }
</div>

@code {
    [Parameter]
    public int Id { get; set; }

    private string nombre = "";
    private string disciplina = "";
    private int duracion = 60;
    private string nivel = "Intermedio";
    private string descripcion = "";
    private string estado = "Activa";

    private bool cargando = true;
    private bool guardando = false;
    private bool toastVisible = false;
    private bool toastIsError = false;
    private string toastMessage = "";

    private Dictionary<string, string> errores = new();

    protected override async Task OnInitializedAsync()
    {
        await CargarClase();
    }

    private async Task CargarClase()
    {
        cargando = true;

        var clase = await ClaseService.ObtenerPorIdAsync(Id);

        if (clase == null)
        {
            Navigation.NavigateTo("/admin/clases", forceLoad: true);
            return;
        }

        if (!string.IsNullOrWhiteSpace(clase.NombreDisciplina) && clase.NombreDisciplina.Contains(" - "))
        {
            var parts = clase.NombreDisciplina.Split(new[] { " - " }, 2, StringSplitOptions.None);
            disciplina = parts[0].Trim();
            nombre = parts[1].Trim();
        }
        else
        {
            nombre = clase.NombreDisciplina ?? "";
            disciplina = clase.Disciplina ?? "";
        }

        duracion = clase.DuracionMinutos;
        nivel = string.IsNullOrWhiteSpace(clase.Nivel) ? "Intermedio" : clase.Nivel;
        descripcion = clase.Descripcion ?? "";
        estado = clase.Activo ? "Activa" : "Inactiva";

        cargando = false;
    }

    private bool Validar()
    {
        errores.Clear();

        if (string.IsNullOrWhiteSpace(nombre))
            errores["nombre"] = "El nombre es obligatorio.";

        if (string.IsNullOrWhiteSpace(disciplina))
            errores["disciplina"] = "Selecciona una disciplina.";

        if (duracion < 10)
            errores["duracion"] = "La duración mínima es 10 minutos.";

        return errores.Count == 0;
    }

    private async Task GuardarCambios()
    {
        if (!Validar())
            return;

        guardando = true;

        var claseEditada = new ClaseGrupalDTO
        {
            IdClase = Id,
            NombreDisciplina = $"{disciplina.Trim()} - {nombre.Trim()}",
            Nivel = nivel,
            DuracionMinutos = duracion,
            Descripcion = descripcion.Trim(),
            Activo = estado == "Activa"
        };

        var msj = await ClaseService.ActualizarAsync(Id, claseEditada);

        guardando = false;

        if (!msj.StartsWith("Error") && !msj.ToLower().Contains("error"))
        {
            toastIsError = false;
            toastMessage = "✅ Clase actualizada correctamente.";
            await MostrarToastYVolver();
        }
        else
        {
            toastIsError = true;
            toastMessage = msj;
            await MostrarToastSinVolver();
        }
    }

    private async Task MostrarToastYVolver()
    {
        toastVisible = true;
        StateHasChanged();

        await Task.Delay(1200);

        toastVisible = false;
        Navigation.NavigateTo("/admin/clases", forceLoad: true);
    }

    private async Task MostrarToastSinVolver()
    {
        toastVisible = true;
        StateHasChanged();

        await Task.Delay(1800);

        toastVisible = false;
        StateHasChanged();
    }
}