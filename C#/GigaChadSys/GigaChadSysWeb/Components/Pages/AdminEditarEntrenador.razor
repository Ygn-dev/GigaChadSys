@page "/admin/entrenadores/editar/{IdUsuarioParametro:int}"
@layout AdminLayout
@rendermode InteractiveServer
@using System.Globalization
@using GigaChadSys.Servicios
@using GigaChadSys.Servicios.DTO
@inject EntrenadorServicio EntrenadorService
@inject NavigationManager Nav
@inject ToastService ToastService

<section class="trainer-edit-page">

    <div class="trainer-breadcrumb">
        <a href="/admin/inicio">Inicio</a>
        <span>/</span>
        <a href="/admin/entrenadores">Entrenadores</a>
        <span>/</span>
        <strong>Editar</strong>
    </div>

    <div class="trainer-form-title">
        <h1>Editar Entrenador</h1>
        <p>Actualiza los datos personales y profesionales del entrenador.</p>
    </div>

    @if (Cargando)
    {
        <div class="trainer-message">
            Cargando datos del entrenador...
        </div>
    }
    else
    {
        <div class="trainer-edit-layout">

            <div class="trainer-edit-main">

                <div class="trainer-section">
                    <h2>Información Personal</h2>

                    <div class="trainer-grid">
                        <div class="trainer-field">
                            <label>DNI <span>*</span></label>
                            <input type="text"
                                   class="@(IntentoGuardar && string.IsNullOrWhiteSpace(DniValor) ? "input-error" : "")"
                                   maxlength="8"
                                   autocomplete="off"
                                   value="@DniValor"
                                   @oninput="CambiarDni" />
                        </div>

                        <div class="trainer-field">
                            <label>Edad <span>*</span></label>
                            <input type="number"
                                   class="@(IntentoGuardar && string.IsNullOrWhiteSpace(EdadValor) ? "input-error" : "")"
                                   min="1"
                                   max="100"
                                   autocomplete="off"
                                   value="@EdadValor"
                                   @oninput="CambiarEdad" />
                        </div>

                        <div class="trainer-field">
                            <label>Nombres <span>*</span></label>
                            <input type="text"
                                   class="@(IntentoGuardar && string.IsNullOrWhiteSpace(NombresValor) ? "input-error" : "")"
                                   autocomplete="off"
                                   value="@NombresValor"
                                   @oninput="CambiarNombres" />
                        </div>

                        <div class="trainer-field">
                            <label>Apellido paterno <span>*</span></label>
                            <input type="text"
                                   class="@(IntentoGuardar && string.IsNullOrWhiteSpace(ApellidoPaternoValor) ? "input-error" : "")"
                                   autocomplete="off"
                                   value="@ApellidoPaternoValor"
                                   @oninput="CambiarApellidoPaterno" />
                        </div>

                        <div class="trainer-field">
                            <label>Apellido materno <span>*</span></label>
                            <input type="text"
                                   class="@(IntentoGuardar && string.IsNullOrWhiteSpace(ApellidoMaternoValor) ? "input-error" : "")"
                                   autocomplete="off"
                                   value="@ApellidoMaternoValor"
                                   @oninput="CambiarApellidoMaterno" />
                        </div>

                        <div class="trainer-field">
                            <label>Teléfono <span>*</span></label>
                            <input type="text"
                                   class="@(IntentoGuardar && string.IsNullOrWhiteSpace(TelefonoValor) ? "input-error" : "")"
                                   maxlength="9"
                                   autocomplete="off"
                                   value="@TelefonoValor"
                                   @oninput="CambiarTelefono" />
                        </div>

                        <div class="trainer-field">
                            <label>Correo electrónico <span>*</span></label>
                            <input type="email"
                                   class="@(IntentoGuardar && string.IsNullOrWhiteSpace(CorreoValor) ? "input-error" : "")"
                                   autocomplete="off"
                                   value="@CorreoValor"
                                   @oninput="CambiarCorreo" />
                        </div>
                    </div>
                </div>

                <div class="trainer-section">
                    <h2>Información Profesional</h2>

                    <div class="trainer-grid">
                        <div class="trainer-field">
                            <label>Especialidad <span>*</span></label>
                            <select class="@(IntentoGuardar && string.IsNullOrWhiteSpace(EspecialidadValor) ? "input-error" : "")" value="@EspecialidadValor" @onchange="CambiarEspecialidad">
                                <option value="">Seleccione una especialidad</option>
                                <option value="CrossFit y Musculación">CrossFit y Musculación</option>
                                <option value="Yoga y Pilates">Yoga y Pilates</option>
                                <option value="Spinning y Cardio">Spinning y Cardio</option>
                                <option value="Boxeo y MMA">Boxeo y MMA</option>
                                <option value="Zumba y Baile">Zumba y Baile</option>
                            </select>
                        </div>

                        <div class="trainer-field">
                            <label>Sueldo mensual <span>*</span></label>
                            <input type="number"
                                   class="@(IntentoGuardar && string.IsNullOrWhiteSpace(SueldoMensualValor) ? "input-error" : "")"
                                   min="0"
                                   step="0.01"
                                   autocomplete="off"
                                   value="@SueldoMensualValor"
                                   @oninput="CambiarSueldoMensual" />
                        </div>

                        <div class="trainer-field">
                            <label>Tiempo de trabajo <span>*</span></label>
                            <select class="@(IntentoGuardar && string.IsNullOrWhiteSpace(TiempoTrabajoValor) ? "input-error" : "")" value="@TiempoTrabajoValor" @onchange="CambiarTiempoTrabajo">
                                <option value="">Seleccione tiempo de trabajo</option>
                                <option value="08:00:00">Tiempo completo - 8 horas</option>
                                <option value="04:00:00">Medio tiempo - 4 horas</option>
                                <option value="02:00:00">Por horas - 2 horas</option>
                            </select>
                        </div>
                    </div>
                </div>

                <div class="trainer-section">
                    <h2>Cuenta de Acceso</h2>

                    <div class="trainer-grid">
                        <div class="trainer-field">
                            <label>Correo de acceso <span>*</span></label>
                            <input type="email"
                                   class="@(IntentoGuardar && string.IsNullOrWhiteSpace(CorreoValor) ? "input-error" : "")"
                                   autocomplete="off"
                                   value="@CorreoValor"
                                   @oninput="CambiarCorreo" />
                        </div>

                        <div class="trainer-field">
                            <label>Nueva contraseña</label>
                            <input type="password"
                                   class="@(IntentoGuardar && !string.IsNullOrWhiteSpace(NuevaContraseniaValor) && NuevaContraseniaValor.Length < 6 ? "input-error" : "")"
                                   autocomplete="new-password"
                                   placeholder="Dejar vacío si no se cambia"
                                   value="@NuevaContraseniaValor"
                                   @oninput="CambiarNuevaContrasenia" />
                        </div>
                    </div>
                </div>

                <div class="trainer-section">
                    <h2>Estado</h2>

                    <div class="trainer-radio-row">
                        <label>
                            <input type="radio"
                                   name="estadoEntrenadorEditar"
                                   checked="@EntrenadorActivo"
                                   @onclick="ActivarEntrenador" />
                            Activo
                        </label>

                        <label>
                            <input type="radio"
                                   name="estadoEntrenadorEditar"
                                   checked="@(!EntrenadorActivo)"
                                   @onclick="DesactivarEntrenador" />
                            Inactivo
                        </label>
                    </div>
                </div>

                <div class="trainer-actions">
                    <button type="button"
                            class="trainer-save-button"
                            disabled="@Guardando"
                            @onclick="GuardarCambios">
                        @(Guardando ? "Guardando..." : "✓ Guardar cambios")
                    </button>

                    <a class="trainer-cancel-button" href="/admin/entrenadores">
                        Cancelar
                    </a>

                    <a class="trainer-return-link" href="/admin/entrenadores">
                        ← Volver al listado
                    </a>
                </div>
            </div>

            <aside class="trainer-summary-card">
                <h2>Resumen</h2>

                <div class="summary-row">
                    <span>Entrenador:</span>
                    <strong>@NombresValor @ApellidoPaternoValor @ApellidoMaternoValor</strong>
                </div>

                <div class="summary-row">
                    <span>DNI:</span>
                    <strong>@DniValor</strong>
                </div>

                <div class="summary-row">
                    <span>Edad:</span>
                    <strong>@EdadValor</strong>
                </div>

                <div class="summary-row">
                    <span>Especialidad:</span>
                    <strong>@MostrarTexto(EspecialidadValor)</strong>
                </div>

                <div class="summary-row">
                    <span>Tiempo:</span>
                    <strong>@DescripcionTiempoTrabajo</strong>
                </div>

                <div class="summary-row">
                    <span>Estado nuevo:</span>
                    @if (EntrenadorActivo)
                    {
                        <strong class="summary-status active">Activo</strong>
                    }
                    else
                    {
                        <strong class="summary-status inactive">Inactivo</strong>
                    }
                </div>

                <div class="summary-warning">
                    Desde aquí puedes modificar los datos del entrenador por motivos administrativos.
                </div>
            </aside>

        </div>
    }
</section>

@code {
    [Parameter]
    public int IdUsuarioParametro { get; set; }

    private bool Cargando { get; set; } = true;
    private bool Guardando { get; set; } = false;
    private bool IntentoGuardar { get; set; } = false;

    private string DniValor { get; set; } = "";
    private string EdadValor { get; set; } = "";
    private string NombresValor { get; set; } = "";
    private string ApellidoPaternoValor { get; set; } = "";
    private string ApellidoMaternoValor { get; set; } = "";
    private string TelefonoValor { get; set; } = "";
    private string CorreoValor { get; set; } = "";

    private string EspecialidadValor { get; set; } = "";
    private string SueldoMensualValor { get; set; } = "";
    private string TiempoTrabajoValor { get; set; } = "";

    private string ContraseniaActualValor { get; set; } = "";
    private string NuevaContraseniaValor { get; set; } = "";
    private bool EntrenadorActivo { get; set; } = true;

    private string DescripcionTiempoTrabajo =>
        TiempoTrabajoValor switch
        {
            "08:00:00" => "Tiempo completo - 8 horas",
            "04:00:00" => "Medio tiempo - 4 horas",
            "02:00:00" => "Por horas - 2 horas",
            "" => "—",
            _ => TiempoTrabajoValor
        };

    protected override async Task OnInitializedAsync()
    {
        await CargarDatosEntrenador();
    }

    private async Task CargarDatosEntrenador()
    {
        Cargando = true;

        var entrenador = await EntrenadorService.ObtenerPorIdAsync(IdUsuarioParametro);

        if (entrenador == null)
        {
            ToastService.ShowError("No se encontró el entrenador solicitado.");
            Cargando = false;
            return;
        }

        DniValor = entrenador.Dni.ToString();
        EdadValor = entrenador.Edad.ToString();
        NombresValor = entrenador.Nombres ?? "";
        ApellidoPaternoValor = entrenador.ApellidoPaterno ?? "";
        ApellidoMaternoValor = entrenador.ApellidoMaterno ?? "";
        TelefonoValor = entrenador.Telefono.ToString();
        CorreoValor = entrenador.Email ?? "";

        EspecialidadValor = entrenador.Especialidad ?? "";
        SueldoMensualValor = entrenador.Sueldo.ToString("0.00", CultureInfo.InvariantCulture);
        TiempoTrabajoValor = entrenador.TiempoTrabajadoTexto ?? "";

        ContraseniaActualValor = entrenador.Contrasenia ?? "";
        NuevaContraseniaValor = "";
        EntrenadorActivo = entrenador.Activo;

        Cargando = false;
    }

    private void CambiarDni(ChangeEventArgs e) => DniValor = e.Value?.ToString() ?? "";
    private void CambiarEdad(ChangeEventArgs e) => EdadValor = e.Value?.ToString() ?? "";
    private void CambiarNombres(ChangeEventArgs e) => NombresValor = e.Value?.ToString() ?? "";
    private void CambiarApellidoPaterno(ChangeEventArgs e) => ApellidoPaternoValor = e.Value?.ToString() ?? "";
    private void CambiarApellidoMaterno(ChangeEventArgs e) => ApellidoMaternoValor = e.Value?.ToString() ?? "";
    private void CambiarTelefono(ChangeEventArgs e) => TelefonoValor = e.Value?.ToString() ?? "";
    private void CambiarCorreo(ChangeEventArgs e) => CorreoValor = e.Value?.ToString() ?? "";
    private void CambiarEspecialidad(ChangeEventArgs e) => EspecialidadValor = e.Value?.ToString() ?? "";
    private void CambiarSueldoMensual(ChangeEventArgs e) => SueldoMensualValor = e.Value?.ToString() ?? "";
    private void CambiarTiempoTrabajo(ChangeEventArgs e) => TiempoTrabajoValor = e.Value?.ToString() ?? "";
    private void CambiarNuevaContrasenia(ChangeEventArgs e) => NuevaContraseniaValor = e.Value?.ToString() ?? "";

    private void ActivarEntrenador()
    {
        EntrenadorActivo = true;
    }

    private void DesactivarEntrenador()
    {
        EntrenadorActivo = false;
    }

    private async Task GuardarCambios()
    {
        IntentoGuardar = true;

        if (string.IsNullOrWhiteSpace(DniValor))
        {
            ToastService.ShowError("El DNI es obligatorio.");
            return;
        }

        if (DniValor.Length != 8 || !int.TryParse(DniValor, out int dniConvertido))
        {
            ToastService.ShowError("El DNI debe tener 8 dígitos numéricos.");
            return;
        }

        if (string.IsNullOrWhiteSpace(EdadValor) || !int.TryParse(EdadValor, out int edadConvertida))
        {
            ToastService.ShowError("La edad debe ser un número válido.");
            return;
        }

        if (edadConvertida <= 0 || edadConvertida > 100)
        {
            ToastService.ShowError("La edad debe estar entre 1 y 100.");
            return;
        }

        if (string.IsNullOrWhiteSpace(NombresValor))
        {
            ToastService.ShowError("Los nombres son obligatorios.");
            return;
        }

        if (string.IsNullOrWhiteSpace(ApellidoPaternoValor))
        {
            ToastService.ShowError("El apellido paterno es obligatorio.");
            return;
        }

        if (string.IsNullOrWhiteSpace(ApellidoMaternoValor))
        {
            ToastService.ShowError("El apellido materno es obligatorio.");
            return;
        }

        if (string.IsNullOrWhiteSpace(TelefonoValor))
        {
            ToastService.ShowError("El teléfono es obligatorio.");
            return;
        }

        if (TelefonoValor.Length != 9 || !int.TryParse(TelefonoValor, out int telefonoConvertido))
        {
            ToastService.ShowError("El teléfono debe tener 9 dígitos numéricos.");
            return;
        }

        if (string.IsNullOrWhiteSpace(CorreoValor))
        {
            ToastService.ShowError("El correo electrónico es obligatorio.");
            return;
        }

        if (!CorreoValor.Contains("@") || !CorreoValor.Contains("."))
        {
            ToastService.ShowError("Ingrese un correo electrónico válido.");
            return;
        }

        if (string.IsNullOrWhiteSpace(EspecialidadValor))
        {
            ToastService.ShowError("Debe seleccionar una especialidad.");
            return;
        }

        if (string.IsNullOrWhiteSpace(SueldoMensualValor))
        {
            ToastService.ShowError("El sueldo mensual es obligatorio.");
            return;
        }

        string sueldoNormalizado = SueldoMensualValor.Replace(",", ".");

        if (!decimal.TryParse(
                sueldoNormalizado,
                NumberStyles.Number,
                CultureInfo.InvariantCulture,
                out decimal sueldoConvertido
            ))
        {
            ToastService.ShowError("El sueldo mensual debe ser un número válido.");
            return;
        }

        if (sueldoConvertido <= 0)
        {
            ToastService.ShowError("El sueldo mensual debe ser mayor a cero.");
            return;
        }

        if (string.IsNullOrWhiteSpace(TiempoTrabajoValor))
        {
            ToastService.ShowError("Debe seleccionar el tiempo de trabajo.");
            return;
        }

        if (!string.IsNullOrWhiteSpace(NuevaContraseniaValor) && NuevaContraseniaValor.Length < 6)
        {
            ToastService.ShowError("La nueva contraseña debe tener mínimo 6 caracteres.");
            return;
        }

        Guardando = true;
        try
        {
            var dto = new EntrenadorDTO
            {
                IdUsuario = IdUsuarioParametro,
                Dni = dniConvertido,
                Edad = edadConvertida,
                Nombres = NombresValor.Trim(),
                ApellidoPaterno = ApellidoPaternoValor.Trim(),
                ApellidoMaterno = ApellidoMaternoValor.Trim(),
                Telefono = telefonoConvertido,
                Email = CorreoValor.Trim(),
                Contrasenia = string.IsNullOrWhiteSpace(NuevaContraseniaValor)
                    ? ContraseniaActualValor
                    : NuevaContraseniaValor.Trim(),
                Rol = "Entrenador",
                Especialidad = EspecialidadValor,
                Sueldo = (double)sueldoConvertido,
                TiempoTrabajadoTexto = TiempoTrabajoValor,
                Activo = EntrenadorActivo
            };

            var resultado = await EntrenadorService.ActualizarAsync(IdUsuarioParametro, dto);

            if (!resultado.StartsWith("Error") && !resultado.ToLower().Contains("error"))
            {
                ToastService.ShowSuccess("Cambios guardados correctamente.");
                Nav.NavigateTo("/admin/entrenadores", forceLoad: true);
            }
            else
            {
                ToastService.ShowError(resultado);
            }
        }
        finally
        {
            Guardando = false;
        }
    }

    private static string MostrarTexto(string? texto)
    {
        return string.IsNullOrWhiteSpace(texto) ? "—" : texto;
    }
}