    private List<PagoDTO> TodosLosPagos = new();
    private List<SuscripcionDTO> TodasLasSuscripciones = new();
    private List<SocioDTO> TodosLosSocios = new();
    private List<EntrenadorDTO> TodosLosEntrenadores = new();

    private List<MovimientoReporteItem> Movimientos = new();
    private List<RecaudacionMembresiaItem> RecaudacionPorMembresia = new();

    private int PaginaActual = 1;
