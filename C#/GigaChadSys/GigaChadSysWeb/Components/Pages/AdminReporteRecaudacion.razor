@page "/admin/reportes/recaudacion"
@layout AdminLayout
@rendermode InteractiveServer

@using System.Globalization
@using System.Text
@using Microsoft.JSInterop
@using GigaChadSys.Servicios
@using GigaChadSys.Servicios.DTO

@inject PagoServicio PagoService
@inject SuscripcionServicio SuscripcionService
@inject SocioServicio SocioService
@inject EntrenadorServicio EntrenadorService
@inject ReporteServicio ReporteService
@inject IJSRuntime JS
@inject NavigationManager Navigation

<section class="reporte-recaudacion-page">

    <div class="rr-breadcrumb">
        <button type="button" @onclick="VolverAReportes">
            <i class="bi bi-arrow-left"></i>
            Reportes
        </button>
        <span>/</span>
        <strong>Recaudación</strong>
    </div>

    <div class="rr-header">
        <div>
            <span class="rr-kicker">Reporte financiero</span>
            <h1>Reporte de Recaudación</h1>
            <p>Analiza ingresos, egresos, balance financiero y recaudación agrupada por tipo de membresía.</p>
            <small>Período evaluado: @PeriodoTexto</small>
        </div>

        <button type="button"
                class="rr-download-btn"
                @onclick="DescargarReporteRecaudacion"
                disabled="@DescargandoReporte">
            @if (DescargandoReporte)
            {
                <span>
                    <i class="bi bi-hourglass-split"></i>
                    Generando PDF...
                </span>
            }
            else
            {
                <span>
                    <i class="bi bi-file-earmark-pdf"></i>
                    Descargar reporte de recaudación
                </span>
            }
        </button>
    </div>

    @if (!string.IsNullOrWhiteSpace(MensajeDescarga))
    {
        <div class="rr-alert">
            <i class="bi bi-info-circle"></i>
            <span>@MensajeDescarga</span>
        </div>
    }

    @if (Cargando)
    {
        <div class="rr-loading">
            <i class="bi bi-hourglass-split"></i>
            <span>Cargando reporte de recaudación...</span>
        </div>
    }
    else if (!string.IsNullOrWhiteSpace(MensajeError))
    {
        <div class="rr-error">
            <i class="bi bi-exclamation-triangle"></i>
            <span>@MensajeError</span>
        </div>
    }
    else
    {
        <div class="rr-period-row">
            <button class="@ClasePeriodoMes" @onclick="MostrarUltimoMes">Último mes</button>
            <button class="@ClasePeriodoTrimestre" @onclick="MostrarUltimoTrimestre">Último trimestre</button>
            <button class="@ClasePeriodoAnio" @onclick="MostrarUltimoAnio">Último año</button>
        </div>

        <div class="rr-kpi-main-grid">

            <div class="rr-kpi-card rr-kpi-feature">
                <div>
                    <span>Ingresos brutos</span>
                    <strong class="rr-green-money">S/ @FormatoMoneda(IngresosBrutos)</strong>
                    <p>Pagos cobrados de socios</p>
                </div>

                <div class="rr-kpi-icon green">
                    <i class="bi bi-arrow-up-right"></i>
                </div>
            </div>

            <div class="rr-kpi-card rr-kpi-feature">
                <div>
                    <span>Egresos totales</span>
                    <strong class="rr-red-money">-S/ @FormatoMoneda(EgresosTotales)</strong>
                    <p>Pagos realizados al staff</p>
                </div>

                <div class="rr-kpi-icon red">
                    <i class="bi bi-arrow-down-left"></i>
                </div>
            </div>

            <div class="rr-kpi-card rr-kpi-feature rr-balance-card @(BalanceNeto < 0 ? "negative" : "positive")">
                <div>
                    <span>Balance neto</span>
                    <strong class="@(BalanceNeto < 0 ? "rr-red-money" : "rr-green-money")">@BalanceNetoTexto</strong>
                    <p>Ingresos menos egresos</p>
                </div>

                <div class="rr-kpi-icon @(BalanceNeto < 0 ? "red" : "green")">
                    <i class="bi bi-calculator"></i>
                </div>
            </div>

        </div>

        <div class="rr-kpi-secondary-grid">

            <div class="rr-kpi-card compact">
                <div>
                    <span>Por cobrar socios</span>
                    <strong class="rr-yellow-money">S/ @FormatoMoneda(PorCobrarSocios)</strong>
                    <p>@PagosPendientesSocios pagos pendientes</p>
                </div>

                <div class="rr-kpi-icon yellow">
                    <i class="bi bi-hourglass-split"></i>
                </div>
            </div>

            <div class="rr-kpi-card compact">
                <div>
                    <span>Por pagar staff</span>
                    <strong class="rr-orange-money">-S/ @FormatoMoneda(PorPagarStaff)</strong>
                    <p>@PagosPendientesStaff pagos pendientes</p>
                </div>

                <div class="rr-kpi-icon orange">
                    <i class="bi bi-clock-history"></i>
                </div>
            </div>

            <div class="rr-kpi-card compact">
                <div>
                    <span>Total movimientos</span>
                    <strong>@TotalMovimientos</strong>
                    <p>Pagos registrados en el período</p>
                </div>

                <div class="rr-kpi-icon neutral">
                    <i class="bi bi-list-check"></i>
                </div>
            </div>

        </div>

        <div class="rr-panel rr-membership-panel">
            <div class="rr-panel-header">
                <div>
                    <h2>Recaudación por membresía</h2>
                    <p>Total cobrado agrupado por tipo de membresía dentro del período seleccionado.</p>
                </div>
            </div>

            <div class="rr-membership-list">
                @foreach (var item in RecaudacionPorMembresia)
                {
                    <div class="rr-membership-row">
                        <div class="rr-membership-head">
                            <div>
                                <strong>@item.Nombre</strong>
                                <span>@item.CantidadPagos pagos realizados</span>
                            </div>

                            <strong class="rr-membership-money">S/ @FormatoMoneda(item.Total)</strong>
                        </div>

                        <div class="rr-bar-track">
                            <div class="rr-bar-fill @item.CssClass" style="width:@item.Barra"></div>
                        </div>
                    </div>
                }
            </div>
        </div>

        <div class="rr-chart-card">
            <div class="rr-chart-title-row">
                <h2>Ingresos vs Egresos Mensuales (S/)</h2>

                <div class="rr-chart-legend-inline">
                    <span><i class="dot green"></i>Ingresos</span>
                    <span><i class="dot red"></i>Egresos</span>
                </div>
            </div>

            <div class="rr-line-chart">
                <div class="rr-chart-y-label y100">@GraficoLabel100</div>
                <div class="rr-chart-y-label y75">@GraficoLabel75</div>
                <div class="rr-chart-y-label y50">@GraficoLabel50</div>
                <div class="rr-chart-y-label y25">@GraficoLabel25</div>
                <div class="rr-chart-y-label y0">0</div>

                <div class="rr-chart-grid-line line100"></div>
                <div class="rr-chart-grid-line line75"></div>
                <div class="rr-chart-grid-line line50"></div>
                <div class="rr-chart-grid-line line25"></div>
                <div class="rr-chart-grid-line line0"></div>

                <svg class="rr-chart-svg" viewBox="0 0 1000 260" preserveAspectRatio="none">
                    <defs>
                        <linearGradient id="rrGreenArea" x1="0" x2="0" y1="0" y2="1">
                            <stop offset="0%" stop-color="#22C55E" stop-opacity="0.30" />
                            <stop offset="100%" stop-color="#22C55E" stop-opacity="0.02" />
                        </linearGradient>
                    </defs>

                    <polygon points="@ChartIngresosAreaPoints" fill="url(#rrGreenArea)" />

                    <polyline points="@ChartIngresosLinePoints"
                              fill="none"
                              stroke="#22C55E"
                              stroke-width="5"
                              stroke-linecap="round"
                              stroke-linejoin="round" />

                    <polyline points="@ChartEgresosLinePoints"
                              fill="none"
                              stroke="#EF3131"
                              stroke-width="5"
                              stroke-linecap="round"
                              stroke-linejoin="round" />

                    @foreach (var punto in PuntosGrafico)
                    {
                        <circle cx="@punto.X"
                                cy="@punto.YIngresos"
                                r="7"
                                fill="#F5F5F5"
                                stroke="#22C55E"
                                stroke-width="4" />

                        <circle cx="@punto.X"
                                cy="@punto.YEgresos"
                                r="7"
                                fill="#F5F5F5"
                                stroke="#EF3131"
                                stroke-width="4" />

                        @if (punto.Ingresos > 0)
                        {
                            @((MarkupString)$"<text x='{punto.X}' y='{punto.LabelYIngresos}' text-anchor='middle' class='rr-chart-income-label'>{punto.ValorIngresos}</text>")
                        }

                        @if (punto.Egresos > 0)
                        {
                            @((MarkupString)$"<text x='{punto.X}' y='{punto.LabelYEgresos}' text-anchor='middle' class='rr-chart-expense-label'>-{punto.ValorEgresos}</text>")
                        }
                    }
                </svg>

                <div class="rr-chart-months">
                    @foreach (var punto in PuntosGrafico)
                    {
                        <span>@punto.Mes</span>
                    }
                </div>
            </div>
        </div>

        <div class="rr-bottom-grid">

            <div class="rr-panel">
                <h2>Métodos de pago utilizados</h2>

                <div class="rr-donut-layout">
                    <div class="rr-donut-card" style="@MetodoPagoDonutStyle">
                        <div class="rr-donut-center">
                            <strong>@TotalMovimientos</strong>
                            <span>Movimientos</span>
                        </div>
                    </div>

                    <div class="rr-donut-list">
                        <div class="rr-donut-row">
                            <span><i class="dot red"></i>Efectivo</span>
                            <strong>@PagosEfectivo (@Porcentaje(PagosEfectivo, TotalMovimientos))</strong>
                        </div>

                        <div class="rr-donut-row">
                            <span><i class="dot blue"></i>Tarjeta</span>
                            <strong>@PagosTarjeta (@Porcentaje(PagosTarjeta, TotalMovimientos))</strong>
                        </div>

                        <div class="rr-donut-row">
                            <span><i class="dot green"></i>Yape</span>
                            <strong>@PagosYape (@Porcentaje(PagosYape, TotalMovimientos))</strong>
                        </div>

                        <div class="rr-donut-row">
                            <span><i class="dot orange"></i>Plin</span>
                            <strong>@PagosPlin (@Porcentaje(PagosPlin, TotalMovimientos))</strong>
                        </div>

                        <p class="rr-donut-total">Total: @TotalMovimientos movimientos</p>
                    </div>
                </div>
            </div>

            <div class="rr-panel">
                <h2>Estado financiero</h2>

                <div class="rr-donut-layout">
                    <div class="rr-donut-card" style="@EstadoPagoDonutStyle">
                        <div class="rr-donut-center">
                            <strong>@TotalPagosEstado</strong>
                            <span>Total</span>
                        </div>
                    </div>

                    <div class="rr-donut-list">
                        <div class="rr-donut-row">
                            <span><i class="dot green"></i>Ingresos pagados</span>
                            <strong>@IngresosPagadosCount (@Porcentaje(IngresosPagadosCount, TotalPagosEstado))</strong>
                        </div>

                        <div class="rr-donut-row">
                            <span><i class="dot red"></i>Egresos pagados</span>
                            <strong>@EgresosPagadosCount (@Porcentaje(EgresosPagadosCount, TotalPagosEstado))</strong>
                        </div>

                        <div class="rr-donut-row">
                            <span><i class="dot orange"></i>Pendientes</span>
                            <strong>@PagosPendientes (@Porcentaje(PagosPendientes, TotalPagosEstado))</strong>
                        </div>

                        <div class="rr-pending-box">
                            <span>Por cobrar socios</span>
                            <strong>S/ @FormatoMoneda(PorCobrarSocios) ›</strong>
                        </div>

                        <div class="rr-pending-box staff">
                            <span>Por pagar staff</span>
                            <strong>-S/ @FormatoMoneda(PorPagarStaff) ›</strong>
                        </div>
                    </div>
                </div>
            </div>

        </div>

        <div class="rr-table-panel">
            <div class="rr-panel-header">
                <div>
                    <h2>Movimientos financieros</h2>
                    <p>Detalle de ingresos y egresos ordenados por fecha descendente.</p>
                </div>
            </div>

            <div class="rr-table-wrapper">
                <table class="rr-table">
                    <thead>
                        <tr>
                            <th>Usuario</th>
                            <th>Rol</th>
                            <th>Concepto</th>
                            <th>Tipo</th>
                            <th>Método</th>
                            <th>Fecha</th>
                            <th>Estado</th>
                            <th>Monto</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var item in MovimientosPaginados)
                        {
                            <tr>
                                <td>
                                    <div class="rr-user-cell">
                                        <div class="rr-avatar">@item.Iniciales</div>
                                        <div>
                                            <strong>@item.Usuario</strong>
                                            <span>@item.DetalleUsuario</span>
                                        </div>
                                    </div>
                                </td>

                                <td>@item.Rol</td>
                                <td>@item.Concepto</td>

                                <td>
                                    <span class="rr-status @item.TipoCss">
                                        @item.TipoMovimiento
                                    </span>
                                </td>

                                <td>@item.Metodo</td>
                                <td>@item.Fecha</td>

                                <td>
                                    <span class="rr-status @item.EstadoCss">
                                        @item.Estado
                                    </span>
                                </td>

                                <td>
                                    <strong class="@item.MontoCss">@item.MontoTexto</strong>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (TotalPaginas > 1)
            {
                <div class="rr-pagination">
                    <button type="button" @onclick="PaginaAnterior" disabled="@(PaginaActual == 1)">
                        <i class="bi bi-chevron-left"></i>
                        Anterior
                    </button>

                    <span>Página @PaginaActual de @TotalPaginas</span>

                    <button type="button" @onclick="PaginaSiguiente" disabled="@(PaginaActual == TotalPaginas)">
                        Siguiente
                        <i class="bi bi-chevron-right"></i>
                    </button>
                </div>
            }
        </div>
    }

</section>

<style>
    .reporte-recaudacion-page {
        width: 100%;
        min-height: 100%;
        padding: 28px 36px 48px;
        color: #f5f5f5;
        background: #0b0b0b;
    }

    .rr-breadcrumb {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 22px;
        color: #9ca3af;
        font-size: 14px;
        font-weight: 700;
    }

        .rr-breadcrumb button {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 0;
            color: #E53935;
            background: transparent;
            border: none;
            font-weight: 900;
            cursor: pointer;
        }

        .rr-breadcrumb strong {
            color: #ffffff;
        }

    .rr-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 24px;
        margin-bottom: 26px;
        padding-bottom: 22px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    }

    .rr-kicker {
        display: inline-block;
        margin-bottom: 8px;
        color: #E53935;
        font-size: 13px;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: 0.08em;
    }

    .rr-header h1 {
        margin: 0;
        color: #ffffff;
        font-size: 42px;
        font-weight: 950;
        line-height: 1.05;
    }

    .rr-header p {
        margin: 10px 0 0;
        max-width: 760px;
        color: #b9b9b9;
        font-size: 16px;
        font-weight: 500;
    }

    .rr-header small {
        display: inline-block;
        margin-top: 8px;
        color: #E53935;
        font-size: 13px;
        font-weight: 900;
    }

    .rr-download-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 280px;
        padding: 13px 18px;
        border-radius: 12px;
        border: 1px solid rgba(229, 57, 53, 0.45);
        background: #E53935;
        color: #ffffff;
        font-size: 14px;
        font-weight: 900;
        cursor: pointer;
    }

        .rr-download-btn span {
            display: inline-flex;
            align-items: center;
            gap: 9px;
        }

        .rr-download-btn:disabled {
            opacity: 0.65;
            cursor: not-allowed;
        }

    .rr-alert,
    .rr-loading,
    .rr-error {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 20px;
        padding: 16px 18px;
        border-radius: 14px;
        background: #171717;
        border: 1px solid rgba(255, 255, 255, 0.08);
        color: #f5f5f5;
        font-weight: 700;
    }

    .rr-alert {
        color: #FACC15;
        border-color: rgba(250, 204, 21, 0.25);
    }

    .rr-error {
        color: #ffb4b4;
        border-color: rgba(229, 57, 53, 0.35);
    }

    .rr-period-row {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 24px;
    }

        .rr-period-row button {
            padding: 10px 16px;
            border-radius: 999px;
            color: #d8d8d8;
            background: #151515;
            border: 1px solid rgba(255, 255, 255, 0.09);
            font-size: 13px;
            font-weight: 900;
            cursor: pointer;
        }

            .rr-period-row button.active {
                color: #ffffff;
                background: #E53935;
                border-color: #E53935;
            }

    .rr-kpi-main-grid,
    .rr-kpi-secondary-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 18px;
        margin-bottom: 18px;
    }

    .rr-kpi-secondary-grid {
        margin-bottom: 28px;
    }

    .rr-kpi-card {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        min-height: 132px;
        padding: 22px;
        border-radius: 16px;
        background: #151515;
        border: 1px solid rgba(255, 255, 255, 0.08);
    }

        .rr-kpi-card.compact {
            min-height: 110px;
        }

    .rr-balance-card.negative {
        border-color: rgba(239, 49, 49, 0.32);
    }

    .rr-balance-card.positive {
        border-color: rgba(34, 197, 94, 0.28);
    }

    .rr-kpi-card span {
        display: block;
        margin-bottom: 7px;
        color: #bdbdbd;
        font-size: 12px;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: 0.07em;
    }

    .rr-kpi-card strong {
        display: block;
        color: #ffffff;
        font-size: 29px;
        font-weight: 950;
        line-height: 1.1;
    }

    .rr-kpi-card p {
        margin: 8px 0 0;
        color: #b9b9b9;
        font-size: 13px;
        font-weight: 500;
    }

    .rr-kpi-icon {
        width: 54px;
        height: 54px;
        min-width: 54px;
        display: grid;
        place-items: center;
        border-radius: 14px;
        font-size: 24px;
    }

        .rr-kpi-icon.green {
            color: #22C55E;
            background: rgba(34, 197, 94, 0.12);
        }

        .rr-kpi-icon.red {
            color: #EF3131;
            background: rgba(239, 49, 49, 0.13);
        }

        .rr-kpi-icon.yellow {
            color: #FACC15;
            background: rgba(250, 204, 21, 0.12);
        }

        .rr-kpi-icon.orange {
            color: #FF9F43;
            background: rgba(255, 159, 67, 0.13);
        }

        .rr-kpi-icon.neutral {
            color: #d1d5db;
            background: rgba(209, 213, 219, 0.10);
        }

    .rr-green-money {
        color: #22C55E !important;
    }

    .rr-red-money {
        color: #ff4d4d !important;
    }

    .rr-yellow-money {
        color: #FACC15 !important;
    }

    .rr-orange-money {
        color: #FF9F43 !important;
    }

    .rr-panel,
    .rr-chart-card,
    .rr-table-panel {
        padding: 24px;
        border-radius: 18px;
        background: #151515;
        border: 1px solid rgba(255, 255, 255, 0.08);
    }

    .rr-membership-panel,
    .rr-chart-card,
    .rr-bottom-grid {
        margin-bottom: 28px;
    }

    .rr-panel-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 16px;
        margin-bottom: 22px;
    }

        .rr-panel-header h2,
        .rr-panel h2,
        .rr-chart-title-row h2 {
            margin: 0;
            color: #ffffff;
            font-size: 22px;
            font-weight: 950;
        }

        .rr-panel-header p {
            margin: 6px 0 0;
            color: #a9a9a9;
            font-size: 14px;
            font-weight: 500;
        }

    .rr-membership-list {
        display: flex;
        flex-direction: column;
        gap: 20px;
    }

    .rr-membership-head {
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
        gap: 16px;
        margin-bottom: 10px;
    }

        .rr-membership-head strong {
            display: block;
            color: #ffffff;
            font-size: 16px;
            font-weight: 950;
        }

        .rr-membership-head span {
            display: block;
            margin-top: 4px;
            color: #a9a9a9;
            font-size: 13px;
            font-weight: 700;
        }

    .rr-membership-money {
        color: #22C55E !important;
        white-space: nowrap;
    }

    .rr-bar-track {
        width: 100%;
        height: 14px;
        border-radius: 999px;
        background: #242424;
        overflow: hidden;
    }

    .rr-bar-fill {
        height: 100%;
        min-width: 4px;
        border-radius: 999px;
    }

        .rr-bar-fill.basic {
            background: #E53935;
        }

        .rr-bar-fill.black {
            background: #FACC15;
        }

        .rr-bar-fill.sinplan {
            background: #6B7280;
        }

    .rr-chart-title-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 18px;
        margin-bottom: 10px;
    }

    .rr-chart-legend-inline {
        display: flex;
        align-items: center;
        gap: 18px;
        color: #cfcfcf;
        font-weight: 800;
        font-size: 13px;
    }

        .rr-chart-legend-inline span {
            display: inline-flex;
            align-items: center;
            gap: 7px;
        }

    .rr-line-chart {
        position: relative;
        height: 330px;
        padding: 30px 28px 42px 56px;
        overflow: hidden;
    }

    .rr-chart-svg {
        position: absolute;
        left: 58px;
        right: 26px;
        top: 34px;
