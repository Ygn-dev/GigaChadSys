    private string ClasePeriodoMes => PeriodoActual == "Mes" ? "active" : "";
    private string ClasePeriodoTrimestre => PeriodoActual == "Trimestre" ? "active" : "";
    private string ClasePeriodoAnio => PeriodoActual == "Anio" ? "active" : "";

    private string PeriodoTexto =>
        $"{FechaInicioPeriodo:dd/MM/yyyy} - {FechaFinPeriodo:dd/MM/yyyy}";

    private DateTime FechaBasePeriodo
    {
        get
        {
            var fechas = TodosLosPagos
                .Where(p => p.FechaPago.HasValue)
                .Select(p => p.FechaPago!.Value)
                .ToList();

            return fechas.Any() ? fechas.Max() : DateTime.Today;
        }
    }

    private DateTime FechaInicioPeriodo
    {
        get
        {
            DateTime baseMes = new DateTime(FechaBasePeriodo.Year, FechaBasePeriodo.Month, 1);

            return PeriodoActual switch
            {
                "Anio" => baseMes.AddMonths(-11),
                "Trimestre" => baseMes.AddMonths(-2),
                _ => baseMes
            };
        }
    }

    private DateTime FechaFinPeriodo =>
        new DateTime(FechaBasePeriodo.Year, FechaBasePeriodo.Month, 1)
            .AddMonths(1)
            .AddDays(-1);

    private IEnumerable<PagoDTO> PagosPeriodo =>
        TodosLosPagos
            .Where(p => p.FechaPago.HasValue)
            .Where(p => p.FechaPago!.Value.Date >= FechaInicioPeriodo.Date &&
                        p.FechaPago!.Value.Date <= FechaFinPeriodo.Date);

    private List<PagoDTO> PagosPeriodoLista => PagosPeriodo.ToList();

    private decimal IngresosBrutos =>
        PagosPeriodoLista
            .Where(p => p.Activo && !EsPagoEgreso(p))
            .Sum(p => (decimal)p.Monto);

    private decimal EgresosTotales =>
        PagosPeriodoLista
            .Where(p => p.Activo && EsPagoEgreso(p))
            .Sum(p => (decimal)p.Monto);

    private decimal BalanceNeto => IngresosBrutos - EgresosTotales;

    private decimal PorCobrarSocios =>
        PagosPeriodoLista
            .Where(p => !p.Activo && !EsPagoEgreso(p))
            .Sum(p => (decimal)p.Monto);

    private decimal PorPagarStaff =>
        PagosPeriodoLista
            .Where(p => !p.Activo && EsPagoEgreso(p))
            .Sum(p => (decimal)p.Monto);

    private int TotalMovimientos => PagosPeriodoLista.Count;

    private int PagosPendientesSocios =>
        PagosPeriodoLista.Count(p => !p.Activo && !EsPagoEgreso(p));

    private int PagosPendientesStaff =>
        PagosPeriodoLista.Count(p => !p.Activo && EsPagoEgreso(p));

    private int PagosPendientes =>
        PagosPeriodoLista.Count(p => !p.Activo);

    private int IngresosPagadosCount =>
        PagosPeriodoLista.Count(p => p.Activo && !EsPagoEgreso(p));

    private int EgresosPagadosCount =>
        PagosPeriodoLista.Count(p => p.Activo && EsPagoEgreso(p));

    private int TotalPagosEstado =>
        IngresosPagadosCount + EgresosPagadosCount + PagosPendientes;

    private int PagosEfectivo => PagosPeriodoLista.Count(p => p.MetodoPago == 1);
    private int PagosTarjeta => PagosPeriodoLista.Count(p => p.MetodoPago == 2);
    private int PagosYape => PagosPeriodoLista.Count(p => p.MetodoPago == 3);
    private int PagosPlin => PagosPeriodoLista.Count(p => p.MetodoPago == 4);

    private string BalanceNetoTexto =>
        BalanceNeto < 0
            ? $"-S/ {FormatoMoneda(Math.Abs(BalanceNeto))}"
            : $"S/ {FormatoMoneda(BalanceNeto)}";

    private IEnumerable<MovimientoReporteItem> MovimientosPaginados =>
        Movimientos
            .Skip((PaginaActual - 1) * TamanoPagina)
            .Take(TamanoPagina);

    private int TotalPaginas =>
        Math.Max(1, (int)Math.Ceiling(Movimientos.Count / (double)TamanoPagina));

    protected override async Task OnInitializedAsync()
    {
        await CargarReporte();
    }

    private async Task CargarReporte()
    {
        try
        {
            Cargando = true;
            MensajeError = "";

            var pagosTask = PagoService.ListarPagosAsync();
            var suscripcionesTask = SuscripcionService.ListarSuscripcionesAsync();
            var sociosTask = SocioService.ListarSociosAsync();
            var entrenadoresTask = EntrenadorService.ListarEntrenadoresAsync();

            await Task.WhenAll(pagosTask, suscripcionesTask, sociosTask, entrenadoresTask);

            TodosLosPagos = pagosTask.Result ?? new List<PagoDTO>();
            TodasLasSuscripciones = suscripcionesTask.Result ?? new List<SuscripcionDTO>();
            TodosLosSocios = sociosTask.Result ?? new List<SocioDTO>();
            TodosLosEntrenadores = entrenadoresTask.Result ?? new List<EntrenadorDTO>();

            ConstruirReporte();
        }
        catch (Exception ex)
        {
            MensajeError = $"No se pudo cargar el reporte de recaudación: {ex.Message}";
        }
        finally
        {
            Cargando = false;
        }
    }

    private void ConstruirReporte()
    {
        ConstruirRecaudacionPorMembresia();
        ConstruirMovimientos();
    }

    private void ConstruirRecaudacionPorMembresia()
    {
        var pagosIngresos = PagosPeriodoLista
            .Where(p => p.Activo && !EsPagoEgreso(p))
            .ToList();

        decimal totalBasic = 0;
        decimal totalBlack = 0;
        decimal totalSinPlan = 0;

        int countBasic = 0;
        int countBlack = 0;
        int countSinPlan = 0;

        foreach (var pago in pagosIngresos)
        {
            var suscripcion = TodasLasSuscripciones.FirstOrDefault(s => s.IdPago == pago.IdPago);

            if (suscripcion?.IdMembresiaBlack != null)
            {
                totalBlack += (decimal)pago.Monto;
                countBlack++;
            }
            else if (suscripcion?.IdMembresiaBasic != null)
            {
                totalBasic += (decimal)pago.Monto;
                countBasic++;
            }
            else
            {
                totalSinPlan += (decimal)pago.Monto;
                countSinPlan++;
            }
        }

        decimal max = new[] { totalBasic, totalBlack, totalSinPlan }.DefaultIfEmpty(0).Max();

        RecaudacionPorMembresia = new List<RecaudacionMembresiaItem>
        {
            new()
            {
                Nombre = "Membresía Basic",
                CantidadPagos = countBasic,
                Total = totalBasic,
                CssClass = "basic",
                Barra = CalcularPorcentajeBarra(totalBasic, max)
            },
            new()
            {
                Nombre = "Membresía Black",
                CantidadPagos = countBlack,
                Total = totalBlack,
                CssClass = "black",
                Barra = CalcularPorcentajeBarra(totalBlack, max)
            },
            new()
            {
                Nombre = "Sin membresía identificada",
                CantidadPagos = countSinPlan,
                Total = totalSinPlan,
                CssClass = "sinplan",
                Barra = CalcularPorcentajeBarra(totalSinPlan, max)
            }
        };
    }

    private void ConstruirMovimientos()
    {
        Movimientos = PagosPeriodoLista
            .OrderByDescending(p => p.FechaPago ?? DateTime.MinValue)
            .ThenByDescending(p => p.IdPago)
            .Select(CrearMovimiento)
            .ToList();

        if (PaginaActual > TotalPaginas)
        {
            PaginaActual = TotalPaginas;
        }
    }

    private MovimientoReporteItem CrearMovimiento(PagoDTO pago)
    {
        bool esEgreso = EsPagoEgreso(pago);

        string usuario = esEgreso
            ? ObtenerNombreEntrenadorDesdePago(pago)
            : ObtenerNombreSocioDesdePago(pago);

        string detalle = esEgreso
            ? "Staff"
            : ObtenerMembresiaDesdePago(pago);

        decimal monto = (decimal)pago.Monto;

        return new MovimientoReporteItem
        {
            Usuario = usuario,
            DetalleUsuario = detalle,
            Iniciales = ObtenerInicialesTexto(usuario),
            Rol = esEgreso ? "Entrenador" : "Socio",
            Concepto = string.IsNullOrWhiteSpace(pago.Tipo) ? "Pago registrado" : pago.Tipo,
            TipoMovimiento = esEgreso ? "Egreso" : "Ingreso",
            TipoCss = esEgreso ? "egreso" : "ingreso",
            Metodo = ObtenerMetodoPago(pago.MetodoPago),
            Fecha = pago.FechaPago?.ToString("dd/MM/yyyy") ?? "—",
            Estado = pago.Activo ? "Pagado" : "Pendiente",
            EstadoCss = pago.Activo ? "pagado" : "pendiente",
            MontoTexto = esEgreso
                ? $"-S/ {FormatoMoneda(monto)}"
                : $"S/ {FormatoMoneda(monto)}",
            MontoCss = esEgreso ? "rr-money-negative" : "rr-money-positive"
        };
    }

    private string ObtenerNombreSocioDesdePago(PagoDTO pago)
    {
        var suscripcion = TodasLasSuscripciones.FirstOrDefault(s => s.IdPago == pago.IdPago);

        if (suscripcion == null)
        {
            return "Socio no identificado";
        }

        var socio = TodosLosSocios.FirstOrDefault(s => s.IdUsuario == suscripcion.IdUsuario);

        if (socio == null)
        {
            return "Socio no identificado";
        }

        return ObtenerNombreCompletoSocio(socio);
    }

    private string ObtenerMembresiaDesdePago(PagoDTO pago)
    {
        var suscripcion = TodasLasSuscripciones.FirstOrDefault(s => s.IdPago == pago.IdPago);

        if (suscripcion == null)
        {
            return "Sin membresía";
        }

        if (suscripcion.IdMembresiaBlack != null)
        {
            return "Membresía Black";
        }

        if (suscripcion.IdMembresiaBasic != null)
        {
            return "Membresía Basic";
        }

        return "Sin membresía";
    }

    private string ObtenerNombreEntrenadorDesdePago(PagoDTO pago)
    {
        var entrenador = ObtenerEntrenadorDesdePago(pago);

        if (entrenador != null)
        {
            return ObtenerNombreCompletoEntrenador(entrenador);
        }

        string extraido = ExtraerNombreEntrenadorDesdePago(pago);

        return string.IsNullOrWhiteSpace(extraido)
            ? "Staff no identificado"
            : extraido;
    }

    private EntrenadorDTO? ObtenerEntrenadorDesdePago(PagoDTO pago)
    {
        string tipo = NormalizarTexto(pago.Tipo);

        foreach (var entrenador in TodosLosEntrenadores)
        {
            string nombres = NormalizarTexto(entrenador.Nombres);
            string apellido = NormalizarTexto(entrenador.ApellidoPaterno);
            string nombreCompleto = NormalizarTexto(ObtenerNombreCompletoEntrenador(entrenador));

            if (!string.IsNullOrWhiteSpace(nombreCompleto) && tipo.Contains(nombreCompleto))
            {
                return entrenador;
            }

            string primerNombre = nombres.Split(' ', StringSplitOptions.RemoveEmptyEntries).FirstOrDefault() ?? "";

            if (!string.IsNullOrWhiteSpace(primerNombre) && tipo.Contains(primerNombre))
            {
                return entrenador;
            }

            if (!string.IsNullOrWhiteSpace(apellido) && tipo.Contains(apellido))
            {
                return entrenador;
            }
        }

        return null;
    }

    private static string ExtraerNombreEntrenadorDesdePago(PagoDTO pago)
    {
        if (string.IsNullOrWhiteSpace(pago.Tipo))
        {
            return "";
        }

        string tipo = pago.Tipo;

        tipo = tipo.Replace("Sueldo Entrenador", "", StringComparison.OrdinalIgnoreCase)
                   .Replace("Sueldo", "", StringComparison.OrdinalIgnoreCase)
                   .Replace("Entrenador", "", StringComparison.OrdinalIgnoreCase)
                   .Replace("Bono", "", StringComparison.OrdinalIgnoreCase)
                   .Trim();

        int guion = tipo.IndexOf('-');

        if (guion >= 0)
        {
            tipo = tipo[..guion].Trim();
        }

        return tipo;
    }

