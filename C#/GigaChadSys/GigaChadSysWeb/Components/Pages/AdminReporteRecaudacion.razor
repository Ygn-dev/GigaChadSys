            int finYape = finTarjeta + yape;

            return $"background: conic-gradient(#E53935 0deg {efectivo}deg, #1976D2 {efectivo}deg {finTarjeta}deg, #4CAF50 {finTarjeta}deg {finYape}deg, #FF9800 {finYape}deg 360deg);";
