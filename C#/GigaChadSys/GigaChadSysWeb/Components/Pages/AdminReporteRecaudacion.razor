    private static string ObtenerInicialesTexto(string texto)
    {
        if (string.IsNullOrWhiteSpace(texto))
        {
            return "U";
        }

        var partes = texto.Split(' ', StringSplitOptions.RemoveEmptyEntries);

        if (partes.Length == 1)
        {
            return partes[0][0].ToString().ToUpperInvariant();
        }

        return $"{partes[0][0]}{partes[1][0]}".ToUpperInvariant();
    }

    private static string NormalizarTexto(string? texto)
    {
        if (string.IsNullOrWhiteSpace(texto))
        {
            return "";
        }

        string normalizado = texto.Trim().ToLowerInvariant().Normalize(NormalizationForm.FormD);

        var builder = new StringBuilder();

        foreach (char c in normalizado)
        {
            var categoria = CharUnicodeInfo.GetUnicodeCategory(c);

            if (categoria != UnicodeCategory.NonSpacingMark)
            {
                builder.Append(c);
            }
        }

        return builder.ToString().Normalize(NormalizationForm.FormC);
    }

