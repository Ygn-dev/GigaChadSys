@page "/admin/membresias/nueva"
@layout AdminLayout
@rendermode InteractiveServer
@using GigaChadSys.Servicios
@using GigaChadSys.Servicios.DTO
@inject MembresiaBasicServicio BasicService
@inject MembresiaBlackServicio BlackService
@inject NavigationManager Nav
@inject ToastService ToastService

<section class="trainer-form-page">

    <div class="trainer-breadcrumb">
        <a href="/admin/inicio">Inicio</a>
        <span>/</span>
        <a href="/admin/membresias">Membresías</a>
        <span>/</span>
        <strong>Nueva Membresía</strong>
    </div>

    <div class="trainer-form-title">
        <h1>Registrar Nuevo Plan de Membresía</h1>
        <p>Crea un nuevo plan Basic o Black para el gimnasio.</p>
    </div>

    <div class="trainer-section">
        <h2>Tipo de Membresía</h2>

        <div class="trainer-grid">
            <div class="trainer-field">
                <label>Selecciona el tipo de plan <span>*</span></label>
                <select value="@TipoPlanValor" @onchange="CambiarTipoPlan">
                    <option value="Basic">Membresía Basic</option>
                    <option value="Black">Membresía Black</option>
                </select>
            </div>
        </div>
    </div>

    <div class="trainer-section">
        <h2>Datos Generales</h2>

        <div class="trainer-grid">
            <div class="trainer-field">
                <label>Nombre del plan <span>*</span></label>
                <input type="text"
                       autocomplete="off"
                       placeholder="Ej: Plan Estudiante"
                       value="@NombreValor"
                       @oninput="CambiarNombre"
                       class="@(IntentoGuardar && string.IsNullOrWhiteSpace(NombreValor) ? "input-error" : "")" />
            </div>
        </div>
    </div>

    <div class="trainer-section">
        <h2>Configuración de Costos y Beneficios</h2>

        <div class="trainer-grid">
            @if (TipoPlanValor == "Basic")
            {
                <div class="trainer-field">
                    <label>Costo Mensual (S/) <span>*</span></label>
                    <input type="number"
                           min="0"
                           step="0.01"
                           autocomplete="off"
                           placeholder="80.00"
                           value="@CostoMensualValor"
                           @oninput="CambiarCostoMensual"
                           class="@(IntentoGuardar && (string.IsNullOrWhiteSpace(CostoMensualValor) || !decimal.TryParse(CostoMensualValor, out decimal cm) || cm < 0) ? "input-error" : "")" />
                </div>
            }
            else
            {
                <div class="trainer-field">
                    <label>Costo Anual (S/) <span>*</span></label>
                    <input type="number"
                           min="0"
                           step="0.01"
                           autocomplete="off"
                           placeholder="1200.00"
                           value="@CostoAnualValor"
                           @oninput="CambiarCostoAnual"
                           class="@(IntentoGuardar && (string.IsNullOrWhiteSpace(CostoAnualValor) || !decimal.TryParse(CostoAnualValor, out decimal ca) || ca < 0) ? "input-error" : "")" />
                </div>

                <div class="trainer-field">
                    <label>Invitados por mes <span>*</span></label>
                    <input type="number"
                           min="0"
                           autocomplete="off"
                           placeholder="2"
                           value="@InvitadosValor"
                           @oninput="CambiarInvitados"
                           class="@(IntentoGuardar && (string.IsNullOrWhiteSpace(InvitadosValor) || !int.TryParse(InvitadosValor, out int inv) || inv < 0) ? "input-error" : "")" />
                </div>
            }
        </div>
    </div>

    <div class="trainer-section">
        <h2>Estado Inicial</h2>

        <div class="trainer-radio-row">
            <label>
                <input type="radio"
                       name="estadoMembresia"
                       checked="@MembresiaActiva"
                       @onclick="ActivarMembresia" />
                Activa
            </label>

            <label>
                <input type="radio"
                       name="estadoMembresia"
                       checked="@(!MembresiaActiva)"
                       @onclick="DesactivarMembresia" />
                Inactiva
            </label>
        </div>
    </div>

    <div class="trainer-actions">
        <button type="button"
                class="trainer-save-button"
                @onclick="RegistrarMembresia"
                disabled="@Guardando">
            @(Guardando ? "Registrando..." : "✓ Registrar Membresía")
        </button>

        <button type="button"
                class="trainer-cancel-button"
                @onclick="LimpiarFormulario"
                disabled="@Guardando">
            × Cancelar
        </button>

        <a class="trainer-return-link" href="/admin/membresias">
            ← Volver al listado
        </a>
    </div>

</section>

    private string TipoPlanValor { get; set; } = "Basic";
    private string NombreValor { get; set; } = "";
    private string CostoMensualValor { get; set; } = "";
    private string CostoAnualValor { get; set; } = "";
    private string InvitadosValor { get; set; } = "2";
    private bool MembresiaActiva { get; set; } = true;

    private bool IntentoGuardar { get; set; } = false;
    private bool Guardando { get; set; } = false;

    private void CambiarTipoPlan(ChangeEventArgs e)
    {
        TipoPlanValor = e.Value?.ToString() ?? "Basic";
    }

    private void CambiarNombre(ChangeEventArgs e) => NombreValor = e.Value?.ToString() ?? "";
    private void CambiarCostoMensual(ChangeEventArgs e) => CostoMensualValor = e.Value?.ToString() ?? "";
    private void CambiarCostoAnual(ChangeEventArgs e) => CostoAnualValor = e.Value?.ToString() ?? "";
    private void CambiarInvitados(ChangeEventArgs e) => InvitadosValor = e.Value?.ToString() ?? "";

    private void ActivarMembresia() => MembresiaActiva = true;
    private void DesactivarMembresia() => MembresiaActiva = false;

    private async Task RegistrarMembresia()
    {
        IntentoGuardar = true;

        if (string.IsNullOrWhiteSpace(NombreValor))
        {
            ToastService.ShowError("El nombre del plan es obligatorio.");
            return;
        }

        string resultado = "";

        if (TipoPlanValor == "Basic")
        {
            if (string.IsNullOrWhiteSpace(CostoMensualValor))
            {
                ToastService.ShowError("El costo mensual es obligatorio.");
                return;
            }

            if (!decimal.TryParse(CostoMensualValor, out decimal costoM) || costoM < 0)
            {
                ToastService.ShowError("El costo mensual debe ser un número válido mayor o igual a cero.");
                return;
            }

            try
            {
                Guardando = true;
                var nuevaBasic = new MembresiaBasicDTO
                {
                    Nombre = NombreValor.Trim(),
                    Activa = MembresiaActiva,
                    CostoMantenimientoMensual = (double)costoM
                };

                resultado = await BasicService.RegistrarAsync(nuevaBasic);
            }
            finally
            {
                Guardando = false;
            }
        }
        else
        {
            if (string.IsNullOrWhiteSpace(CostoAnualValor))
            {
                ToastService.ShowError("El costo anual es obligatorio.");
                return;
            }

            if (!decimal.TryParse(CostoAnualValor, out decimal costoA) || costoA < 0)
            {
                ToastService.ShowError("El costo anual debe ser un número válido mayor o igual a cero.");
                return;
            }

            if (string.IsNullOrWhiteSpace(InvitadosValor) || !int.TryParse(InvitadosValor, out int invitados) || invitados < 0)
            {
                ToastService.ShowError("La cantidad de invitados debe ser un número válido mayor o igual a cero.");
                return;
            }

            try
            {
                Guardando = true;
                var nuevaBlack = new MembresiaBlackDTO
                {
                    Nombre = NombreValor.Trim(),
                    Activa = MembresiaActiva,
                    CostoMantenimientoAnual = (double)costoA,
                    CantidadInvitadosPorMes = invitados
                };

                resultado = await BlackService.RegistrarAsync(nuevaBlack);
            }
            finally
            {
                Guardando = false;
            }
        }

        if (!resultado.StartsWith("Error") && !resultado.ToLower().Contains("error"))
        {
            ToastService.ShowSuccess("Membresía registrada correctamente.");
            Nav.NavigateTo("/admin/membresias");
        }
        else
        {
            ToastService.ShowError(resultado);
        }
    }

    private void LimpiarFormulario()
    {
        NombreValor = "";
        CostoMensualValor = "";
        CostoAnualValor = "";
        InvitadosValor = "2";
        MembresiaActiva = true;
        IntentoGuardar = false;
    }
}
