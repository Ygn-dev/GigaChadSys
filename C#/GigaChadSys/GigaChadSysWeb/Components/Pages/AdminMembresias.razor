@page "/admin/membresias"
@using GigaChadSys.Servicios
@using GigaChadSys.Servicios.DTO
@layout AdminLayout
@rendermode InteractiveServer
@inject MembresiaBasicServicio BasicService
@inject MembresiaBlackServicio BlackService
@inject ToastService ToastService

<section class="membership-page">

    <div class="membership-header">
        <div>
            <h1>Planes de Membresía</h1>
            <p>Gestiona los planes disponibles para los socios.</p>
        </div>
        <a class="new-button" href="/admin/membresias/nueva">
            + Nuevo Plan
        </a>
    </div>

    @if (Cargando)
    {
        <div class="membership-card" style="padding: 32px;">
            <h2>Cargando membresías...</h2>
            <p>Obteniendo datos actualizados desde la base de datos.</p>
        </div>
    }
    else
    {
        <div class="membership-grid">

            @foreach (var basic in MembresiasBasic)
            {
                <div class="membership-card">
                    <div class="membership-top">
                        <div class="membership-title-block">
                            <div class="membership-icon">◎</div>
                            <div>
                                <h2>@GetNombre(basic.Nombre, "Basic")</h2>

                                @if (basic.Activa)
                                {
                                    <span class="membership-status">Activa</span>
                                }
                                else
                                {
                                    <span class="membership-status inactive">Inactiva</span>
                                }
                            </div>
                        </div>

                        <div class="membership-price">
                            <strong>S/ @Math.Round((decimal)basic.CostoMantenimientoMensual, 0).ToString("0")</strong>
                            <span>/mes</span>
                        </div>
                    </div>

                    <div class="membership-section">
                        <h3>Beneficios</h3>
                        <ul>
                            <li>Acceso a sala de musculación</li>
                            <li>Acceso a cardio</li>
                            <li>Vestuario incluido</li>
                            <li>App móvil</li>
                        </ul>
                    </div>

                    <div class="membership-section">
                        <h3>Características</h3>
                        <div class="membership-tags">
                            <span>Sin clases grupales</span>
                            <span>Acceso limitado a horario diurno</span>
                            <span>Sin zona de spa</span>
                        </div>
                    </div>

                    <div class="membership-actions">
                        <a class="membership-button-secondary" href="/admin/membresias/basic/editar/@basic.IdMembresia">
                            ✎ Editar Plan
                        </a>
                        <a class="membership-button-primary" href="/admin/suscripciones/nuevo/basic/@basic.IdMembresia">
                            ♙ Suscribir Socio
                        </a>
                    </div>
                </div>
            }

            @foreach (var black in MembresiasBlack)
            {
                <div class="membership-card">
                    <div class="membership-top">
                        <div class="membership-title-block">
                            <div class="membership-icon black">♛</div>
                            <div>
                                <h2>@GetNombre(black.Nombre, "Black")</h2>

                                @if (black.Activa)
                                {
                                    <span class="membership-status">Activa</span>
                                }
                                else
                                {
                                    <span class="membership-status inactive">Inactiva</span>
                                }
                            </div>
                        </div>

                        <div class="membership-price">
                            <strong>S/ @Math.Round((decimal)black.CostoMantenimientoAnual / 12m, 0).ToString("0")</strong>
                            <span>/mes</span>
                        </div>
                    </div>

                    <div class="membership-section">
                        <h3>Beneficios</h3>
                        <ul>
                            <li>Todo lo de Basic</li>
                            <li>Clases grupales ilimitadas</li>
                            <li>Acceso 24/7</li>
                            <li>Zona de spa</li>
                            <li>Entrenador personal 2x/mes</li>
                        </ul>
                    </div>

                    <div class="membership-section">
                        <h3>Características</h3>
                        <div class="membership-tags">
                            <span>Acceso total a horarios</span>
                            <span>Reserva de clases preferencial</span>
                            <span>Invitados gratuitos @black.CantidadInvitadosPorMes/mes</span>
                        </div>
                    </div>

                    <div class="membership-actions">
                        <a class="membership-button-secondary" href="/admin/membresias/black/editar/@black.IdMembresia">
                            ✎ Editar Plan
                        </a>
                        <a class="membership-button-primary" href="/admin/suscripciones/nuevo/black/@black.IdMembresia">
                            ♙ Suscribir Socio
                        </a>
                    </div>
                </div>
            }

        </div>
    }

</section>

@code {
    private bool Cargando { get; set; } = true;

    private List<MembresiaBasicDTO> MembresiasBasic { get; set; } = new();
    private List<MembresiaBlackDTO> MembresiasBlack { get; set; } = new();

    private string GetNombre(string? nombre, string tipo)
    {
        if (string.IsNullOrWhiteSpace(nombre)) return $"Membresía {tipo}";
        return nombre.Contains("Membresía", StringComparison.OrdinalIgnoreCase)
            ? nombre
            : $"Membresía {nombre}";
    }

    protected override async Task OnInitializedAsync()
    {
        await CargarMembresias();
    }

    private async Task CargarMembresias()
    {
        try
        {
            Cargando = true;

            var basics = await BasicService.ListarMembresiasBasicAsync();
            var blacks = await BlackService.ListarMembresiasBlackAsync();

            MembresiasBasic = basics.OrderBy(b => b.IdMembresia).ToList();
            MembresiasBlack = blacks.OrderBy(b => b.IdMembresia).ToList();
        }
        catch (Exception ex)
        {
            ToastService.ShowError("No se pudieron cargar las membresías: " + ex.Message);
        }
        finally
        {
            Cargando = false;
        }
    }
}