@page "/admin/reportes/entrenadores"
@layout AdminLayout
@rendermode InteractiveServer

@using System.Globalization
@using System.Text
@using Microsoft.JSInterop
@using GigaChadSys.Servicios
@using GigaChadSys.Servicios.DTO

@inject EntrenadorServicio EntrenadorService
@inject SesionClaseServicio SesionClaseService
@inject PagoServicio PagoService
@inject HttpClient Http
@inject IJSRuntime JS
@inject NavigationManager Navigation

<section class="reporte-entrenadores-page">

    <div class="re-breadcrumb">
        <button type="button" @onclick="VolverAReportes">
            <i class="bi bi-arrow-left"></i>
            Reportes
        </button>
        <span>/</span>
        <strong>Entrenadores</strong>
    </div>

    <div class="re-header">
        <div>
            <span class="re-kicker">Reporte administrativo</span>
            <h1>Reporte de Entrenadores</h1>
            <p>Consulta el estado del staff, sueldos del mes y carga de sesiones asignadas.</p>
            <small>Mes evaluado: @MesReferenciaTexto</small>
        </div>

        <button type="button"
                class="re-download-btn"
                @onclick="DescargarReporteEntrenadores"
                disabled="@DescargandoReporte">
            @if (DescargandoReporte)
            {
                <span>
                    <i class="bi bi-hourglass-split"></i>
                    Generando PDF...
                </span>
            }
            else
            {
                <span>
                    <i class="bi bi-file-earmark-pdf"></i>
                    Descargar reporte de entrenadores
                </span>
            }
        </button>
    </div>

    @if (!string.IsNullOrWhiteSpace(MensajeDescarga))
    {
        <div class="re-alert">
            <i class="bi bi-info-circle"></i>
            <span>@MensajeDescarga</span>
        </div>
    }

    @if (Cargando)
    {
        <div class="re-loading">
            <i class="bi bi-hourglass-split"></i>
            <span>Cargando reporte de entrenadores...</span>
        </div>
    }
    else if (!string.IsNullOrWhiteSpace(MensajeError))
    {
        <div class="re-error">
            <i class="bi bi-exclamation-triangle"></i>
            <span>@MensajeError</span>
        </div>
    }
    else
    {
        <div class="re-kpi-grid">

            <div class="re-kpi-card">
                <div class="re-kpi-icon blue">
                    <i class="bi bi-person-badge"></i>
                </div>
                <div>
                    <span>Entrenadores activos</span>
                    <strong>@EntrenadoresActivos</strong>
                    <p>@Porcentaje(EntrenadoresActivos, TotalEntrenadores) del staff</p>
                </div>
            </div>

            <div class="re-kpi-card">
                <div class="re-kpi-icon green">
                    <i class="bi bi-cash-coin"></i>
                </div>
                <div>
                    <span>Sueldos pagados</span>
                    <strong>S/ @FormatoMoneda(SueldosPagadosMes)</strong>
                    <p>Pagos de staff registrados como cobrados</p>
                </div>
            </div>

            <div class="re-kpi-card">
                <div class="re-kpi-icon yellow">
                    <i class="bi bi-clock-history"></i>
                </div>
                <div>
                    <span>Sueldos pendientes</span>
                    <strong>S/ @FormatoMoneda(SueldosPendientesMes)</strong>
                    <p>Pagos de staff pendientes</p>
                </div>
            </div>

            <div class="re-kpi-card">
                <div class="re-kpi-icon red">
                    <i class="bi bi-calendar-check"></i>
                </div>
                <div>
                    <span>Sesiones asignadas</span>
                    <strong>@SesionesAsignadasMes</strong>
                    <p>Clases programadas en el mes</p>
                </div>
            </div>

        </div>

        <div class="re-main-grid">

            <div class="re-panel">
                <div class="re-panel-header">
                    <div>
                        <h2>Sesiones por entrenador</h2>
                        <p>Carga de clases asignadas durante el mes evaluado.</p>
                    </div>
                </div>

                <div class="re-bars-list">
                    @foreach (var item in EntrenadoresReporte)
                    {
                        <div class="re-bar-row">
                            <div class="re-bar-head">
                                <span>@item.NombreCompleto</span>
                                <strong>@item.SesionesAsignadas sesiones</strong>
                            </div>

                            <div class="re-bar-track">
                                <div class="re-bar-fill red"
                                     style="width:@item.BarraSesiones">
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>

            <div class="re-panel">
                <div class="re-panel-header">
                    <div>
                        <h2>Estado de pagos</h2>
                        <p>Resumen del pago de sueldos del staff.</p>
                    </div>
                </div>

                <div class="re-state-content">
                    <div class="re-donut" style="@EstadoPagosDonutStyle">
                        <div class="re-donut-center">
                            <strong>@TotalEntrenadores</strong>
                            <span>Staff</span>
                        </div>
                    </div>

                    <div class="re-donut-list">
                        <div class="re-donut-row">
                            <span><i class="dot green"></i>Pagados</span>
                            <strong>@PagosPagados (@Porcentaje(PagosPagados, TotalEntrenadores))</strong>
                        </div>

                        <div class="re-donut-row">
                            <span><i class="dot yellow"></i>Pendientes</span>
                            <strong>@PagosPendientes (@Porcentaje(PagosPendientes, TotalEntrenadores))</strong>
                        </div>

                        <div class="re-donut-row">
                            <span><i class="dot gray"></i>Sin registro</span>
                            <strong>@PagosSinRegistro (@Porcentaje(PagosSinRegistro, TotalEntrenadores))</strong>
                        </div>
                    </div>
                </div>
            </div>

        </div>

        <div class="re-panel re-egresos-panel">
            <div class="re-panel-header">
                <div>
                    <h2>Resumen de egresos por staff</h2>
                    <p>Entrenadores ordenados de mayor a menor sueldo mensual.</p>
                </div>
            </div>

            <div class="re-salary-list">
                @foreach (var item in EntrenadoresReporteOrdenadosPorSueldo)
                {
                    <div class="re-salary-row">
                        <div class="re-salary-info">
                            <strong>@item.NombreCompleto</strong>
                            <span>@item.Especialidad</span>
                        </div>

                        <div class="re-salary-bar">
                            <div style="width:@item.BarraSueldo"></div>
                        </div>

                        <strong class="re-salary-money">S/ @FormatoMoneda(item.SueldoMensual)</strong>
                    </div>
                }
            </div>
        </div>

        <div class="re-table-panel">
            <div class="re-panel-header">
                <div>
                    <h2>Detalle por entrenador</h2>
                    <p>Información personal, especialidad, sueldo, pago del mes y sesiones asignadas.</p>
                </div>
            </div>

            <div class="re-table-wrapper">
                <table class="re-table">
                    <thead>
                        <tr>
                            <th>Entrenador</th>
                            <th>DNI</th>
                            <th>Especialidad</th>
                            <th>Estado</th>
                            <th>Sueldo</th>
                            <th>Pago del mes</th>
                            <th>Sesiones</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var item in EntrenadoresReporte)
                        {
                            <tr>
                                <td>
                                    <div class="re-user-cell">
                                        <div class="re-avatar">@item.Iniciales</div>
                                        <div>
                                            <strong>@item.NombreCompleto</strong>
                                            <span>@item.Email</span>
                                        </div>
                                    </div>
                                </td>

                                <td>@item.Dni</td>
                                <td>@item.Especialidad</td>

                                <td>
                                    <span class="re-status @item.EstadoCss">
                                        @item.Estado
                                    </span>
                                </td>

                                <td>
                                    <strong>S/ @FormatoMoneda(item.SueldoMensual)</strong>
                                </td>

                                <td>
                                    <span class="re-status @item.EstadoPagoCss">
                                        @item.EstadoPago
                                    </span>
                                </td>

                                <td>
                                    <strong>@item.SesionesAsignadas</strong>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }

</section>

<style>
    .reporte-entrenadores-page {
        width: 100%;
        min-height: 100%;
        padding: 28px 36px 48px;
        color: #f5f5f5;
        background: #0b0b0b;
