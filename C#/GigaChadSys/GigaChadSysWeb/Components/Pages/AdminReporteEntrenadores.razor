        grid-template-columns: 190px 1fr;
        align-items: center;
        gap: 26px;
    }

    .re-donut {
        position: relative;
        width: 180px;
        height: 180px;
        border-radius: 50%;
    }

        .re-donut::after {
            content: "";
            position: absolute;
            inset: 38px;
            border-radius: 50%;
            background: #151515;
        }

    .re-donut-center {
        position: absolute;
        inset: 0;
        z-index: 2;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
    }

        .re-donut-center strong {
            color: #ffffff;
            font-size: 34px;
            font-weight: 950;
        }

        .re-donut-center span {
            color: #bdbdbd;
            font-size: 13px;
            font-weight: 700;
        }

    .re-donut-list {
        display: flex;
        flex-direction: column;
        gap: 13px;
    }

    .re-donut-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 16px;
        padding-bottom: 13px;
