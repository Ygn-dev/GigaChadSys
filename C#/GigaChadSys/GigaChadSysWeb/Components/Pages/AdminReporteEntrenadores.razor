    private static string ObtenerNombreCompleto(EntrenadorDTO entrenador)
    {
        string nombre = $"{entrenador.Nombres} {entrenador.ApellidoPaterno} {entrenador.ApellidoMaterno}".Trim();
        return string.IsNullOrWhiteSpace(nombre) ? "Entrenador sin nombre" : nombre;
    }

    private static string ObtenerIniciales(EntrenadorDTO entrenador)
    {
        string nombres = entrenador.Nombres?.Trim() ?? "";
        string apellido = entrenador.ApellidoPaterno?.Trim() ?? "";

        string inicial1 = !string.IsNullOrWhiteSpace(nombres) ? nombres[0].ToString().ToUpperInvariant() : "E";
        string inicial2 = !string.IsNullOrWhiteSpace(apellido) ? apellido[0].ToString().ToUpperInvariant() : "";

        return inicial1 + inicial2;
    }

    private static string FormatoMoneda(decimal valor)
    {
        return valor.ToString("0.00", CultureInfo.InvariantCulture);
    }

    private static string Porcentaje(int cantidad, int total)
    {
        if (total == 0)
        {
            return "0.0%";
        }

        double porcentaje = 100.0 * cantidad / total;
        return porcentaje.ToString("0.0", CultureInfo.InvariantCulture) + "%";
    }

    private static int CalcularGrados(int cantidad, int total)
    {
        if (total == 0)
        {
            return 0;
        }

        return Convert.ToInt32(Math.Round(360.0 * cantidad / total));
    }

    private static string CalcularPorcentajeBarra(int valor, int maximo)
    {
        if (maximo <= 0)
        {
            return "4%";
        }

        double porcentaje = 100.0 * valor / maximo;
        return Math.Max(porcentaje, 4).ToString("0.0", CultureInfo.InvariantCulture) + "%";
    }

    private static string CalcularPorcentajeBarra(decimal valor, decimal maximo)
    {
        if (maximo <= 0)
        {
            return "4%";
        }

        decimal porcentaje = 100 * valor / maximo;
        return Math.Max((double)porcentaje, 4).ToString("0.0", CultureInfo.InvariantCulture) + "%";
    }

    private static string NormalizarTexto(string? texto)
    {
        if (string.IsNullOrWhiteSpace(texto))
        {
            return "";
        }

        string normalizado = texto.Trim().ToLowerInvariant().Normalize(NormalizationForm.FormD);

        var builder = new StringBuilder();

        foreach (char c in normalizado)
        {
            var categoria = CharUnicodeInfo.GetUnicodeCategory(c);

            if (categoria != UnicodeCategory.NonSpacingMark)
            {
                builder.Append(c);
            }
        }

        return builder.ToString().Normalize(NormalizationForm.FormC);
    }

    private class EntrenadorReporteItem
    {
        public int IdUsuario { get; set; }
        public string NombreCompleto { get; set; } = "";
        public string Iniciales { get; set; } = "";
        public string Email { get; set; } = "";
        public string Dni { get; set; } = "";
        public string Especialidad { get; set; } = "";
        public string Estado { get; set; } = "";
        public string EstadoCss { get; set; } = "";
        public decimal SueldoMensual { get; set; }
        public string EstadoPago { get; set; } = "";
        public string EstadoPagoCss { get; set; } = "";
        public int SesionesAsignadas { get; set; }
        public string BarraSesiones { get; set; } = "4%";
        public string BarraSueldo { get; set; } = "4%";
    }
