        }

        .re-kpi-icon.red {
            color: #EF3131;
            background: rgba(239, 49, 49, 0.13);
        }

        .re-kpi-icon.yellow {
            color: #FACC15;
            background: rgba(250, 204, 21, 0.12);
        }

        .re-kpi-icon.blue {
            color: #60A5FA;
            background: rgba(59, 130, 246, 0.12);
        }

    .re-kpi-card span {
        display: block;
        margin-bottom: 6px;
        color: #bdbdbd;
        font-size: 12px;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: 0.07em;
    }

    .re-kpi-card strong {
        display: block;
        color: #ffffff;
        font-size: 28px;
        font-weight: 950;
        line-height: 1.1;
    }

    .re-kpi-card p {
        margin: 8px 0 0;
        color: #b9b9b9;
        font-size: 13px;
        font-weight: 500;
    }

    .re-main-grid {
        display: grid;
        grid-template-columns: 1.15fr 0.85fr;
        gap: 18px;
        margin-bottom: 28px;
    }

    .re-panel,
    .re-table-panel {
        padding: 24px;
        border-radius: 18px;
        background: #151515;
        border: 1px solid rgba(255, 255, 255, 0.08);
    }

    .re-egresos-panel {
        margin-bottom: 28px;
    }

    .re-panel-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 16px;
        margin-bottom: 22px;
    }

        .re-panel-header h2 {
            margin: 0;
            color: #ffffff;
            font-size: 22px;
            font-weight: 950;
        }

        .re-panel-header p {
            margin: 6px 0 0;
            color: #a9a9a9;
            font-size: 14px;
            font-weight: 500;
        }

    .re-bars-list {
        display: flex;
        flex-direction: column;
        gap: 22px;
    }

    .re-bar-head {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 16px;
        margin-bottom: 10px;
    }

        .re-bar-head span {
            color: #ffffff;
            font-size: 15px;
            font-weight: 850;
        }

        .re-bar-head strong {
            color: #dcdcdc;
            font-size: 14px;
            font-weight: 900;
        }

    .re-bar-track {
