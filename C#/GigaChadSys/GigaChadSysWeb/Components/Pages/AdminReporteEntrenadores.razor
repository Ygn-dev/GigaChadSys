        .re-status.pagado {
            color: #22C55E;
            background: rgba(34, 197, 94, 0.12);
        }

        .re-status.inactivo {
            color: #EF3131;
            background: rgba(239, 49, 49, 0.13);
        }

        .re-status.pendiente {
            color: #FACC15;
            background: rgba(250, 204, 21, 0.12);
        }

        .re-status.sinregistro {
            color: #9CA3AF;
            background: rgba(156, 163, 175, 0.13);
        }

    @@media (max-width: 1180px) {
        .re-kpi-grid {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }

        .re-main-grid {
            grid-template-columns: 1fr;
        }

        .re-salary-row {
            grid-template-columns: 1fr;
        }

        .re-salary-money {
            text-align: left;
        }
    }

    @@media (max-width: 760px) {
        .reporte-entrenadores-page {
            padding: 22px 18px 38px;
        }

        .re-header {
            flex-direction: column;
        }

            .re-header h1 {
                font-size: 34px;
            }

        .re-download-btn {
            width: 100%;
        }

        .re-kpi-grid {
            grid-template-columns: 1fr;
        }

        .re-state-content {
            grid-template-columns: 1fr;
        }
    }
</style>

@code {
    private bool Cargando = true;
    private bool DescargandoReporte = false;
    private string MensajeError = "";
    private string MensajeDescarga = "";

    private List<EntrenadorDTO> TodosLosEntrenadores = new();
    private List<SesionClaseDTO> TodasLasSesiones = new();
    private List<PagoDTO> TodosLosPagos = new();

    private List<EntrenadorReporteItem> EntrenadoresReporte = new();

    private DateTime MesReferencia = DateTime.Today;

    private int TotalEntrenadores = 0;
    private int EntrenadoresActivos = 0;
    private int SesionesAsignadasMes = 0;

    private int PagosPagados = 0;
    private int PagosPendientes = 0;
    private int PagosSinRegistro = 0;

    private decimal SueldosPagadosMes = 0;
    private decimal SueldosPendientesMes = 0;

    private string MesReferenciaTexto =>
        MesReferencia.ToString("MMMM yyyy", new CultureInfo("es-PE"));

    private IEnumerable<EntrenadorReporteItem> EntrenadoresReporteOrdenadosPorSueldo =>
        EntrenadoresReporte.OrderByDescending(e => e.SueldoMensual);

    private string EstadoPagosDonutStyle
    {
        get
        {
            if (TotalEntrenadores == 0)
            {
                return "background:#242424;";
            }

            int pagados = CalcularGrados(PagosPagados, TotalEntrenadores);
            int pendientes = CalcularGrados(PagosPendientes, TotalEntrenadores);

            int finPagados = pagados;
            int finPendientes = pagados + pendientes;

            return $"background: conic-gradient(#22C55E 0deg {finPagados}deg, #FACC15 {finPagados}deg {finPendientes}deg, #6B7280 {finPendientes}deg 360deg);";
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await CargarReporte();
    }

    private async Task CargarReporte()
    {
        try
        {
            Cargando = true;
            MensajeError = "";

            var entrenadoresTask = EntrenadorService.ListarEntrenadoresAsync();
            var sesionesTask = SesionClaseService.ListarSesionesAsync();
            var pagosTask = PagoService.ListarPagosAsync();

            await Task.WhenAll(entrenadoresTask, sesionesTask, pagosTask);

            TodosLosEntrenadores = entrenadoresTask.Result ?? new List<EntrenadorDTO>();
            TodasLasSesiones = sesionesTask.Result ?? new List<SesionClaseDTO>();
            TodosLosPagos = pagosTask.Result ?? new List<PagoDTO>();

            ConfigurarMesReferencia();
            ConstruirReporte();
        }
        catch (Exception ex)
        {
            MensajeError = $"No se pudo cargar el reporte de entrenadores: {ex.Message}";
        }
        finally
        {
            Cargando = false;
        }
    }

    private void ConfigurarMesReferencia()
    {
        var pagosStaff = TodosLosPagos
            .Where(EsPagoEgreso)
            .Where(p => p.FechaPago.HasValue)
            .ToList();

        bool hayPagosMesActual = pagosStaff.Any(p => EsDelMes(DateTime.Today, p.FechaPago!.Value));

        if (hayPagosMesActual)
        {
            MesReferencia = DateTime.Today;
            return;
        }

        var ultimoPagoStaff = pagosStaff
            .OrderByDescending(p => p.FechaPago)
            .FirstOrDefault();

        if (ultimoPagoStaff?.FechaPago != null)
        {
            MesReferencia = ultimoPagoStaff.FechaPago.Value;
        }
        else
        {
            MesReferencia = DateTime.Today;
        }
    }

    private void ConstruirReporte()
    {
        EntrenadoresReporte.Clear();

        var pagosStaffMes = TodosLosPagos
            .Where(EsPagoEgreso)
            .Where(EsPagoDelMesReferencia)
            .ToList();

        var sesionesMes = TodasLasSesiones
            .Where(s => s.Activo)
            .Where(s => s.FechaSesion != default)
            .Where(s => EsDelMes(MesReferencia, s.FechaSesion))
            .ToList();

        foreach (var entrenador in TodosLosEntrenadores)
        {
            var pagoMes = ObtenerPagoEntrenadorMes(entrenador, pagosStaffMes);

            int sesionesAsignadas = sesionesMes
                .Count(s => s.Entrenador != null && s.Entrenador.IdUsuario == entrenador.IdUsuario);

            decimal sueldoMensual = pagoMes != null
                ? (decimal)pagoMes.Monto
                : (decimal)entrenador.Sueldo;

            string estadoPago = ObtenerEstadoPago(pagoMes);
            string estadoPagoCss = ObtenerEstadoPagoCss(estadoPago);

            EntrenadoresReporte.Add(new EntrenadorReporteItem
            {
                IdUsuario = entrenador.IdUsuario,
                NombreCompleto = ObtenerNombreCompleto(entrenador),
                Iniciales = ObtenerIniciales(entrenador),
                Email = entrenador.Email,
                Dni = entrenador.Dni == 0 ? "—" : entrenador.Dni.ToString(),
                Especialidad = string.IsNullOrWhiteSpace(entrenador.Especialidad) ? "Sin especialidad" : entrenador.Especialidad,
                Estado = entrenador.Activo ? "Activo" : "Inactivo",
                EstadoCss = entrenador.Activo ? "activo" : "inactivo",
                SueldoMensual = sueldoMensual,
                EstadoPago = estadoPago,
                EstadoPagoCss = estadoPagoCss,
                SesionesAsignadas = sesionesAsignadas
            });
        }

        TotalEntrenadores = EntrenadoresReporte.Count;
        EntrenadoresActivos = EntrenadoresReporte.Count(e => e.Estado == "Activo");
        SesionesAsignadasMes = EntrenadoresReporte.Sum(e => e.SesionesAsignadas);

        SueldosPagadosMes = pagosStaffMes
            .Where(p => p.Activo)
            .Sum(p => (decimal)p.Monto);

        SueldosPendientesMes = pagosStaffMes
            .Where(p => !p.Activo)
            .Sum(p => (decimal)p.Monto);

        PagosPagados = EntrenadoresReporte.Count(e => e.EstadoPago == "Pagado");
        PagosPendientes = EntrenadoresReporte.Count(e => e.EstadoPago == "Pendiente");
        PagosSinRegistro = EntrenadoresReporte.Count(e => e.EstadoPago == "Sin registro");

        CalcularBarras();
    }

    private void CalcularBarras()
    {
        int maxSesiones = EntrenadoresReporte.Any()
            ? EntrenadoresReporte.Max(e => e.SesionesAsignadas)
            : 0;

        decimal maxSueldo = EntrenadoresReporte.Any()
            ? EntrenadoresReporte.Max(e => e.SueldoMensual)
            : 0;

        foreach (var item in EntrenadoresReporte)
        {
            item.BarraSesiones = CalcularPorcentajeBarra(item.SesionesAsignadas, maxSesiones);
            item.BarraSueldo = CalcularPorcentajeBarra(item.SueldoMensual, maxSueldo);
        }
    }

    private PagoDTO? ObtenerPagoEntrenadorMes(EntrenadorDTO entrenador, List<PagoDTO> pagosStaffMes)
    {
        return pagosStaffMes
            .Where(p => PagoPerteneceAEntrenador(p, entrenador))
            .OrderByDescending(p => p.Activo)
            .ThenByDescending(p => p.FechaPago ?? DateTime.MinValue)
            .FirstOrDefault();
    }

    private static bool PagoPerteneceAEntrenador(PagoDTO pago, EntrenadorDTO entrenador)
    {
        string tipo = NormalizarTexto(pago.Tipo);
        string nombres = NormalizarTexto(entrenador.Nombres);
        string apellidoPaterno = NormalizarTexto(entrenador.ApellidoPaterno);
        string nombreCompleto = NormalizarTexto(ObtenerNombreCompleto(entrenador));

        if (string.IsNullOrWhiteSpace(tipo))
        {
            return false;
        }

        if (!tipo.Contains("entrenador") && !tipo.Contains("sueldo") && !tipo.Contains("bono"))
        {
            return false;
        }

        if (!string.IsNullOrWhiteSpace(nombreCompleto) && tipo.Contains(nombreCompleto))
        {
            return true;
        }

        if (!string.IsNullOrWhiteSpace(nombres))
        {
            var primerNombre = nombres.Split(' ', StringSplitOptions.RemoveEmptyEntries).FirstOrDefault() ?? "";

            if (!string.IsNullOrWhiteSpace(primerNombre) && tipo.Contains(primerNombre))
            {
                return true;
            }
        }

        if (!string.IsNullOrWhiteSpace(apellidoPaterno) && tipo.Contains(apellidoPaterno))
        {
            return true;
        }

        return false;
    }

    private bool EsPagoDelMesReferencia(PagoDTO pago)
    {
        if (pago.FechaPago.HasValue)
        {
            return EsDelMes(MesReferencia, pago.FechaPago.Value);
        }

        string tipo = NormalizarTexto(pago.Tipo);
        string mesTexto = NormalizarTexto(MesReferencia.ToString("MMMM yyyy", new CultureInfo("es-PE")));

        return tipo.Contains(mesTexto);
    }

    private static bool EsDelMes(DateTime referencia, DateTime fecha)
    {
        return referencia.Month == fecha.Month && referencia.Year == fecha.Year;
    }

    private static bool EsPagoEgreso(PagoDTO pago)
    {
        if (string.IsNullOrWhiteSpace(pago.Tipo))
        {
            return false;
        }

        string tipo = pago.Tipo.Trim().ToLowerInvariant();

        return tipo.Contains("sueldo") ||
               tipo.Contains("bono") ||
               tipo.Contains("entrenador");
    }

    private static string ObtenerEstadoPago(PagoDTO? pago)
    {
        if (pago == null)
        {
            return "Sin registro";
        }

        return pago.Activo ? "Pagado" : "Pendiente";
    }

    private static string ObtenerEstadoPagoCss(string estadoPago)
    {
        return estadoPago switch
        {
            "Pagado" => "pagado",
            "Pendiente" => "pendiente",
            _ => "sinregistro"
        };
    }

    private async Task DescargarReporteEntrenadores()
    {
        try
        {
            DescargandoReporte = true;
            MensajeDescarga = "";

            var bytes = await Http.GetByteArrayAsync("reportes/entrenadores");
            var base64 = Convert.ToBase64String(bytes);

            await JS.InvokeVoidAsync(
                "downloadFileFromBytes",
                "reporte_entrenadores.pdf",
                "application/pdf",
                base64
            );
        }
        catch
        {
            MensajeDescarga = "La pantalla ya está lista. Falta conectar el endpoint Java del PDF: reportes/entrenadores.";
        }
        finally
        {
            DescargandoReporte = false;
        }
    }

