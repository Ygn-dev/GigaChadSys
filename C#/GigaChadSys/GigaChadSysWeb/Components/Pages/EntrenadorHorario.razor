@page "/entrenador/horario"
@using GigaChadSys.Servicios
@using GigaChadSys.Servicios.DTO
@layout EntrenadorLayout
@rendermode InteractiveServer
@inject SessionServicio Session
@inject SesionClaseServicio SesionClaseService
@inject ReservaServicio ReservaService

<section class="container-fluid py-4">
    <!-- Breadcrumb -->
    <nav class="breadcrumb-nav">
        <span class="breadcrumb-current">Mi Horario</span>
        <span class="breadcrumb-sep">/</span>
        <span class="breadcrumb-hint">Gestiona tus clases asignadas</span>
    </nav>

    <div class="horario-header">
        <h1>Mi Horario</h1>
        <p class="horario-subtitle">Gestiona tus clases asignadas</p>
    </div>

    <!-- Tabs -->
    <div class="horario-tabs">
        <button class="horario-tab @(tabActiva == "activas" ? "tab-active" : "")"
                @onclick='() => tabActiva = "activas"'>
            Sesiones Activas (@sesionesActivas.Count)
        </button>
        <button class="horario-tab @(tabActiva == "historial" ? "tab-active" : "")"
                @onclick='() => tabActiva = "historial"'>
            Historial (@sesionesHistorial.Count)
        </button>
    </div>

    <!-- Session List -->
    <div class="horario-list">
        @{
            var listaMostrar = tabActiva == "activas" ? sesionesActivas : sesionesHistorial;
        }

        @foreach (var sesion in listaMostrar)
        {
            <a href="/entrenador/sesiones/detalle/@sesion.Id" class="horario-sesion-card" style="text-decoration:none; color:inherit; cursor:pointer;">
                <div class="horario-sesion-left">
                    <div class="horario-sesion-icon">
                        <span>📋</span>
                    </div>
                    <div class="horario-sesion-info">
                        <strong>@sesion.NombreClase</strong>
                        <span class="horario-sesion-cat">@sesion.Categoria</span>
                    </div>
                </div>

                <div class="horario-sesion-meta">
                    <div class="horario-meta-col">
                        <span class="meta-label">Fecha</span>
                        <span class="meta-value">@sesion.Fecha.ToString("yyyy-MM-dd")</span>
                    </div>
                    <div class="horario-meta-col">
                        <span class="meta-label">Hora</span>
                        <span class="meta-value">@sesion.Hora</span>
                    </div>
                    <div class="horario-meta-col">
                        <span class="meta-label">Salón</span>
                        <span class="meta-value">@sesion.Salon</span>
                    </div>
                </div>

                <div class="horario-sesion-right">
                    <span class="badge badge-@sesion.Estado.ToLower()">@sesion.Estado</span>
                    <span class="horario-alumnos">@sesion.Inscritos/@sesion.Capacidad alumnos</span>
                </div>

                <button class="horario-btn-cancel" title="Cancelar sesión" @onclick="() => CancelarSesion(sesion)" @onclick:preventDefault="true">
                    ✕
                </button>
            </a>
        }

        @if (!listaMostrar.Any())
        {
            <div class="horario-empty">
                <p>No hay sesiones en esta categoría.</p>
            </div>
        }
    </div>
</section>

@code {
    private string tabActiva = "activas";
    private List<SesionHorario> sesionesActivas = new();
    private List<SesionHorario> sesionesHistorial = new();

    protected override async Task OnInitializedAsync()
    {
        await CargarSesiones();
    }

    private async Task CargarSesiones()
    {
        if (!Session.EstaAutenticado) return;

        var todasSesiones = await SesionClaseService.ListarSesionesAsync();
        var todasReservas = await ReservaService.ListarReservasAsync();

        var misSesiones = todasSesiones
            .Where(s => s.Entrenador != null && s.Entrenador.IdUsuario == Session.IdUsuario)
            .ToList();

        sesionesActivas.Clear();
        sesionesHistorial.Clear();

        foreach (var s in misSesiones)
        {
            int inscritos = todasReservas.Count(r => r.SesionClase?.IdSesion == s.IdSesion);
            int capacidad = s.Salon?.AforoMaximo ?? 0;

            var vista = new SesionHorario
            {
                Id = s.IdSesion,
                NombreClase = s.ClaseGrupal?.NombreDisciplina ?? "Sin nombre",
                Categoria = s.ClaseGrupal?.NombreDisciplina ?? "General",
                Fecha = s.FechaSesion,
                Hora = $"{s.HoraInicio:HH:mm} - {s.HoraFin:HH:mm}",
                Salon = s.Salon?.NombreSalon ?? "Sin asignar",
                Estado = s.FechaSesion >= DateTime.Today ? "Programada" : "Finalizada",
                Inscritos = inscritos,
                Capacidad = capacidad
            };

            if (s.FechaSesion < DateTime.Today)
            {
                sesionesHistorial.Add(vista);
            }
            else
            {
                sesionesActivas.Add(vista);
            }
        }
    }

    private async Task CancelarSesion(SesionHorario sesion)
    {
        var response = await SesionClaseService.EliminarAsync(sesion.Id);
        if (!response.StartsWith("Error"))
        {
            await CargarSesiones();
        }
    }

    private class SesionHorario
    {
        public int Id { get; set; }
        public string NombreClase { get; set; } = "";
        public string Categoria { get; set; } = "";
        public DateTime Fecha { get; set; }
        public string Hora { get; set; } = "";
        public string Salon { get; set; } = "";
        public string Estado { get; set; } = "";
        public int Inscritos { get; set; }
        public int Capacidad { get; set; }
    }
}
