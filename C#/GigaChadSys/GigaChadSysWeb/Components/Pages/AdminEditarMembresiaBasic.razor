@page "/admin/membresias/editar/{IdParam:int}"
@inject MembresiaBasicServicio BasicService
@inject NavigationManager Nav

@code {
    [Parameter]
    public int IdParam { get; set; }

    private string NombrePlan = "Membresía Basic";
    private decimal PrecioMensual = 79;
    private bool Activo = true;

    private bool Cargando = true;
    private string Mensaje = "";
    private string ClaseMensaje = "";

    private string PrecioMensualTexto => PrecioMensual.ToString("0.00", CultureInfo.InvariantCulture);

    protected override async Task OnInitializedAsync()
    {
        await CargarMembresia();
    }

    private async Task CargarMembresia()
    {
        Cargando = true;
        Mensaje = "";

        try
        {
            var dto = await BasicService.ObtenerPorIdAsync(IdParam);
            if (dto == null)
            {
                MostrarError("No se encontró el plan especificado.");
            }
            else
            {
                NombrePlan = dto.Nombre ?? "Membresía Basic";
                PrecioMensual = (decimal)dto.CostoMantenimientoMensual;
                Activo = dto.Activa;
            }
        }
        catch (Exception ex)
        {
            MostrarError("Error al cargar la membresía: " + ex.Message);
        }
        finally
        {
            Cargando = false;
        }
    }

    private void CambiarNombrePlan(ChangeEventArgs e)
    {
        NombrePlan = e.Value?.ToString() ?? "";
    }

    private void CambiarPrecioMensual(ChangeEventArgs e)
    {
        string valor = e.Value?.ToString() ?? "";

        if (decimal.TryParse(valor, NumberStyles.Any, CultureInfo.InvariantCulture, out decimal precio))
        {
            PrecioMensual = precio;
        }
        else if (decimal.TryParse(valor, NumberStyles.Any, CultureInfo.CurrentCulture, out decimal precioLocal))
        {
            PrecioMensual = precioLocal;
        }
    }

    private void ActivarPlan()
    {
        Activo = true;
    }

    private void DesactivarPlan()
    {
        Activo = false;
    }

    private async Task GuardarCambios()
    {
        Mensaje = "";

        if (string.IsNullOrWhiteSpace(NombrePlan))
        {
            MostrarError("El nombre del plan es obligatorio.");
            return;
        }

        if (PrecioMensual <= 0)
        {
            MostrarError("El precio mensual debe ser mayor a cero.");
            return;
        }

        try
        {
            var dto = new MembresiaBasicDTO
            {
                IdMembresia = IdParam,
                Nombre = NombrePlan.Trim(),
                CostoMantenimientoMensual = (double)PrecioMensual,
                Activa = Activo
            };

            var respuesta = await BasicService.ActualizarAsync(IdParam, dto);

            if (!respuesta.StartsWith("Error") && !respuesta.ToLower().Contains("error"))
            {
                MostrarExito("Membresía Basic actualizada correctamente.");
                await Task.Delay(1500);
                Nav.NavigateTo("/admin/membresias");
            }
            else
            {
                MostrarError(respuesta);
            }
        }
        catch (Exception ex)
        {
            MostrarError("Error al guardar cambios: " + ex.Message);
        }
    }

    private void MostrarError(string mensaje)
    {
        Mensaje = mensaje;
        ClaseMensaje = "membership-message error";
    }

    private void MostrarExito(string mensaje)
    {
        Mensaje = mensaje;
        ClaseMensaje = "membership-message success";
    }

    private static string LeerTexto(JsonElement root, string defecto, params string[] nombres)
    {
        if (TryGetAny(root, out JsonElement value, nombres))
        {
            if (value.ValueKind == JsonValueKind.String)
                return value.GetString() ?? defecto;

            return value.ToString();
        }

        return defecto;
    }

    private static int LeerEntero(JsonElement root, int defecto, params string[] nombres)
    {
        if (TryGetAny(root, out JsonElement value, nombres))
        {
            if (value.ValueKind == JsonValueKind.Number && value.TryGetInt32(out int numero))
                return numero;

            if (int.TryParse(value.ToString(), out int convertido))
                return convertido;
        }

        return defecto;
    }

    private static decimal LeerDecimal(JsonElement root, decimal defecto, params string[] nombres)
    {
        if (TryGetAny(root, out JsonElement value, nombres))
        {
            if (value.ValueKind == JsonValueKind.Number && value.TryGetDecimal(out decimal numero))
                return numero;

            if (decimal.TryParse(value.ToString(), NumberStyles.Any, CultureInfo.InvariantCulture, out decimal convertido))
                return convertido;

            if (decimal.TryParse(value.ToString(), NumberStyles.Any, CultureInfo.CurrentCulture, out decimal convertidoLocal))
                return convertidoLocal;
        }

        return defecto;
    }

    private static bool LeerBooleano(JsonElement root, bool defecto, params string[] nombres)
    {
        if (TryGetAny(root, out JsonElement value, nombres))
        {
            if (value.ValueKind == JsonValueKind.True)
                return true;

            if (value.ValueKind == JsonValueKind.False)
                return false;

            string texto = value.ToString();

            if (bool.TryParse(texto, out bool b))
                return b;

            if (texto == "1")
                return true;

            if (texto == "0")
                return false;
        }

        return defecto;
    }

    private static bool TryGetAny(JsonElement root, out JsonElement value, params string[] nombres)
    {
        foreach (string nombre in nombres)
        {
            if (root.TryGetProperty(nombre, out value))
                return true;
        }

        foreach (var prop in root.EnumerateObject())
        {
            foreach (string nombre in nombres)
            {
                if (string.Equals(prop.Name, nombre, StringComparison.OrdinalIgnoreCase))
                {
                    value = prop.Value;
                    return true;
                }
            }
        }

        value = default;
        return false;
    }
}