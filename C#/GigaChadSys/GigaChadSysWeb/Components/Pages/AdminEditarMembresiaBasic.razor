@page "/admin/membresias/basic/editar/{IdParam:int}"
@layout AdminLayout
@rendermode InteractiveServer

@using System.Globalization
@using GigaChadSys.Servicios
@using GigaChadSys.Servicios.DTO
@inject MembresiaBasicServicio BasicService
@inject NavigationManager Nav

<section class="membership-edit-page">

    <div class="membership-breadcrumb">
        <a href="/admin/inicio">Inicio</a>
        <span>›</span>
        <a href="/admin/membresias">Membresías</a>
        <span>›</span>
        <strong>Membresía Basic</strong>
        <span>›</span>
        <strong>Editar Plan</strong>
    </div>

    <div class="membership-title">
        <h1>Editar Membresía Basic</h1>
        <p>Actualiza la información administrativa del plan Basic.</p>
    </div>

    @if (!string.IsNullOrWhiteSpace(Mensaje))
    {
        <div class="@ClaseMensaje">
            @Mensaje
        </div>
    }

    @if (Cargando)
    {
        <div class="membership-message success">
            Cargando datos de la membresía...
        </div>
    }
    else
    {
        <div class="membership-layout">

            <div class="membership-main">

                <div class="membership-section">
                    <h2>Información del Plan</h2>

                    <div class="membership-grid">
                        <div class="membership-field">
                            <label>Nombre del plan <span>*</span></label>
                            <input type="text"
                                   value="@NombrePlan"
                                   @oninput="CambiarNombrePlan" />
                        </div>

                        <div class="membership-field">
                            <label>Precio mensual (S/) <span>*</span></label>
                            <input type="number"
                                   min="0"
                                   step="0.01"
                                   value="@PrecioMensualTexto"
                                   @oninput="CambiarPrecioMensual" />
                        </div>
                    </div>
                </div>

                <div class="membership-section">
                    <h2>Beneficios</h2>

                    <p class="membership-static-note">
                        Los beneficios de este plan son definidos por el sistema y no se editan desde esta pantalla.
                    </p>

                    <div class="membership-chip-list">
                        <span class="membership-chip">✓ Acceso a sala de musculación</span>
                        <span class="membership-chip">✓ Acceso a cardio</span>
                        <span class="membership-chip">✓ Vestuario incluido</span>
                        <span class="membership-chip">✓ App móvil</span>
                    </div>
                </div>

                <div class="membership-section">
                    <h2>Características</h2>

                    <p class="membership-static-note">
                        Las características comerciales del plan son fijas para evitar inconsistencias con la base de datos.
                    </p>

                    <div class="membership-chip-list">
                        <span class="membership-chip muted">⊙ Sin clases grupales</span>
                        <span class="membership-chip muted">⊙ Acceso limitado a horario diurno</span>
                        <span class="membership-chip muted">⊙ Sin zona de spa</span>
                    </div>
                </div>

                <div class="membership-section">
                    <h2>Estado del Plan</h2>

                    <div class="membership-state-grid">
                        <label class="membership-state-card @(Activo ? "selected" : "")">
                            <input type="radio"
                                   name="estadoBasic"
                                   checked="@Activo"
                                   @onclick="ActivarPlan" />
                            <div>
                                <strong>Activa</strong>
                                <p>El plan está disponible para nuevas suscripciones.</p>
                            </div>
                        </label>

                        <label class="membership-state-card @(!Activo ? "selected" : "")">
                            <input type="radio"
                                   name="estadoBasic"
                                   checked="@(!Activo)"
                                   @onclick="DesactivarPlan" />
                            <div>
                                <strong>Inactiva</strong>
                                <p>El plan no estará disponible para nuevas suscripciones.</p>
                            </div>
                        </label>
                    </div>
                </div>

                <div class="membership-actions">
                    <button type="button"
                            class="membership-save"
                            @onclick="GuardarCambios">
                        💾 Guardar Cambios
                    </button>

                    <a class="membership-cancel" href="/admin/membresias">
                        Cancelar
                    </a>

                    <a class="membership-back" href="/admin/membresias">
                        ← Volver a Membresías
                    </a>
                </div>

            </div>

            <aside class="membership-preview-panel">
                <h2>Vista Previa</h2>

                <div class="membership-preview-card">
                    <div class="preview-header">
                        <div class="preview-icon basic">⊙</div>

                        <div>
                            <h3>@NombrePlan</h3>

                            @if (Activo)
                            {
                                <span class="preview-status active">Activa</span>
                            }
                            else
                            {
                                <span class="preview-status inactive">Inactiva</span>
                            }
                        </div>

                        <div class="preview-price">
                            <strong>S/ @PrecioMensual.ToString("0.00")</strong>
                            <span>/mes</span>
                        </div>
                    </div>

                    <div class="preview-section">
                        <span>BENEFICIOS</span>
                        <p>✓ Acceso a sala de musculación</p>
                        <p>✓ Acceso a cardio</p>
                        <p>✓ Vestuario incluido</p>
                        <p>✓ App móvil</p>
                    </div>

                    <div class="preview-section">
                        <span>CARACTERÍSTICAS</span>

                        <div class="preview-tags">
                            <strong>Sin clases grupales</strong>
                            <strong>Acceso limitado a horario diurno</strong>
                            <strong>Sin zona de spa</strong>
                        </div>
                    </div>
                </div>

                <div class="membership-side-card">
                    <span>Socios activos con este plan</span>
                    <strong>24</strong>
                    <p>suscripciones activas</p>
                </div>

                <div class="membership-side-card">
                    <span>Ingreso mensual estimado</span>
                    <strong>S/ @((PrecioMensual * 24).ToString("0"))</strong>
                    <p>basado en suscripciones activas</p>
                </div>
            </aside>

        </div>
    }

</section>

