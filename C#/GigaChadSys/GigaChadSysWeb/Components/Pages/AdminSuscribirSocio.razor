@page "/admin/suscripciones/nuevo/{PlanTipo}/{IdPlanParam:int}"
@using System.Globalization
@using GigaChadSys.Servicios
@using GigaChadSys.Servicios.DTO
@layout AdminLayout
@rendermode InteractiveServer
@inject SocioServicio SocioService
@inject SuscripcionServicio SuscripcionService
@inject MembresiaBasicServicio MembresiaBasicService
@inject MembresiaBlackServicio MembresiaBlackService
@inject NavigationManager Nav

<section class="container-fluid py-4">

    <div class="subscribe-breadcrumb">
        <a href="/admin/inicio">Inicio</a>
        <span>/</span>
        <a href="/admin/membresias">Membresías</a>
        <span>/</span>
        <strong>Suscribir Socio</strong>
    </div>

    <div class="subscribe-title">
        <h1>Suscribir Socio a @NombrePlan</h1>
        <p>Selecciona un socio y registra su suscripción al plan.</p>
    </div>

    @if (!string.IsNullOrWhiteSpace(MensajeFormulario))
    {
        <div class="@ClaseMensajeFormulario">
            @MensajeFormulario
        </div>
    }

    <div class="row g-4">

        <div class="subscribe-main">

            <div class="subscribe-section">
                <h2>Selección de Socio</h2>

                <input class="subscribe-search"
                       type="text"
                       placeholder="Buscar por DNI, nombre o correo..."
                       value="@TextoBusqueda"
                       @oninput="CambiarBusqueda" />

                <div class="subscribe-member-list">
                    @foreach (var socio in SociosFiltrados)
                    {
                        <button type="button"
                                class="@ObtenerClaseSocio(socio.Dni)"
                                @onclick="() => SeleccionarSocio(socio)">
                            <div>
                                <strong>@socio.NombreCompleto</strong>
                                <span>@socio.Dni · @socio.Email</span>
                            </div>

                            <small>@socio.EstadoMembresia</small>
                        </button>
                    }
                </div>
            </div>

            <div class="subscribe-section">
                <h2>Plan Seleccionado</h2>

                <div class="subscribe-plan-card">
                    <div class="subscribe-plan-top">
                        <div class="subscribe-plan-name">
                            <div class="subscribe-plan-icon">@IconoPlan</div>

                            <div>
                                <h3>@NombrePlan</h3>
                                <span>Activa</span>
                            </div>
                        </div>

                        <div class="subscribe-plan-price">
                            <strong>S/ @PrecioPlan</strong>
                            <span>/mes</span>
                        </div>
                    </div>

                    <div class="subscribe-plan-info">
                        <div>
                            <h4>Beneficios</h4>

                            @foreach (var beneficio in BeneficiosPlan)
                            {
                                <p>✓ @beneficio</p>
                            }
                        </div>

                        <div>
                            <h4>Características</h4>

                            @foreach (var caracteristica in CaracteristicasPlan)
                            {
                                <p>☆ @caracteristica</p>
                            }
                        </div>
                    </div>
                </div>
            </div>

            <div class="subscribe-section">
                <h2>Datos de Suscripción</h2>

                <div class="subscribe-grid">
                    <div class="subscribe-field">
                        <label>Fecha de inicio</label>
                        <input type="date"
                               value="@FechaInicioInput"
                               @onchange="CambiarFechaInicio" />
                    </div>

                    <div class="subscribe-field">
                        <label>Fecha de vencimiento</label>
                        <input type="date"
                               value="@FechaVencimientoInput"
                               @onchange="CambiarFechaVencimiento" />
                    </div>
                </div>

                <div class="subscribe-status-row">
                    <button type="button"
                            class="@ClaseEstadoActiva"
                            @onclick="ActivarSuscripcion">
                        Activa
                    </button>

                    <button type="button"
                            class="@ClaseEstadoInactiva"
                            @onclick="DesactivarSuscripcion">
                        Inactiva
                    </button>
                </div>
            </div>

            <div class="subscribe-actions">
                <button type="button"
                        class="subscribe-save-button"
                        @onclick="RegistrarSuscripcion">
                    Registrar Suscripción
                </button>

                <a class="subscribe-cancel-button" href="/admin/membresias">
                    Cancelar
                </a>

                <a class="subscribe-return-link" href="/admin/membresias">
                    ← Volver a Membresías
                </a>
            </div>

        </div>

        <aside class="subscribe-summary">
            <h2>Resumen de Suscripción</h2>

            <div class="subscribe-summary-row">
                <span>Socio seleccionado</span>

                @if (SocioSeleccionado == null)
                {
                    <strong class="muted">Ningún socio seleccionado</strong>
                }
                else
                {
                    <strong>@SocioSeleccionado.NombreCompleto</strong>
                }
            </div>

            <div class="subscribe-summary-row">
                <span>Plan</span>
                <strong>@NombrePlan</strong>
            </div>

            <div class="subscribe-summary-row">
                <span>Precio mensual</span>
                <strong class="price">S/ @PrecioPlan</strong>
            </div>

            <div class="subscribe-summary-row">
                <span>Fechas</span>
                <strong>Inicio: @FechaInicioTexto</strong>
                <strong>Vencimiento: @FechaVencimientoTexto</strong>
            </div>

            <div class="subscribe-summary-row">
                <span>Estado</span>

                @if (SuscripcionActiva)
                {
                    <strong class="summary-active">Activa</strong>
                }
                else
                {
                    <strong class="summary-inactive">Inactiva</strong>
                }
            </div>
        </aside>

    </div>
</section>

@code {
    [Parameter]
    public string PlanTipo { get; set; } = "basic";
    
    [Parameter]
    public int IdPlanParam { get; set; }

    private string TextoBusqueda { get; set; } = "";

    private DateTime FechaInicio { get; set; } = DateTime.Today;
    private DateTime FechaVencimiento { get; set; } = DateTime.Today.AddMonths(1);

    private bool SuscripcionActiva { get; set; } = true;

    // Formato obligatorio para input type="date"
    private string FechaInicioInput => FechaInicio.ToString("yyyy-MM-dd");
    private string FechaVencimientoInput => FechaVencimiento.ToString("yyyy-MM-dd");

    // Texto mostrado en el resumen
    private string FechaInicioTexto => FechaInicio.ToString("yyyy-MM-dd");
    private string FechaVencimientoTexto => FechaVencimiento.ToString("yyyy-MM-dd");

    private string MensajeFormulario { get; set; } = "";
    private string ClaseMensajeFormulario { get; set; } = "";

    private SocioVista? SocioSeleccionado { get; set; }

    private string NombrePlan => PlanTipo.ToLower() == "black" ? "Membresía Black" : "Membresía Basic";
    private string PrecioPlan { get; set; } = "0.00";
    private int IdPlanSeleccionado { get; set; } = 1;

    private string IconoPlan => PlanTipo.ToLower() == "black" ? "♛" : "◎";

    private string ClaseEstadoActiva => SuscripcionActiva ? "subscribe-status-button active" : "subscribe-status-button";
    private string ClaseEstadoInactiva => !SuscripcionActiva ? "subscribe-status-button active" : "subscribe-status-button";

    private List<string> BeneficiosPlan => PlanTipo.ToLower() == "black"
        ? new List<string>
        {
            "Todo lo de Basic",
            "Clases grupales ilimitadas",
            "Acceso 24/7",
            "Zona de spa",
            "Entrenador personal 2x/mes"
        }
        : new List<string>
        {
            "Acceso a sala de musculación",
            "Acceso a cardio",
            "Vestuario incluido",
            "App móvil"
        };

    private List<string> CaracteristicasPlan => PlanTipo.ToLower() == "black"
        ? new List<string>
        {
            "Acceso total a horarios",
            "Reserva de clases preferencial",
            "Invitados gratuitos 2/mes"
        }
        : new List<string>
        {
            "Sin clases grupales",
            "Acceso limitado a horario diurno",
            "Sin zona de spa"
        };

    private List<SocioVista> Socios { get; set; } = new();

    protected override async Task OnInitializedAsync()
    {
        IdPlanSeleccionado = IdPlanParam;
        
        if (PlanTipo.ToLower() == "black")
        {
            var plan = await MembresiaBlackService.ObtenerPorIdAsync(IdPlanParam);

            if (plan != null)
            {
                PrecioPlan = (plan.CostoMantenimientoAnual / 12.0).ToString("0.00");
                // TODO: we could map specific features if the DB provides them, for now fallback to defaults
            }
        }
        else
        {
            var plan = await MembresiaBasicService.ObtenerPorIdAsync(IdPlanParam);

            if (plan != null)
            {
                PrecioPlan = plan.CostoMantenimientoMensual.ToString("0.00");
            }
        }

        var listaSocios = await SocioService.ListarSociosAsync();
        var listaSuscripciones = await SuscripcionService.ListarSuscripcionesAsync();

        foreach (var s in listaSocios)
        {
            var sub = listaSuscripciones.FirstOrDefault(x => x.IdUsuario == s.IdUsuario && x.Activo);
            string estado = sub != null ? sub.TipoPlan : "Sin membresía";

            Socios.Add(new SocioVista
            {
                IdUsuario = s.IdUsuario,
                Dni = s.Dni.ToString(),
                NombreCompleto = s.NombreCompleto,
                Email = s.CorreoElectronico,
                EstadoMembresia = estado
            });
        }
    }

    private IEnumerable<SocioVista> SociosFiltrados
    {
        get
        {
            if (string.IsNullOrWhiteSpace(TextoBusqueda))
            {
                return Socios.Take(3);
            }

            return Socios.Where(s =>
                s.Dni.Contains(TextoBusqueda, StringComparison.OrdinalIgnoreCase) ||
                s.NombreCompleto.Contains(TextoBusqueda, StringComparison.OrdinalIgnoreCase) ||
                s.Email.Contains(TextoBusqueda, StringComparison.OrdinalIgnoreCase)
            );
        }
    }

    private void CambiarBusqueda(ChangeEventArgs e)
    {
        TextoBusqueda = e.Value?.ToString() ?? "";
    }

    private void CambiarFechaInicio(ChangeEventArgs e)
    {
        var valor = e.Value?.ToString();

        if (DateTime.TryParseExact(
                valor,
                "yyyy-MM-dd",
                CultureInfo.InvariantCulture,
                DateTimeStyles.None,
                out DateTime fecha
            ))
        {
            FechaInicio = fecha;

            if (FechaVencimiento <= FechaInicio)
            {
                FechaVencimiento = FechaInicio.AddMonths(1);
            }
        }
    }

    private void CambiarFechaVencimiento(ChangeEventArgs e)
    {
        var valor = e.Value?.ToString();

        if (DateTime.TryParseExact(
                valor,
                "yyyy-MM-dd",
                CultureInfo.InvariantCulture,
                DateTimeStyles.None,
                out DateTime fecha
            ))
        {
            FechaVencimiento = fecha;
        }
    }

    private void SeleccionarSocio(SocioVista socio)
    {
        SocioSeleccionado = socio;
        MensajeFormulario = "";
        ClaseMensajeFormulario = "";
    }

    private string ObtenerClaseSocio(string dni)
    {
        if (SocioSeleccionado != null && SocioSeleccionado.Dni == dni)
        {
            return "subscribe-member-card selected";
        }

        return "subscribe-member-card";
    }

    private void ActivarSuscripcion()
    {
        SuscripcionActiva = true;
    }

    private void DesactivarSuscripcion()
    {
        SuscripcionActiva = false;
    }

    private async Task RegistrarSuscripcion()
    {
        if (SocioSeleccionado == null)
        {
            MostrarError("Debes seleccionar un socio.");
            return;
        }

        if (FechaVencimiento <= FechaInicio)
        {
            MostrarError("La fecha de vencimiento debe ser posterior a la fecha de inicio.");
            return;
        }

        var nuevaSuscripcion = new SuscripcionDTO
        {
            IdUsuario = SocioSeleccionado.IdUsuario,
            EstadoMembresia = SuscripcionActiva ? "activa" : "inactiva",
            FechaIngreso = FechaInicio,
            FechaFinMembresia = FechaVencimiento,
            Activo = SuscripcionActiva,
            IdPago = 1
        };

        if (PlanTipo.ToLower() == "black")
        {
            nuevaSuscripcion.IdMembresiaBlack = IdPlanSeleccionado;
        }
        else
        {
            nuevaSuscripcion.IdMembresiaBasic = IdPlanSeleccionado;
        }

        var resultado = await SuscripcionService.RegistrarAsync(nuevaSuscripcion);

        if (!resultado.StartsWith("Error") && !resultado.ToLower().Contains("error"))
        {
            MostrarExito("Suscripción registrada correctamente.");
            await Task.Delay(1500);
            Nav.NavigateTo("/admin/membresias");
        }
        else
        {
            MostrarError(resultado);
        }
    }

    private void MostrarError(string mensaje)
    {
        MensajeFormulario = mensaje;
        ClaseMensajeFormulario = "subscribe-message error";
    }

    private void MostrarExito(string mensaje)
    {
        MensajeFormulario = mensaje;
        ClaseMensajeFormulario = "subscribe-message success";
    }

    private class SocioVista
    {
        public int IdUsuario { get; set; }
        public string Dni { get; set; } = "";
        public string NombreCompleto { get; set; } = "";
        public string Email { get; set; } = "";
        public string EstadoMembresia { get; set; } = "";
    }
}