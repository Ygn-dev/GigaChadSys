@page "/admin/sesiones"
@using Components.Layout
@using GigaChadSys.Servicios
@using GigaChadSys.Servicios.DTO
@inject SesionClaseServicio SesionService
@layout AdminLayout
@inject NavigationManager Navigation
@rendermode InteractiveServer

<section class="admin-list-page">
    <div class="admin-list-header">
        <div>
            <h1>Sesiones Programadas</h1>
            <p>Calendario y gestión de sesiones de clases.</p>
        </div>
        <a class="new-button" href="/admin/sesiones/nuevo">
            + Nueva Sesión
        </a>
    </div>

    <div class="admin-list-toolbar">
        <input class="admin-search"
               type="text"
               placeholder="Buscar por clase, entrenador o salón..."
               @bind="TextoBusqueda"
               @bind:event="oninput" />

        <input class="admin-search"
               style="max-width: 180px; flex: none;"
               type="date"
               @bind="FechaFiltro"
               @bind:event="onchange" />

        <div class="admin-filter-group">
            <button class="@FiltroClaseTodos" @onclick="MostrarTodos">Todos</button>
            <button class="@FiltroClaseProgramadas" @onclick="MostrarProgramadas">Programada</button>
            <button class="@FiltroClaseCanceladas" @onclick="MostrarCanceladas">Cancelada</button>
            <button class="@FiltroClaseFinalizadas" @onclick="MostrarFinalizadas">Finalizada</button>
        </div>
    </div>

    @if (Cargando)
    {
        <p>Cargando sesiones...</p>
    }
    else
    {
        var sesiones = SesionesFiltradas.ToList();

        <div class="admin-table-card">
            <table class="admin-table">
                <thead>
                    <tr>
                        <th>Fecha</th>
                        <th>Hora</th>
                        <th>Clase</th>
                        <th>Entrenador</th>
                        <th>Salón</th>
                        <th>Cupos</th>
                        <th>Estado</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @if (sesiones.Count == 0)
                    {
                        <tr>
                            <td colspan="8" class="empty-row">No se encontraron sesiones.</td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var sesion in sesiones)
                        {
                            var salon = sesion.Salon;
                            var clase = sesion.ClaseGrupal;
                            var entrenador = sesion.Entrenador;

                            var cuposMaximos = salon?.AforoMaximo ?? 0;
                            var cuposOcupados = cuposMaximos - sesion.CuposDisponibles;
                            var porcentajeCupos = cuposMaximos > 0 ? (int)((double)cuposOcupados / cuposMaximos * 100) : 0;
                            var estado = sesion.HoraFin < DateTime.Now ? "Finalizada" : "Programada";
                            var nombreClase = clase?.NombreDisciplina ?? "Sin Clase";
                            var nombreEntrenador = entrenador != null ? entrenador.NombreCompleto : "Sin Entrenador";
                            var nombreSalon = salon?.NombreSalon ?? "Sin Salón";

                            <tr>
                                <td>@sesion.FechaSesion.ToString("yyyy-MM-dd")</td>
                                <td>@sesion.HoraInicio.ToString("HH:mm") - @sesion.HoraFin.ToString("HH:mm")</td>

                                <td>
                                    <div class="sesion-clase-cell">
                                        <strong>@nombreClase</strong>
                                        <span></span>
                                    </div>
                                </td>

                                <td>@nombreEntrenador</td>
                                <td>@nombreSalon</td>

                                <td>
                                    <div class="cupos-cell">
                                        <span>@cuposOcupados / @cuposMaximos</span>
                                        <div class="cupos-bar">
                                            <div class="cupos-fill" style="width: @(porcentajeCupos)%"></div>
                                        </div>
                                    </div>
                                </td>

                                <td>
                                    @if (estado == "Programada")
                                    {
                                        <span class="status-badge active">Programada</span>
                                    }
                                    else if (estado == "Cancelada")
                                    {
                                        <span class="status-badge inactive">Cancelada</span>
                                    }
                                    else
                                    {
                                        <span class="status-badge finished">Finalizada</span>
                                    }
                                </td>

                                <td>
                                    <button type="button" class="action-button" title="Ver">👁</button>
                                    <button type="button" class="action-button" title="Editar" @onclick="() => IrAEditarSesion(sesion.IdSesion)">✎</button>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    }
</section>

@code {
    private string TextoBusqueda { get; set; } = "";
    private string FiltroEstado { get; set; } = "Todos";
    private DateTime? FechaFiltro { get; set; } = null;
    private bool Cargando { get; set; } = true;

    private List<SesionClaseDTO> ListaSesiones = new();

    private string FiltroClaseTodos => FiltroEstado == "Todos" ? "filter-button active" : "filter-button";
    private string FiltroClaseProgramadas => FiltroEstado == "Programada" ? "filter-button active" : "filter-button";
    private string FiltroClaseCanceladas => FiltroEstado == "Cancelada" ? "filter-button active" : "filter-button";
    private string FiltroClaseFinalizadas => FiltroEstado == "Finalizada" ? "filter-button active" : "filter-button";

    private void MostrarTodos() => FiltroEstado = "Todos";
    private void MostrarProgramadas() => FiltroEstado = "Programada";
    private void MostrarCanceladas() => FiltroEstado = "Cancelada";
    private void MostrarFinalizadas() => FiltroEstado = "Finalizada";

    protected override async Task OnInitializedAsync()
    {
        try
        {
            ListaSesiones = await SesionService.ListarSesionesAsync();
        }
        finally
        {
            Cargando = false;
        }
    }

    private void IrAEditarSesion(int id)
    {
        Navigation.NavigateTo($"/admin/sesiones/editar/{id}");
    }

    private IEnumerable<SesionClaseDTO> SesionesFiltradas
    {
        get
        {
            IEnumerable<SesionClaseDTO> resultado = ListaSesiones;

            if (FiltroEstado != "Todos")
            {
                if (FiltroEstado == "Finalizada")
                {
                    resultado = resultado.Where(s => s.HoraFin < DateTime.Now);
                }
                else if (FiltroEstado == "Programada")
                {
                    resultado = resultado.Where(s => s.HoraFin >= DateTime.Now);
                }
            }

            if (FechaFiltro.HasValue)
                resultado = resultado.Where(s => s.FechaSesion.Date == FechaFiltro.Value.Date);

            if (!string.IsNullOrWhiteSpace(TextoBusqueda))
            {
                string texto = TextoBusqueda.Trim();
                resultado = resultado.Where(s =>
                    (s.ClaseGrupal?.NombreDisciplina?.Contains(texto, StringComparison.OrdinalIgnoreCase) ?? false) ||
                    (s.Entrenador?.Nombres?.Contains(texto, StringComparison.OrdinalIgnoreCase) ?? false) ||
                    (s.Entrenador?.ApellidoPaterno?.Contains(texto, StringComparison.OrdinalIgnoreCase) ?? false) ||
                    (s.Salon?.NombreSalon?.Contains(texto, StringComparison.OrdinalIgnoreCase) ?? false)
                );
            }

            return resultado.OrderBy(s => s.FechaSesion).ThenBy(s => s.HoraInicio);
        }
    }
}