@page "/admin/reservas/nueva"
@using GigaChadSys.Servicios.DTO
@layout AdminLayout
@rendermode InteractiveServer

@inject GigaChadSys.Servicios.SocioServicio SocioService
@inject GigaChadSys.Servicios.SesionClaseServicio SesionClaseService
@inject GigaChadSys.Servicios.ReservaServicio ReservaService
@inject NavigationManager NavManager

<section class="admin-list-page">

    <!-- Breadcrumb -->
    <div class="breadcrumb-nav">
        <a href="/admin/inicio">Inicio</a>
        <span class="breadcrumb-sep">/</span>
        <a href="/admin/reservas">Reservas</a>
        <span class="breadcrumb-sep">/</span>
        <span class="breadcrumb-current">Nueva Reserva</span>
    </div>

    <!-- Page Header -->
    <div style="margin-bottom:28px;">
        <h1 style="font-size:26px;font-weight:800;color:#F5F5F5;margin:0 0 6px;">
            Registrar Nueva Reserva
        </h1>
        <p style="color:#B0B0B0;font-size:14px;margin:0;">
            Reserve un cupo para un socio en una sesión programada
        </p>
    </div>

    <!-- Two-column layout -->
    <div class="nr-layout">

        <!-- LEFT: Form sections -->
        <div class="nr-form-col">

            <!-- Selección de Socio -->
            <div class="sf-section-card">
                <div class="sf-section-head">
                    <span class="sf-section-icon">👤</span>
                    <span>Selección de Socio</span>
                </div>
                <div class="sf-form-group">
                    <label class="sf-label">Socio <span style="color:#E53935">*</span></label>
                    <select class="sf-select" @bind="SocioSeleccionado">
                        <option value="0">Seleccione un socio</option>
                        @foreach (var s in Socios)
                        {
                            <option value="@s.IdUsuario">@s.NombreCompleto — DNI: @s.Dni</option>
                        }
                    </select>
                </div>
            </div>

            <!-- Selección de Sesión -->
            <div class="sf-section-card">
                <div class="sf-section-head">
                    <span class="sf-section-icon">📅</span>
                    <span>Selección de Sesión</span>
                </div>
                <div class="sf-form-group">
                    <label class="sf-label">Sesión disponible <span style="color:#E53935">*</span></label>
                    <select class="sf-select" @bind="SesionSeleccionada">
                        <option value="0">Seleccione una sesión</option>
                        @foreach (var s in Sesiones)
                        {
                            <option value="@s.IdSesion">
                                @(s.ClaseGrupal?.NombreDisciplina ?? "Clase") — @s.FechaSesion.ToString("dd/MM/yyyy") @s.HoraInicio.ToString("HH:mm") (@s.CuposDisponibles cupos libres)
                            </option>
                        }
                    </select>
                </div>
            </div>

            <!-- Estado de la Reserva -->
            <div class="sf-section-card">
                <div class="sf-section-head">
                    <span class="sf-section-icon">👁</span>
                    <span>Estado de la Reserva</span>
                </div>
                <div class="sf-estado-row">
                    <button class="sf-estado-btn @(EstadoReserva == "Confirmada" ? "sf-estado-activo" : "")"
                            @onclick='() => EstadoReserva = "Confirmada"'>
                        <span class="sf-estado-dot @(EstadoReserva == "Confirmada" ? "dot-green" : "")"></span>
                        Confirmada
                    </button>
                    <button class="sf-estado-btn @(EstadoReserva == "Pendiente" ? "sf-estado-pendiente-sel" : "")"
                            @onclick='() => EstadoReserva = "Pendiente"'>
                        <span class="sf-estado-dot @(EstadoReserva == "Pendiente" ? "dot-yellow" : "")"></span>
                        Pendiente
                    </button>
                    <button class="sf-estado-btn @(EstadoReserva == "Cancelada" ? "sf-estado-inactivo" : "")"
                            @onclick='() => EstadoReserva = "Cancelada"'>
                        <span class="sf-estado-dot @(EstadoReserva == "Cancelada" ? "dot-red" : "")"></span>
                        Cancelada
                    </button>
                </div>
            </div>

            <!-- Action Buttons -->
            <div class="sf-form-actions">
                <button class="sf-btn-primary" @onclick="RegistrarReserva">
                    ✔ Registrar Reserva
                </button>
                <button class="sf-btn-secondary" @onclick="LimpiarFormulario">
                    ✕ Cancelar
                </button>
                <div class="sf-back-link">
                    <a href="/admin/reservas">← Volver al listado</a>
                </div>
            </div>

        </div>

        <!-- RIGHT: Vista Previa -->
        <div class="nr-preview-col">
            <div class="sf-resumen-card">
                <div class="sf-section-head" style="margin-bottom:18px;">
                    <span class="sf-section-icon">📅</span>
                    <span>Vista Previa</span>
                </div>

                @if (SocioSeleccionado <= 0 || SesionSeleccionada <= 0)
                {
                    <div class="nr-preview-empty">
                        <span class="nr-preview-empty-icon">📅</span>
                        <p>Complete el formulario para ver la vista previa de la reserva.</p>
                    </div>
                }
                else
                {
                    var socio  = Socios.FirstOrDefault(s => s.IdUsuario == SocioSeleccionado);
                    var sesion = Sesiones.FirstOrDefault(s => s.IdSesion == SesionSeleccionada);

                    if (socio != null && sesion != null)
                    {
                        <div class="sf-resumen-rows">
                            <div class="sf-resumen-row">
                                <span>SOCIO</span>
                                <strong>@socio.NombreCompleto</strong>
                            </div>
                            <div class="sf-resumen-row">
                                <span>DNI</span>
                                <strong>@socio.Dni</strong>
                            </div>
                            <div class="sf-resumen-row">
                                <span>CLASE</span>
                                <strong>@sesion.ClaseGrupal?.NombreDisciplina</strong>
                            </div>
                            <div class="sf-resumen-row">
                                <span>ENTRENADOR</span>
                                <strong>@sesion.Entrenador?.NombreCompleto</strong>
                            </div>
                            <div class="sf-resumen-row">
                                <span>FECHA</span>
                                <strong>@sesion.FechaSesion.ToString("dd/MM/yyyy")</strong>
                            </div>
                            <div class="sf-resumen-row">
                                <span>HORARIO</span>
                                <strong>@sesion.HoraInicio.ToString("HH:mm") - @sesion.HoraFin.ToString("HH:mm")</strong>
                            </div>
                            <div class="sf-resumen-row">
                                <span>CUPOS LIBRES</span>
                                <strong class="@(sesion.CuposDisponibles <= 2 ? "rsm-inactivo" : "rsm-activo")">
                                    @sesion.CuposDisponibles disponibles
                               </strong>
                            </div>
                            <div class="sf-resumen-row">
                                <span>ESTADO</span>
                                <span class="reserva-estado-badge reserva-estado-@EstadoReserva.ToLower()">
                                    <span class="reserva-estado-dot"></span>
                                    @EstadoReserva
                                </span>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>

    </div>

</section>

@if (MostrarToast)
{
    <div class="socios-toast socios-toast-show">
        <span>✅</span> @MensajeToast
    </div>
}

@code {
    private int SocioSeleccionado { get; set; } = 0;
    private int SesionSeleccionada { get; set; } = 0;
    private string EstadoReserva { get; set; } = "Confirmada";
    private bool MostrarToast { get; set; } = false;
    private string MensajeToast { get; set; } = "Reserva registrada correctamente";

    private List<SocioDTO> Socios = new();
    private List<SesionClaseDTO> Sesiones = new();

    protected override async Task OnInitializedAsync()
    {
        var taskSocios = SocioService.ListarSociosAsync();
        var taskSesiones = SesionClaseService.ListarSesionesAsync();

        await Task.WhenAll(taskSocios, taskSesiones);

        Socios = await taskSocios;
        Sesiones = await taskSesiones;
    }

    private async Task RegistrarReserva()
    {
        if (SocioSeleccionado <= 0 || SesionSeleccionada <= 0)
            return;

        var reserva = new ReservaDTO
        {
            FechaHoraReserva = DateTime.Now,
            Asistio = false,
            IdUsuario = SocioSeleccionado,
            SesionClase = new SesionClaseDTO { IdSesion = SesionSeleccionada }
        };

        var responseMsg = await ReservaService.RegistrarAsync(reserva);
        
        MensajeToast = responseMsg;
        MostrarToast = true;
        StateHasChanged();
        await Task.Delay(2800);
        MostrarToast = false;
        
        // Return to reservations list or just clear form
        NavManager.NavigateTo("/admin/reservas");
    }

    private void LimpiarFormulario()
    {
        SocioSeleccionado = 0;
        SesionSeleccionada = 0;
        EstadoReserva = "Confirmada";
    }
}
