DROP DATABASE IF EXISTS gygabd;
CREATE DATABASE gygabd
CHARACTER SET utf8mb4
COLLATE utf8mb4_unicode_ci;

USE gygabd;

SET FOREIGN_KEY_CHECKS = 0;

DROP TABLE IF EXISTS Reserva;
DROP TABLE IF EXISTS Suscripcion;
DROP TABLE IF EXISTS SesionClase;
DROP TABLE IF EXISTS Pago;
DROP TABLE IF EXISTS MetodoPago;
DROP TABLE IF EXISTS Salon;
DROP TABLE IF EXISTS ClaseGrupal;
DROP TABLE IF EXISTS MembresiaBasic;
DROP TABLE IF EXISTS MembresiaBlack;
DROP TABLE IF EXISTS Socio;
DROP TABLE IF EXISTS Entrenador;
DROP TABLE IF EXISTS Administrador;
DROP TABLE IF EXISTS Maquina;

SET FOREIGN_KEY_CHECKS = 1;

-- =========================================================
-- USUARIOS
-- Compatible con UsuarioDTO, SocioDTO, EntrenadorDTO,
-- AdministradorDTO y los DAO Java actuales.
-- =========================================================

CREATE TABLE Socio (
    idUsuario INT AUTO_INCREMENT PRIMARY KEY,
    nombres VARCHAR(100) NOT NULL,
    apellidoPaterno VARCHAR(100) NOT NULL,
    apellidoMaterno VARCHAR(100) NOT NULL,
    edad INT DEFAULT 0,
    DNI INT UNIQUE,
    email VARCHAR(100) UNIQUE NOT NULL,
    telefono INT,
    contrasenia VARCHAR(255) NOT NULL,
    rol VARCHAR(50) DEFAULT 'Socio',
    estadoMembresia BOOLEAN DEFAULT FALSE,
    activo BOOLEAN DEFAULT TRUE
);

CREATE TABLE Entrenador (
    idUsuario INT AUTO_INCREMENT PRIMARY KEY,
    nombres VARCHAR(100) NOT NULL,
    apellidoPaterno VARCHAR(100) NOT NULL,
    apellidoMaterno VARCHAR(100) NOT NULL,
    edad INT DEFAULT 0,
    DNI INT UNIQUE,
    email VARCHAR(100) UNIQUE NOT NULL,
    telefono INT,
    contrasenia VARCHAR(255) NOT NULL,
    rol VARCHAR(50) DEFAULT 'Entrenador',
    Especialidad VARCHAR(100),
    sueldo DECIMAL(10,2),
    tiempoTrabajo TIME,
    activo BOOLEAN DEFAULT TRUE
);

CREATE TABLE Administrador (
    idUsuario INT AUTO_INCREMENT PRIMARY KEY,
    nombres VARCHAR(100) NOT NULL,
    apellidoPaterno VARCHAR(100) NOT NULL,
    apellidoMaterno VARCHAR(100) NOT NULL,
    edad INT DEFAULT 0,
    DNI INT UNIQUE,
    email VARCHAR(100) UNIQUE NOT NULL,
    telefono INT,
    contrasenia VARCHAR(255) NOT NULL,
    rol VARCHAR(50) DEFAULT 'Administrador',
    Sede VARCHAR(100),
    sueldo DECIMAL(10,2),
    cargo VARCHAR(100),
    activo BOOLEAN DEFAULT TRUE
);

-- =========================================================
-- MEMBRESÍAS
-- Compatible con MembresiaBasicDAOImpl y MembresiaBlackDAOImpl.
-- =========================================================

CREATE TABLE MembresiaBasic (
    membresia_ID INT AUTO_INCREMENT PRIMARY KEY,
    nombrePlan VARCHAR(50) DEFAULT 'Basic',
    costoMantenimientoMensual DECIMAL(10,2) NOT NULL,
    activo BOOLEAN DEFAULT TRUE
);

CREATE TABLE MembresiaBlack (
    membresia_ID INT AUTO_INCREMENT PRIMARY KEY,
    nombrePlan VARCHAR(50) DEFAULT 'Black',
    costoMantenimientoAnual DECIMAL(10,2) NOT NULL,
    cantidadInvitadosPorMes INT NOT NULL,
    activo BOOLEAN DEFAULT TRUE
);

-- =========================================================
-- CLASES, SALONES, SESIONES Y RESERVAS
-- Compatible con ClaseGrupal, Salon, SesionClase y Reserva.
-- =========================================================

CREATE TABLE ClaseGrupal (
    idClase INT AUTO_INCREMENT PRIMARY KEY,
    nombreDisciplina VARCHAR(100) NOT NULL,
    descripcion TEXT,
    duracionMinutos INT,
    nivel VARCHAR(50),
    activo BOOLEAN DEFAULT TRUE
);

CREATE TABLE Salon (
    idSalon INT AUTO_INCREMENT PRIMARY KEY,
    nombreSalon VARCHAR(100) NOT NULL,
    aforoMaximo INT NOT NULL,
    activo BOOLEAN DEFAULT TRUE
);

CREATE TABLE SesionClase (
    idSesion INT AUTO_INCREMENT PRIMARY KEY,
    fechaSesion DATE NOT NULL,
    horaInicio DATETIME NOT NULL,
    horaFin DATETIME NOT NULL,
    cuposDisponibles INT NOT NULL,
    activo BOOLEAN DEFAULT TRUE,

    idSalon INT NOT NULL,
    idEntrenador INT NOT NULL,
    idClase INT NOT NULL,

    CONSTRAINT fk_sesion_salon
        FOREIGN KEY (idSalon) REFERENCES Salon(idSalon),

    CONSTRAINT fk_sesion_entrenador
        FOREIGN KEY (idEntrenador) REFERENCES Entrenador(idUsuario),

    CONSTRAINT fk_sesion_clase
        FOREIGN KEY (idClase) REFERENCES ClaseGrupal(idClase)
);

CREATE TABLE Reserva (
    idReserva INT AUTO_INCREMENT PRIMARY KEY,
    fechaHoraReserva DATETIME DEFAULT CURRENT_TIMESTAMP,
    asistio BOOLEAN DEFAULT FALSE,
    idSesion INT NOT NULL,
    idUsuario INT NOT NULL,
    activo BOOLEAN DEFAULT TRUE,

    CONSTRAINT fk_reserva_sesion
        FOREIGN KEY (idSesion) REFERENCES SesionClase(idSesion),

    CONSTRAINT fk_reserva_socio
        FOREIGN KEY (idUsuario) REFERENCES Socio(idUsuario)
);

-- =========================================================
-- PAGOS Y SUSCRIPCIONES
-- Compatible con PagoDTO/SuscripcionDTO y DAO Java actuales.
-- Ojo: estadoMembresia aquí va como VARCHAR porque Java lo trata como String.
-- =========================================================

CREATE TABLE MetodoPago (
    idMetodoPago INT AUTO_INCREMENT PRIMARY KEY,
    tipo VARCHAR(50) NOT NULL,
    detalle VARCHAR(255),
    activo BOOLEAN DEFAULT TRUE
);

CREATE TABLE Pago (
    idPago INT AUTO_INCREMENT PRIMARY KEY,
    fechaPago DATE,
    montoTotal DECIMAL(10,2) NOT NULL,
    tipo VARCHAR(50),
    idMetodoPago INT NOT NULL,
    activo BOOLEAN DEFAULT TRUE,

    CONSTRAINT fk_pago_metodo
        FOREIGN KEY (idMetodoPago) REFERENCES MetodoPago(idMetodoPago)
);

CREATE TABLE Suscripcion (
    idSuscripcion INT AUTO_INCREMENT PRIMARY KEY,
    estadoMembresia VARCHAR(50) DEFAULT 'activa',
    fechaIngreso DATE NOT NULL,
    fechaFinMembresia DATE NOT NULL,

    idPago INT NOT NULL,
    idUsuario INT NOT NULL,
    membresia_ID_basic INT NULL,
    membresia_ID_black INT NULL,
    activo BOOLEAN DEFAULT TRUE,

    CONSTRAINT fk_susc_pago
        FOREIGN KEY (idPago) REFERENCES Pago(idPago),

    CONSTRAINT fk_susc_socio
        FOREIGN KEY (idUsuario) REFERENCES Socio(idUsuario),

    CONSTRAINT fk_susc_basic
        FOREIGN KEY (membresia_ID_basic) REFERENCES MembresiaBasic(membresia_ID),

    CONSTRAINT fk_susc_black
        FOREIGN KEY (membresia_ID_black) REFERENCES MembresiaBlack(membresia_ID)
);

-- =========================================================
-- MÁQUINAS
-- =========================================================

CREATE TABLE Maquina (
    idMaquina INT AUTO_INCREMENT PRIMARY KEY,
    nombre VARCHAR(100) NOT NULL,
    marca VARCHAR(50),
    estado VARCHAR(50) DEFAULT 'Operativa',
    fechaUltimoMantenimiento DATE,
    activo BOOLEAN DEFAULT TRUE
);

